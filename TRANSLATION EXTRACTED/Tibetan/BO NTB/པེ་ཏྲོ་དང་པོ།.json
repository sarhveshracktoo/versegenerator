{
  "name": "པེ་ཏྲོ་དང་པོ།",
  "id": "པེ་ཏྲོ་དང་པོ།",
  "order": 60,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་པེ་ཏྲོ་ང་རང་ནི་ཡེ་ཤུ་མཱ་ཤི་ཀའི་སྐུ་ཚབ་པ་ཞིག་ཡིན་ཞིང་། འཕྲིན་ཡིག་འདི་ནི་ཕོན་ཐུ་དང༌། ག་ལད༌ཡཱ། ཀ་པ་ཏོ་ཡཱ། ཨེ་ཞི༌ཡཱ། པི་ཐིན་ཡཱ་ཡུལ་བཅས་ལ་ཐར་ཐོར་དུ་བྱེས་སུ་སྡོད་པ་རྣམས་ལ་སྤྲིངས་པའོ།།",
      "2": "ཁྱོད་ཅག་ནི་ཡེ་ཤུ་མཱ་ཤི་ཀའི་བཀའ་བརྩི་བ་དང་ཁོང་གི་སྐུ་ཁྲག་གཏོར་ཡུལ་ཡིན་པའི༌ཕྱིར། ཡབ་དཀོན་མཆོག་གིས་སྔ་མོ་ནས་མཁྱེན་པ་བཞིན་དུ་བདམས་ཤིང་། དམ་པའི་ཐུགས་ཉིད་བརྒྱུད་ནས་དམ་པར་མཛད་པའི་མི་རྣམས་ཡིན། ཁྱོད་ཅག་ལ་ཐུགས་རྗེ་དང་ཞི་བདེ་མང་དུ་གནང་བར༌སྨོན།",
      "3": "¶ བདག་ཅག་གི་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀའི་ཡབ་དཀོན་མཆོག་ལ་བསྟོད་བསྔགས་བརྗོད་པར༌བྱའོ།། ཁོང་གིས་རང་ཉིད་ཀྱི་ཐུགས་རྗེ་ཆེན་པོ་བཞིན། ཡེ་ཤུ་མཱ་ཤི་ཀ་སྐུ་གྲོངས་པ་ནས་སླར་གསོན་པར་མཛད་པ་བརྒྱུད་ནས། བདག་ཅག་ལ་རེ་བ་གསོན་པོ་ལྡན་པའི་ཆེད་དུ། བདག་ཅག་ཡང་བསྐྱར་སྐྱེས་པར་མཛད་དེ།",
      "4": "བདག་ཅག་ལ་འཇིག་པ་མེད་པ་དང་། ནག་ནོག་གི་དྲི་མས་མ་གོས༌པ། ཉམས་པར་མི་འགྱུར༌བ། ནམ་མཁའི་ཞིང་ཁམས་སུ་ཉར་ཚགས་བྱས་ཡོད་པ་བཅས་ཀྱི་བགོ་སྐལ་འཐོབ་པར་འགྱུར་བའི་ཕྱིར༌རོ།།",
      "5": "ཁྱོད་རྣམས་ལ་སྟ་གོན་མཛད་པ་དང་དུས་ཀྱི་མཐའ་མར་མངོན་པར་འགྱུར་བའི་ཐར་པ་དེ་འཐོབ་པའི་ཆེད་དུ། ད་ལྟ་ཁྱོད་ཅག་ནི་དད་པའི་སྒོ་ནས་དཀོན་མཆོག་གི་ནུས་མཐུས་སྲུང་བར་མཛད་དོ།།",
      "6": "དེའི༌ཕྱིར། ཁྱོད་ཅག་ལ་དགའ་སྤྲོ་ཆེན་པོ་ལྡན་ཡང་། ད་ལྟ་དཀའ་སྡུག་སྣ་ཚོགས་ཀྱི་ཁྲོད་དུ་གནས་སྐབས་སུ་ཡིད་གདུང་དགོས་པ་ཡིན།",
      "7": "ཁྱོད་རྣམས་ཀྱི་དད་པར་ཚོད་བརྟག་བྱེད་པ་དེ་ནི། མེས་བཙོ་སྦྱང་བྱས་ནའང་འཇིག་པར་འགྱུར་བའི་གསེར་ལས་ཀྱང་རིན་ཆེན་པོར་སྣང༌ཞིང༌། ཡེ་ཤུ་མཱ་ཤི་ཀ་མངོན་སུམ་དུ་ཕེབས་པའི་དུས་སུ། དད་པ་དེ་ལ་བསྔགས་བརྗོད་དང་། གཟི༌བརྗིད། བརྩི་མཐོང་བཅས་འཐོབ་པར་འགྱུར་བའི་ཕྱིར༌རོ།།",
      "8": "ཁྱོད་རྣམས་ཀྱིས་ཁོང་ཉིད་དངོས་སུ་མཐོང་མ་མྱོང་ཡང་གཅེས་སུ་འཛིན་པར་བྱེད། ད་ལྟ་ཁོང་ཉིད་མ་མཐོང་ཡང་ཁོང་ལ་དད་པ་བྱས་པའི་རྐྱེན་གྱིས། བརྗོད་ཀྱིས་མི་ལང་བ་དང་གཟི་བརྗིད་ལྡན་པའི་དགའ་སྤྲོ་ཆེན་པོ་ཡོད་པར་མ༌ཟད།",
      "9": "ཁྱོད་ཅག་གི་དད་པའི་འབྲས་བུ་སྟེ། རྣམ་ཤེས་ལ་ཐར་པ་འཐོབ་པར་འགྱུར་རོ།།",
      "10": "¶ ཐར་པ་འདིའི་སྐོར་གླེང་བ་ཡིན་ན། སྔོན་ཆད་ཁྱོད་ཅག་ལ་ཐུགས་རྗེ་འཐོབ་པར་འགྱུར་ཞེས་གསུང་མཁན་ཏེ། ལུང་སྟོན་པ་རྣམས་ཀྱིས་སྔར་ནས་འཚོལ་རྟོག་དང་བརྟག་དཔྱད་ཞིབ་མོ་བྱས་མྱོང་ངོ་།།",
      "11": "དེ་ནི་ཁོ་རྣམས་ཀྱི་སེམས་ཁོང་དུ་ཡོད་པའི་སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ཐུགས་ཉིད་ཀྱིས། སྐྱབས་མགོན་མཱ་ཤི་ཀས་སྡུག་བསྔལ་མྱང་བར་འགྱུར་བ་དང་ཕྱིས་སུ་གཟི་བརྗིད་འཐོབ་པར་འགྱུར་བར་སྔ་མོ་ནས་བདེན་དཔང་བྱས་ཏེ། དུས་ནམ་ཞིག་དང་དུས་ཅི་ལྟ་བུ་ཞིག་ཡིན་པ་ལ་བརྟག་དཔྱད་བྱས་པ་ཡིན།",
      "12": "ཡང་ཁོ་རྣམས་ལ་མངོན་པར་མཛད་པ༌བཞིན། ཁོ་རྣམས་ཀྱིས་རང་གི་དོན་དུ་མ་ཡིན་པར་ཁྱོད་རྣམས་ཀྱི་ཆེད་དུ་ཞབས་ཕྱི་བསྒྲུབས་ཤིང་། ནམ་མཁའི་ཞིང་ཁམས་ནས་མངགས་ཡོང་བའི་དམ་པའི་ཐུགས་ཉིད་ལ་བརྟེན༌ནས་ཁྱོད་རྣམས་ལ་འཕྲིན་བཟང་སྒྲོག་མཁན་རྣམས་ཀྱིས། ད་ལྟ་དོན་དེ་རྣམས་ཁྱོད་ཅག་ལ་བསྒྲགས་པ་དང༌། ཐ་ན་ཕོ་ཉ་རྣམས་ཀྱིས་ཀྱང་དོན་འདི་དག་ལ་ཞིབ་ཏུ་བརྟག་པར་དགོངས་སོ།།",
      "13": "¶ དེའི༌ཕྱིར། ཁྱོད་ཅག་གིས་རང་གི་སེམས་གཅུན་ཞིང་རང་ཚོད་ཟིན་དགོས་པ༌དང༌། ཡེ་ཤུ་མཱ་ཤི་ཀ་མངོན་སུམ་དུ་ཕེབས་པའི་དུས༌སུ། ཁྱོད་རྣམས་ལ་གནང་ངེས་པའི་ཐུགས་རྗེ་ལ་བློ་སེམས་རྩེ་གཅིག་གིས་རེ་བ་གཟུང་དགོས་སོ།།",
      "14": "ཁྱོད་རྣམས་ནི་བཀའ་བརྩི་བའི་བུ་ཕྲུག་ཡིན་པ་བཞིན། སྔོན་ཆད་རྨོངས་པའི་དུས་ཀྱི་འདོད་ཆགས་བཞིན་དུ་མ་བྱེད༌ཅིག",
      "15": "དེ་ལས་ལྡོག་སྟེ་ཁྱོད་ཅག་ལ་ཞལ་འབོད་གནང་མཁན་ནི་དམ་པ་ཡིན་པ་བཞིན། ཁྱོད་རྣམས་ཀྱང་སྤྱོད་ལམ་ཀུན་ནས་དམ་པ་ཡིན་དགོས༌ཏེ།",
      "16": "གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། བདག་ནི་དམ་པ་ཡིན་པའི༌ཕྱིར་ཁྱོད་རྣམས་ཀྱང་དམ་པ་ཡིན་དགོས༌སོ། །ཞེས་བཀོད་པའི་ཕྱིར༌རོ།།",
      "17": "¶ དེ་ཡང་མི་ལ་ཕྱོགས་རིས་མི་འཛིན་པར་མི་རེ་རེའི་སྤྱོད་ལམ་བཞིན་དུ་ཁྲིམས་ཐག་གཅོད་མཁན་ལ་ཁྱོད་རྣམས་ཀྱིས་ཡབ་ལགས་ཞེས་འབོད་པས། ཁྱོད་རྣམས་བྱེས་སུ་སྡོད་དུས་གུས་ཤིང་འཇིགས་པའི་སེམས་བཅང་དགོས་སོ།།",
      "18": "ཁྱོད་རྣམས་རང་གི་ཕ་མེས་ཡང་མེས་ནས་བརྒྱུད་ཅིང་སྙིང་པོ་མེད་པའི་སྤྱོད་ལམ་དག་ལས་བླུས་ནས་ཐར་བར་མཛད་པ༌ནི། འཇིག་པར་འགྱུར་བའི་གསེར་དངུལ་ལ་སོགས་པའི་དངོས་པོར་བརྟེན་པ་མ་ཡིན༌པར།",
      "19": "སྐྱབས་མགོན་མཱ་ཤི་ཀའི་སྐུ་ཁྲག་རིན་ཆེན་ཏེ། ནག་ནོག་མ་འདྲེས་པ་དང་། དྲི་མས་མ་གོས་པའི་ལུ་གུའི་ཁྲག་དང་མཚུངས་པ་དེ་ལ་བརྟེན་པ་ནི་ཁྱོད་རྣམས་ཀྱིས་ཤེས༌སོ།།",
      "20": "དཀོན་མཆོག་གིས་འཇིག་རྟེན་ཁམས་མ་བཀོད་པའི་ཡར་སྔོན་ལ་སྐྱབས་མགོན་ཡེ་ཤུ་སྔ་མོ་ནས་མཁྱེན་པ་ཡིན༌ཡང༌། དུས་ཀྱི་མཐའ་མ་འདིར་ད་གཟོད་ཁྱོད་རྣམས་ཀྱི་དོན་དུ་མངོན༌པར་མཛད།",
      "21": "ཁྱོད་རྣམས་ཀྱིས་ཀྱང་ཁོང་ཉིད་བརྒྱུད་ནས་དཀོན་མཆོག་ལ་དད་པ་བྱས༌ཤིང༌། དཀོན་མཆོག་གིས་ཁོང་ཉིད་སྐུ་གྲོངས་པ་ནས་སླར་གསོན་པ་དང་གཟི་བརྗིད་དང་ལྡན་པར་མཛད་དོ།། དེ་ནི་ཁྱོད་རྣམས་ཀྱིས་དཀོན་མཆོག་ལ་དད་པ་དང་རེ་བ་བྱེད་པའི་ཕྱིར༌རོ།།",
      "22": "¶ ཡང་ཁྱོད་ཅག་གིས་བདེན་པ་ཉིད་བརྩིས་ནས་རང་གི་སེམས་གཙང་མར་བྱས་པ་དང་སྤུན་ཟླ་རྣམས་ལ་ཟོལ་གྱིས་གཅེས་པ་མ་ཡིན་པས། སེམས་གཏིང་ནས་ཕན་ཚུན་ལ་གཅེས་དགོས་སོ།།",
      "23": "ཁྱོད་རྣམས་ཡང་བསྐྱར་སྐྱེས་པ་ནི་འཇིག་པར་འགྱུར་བའི་ས་བོན་ལས་བྱུང་བ་མ་ཡིན་པར། འཇིག་པ་མེད་པའི་ས་བོན༌ཏེ། དཀོན་མཆོག་གི་སྲོག་དང་ལྡན་ཞིང་གཏན་དུ་བཞུགས་པའི་བཀའ་ལ་བརྟེན་ནས་བྱུང་བའོ།།",
      "24": "ཅིའི་ཕྱིར་ཞེ་ན། ལུས་ཅན་ཐམས་ཅད་རྩྭ་དང༌འདྲ།། གཟི་བརྗིད་རྩྭ་ཡི་མེ་ཏོག༌འདྲ།། རྩྭ་ནི་བསྐམས་ནས་མེ་ཏོག༌ཡལ།།",
      "25": "གཙོ་བོའི་བཀའ་ནི་རྟག་ཏུ་གནས།། ཞེས་གསུངས་པའི་ཕྱིར༌ཡིན་ཞིང་། ཁྱོད་རྣམས་ལ་བསྒྲགས་པའི་འཕྲིན་བཟང་ཡང་བཀའ་འདི་ཡིན༌ནོ།།"
    },
    "2": {
      "1": "¶ དེ་ལྟར་ཡིན་པས། ཁྱོད་རྣམས་ཀྱིས་གདུག་རྩུབ་དང་། གཡོ༌སྒྱུ། ཚུལ་འཆོས། ཕྲག༌དོག སྐུར་འདེབས་ཀྱི་གཏམ་སྣ་ཚོགས་སྤངས༌ནས།",
      "2": "གསར་སྐྱེས་ཀྱི་ཕྲུ་གུས་བྱེད་པ་བཞིན། ཁྱོད་ཅག་གིས་བཀའ་ཡི་འོ་མ་ལྷད་མེད་དེ་ལ་ཡིད་སྨོན་བྱེད་དགོས༌ཏེ། ཁྱོད་རྣམས་དེ་ལ་བརྟེན་ནས་ཐར་པའི་ཕྱོགས་སུ་རིམ་བཞིན་དད་པ་ཇེ་བརྟན་དུ་འགྱུར་བའི་ཕྱིར༌ཡིན་ཞིང་།",
      "3": "ཁྱོད་རྣམས་ཀྱིས་གཙོ་བོའི་ཐུགས་རྗེ་ཉམས་སུ་མྱངས་པས་དེ་ལྟར་བྱེད་འོས་སོ།།",
      "4": "¶ ཁོང་ནི་རྡོ་གསོན་པོ་ཞིག་ཡིན་ལ། དེ་ནི་མི་ཡིས་སྤངས་ནའང་དཀོན་མཆོག་གིས་བདམས་ཤིང་རིན་ཐང་ཆེན་པོར་བརྩིས་པ་ཡིན་ལ། ཁྱོད་རྣམས་ཁོང་གི་དྲུང་དུ་ཡོང་བའི་དུས་སུ།",
      "5": "ཁྱོད་ཅག་ཀྱང་རྡོ་གསོན་པོ་ཡིན་པ་བཞིན་དུ། དམ་པའི་ཐུགས་ཉིད་ཀྱི་བཞུགས་གནས་སུ་བཟོ་བ་སྟེ། ཁྱོད་ཅག་ནི་དམ་པའི་མཆོད་དཔོན་ཡིན་ཞིང་། ཡེ་ཤུ་མཱ་ཤི་ཀར་བརྟེན་ནས་དཀོན་མཆོག་དགྱེས་པའི་ཐུགས་ཉིད་ཀྱི་མཆོད་པ་འབུལ་བའི་ཕྱིར༌རོ།།",
      "6": "ཅིའི་ཕྱིར་ཞེ་ན། དེ་ལ་གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། ལྟོས་དང་། བདག་གིས་ཛ་ཡན་ཡུལ་དུ་རྡོ་ཞིག༌བཞག། བདམས་པའི་ཟུར་གྱི་རྨང་རྡོ་ནོར་བུ་ཡིན༎ ཁོང་ལ་བརྟེན་ཅིང་དད་པ་བྱེད་མཁན༌ཀུན།། ཁ་ནི་མི་སྐྱེངས་ངོ་ཡང་མི་གནོང༌ངོ༌།། ཞེས་གསུངས༌པའི་ཕྱིར་རོ།།",
      "7": "¶ དེའི༌ཕྱིར། ཁྱོད་ཅག་དད་ལྡན་རྣམས་ལ་མཚོན་ན་ཁོང་ནི་ནོར་བུ་ཞིག་ཡིན༌ལ། དད་པ་མེད་པ་རྣམས་ལ་མཚོན་ན་ཇི་སྐད༌དུ་གསུངས་པ་སྟེ། བཟོ་བ་རྣམས་ཀྱིས་སྤངས་པའི༌རྡོ།། ཁང་པའི་ཟུར་གྱི་རྨང་རྡོར༌གྱུར།། ཞེས་པའོ།།",
      "8": "ཡང་ཇི་སྐད༌དུ། དེ་ནི་རྐང་པ་འདྲེད་པའི་རྡོ།། ས་རུ་སྒྱེལ་བའི་ཕ་བོང་ཡིན།། ཞེས་གསུངས། ཁོ་རྣམས་ཀྱིས་བཀའ་དེ་ལ་མི་ཉན་པས་ས་རུ་འགྱེལ། ཁོ་རྣམས་དེ་ལྟར་འགྱེལ་བ་ནི་དཀོན་མཆོག་གིས་སྔར་ནས་ཐག་གིས་བཅད་ཟིན༌ནོ།།",
      "9": "¶ འོན་ཀྱང་། ཁྱོད་རྣམས་ནི་བདམས་ཟིན་པའི་རིགས་རྒྱུད་དང་། རྒྱལ་རྒྱུད་ཀྱི་མཆོད་དཔོན། མི་རིགས་དམ༌པ། དཀོན་མཆོག་ལ་གཏོགས་པའི་མི་བཅས་ཡིན་ཏེ། དེ་ནི་ཁྱོད་རྣམས་མུན་ནག་ལས་ཁོང་གི་ངོ་མཚར་ཆེ་བའི་འོད་ཟེར་ནང་དུ་ཞལ་འབོད་གནང་མཁན་ཁོང་གི་འཕྲིན་ལས་སྒྲོག་པའི་ཕྱིར་རོ།།",
      "10": "སྔོན་ཆད་ཁྱོད་རྣམས་ནི་འབངས་མི་མིན་མོད། འོན་ཀྱང་ད་ལྟ་ཁྱོད་ཅག་ནི་དཀོན་མཆོག་གི་འབངས་མི་ཡིན། སྔོན་ཆད་ཁྱོད་རྣམས་ལ་ཐུགས་རྗེ་མ་ཐོབ༌མོད། འོན་ཀྱང་ད་ལྟ་ཁྱོད་རྣམས་ལ་ཐུགས་རྗེ་ཐོབ་ཟིན༌ནོ།།",
      "11": "¶ སྙིང་ཉེ་བའི་སྤུན་ཟླ༌རྣམས། ཁྱོད་རྣམས་ནི་མགྲོན་པོ་དང་ཕྱི་མི་ཡིན་པ༌བཞིན། བདག་གིས་ཁྱོད་རྣམས་ལ་ཤ་གཟུགས་ཀྱི་འདོད་ཆགས་སྤང་བར་བསྐུལ༌བར་བྱའོ།། འདོད་ཆགས་ཀྱིས་སེམས་ལ་རྒོལ་བ་ཡིན་ནོ།།",
      "12": "ཕྱི་ཕྱོགས་པ་རྣམས་ཀྱི་ཁྲོད་དུ་ཁྱོད་ཅག་གི་སྤྱོད་ལམ་དྲང་པོ་ཡིན་དགོས་སོ།། ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་རྣམས་ནི་ལས་ངན་པ་བྱེད་མཁན་ཡིན་ཞེས་དམའ་འབེབས་བྱེད་མཁན་དག་གིས་ཁྱོད་ཅག་གི་ལས་བཟང་པོར་བལྟས་ནས། དཀོན་མཆོག་གི་གཟིགས་སྐྱོང་མཛད་པའི་དུས་སུ། ཁོང་ལ་བསྟོད་བསྔགས་བརྗོད་པའི་ཕྱིར༌རོ།།",
      "13": "¶ གཙོ་བོའི་ཆེད་དུ་ཁྱོད་རྣམས་ཀྱིས་གོང་མ་རྒྱལ་པོའམ། ཡང་ན་རྒྱལ་པོས་ལས་ངན་པ་བྱེད་མཁན་ལ་ཁྲིམས་ཐག་གཅོད་པ་དང་ལས་བཟང་པོ་བྱེད་མཁན་ལ་གཟེངས་བསྟོད་བྱེད་པར་མངགས་པའི་སྤྱི་དཔོན་ནམ། མིའི་ལམ་ལུགས་ཐམས་ཅད་བརྩི་སྲུང་བྱེད་དགོས་སོ།།",
      "15": "ཅིའི་ཕྱིར་ཞེ་ན། དཀོན་མཆོག་གི་ཐུགས་དགོངས་ནི་ཁྱོད་རྣམས་ཀྱིས་ལས་བཟང་པོ་བྱས་ཏེ། ཤེས་པ་མེད་པའི་བླུན་པོ་རྣམས་ཀྱི་སྨྲ་སྒོ་གཅོད་པའི་ཕྱིར་ཡིན།",
      "16": "ཁྱོད་ཅག་ནི་མི་རང་དབང་ཅན་ཡིན་ནའང་། རང་དབང་ལ་བརྟེན་ནས་ལས་ངན་པ་འགེབས་མི་རུང༌སྟེ། རྟག་ཏུ་དཀོན་མཆོག་གི་ཞབས་ཕྱི་པ་ཡིན་དགོས་སོ།།",
      "17": "ཁྱོད་ཅག་གིས་མི་ཐམས་ཅད་ལ་བརྩི་བཀུར་དང་། དད་ལྡན་སྤུན་ཟླ་ལ་གཅེས་པ། དཀོན་མཆོག་ལ་གུས༌ཤིང་འཇིགས་པ། རྒྱལ་པོ་ལ་བརྩི་བཀུར་བཅས་བྱེད་པར༌གྱིས།",
      "18": "¶ ཁྱོད་ཅག་གཡོག་པོ་རྣམས་ཀྱིས་དོན་ཐམས་ཅད་ཀྱི་ཆ་ནས་གུས་ཞུམ་ངང་བདག་པོའི་བཀའ་བརྩི་དགོས་པ་དང་། བདག་པོ་བཟང་པོ་ཞི་དུལ་ཅན་གྱི་བཀའ་བརྩི་དགོས་པར་མ་ཟད། བདག་པོ་སྤྱོད་རྩིང་ཅན་གྱི་བཀའ་ཡང་བརྩི་དགོས་སོ།།",
      "19": "མི་ཞིག་གིས་དཀོན་མཆོག་གི་སྤྱན་སྔར་བསམ་པའི་རྐྱེན་གྱིས། བསྙོན་བཙུགས་པའི་སྡུག་བསྔལ་ལ་བཟོད་བསྲན་བྱས་པ་ཡིན་ན། དེ་ནི་གཅེས་སུ་འཛིན་འོས་སོ།།",
      "20": "ཁྱོད་ཅག་གིས་ཉེས་པ་བྱས་པས་རྡུང་རྡེག་མྱངས་ཤིང་བཟོད་བསྲན་བྱས་པ་ཡིན་ན། དེ་ལ་བསྟོད་འོས་པ་ཅི་ཡོད༌དམ། འོན་ཀྱང་། ཁྱོད་རྣམས་ཀྱིས་ལས་བཟང་པོ་བྱས་པའི་རྐྱེན་གྱིས། སྡུག་བསྔལ་མྱངས་ཤིང་བཟོད་བསྲན་བྱས་པ་ཡིན༌ན། དེ་ནི་དཀོན་མཆོག་གི་སྤྱན་སྔར་གཅེས་སུ་འཛིན་འོས་སོ།།",
      "21": "ཁྱོད་རྣམས་ལ་ཞལ་འབོད་ཐོབ་པ་ནི་དེའི་ཕྱིར་ཡིན། རྒྱུ་མཚན་ནི་སྐྱབས་མགོན་མཱ་ཤི་ཀས་ཀྱང་ཁྱོད་ཅག་གི་དོན་དུ་སྡུག་བསྔལ་མྱངས་ཤིང་། ཁྱོད་རྣམས་ལ་མིག་དཔེ་མཛད་པ་ཡིན་ཏེ། ཁྱོད་རྣམས་ཁོང་གི་རྗེས་སུ་འབྲང་བའི་ཕྱིར་རོ།།",
      "22": "དེ་ལ་ཇི་སྐད༌དུ། ཁོང་གིས་ཉེས་པ་ཅི་ཡང་མ་བྱས༌ཤིང༌།། གཡོ་སྒྱུའི་ཚིག་ཀྱང༌ངག་ལས་བརྗོད་པ་མེད།། ཅེས༌གསུངས་པའོ།།",
      "23": "ཁོང་གིས་སྡིགས་དམོད་མྱོང་བའི་དུས་སུ་ཚིག་ལོག་མ་བརྒྱབ་ཅིང་། གནོད་འཚེ་མྱོང་བའི་དུས་སུ་འཇིགས་སྐུལ་གྱི་ཚིག་མ་གསུངས༌པར། དྲང་བདེན་གྱིས་མི་ལ་ཁྲིམས་ཐག་གཅོད་མཁན་དཀོན་མཆོག་ལ་རང་ཉིད་བཅོལ་བ་ཡིན།",
      "24": "ཁོང་ཉིད་སྡོང་པོའི་སྟེང་དུ་བཀལ་ཞིང་། ཁོང་གིས་སྐུ་དངོས་སུ་བདག་ཅག་གི་སྡིག་པ་འཁུར་ཏེ། བདག་ཅག་ནི་སྡིག་པའི་ཆ་ནས་འཆི་བ་དང་། དྲང་བདེན་གྱི་ཆ་ནས་སྲོག་འཚོ་བར་འགྱུར་བའི་ཕྱིར་ཡིན་ཞིང་། ཁོང་གི་རྨ་ཁས་ཁྱོད་རྣམས་སོས་པར་གྱུར་ཏོ།།",
      "25": "སྔོན་ཆད་ཁྱོད་རྣམས་ནི་མགོ་འཐོམ་པའི་ལུག་དང་མཚུངས༌མོད། འོན་ཀྱང་ད་ལྟ་ཁྱོད་ཅག་ནི་སེམས་ཀྱི་རྫི་བོ་དང་སྲུང་མཁན་གྱི་ཕྱོགས་སུ་འཁོར་བའོ།།"
    },
    "3": {
      "1": "¶ དེ་དང་དེ་བཞིན་དུ་ཁྱོད་ཅག་ཆུང་མ་རྣམས་ཀྱིས་རང་གི་ཁྱོ་གར་བསྟུན་དགོས་སོ།། དེ་ལྟར་ཡིན་ན། དཀོན་མཆོག་གི་བཀའ་མི་བརྩི་བའི་ཁྱོ་ག་ཡོད་ཅིང་། ཁོ་རྣམས་ཀྱིས་བཀའ་ལ་མི་ཉན༌ཡང༌། ཆུང་མས་ཅི་ཡང་མི་སྨྲ་བར་རང་གི་སྤྱོད་ལམ་གྱིས་ཁྱོ་ག་ཚུར་འགུག་ཀྱང་སྲིད།",
      "2": "དེ་ནི་ཁྱོད་རྣམས་ལ་སྤྱོད་ལམ་གཙང་མ་དང་གུས་པའི་སེམས་ཡོད་པ་མཐོང་བའི་ཕྱིར༌ཡིན།",
      "3": "ཁྱོད་རྣམས་ཀྱིས་མགོའི་སྐྲ་སླས་པ་དང་། གསེར་གྱི་རྒྱན་ཆ་འདོགས༌པ། གོས་ཡག་པོ་གྱོན་པ་བཅས་ཕྱི་ཚུལ་གྱི་གཟབ་མཆོར་མི་སྤྲ་བར།",
      "4": "ཁྱོད་ཅག་གི་སེམས་ནང་དུ་འགྱུར་བ་མེད་པའི་གཤིས་འཇམ་དང་། ཞི་དུལ་གྱི་སེམས་ཡོད་པ་ནི་རྒྱན་ཆར་བརྩི་དགོས༌ཤིང༌། དེ་ནི་དཀོན་མཆོག་གི་སྤྱན་སྔར་རིན་ཐང་ཆེན་པོ་ལྡན་ནོ།།",
      "5": "ཅིའི་ཕྱིར་ཞེ་ན། གནའ་དུས་སུ་དཀོན་མཆོག་ལ་རེ་བ་བཅོལ་བའི་བུད་མེད་དམ་པ་རྣམས་ཀྱིས་ཀྱང་དེ་ལྟར་རང་ལ་བརྒྱན༌ནས་རང་གི་ཁྱོ་གར་བསྟུན་པའི་ཕྱིར་ཡིན།",
      "6": "དཔེར་ན། སཱ་ར་ཡིས་ཨབ་ར་ཧམ་གྱི་བཀའ་ལ་མཉན་ནས་ཁོང་ལ་བདག་པོ་ཞེས༌འབོད་པ་ལྟ་བུ་ཡིན། གལ་ཏེ། ཁྱོད་རྣམས་འཇིགས་སྐུལ་ལ་མི་སྐྲག་པར་ལས་བཟང་པོ་བྱེད་པ་ཡིན་ན་སཱ་རའི་བུ་མོ་ཡིན༌ནོ།།",
      "7": "¶ དེ་དང་དེ་བཞིན་དུ། ཁྱོད་ཅག་ཁྱོ་ག་རྣམས་ཀྱང་ཤེས་རྟོགས་ལྡན་པའི་སྒོ་ནས་ཆུང་མ་ལྷན་དུ་སྡོད་དགོས་ཤིང་། ཁོ་མོ་ནི་བུད་མེད་ཡིན་པས་ཁྱོད་ལས་གཉོམ་པ་དང་། ཁྱོད་དང་མཉམ་དུ་ཚེ་སྲོག་གི་ཐུགས་རྗེ་ཐོབ་མཁན་ཡིན༌པས། ཁྱོད་ཀྱིས་ཀྱང་ཁོ་མོ་ལ་བརྩི་བཀུར་བྱ་འོས་སོ།། དེ་ལྟར་ཡིན་ན། ཁྱོད་ཅག་གི་སྨོན་ལམ་ལ་བར་ཆད་ཅི་ཡང་མི་འབྱུང་ངོ་།།",
      "8": "¶ མདོར་བསྡུས་ན། ཁྱོད་རྣམས་ཐམས་ཅད་ཀྱིས་བསམ་པ་མཐུན་ཞིང་ཕན་ཚུན་ལ་ཤ་ཚ་བ༌དང༌། སྤུན་ཟླ་ལྟར་བརྩེ་ཞིང་དུང་བ་དང་། སྙིང་རྗེ་དང་ཁེངས་སྐྱུང་གི་བསམ་པ་ལྡན་དགོས་སོ།།",
      "9": "ཁྱོད་རྣམས་ཀྱིས་གནོད་ལན་གནོད་འཇལ་མི་བྱེད་པ་དང་། དམའ་འབེབས་ཀྱི་ཚིག་ལ་དམའ་འབེབས་ཀྱི་ལན་མི་སློག་པར། དེ་ལས་ལྡོག་སྟེ་བྱིན་རླབས་ཞུ་འོས་སོ།། ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་རྣམས་ལ་ཞལ་འབོད་གནང་བ་ནི་བྱིན་རླབས་འཐོབ་པའི་ཆེད་དུ་ཡིན།",
      "10": "དེ་ལ་གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། སུ་ཞིག་སྲོག་ལ་གཅེས་པ་དང་།། སྐྱིད་པའི་འཚོ་བ་རོལ་འདོད་ན།། ཚིག་ངན་སྨྲ་ལྕེ་བསྡམ་དགོས་ཤིང་།། མཆུ་ཏོའི་གཡོ་སྒྱུ་བསྲུང་བར་གྱིས།།",
      "11": "ངན་པ་སྤངས་ནས་བཟང་པོ་སྒྲུབས།། ཞི་མཐུན་འཚོལ་ཞིང་དེའི་རྗེས་སྙེགས།།",
      "12": "དེ་ནི་གཙོ་བོ་ལགས་ཀྱི་སྤྱན་ཟུང་གིས།། དྲང་བདེན་མི་ལ༌གཟིགས་ཤིང་ཐོས་འཛིན་གྱིས།། དེ་ཡི་སྨོན་ལམ་དག་ལ་གསན་ཕྱིར་རོ།། འོན་ཀྱང་ངན་པའི་ལས་སུ་འཇུག་མཁན་ལ།། གཙོ་བོ་ལགས་ཀྱི་ཞལ་རས་འགྱུར་བ་འོ།། ཞེས་གསུངས་པའི་ཕྱིར༌རོ།།",
      "13": "¶ ཁྱོད་ཅག་གིས་བརྩོན་སེམས་ངང་ནས་ལས་བཟང་པོ་བྱས་པ་ཡིན་ན། ཁྱོད་རྣམས་ལ་གནོད་འཚེ་གཏོང་མཁན་སུ་ཡོད།",
      "14": "ཁྱོད་ཅག་གིས་དྲང་བདེན་གྱི་ལས་སྒྲུབ་པའི་ཕྱིར་སྡུག་བསྔལ་མྱངས་ནའང་ཁྱོད་རྣམས༌བདེའོ།། དེ་དག་གི་འཇིགས་སྐུལ་ལ་མི་སྐྲག་ཅིང་སེམས་ཀྱང་མ་འཚབ༌ཅིག",
      "15": "འོན་ཀྱང་། ཁྱོད་ཅག་གི་སེམས་སུ་སྐྱབས་མགོན་མཱ་ཤི་ཀ་ནི་གཙོ་བོར་བཀུར་འོས་སོ།། སུ་ཞིག་གིས་ཁྱོད་རྣམས་ལ་སེམས་ཀྱི་རེ་སྨོན་ཅི་ཡིན་དྲི་བའི་ཕྱིར། ཁྱོད་ཅག་གིས་རྟག་ཏུ་སྟ་གོན་བྱེད་ཅིང་ཞི་འཇམ་དང་གུས་སེམས་བཅངས་ཏེ། མི་རེ་རེ་ལ་ལན་གདབ་པར༌བྱའོ།།",
      "16": "ཁྱོད་ཅག་གིས་བསམ་པ་རྣམ་དག་དང་བཅས། ཁྱོད་རྣམས་ལ་དོན་གང་ཞིག་གི་ཆ་ནས་དམའ་འབེབས་བྱས༌ན། དོན་དེའི་ཆ་ནས་སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ནང་དུ་ཁྱོད་ཅག་གི་སྤྱོད་ལམ་བཟང་པོ་ལ་སྙོན་འཛུགས་མཁན་གྱི་མི་དེ་ངོ་ཚར་སྦྱོར་བ་ཡིན།",
      "17": "དཀོན་མཆོག་གི་ཐུགས་དགོངས་ཡིན་ན། ཁྱོད་རྣམས་ཀྱིས་ལས་བཟང་པོ་བྱས་པའི་ཕྱིར་སྡུག་བསྔལ་མྱོང་བ་ནི། ལས་ངན་པ་བྱས་པའི་ཕྱིར་སྡུག་བསྔལ་མྱོང་བ་ལས་ལེགས་སོ།།",
      "18": "ཅིའི་ཕྱིར་ཞེ་ན། སྐྱབས་མགོན་མཱ་ཤི་ཀས་ཀྱང་དེ་སྔར་ཐེངས་གཅིག་ལ་སྡིག་པའི་ཆེད་དུ་སྡུག་བསྔལ་མྱངས༌ཤིང་། དེ་ནི་རྣམ་པར་དག་པ་དེ་ཡིས་རྣམ་དག་མ་ཡིན་པའི་ཚབ་བྱས་ཏེ། བདག་ཅག་དཀོན་མཆོག་གི་དྲུང་དུ་འདྲེན་པའི་ཕྱིར༌ཡིན། ལུས་ཕུང་གི་ཆ་ནས་བརྗོད་ན། ཁོང་ཉིད་སྐུ་བཀྲོངས་ཤིང་། ཐུགས་ཉིད་ཀྱི་ཆ་ནས་བརྗོད་ན། ཁོང་ཉིད་སླར་གསོན་པ་ཡིན།",
      "19": "དེ་སྔར་ཁོང་གིས་ཐུགས་ཉིད་དེ་ལ་བརྟེན་ནས་བཙོན་དུ་ཡོད་པའི་སེམས་ཉིད་དག་ལ་བཀའ་བསྒྲགས་པར་ཕེབས་ཤིང༌།",
      "20": "དེ་དག་ནི་སྔོན་ཆད་ནོ་ཨས་གྲུ་གཟིངས་བཟོ་བའི་དུས༌དང༌། དཀོན་མཆོག་གིས་ངང་རྒྱུད་རིང་པོས་རེ་སྒུག་མཛད་པའི་དུས་སུ། དཀོན་མཆོག་གི་བཀའ་ལ་མི་ཉན་པའི་མི་རྣམས་ཡིན། དུས་དེར། གྲུ་གཟིངས་ནང་དུ་སོང་ཞིང་ཆུ་ལ་བརྟེན་ནས་ཐར་མཁན་མི་བརྒྱད་ལས་མང་པོ་མེད།",
      "21": "ཆུ་དེ་ཡིས་ཁྲུས་གསོལ་མཚོན་ཞིང༌། ད་ལྟ་ཡེ་ཤུ་མཱ་ཤི་ཀ་སླར་གསོན་པ་བརྒྱུད་ནས་ཁྱོད་རྣམས་ཀྱང་སྐྱོབ་པ་དང་། ཁྲུས་གསོལ་དེ་ནི་ལུས་ཀྱི་མི་གཙང་བ་མེད་པར་བཟོ་བ་མ་ཡིན་པར། དཀོན་མཆོག་གི་སྤྱན་སྔར་བསམ་པ་རྣམ་དག་ལྡན་པའི་ཕྱིར་ཡིན།",
      "22": "སྐྱབས་མགོན་ཡེ་ཤུ་ནམ་མཁའི་ཞིང་ཁམས་སུ་ཕེབས་ཏེ། དཀོན་མཆོག་གི་གཡས་ཕྱོགས་སུ་བཞུགས་ཤིང༌། ཕོ་ཉའི་ཚོགས་དང་། དབང་འཛིན༌མཁན། མཐུ་སྟོབས་ཅན་ཐམས་ཅད་ཁོང་གི་མངའ་འོག་ཏུ་མཛད་དོ།།"
    },
    "4": {
      "1": "¶ དེ་བས་ན་སྐྱབས་མགོན་མཱ་ཤི་ཀས་སྐུ་ལུས་ཀྱི་ཆ་ནས་སྡུག་བསྔལ་མྱངས༌པས། ཁྱོད་ཅག་གིས་ཀྱང་བློ་སྟོབས་དེ་ལྟ་བུའི་གོ་མཚོན་སྤྲ་བར་བྱ་འོས་སོ།། ཅིའི་ཕྱིར་ཞེ་ན། ལུས་སྟེང་ནས་སྡུག་བསྔལ་མྱངས་པ་རྣམས་ནི་སྡིག་པ་དང་ཁ་བྲལ་བའི་ཕྱིར༌ཡིན།",
      "2": "ཁྱོད་རྣམས་ལ་སེམས་དེ་ལྟ་བུ་ལྡན་ན། དེང་ཕྱིན་མིའི་འདོད་ཆགས་ཀྱི་རྗེས་སུ་མི་འབྲང་བར། དཀོན་མཆོག་གི་ཐུགས་དགོངས་བཞིན་འཇིག་རྟེན་འདིའི་ཚེ་སྨད་ཀྱི་དུས་འདའ་དགོས་སོ།།",
      "3": "ཅིའི་ཕྱིར་ཞེ་ན། སྔོན་ཆད་ཁྱོད་རྣམས་ཀྱིས་ཕྱི་ཕྱོགས་པའི་འདོད་བློ་བཞིན་དུ་ལོག་གཡེམ་དང་། འདོད༌ངན། ཆང་རག་གིས་བཟི་བ། ཟས་བག་མེད་དུ་ཟ་བ། བཟའ་བཏུང་བག་མེད་ལ་ཞུགས་པར་མ༌ཟད། སྐུ་འདྲར་བརྟེན་པའི་སྐྱུག་བྲོ་བའི་དོན་ལ་སོགས་པའི་དུས་ཡུན་ལོངས་པའི་ཕྱིར་ཡིན།",
      "4": "མི་དེ་དག་གིས་ཁྱོད་རྣམས་དོན་འདིའི་ཆ་ནས་ཁོ་རྣམས་དང་མཉམ་དུ་བག་མེད་ལང་ཤོར་གྱི་ལས་ལ་མི་ཞུགས་པ་མཐོང་སྟེ། ཧ་ལས་ཤིང་ཁྱོད་ཅག་ལ་འཕྱ་དམོད་བྱེད་མོད།",
      "5": "འོན་ཀྱང་། དེ་རྣམས་ཀྱིས་ངེས་པར་གསོན་པོ་དང་འདས་པོ་ཀུན་ལ་ལེགས་ཉེས་འབྱེད་མཁན་ཁོང་ཉིད་ལ་རྩིས་སྤྲོད་དགོས་སོ།།",
      "6": "དེའི་ཕྱིར། འདས་པོ་རྣམས་ལའང་འཕྲིན་བཟང་བསྒྲགས་ཤིང་། དེ་ནི་མིའི་ཚུལ་བཞིན་དུ་དེ་དག་གི་ལུས་གཟུགས་ལ་ཉེས་ཆད་འཕོག་པར་འགྱུར་ཡང་། དེ་རྣམས་ཀྱི་སེམས་ཉིད་ནི་དཀོན་མཆོག་ལ་བརྟེན་ནས་འཚོ་བའི་ཕྱིར་རོ།།",
      "7": "¶ དངོས་པོ་ཐམས་ཅད་ཀྱི་མཐའ་མཇུག་སླེབས་ལ་ཉེ་བས། ཁྱོད་ཅག་གིས་གཟབ་ནན་ངང་རང་ཉིད་བསྲུང་བ་དང་། སྨོན་ལམ་འདེབས་པར་གཟབ་གཟབ་བྱ་དགོས་སོ།།",
      "8": "དེ་ལས་ཀྱང་གལ་ཆེ་བ་ནི་ཕན་ཚུན་ལ་དངོས་གནས་བྱམས་དགོས་པ་དེ་ཡིན། ཅིའི་ཕྱིར་ཞེ་ན། བྱམས་པས་སྡིག་པ་མང་པོ་འགེབས་ཐུབ་པའི་ཕྱིར༌རོ།།",
      "9": "ཁྱོད་རྣམས་ཀྱིས་ཕན་ཚུན་ལ་སྣེ་ལེན་བཟང་པོ་བྱེད་པ་ལས་སྡུག་ཡུས་འདོན༌པར་མི་བྱའོ།།",
      "10": "མི་རེ་རེར་གནང་སྦྱིན་གང་ཞིག་ཐོབ་པ་ལྟར་ཕན་ཚུན་ལ་ཞབས་ཕྱི་བསྒྲུབས༌ཏེ། དཀོན་མཆོག་གི་ཐུགས་རྗེ་སྣ་ཚོགས་ཀྱི་གཉེར་པ་ལེགས་པོ་ཞིག་བྱ་དགོས་སོ།།",
      "11": "སུ་ཞིག་ཆོས་གསུང་མཁན་ཡིན་ན། དཀོན་མཆོག་གི་བཀའ་བཞིན་དུ་གསུང་བ༌དང༌། སུ་ཞིག་ཞབས་ཕྱི་སྒྲུབ་མཁན་ཡིན་ན། དཀོན་མཆོག་གིས་གནང་བའི་མཐུ་སྟོབས་བཞིན་དུ་བསྒྲུབ༌དགོས་སོ།། དེ་ནི་དོན་ཐམས་ཅད་ལས་ཡེ་ཤུ་མཱ་ཤི་ཀ་བརྒྱུད་ནས་དཀོན་མཆོག་ལ་བསྟོད་བསྔགས་འཐོབ་པའི་ཕྱིར༌ཡིན། མ་གཞི་གཟི་བརྗིད་དང་མངའ་ཐང་ཐམས་ཅད་ནམ་ཡང་ཁོང་ལ་དབང་ངོ་། །ཨ༌མེན།",
      "12": "¶ སྙིང་ནས་བརྩེ་བའི་སྤུན་ཟླ༌རྣམས། ཁྱོད་རྣམས་ལ་ཚོད་བགམ་པའི་ཕྱིར་མེ་ལྟ་བུའི་སྡུག་བསྔལ་དང་འཕྲད་པའི་དུས་སུ། དེ་ནི་རང་ཉིད་ལ་ཧ་ལས་པའི་དོན་ཞིག་བྱུང་བར་སྙམ་ཞིང་ཡ་མཚན་དུ་མ་འདོད་ཅིག",
      "13": "སྐྱབས་མགོན་མཱ་ཤི་ཀའི་གཟི་བརྗིད་མངོན་པའི་དུས་སུ། ཁྱོད་རྣམས་ཀྱང་ཤིན་ཏུ་དགའ་ཞིང་སྤྲོ་བའི་ཕྱིར། ད་ལྟ་ཁྱོད་ཅག་གིས་སྐྱབས་མགོན་མཱ་ཤི་ཀའི་སྡུག་བསྔལ་མཉམ་དུ་འཁུར་བས་དགའ་ཞིང་སྤྲོ་བར༌གྱིས།",
      "14": "ཁྱོད་རྣམས་ཀྱིས་སྐྱབས་མགོན་མཱ་ཤི་ཀའི་མཚན་གྱི་ཆེད་དུ་སྡིགས་དམོད་མྱངས་ན་བདེའོ། །ཅིའི་ཕྱིར་ཞེ་ན། དཀོན་མཆོག་གི་གཟི་བརྗིད་དང་ལྡན་པའི་ཐུགས་ཉིད་ནི་རྟག་ཏུ་ཁྱོད་རྣམས་ཀྱི་སྟེང་དུ་བཞུགས་པའི་ཕྱིར་རོ།།",
      "15": "ཁྱོད་ཅག་གི་ཁྲོད་དུ་མི་གསོད་པ་དང་། རྐུ་བྱེད་པ། ལས་ངན་པ་བྱེད་པ། གཞན་དོན་ལ་ཐེ་གཏོགས་བྱེད་པ་བཅས་ཀྱི་རྐྱེན་གྱིས་སྡུག་བསྔལ་མྱོང་མཁན་ཡོད་མི་འོས་སོ།།",
      "16": "འོན་ཀྱང་མཱ་ཤི་ཀ་པ་ཡིན་པའི་རྐྱེན་གྱིས་སྡུག་བསྔལ་མྱངས་ན་ངོ་གནོང༌བར་མི་བྱ་ཞིང་། མཚན་དེའི་རྐྱེན་གྱིས་དཀོན་མཆོག་ལ་བསྟོད་བསྔགས་འབུལ་དགོས་སོ།།",
      "17": "ཅིའི་ཕྱིར་ཞེ་ན། ད་ལྟ་དུས་དེ་སླེབས་ཟིན་ཅིང་། ལེགས་ཉེས་ཀྱི་ཁྲིམས་ཐག་གཅོད་པ་ནི་དཀོན་མཆོག་གི་ཁྱིམ་རྒྱུད་ནས་འགོ་རྩོམ༌པའི་ཕྱིར་ཡིན། གལ་ཏེ། བདག་ཅག་ནས་འགོ་རྩོམ་པ་ཡིན་ན། དཀོན་མཆོག་གི་འཕྲིན་བཟང་ལ་མི་ཉན་པ་རྣམས་ཀྱི་མཇུག་འབྲས་ནི་ཅི་ལྟ་བུ་ཞིག་ཡིན༌ནམ།",
      "18": "དེ་ལ་ཇི་སྐད༌དུ། གཞུང་དྲང་མི་རྣམས་ཐར་བ་ཙམ་ཡིན༌ན།། དད་པ་མེད་པའི་མི་དང་སྡིག་ཅན༌ལ།། ལངས་ནས་སྡོད་ས་ཙམ་ཡང་གང་དུ་ཡོད།། ཅེས༌གསུངས་པའོ།།",
      "19": "¶ དེའི༌ཕྱིར། དཀོན་མཆོག་གི་ཐུགས་དགོངས་བཞིན་སྡུག་བསྔལ་མྱོང་བའི་མི་རྣམས་ཀྱིས་བློ་སེམས་རྩེ་གཅིག་གིས་ལས་བཟང་པོ་བྱེད་དགོས་ཤིང༌། རང་གི་རྣམ་ཤེས་ནི་ཡིད་རྟོན་རུང་བའི་མཛད་པོ་དཀོན་མཆོག་ལ་བཅོལ་དགོས༌སོ།།"
    },
    "5": {
      "1": "¶ དེ་བས་ན་ང་རང་ནི་ཆོས་ཚོགས་ཀྱི་རྒན་པོ༌དང༌། སྐྱབས་མགོན་མཱ་ཤི་ཀས་སྡུག་བསྔལ་མྱངས་པའི་དཔང་པོ། ཕྱིས་སུ་མངོན་པར་འགྱུར་བའི་གཟི་བརྗིད་ལ་ཞུགས་མཁན་བཅས་ཡིན༌ལ། བདག་གིས་ཁྱོད་ཅག་ཁྲོད་ཆོས་ཚོགས་ཀྱི་རྒན་པོ་དག་ལ་འདི་ལྟར་བསྐུལ་བར་བྱ་སྟེ།",
      "2": "ཁྱོད་རྣམས་ཀྱིས་ངེས་པར་ཁྱོད་ཅག་ཁྲོད་ཀྱི་དཀོན་མཆོག་གི་ལུག་ཁྱུ་འཚོ་སྐྱོང་བྱེད་པ་དང་། དཀོན་མཆོག་གི་ཐུགས་དགོངས་ལྟར་བདག་སྐྱོང་བྱེད་དགོས། དེ་ནི་རང་མོས་ཡིན་པ་ལས་བཙན་གྱིས་བྱེད་དུ་བཅུག་པ་ཞིག་མིན་ལ། རྒྱུ་ནོར་ལ་རྔམ་པའི་རྐྱེན་ཡང་མིན་ཏེ།",
      "3": "ལུག་ཁྱུའི་མིག་དཔེར་བྱེད་པ་ལས་ཁྱོད་ཅག་ལ་བཅོལ་བ་རྣམས་ལ་ཚོད་འཛིན་བྱེད་པའི་ཕྱིར་མ་ཡིན་ནོ།།",
      "4": "དེ་ནས་རྫི་བོ་ཆེན་པོ་མངོན་སུམ་དུ་ཕེབས་པའི་དུས་སུ། ནམ་ཡང་འཇིག་པ་མེད་པའི་གཟི་བརྗིད་ཀྱི་ཅོད་པན་ཁྱོད་ཅག་ལ་འཐོབ་པར་འགྱུར༌རོ།།",
      "5": "¶ དེ་བཞིན་དུ། ཁྱོད་ཅག་ན་གཞོན་རྣམས་ཀྱིས་ཀྱང་ཆོས་ཚོགས་ཀྱི་རྒན་པོ་དག་གི་བཀའ་ལ་མཉན་དགོས༌ཤིང༌། ཁྱོད་ཅག་ཐམས་ཅད་ཀྱིས་ཀྱང་ཁེངས་སྐྱུང་གི་སེམས་པ་གོས་བཞིན་གྱོན་ནས་ཕན་ཚུན་ལ་བསྟུན་དགོས་སོ།། དེ་ལ་ཇི་སྐད༌དུ། དཀོན་མཆོག་ཉིད་ཀྱིས་ང་རྒྱལ་ཅན་ལ༌རྒོལ།། ཁེངས་སྐྱུང་མི་ལ་ཁོང་གིས་ཐུགས་རྗེ༌གནང༌།། ཞེས་གསུངས་པའི་ཕྱིར༌རོ།།",
      "6": "¶ དེའི་ཕྱིར། ཁྱོད་ཅག་གིས་དམན་སེམས་བཅངས་ཏེ་དཀོན་མཆོག་གི་མཐུ་སྟོབས་ཆེ་བའི་ཕྱག་འོག་ཏུ་སྡོད་དགོས་ཤིང་། དུས་ལ་བབས་པ་ན། ཁོང་གིས་ཁྱོད་རྣམས་མཐོན་པོར་བསྒྲེང་ངེས༌སོ།།",
      "7": "ཁྱོད་ཅག་གིས་རང་གི་སེམས་ཁུར་མཐའ་དག་དཀོན་མཆོག་ལ་བཅོལ་དགོས་ཏེ། རྒྱུ་མཚན་ནི་ཁོང་གིས་ཁྱོད་རྣམས་ལ་གཟིགས་སྐྱོང་མཛད་པས༌སོ།།",
      "8": "¶ ཁྱོད་རྣམས་ཀྱིས་གཟབ་ནན་ངང་ནས་རང་ཉིད་བསྲུངས་ཏེ་དོགས་ཟོན་བྱ་དགོས་སོ།། ཁྱོད་ཅག་གི་དགྲ་ཟླ་སྟེ་བདུད་ནི་ངར་སྐད་སྒྲོག་པའི་སེང་གེ་དང་མཚུངས༌པར། ཡུལ་ཕྱོགས་ཀུན་ཏུ་རྒྱུ་ཞིང་ཁྱུར་མིད་གཏོང་འདོད་པའི་མི་རྣམས་འཚོལ་བཞིན་ཡོད།",
      "9": "ཁྱོད་རྣམས་ཀྱིས་དད་སེམས་བརྟན་པོས་དེ་ལ་འགོག་རྒོལ་བྱ་དགོས་ཏེ། འཇིག་རྟེན་དུ་ཡོད་པའི་བདག་ཅག་གི་སྤུན་ཟླ་རྣམས་ཀྱིས་ཀྱང་སྡུག་བསྔལ་འདི་ལྟ་བུ་མྱོང་བཞིན་པ་ཁྱོད་ཅག་གིས་ཤེས་པས༌སོ།།",
      "10": "¶ སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ནང་དུ་ཁྱོད་ཅག་ལ་ཞལ་འབོད་གནང་མཁན་དང༌། ཁྱོད་ཅག་ལ་མཐའ་མེད་པའི་གཟི་བརྗིད་ཉམས་སུ་མྱོང་དུ་འཇུག་མཁན་དང་། ཐུགས་རྗེ་ཆེན་པོ་གནང་མཁན་དཀོན་མཆོག་གིས། གནས་སྐབས་སུ་ཁྱོད་རྣམས་ཀྱིས་སྡུག་བསྔལ་མྱངས༌རྗེས། ཁོང་ཉིད་ཀྱིས་དངོས་སུ་ཁྱོད་རྣམས་ཡོངས་སུ་རྫོགས་པར་མཛད༌ཅིང༌། བརྟན་པོར་མཛད་དེ་སྟོབས་ཤུགས་གནང་བ་དང་། གཡོ་བ་མེད་པར་མཛད་ངེས་སོ།།",
      "11": "མངའ་ཐང་ནམ་ཡང་ཁོང་ལ་དབང་བར་སྨོན། ཨ༌མེན།",
      "12": "¶ བདག་གིས་འཕྲིན་ཡིག་མདོར་བསྡུས་འདི་བྲིས་ཏེ། ངས་ཡིད་རྟོན་རུང་བར་འདོད་པའི་སྤུན་ཟླ་སིལ་ཝ་ནཱ་བརྒྱུད་ནས་ཁྱོད་ཅག་ལ་སྤྲོད་པར་བྱས་ཤིང༌། ངས་ཁྱོད་རྣམས་ལ་སྐུལ་སློང་བྱེད་པར་མ་ཟད། ཐུགས་རྗེ་འདི་ནི་དཀོན་མཆོག་གི་ཐུགས་རྗེ་དངོས་ཡིན་པར་བདེན་དཔང་བྱས་པ་ཡིན། ཁྱོད་ཅག་ནི་ངེས་པར་ཐུགས་རྗེ་འདིའི་ནང་དུ་བརྟན་པོར་ལངས་ནས་སྡོད་དགོས༌སོ།།",
      "13": "¶ དཀོན་མཆོག་གིས་པཱ་པེལ་ལོན་གྱི་ཆོས་ཚོགས་ནི་ཁྱོད་ཅག་དང་མཉམ་དུ་བདམས་པ་ཡིན་ལ། ད་ལྟ་ཁོ་རྣམས་ཀྱིས་ཀྱང་ཁྱོད་རྣམས་ལ་འཚམས་འདྲི་ཞུའོ།། བདག་གི་བུ་བཞིན་དུ་གྱུར་པ་མཱར་ཀུས་ཀྱང་ཁྱོད་ཅག་ལ་འཚམས་འདྲི༌ཞུའོ།།",
      "14": "ཁྱོད་རྣམས་ཀྱིས་ཕན་ཚུན་ལ་བྱམས་པའི་འོ་དང་བཅས་འཚམས་འདྲི་ཞུ་བར་བྱའོ།། སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ནང་དུ་གནས་པ་ཁྱོད་ཅག་ཐམས་ཅད་ལ་ཞི་བདེ་འཐོབ་པར༌སྨོན།། །།"
    }
  }
}
