{
  "name": "ཐི་མོ་ཐེ་དང་པོ།",
  "id": "ཐི་མོ་ཐེ་དང་པོ།",
  "order": 54,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་ཕོལ་ལོལ་ང་རང་ནི་བདག་ཅག་གི་སྐྱབས་མགོན་དཀོན་མཆོག་དང་བདག་ཅག་གིས་རེ་སྨོན་བྱེད་པའི་མཱ་ཤི་ཀ་ཡེ་ཤུའི་བཀའ་བཞིན་དུ་ཁོང་གི་སྐུ་ཚབ་པ་ཞིག་ཡིན་ནོ།།",
      "2": "འཕྲིན་ཡིག་འདི་ནི་དད་པ་བརྒྱུད་ནས་རང་གི་བུ་དངོས་སུ་གྱུར་པ་ཐི་མོ་ཐེ་ལ་སྤྲིངས་པ་ཡིན༌ཏེ། ཡབ་དཀོན་མཆོག་དང་བདག་ཅག་གི་གཙོ་བོ་མཱ་ཤི་ཀ་ཡེ་ཤུས་ཁྱོད་ལ་བྱམས་དང་སྙིང༌རྗེ། ཞི་བདེ་བཅས་གནང་བར༌སྨོན།",
      "3": "¶ སྔོན་ཆད་ང་རང་མ་ཀེ་དོན་ཡཱ་ཡུལ་དུ་འགྲོ་བའི་དུས༌སུ། ཁྱོད་རང་སྔར་བཞིན་ཨེ་ཕེ་སི་རུ་སྡོད༌པར་ནན་གྱིས་བསྐུལ་མྱོང་བ་ཡིན། དེ་ནི་ཁྱོད་ཀྱིས་ལོག་ལྟ་ཅན་དེ་དག་ལ་ལོག་ཁྲིད་མི་བྱེད་པ༌དང༌།",
      "4": "ཁུངས་ལུང་མེད་པའི་གཏམ་རྒྱུད་དང༌། རྫོགས་མཐའ་མེད་པའི་ཁྱིམ་རྒྱུད་ཀྱི་སྟོང་བཤད་ལའང་མགོ་བོ་འཁོར་མི་རུང་ཞེས་ཁ་བསྒོ་གཏོང་ཐུབ་པའི་ཕྱིར༌ཡིན་ལ། ལས་འདི་རིགས་ཀྱིས་དོན་སྙིང་མེད་པའི་རྩོད་པ་སློང་བ་ལས། དད་པར་བརྟེན་ནས་བསྒྲུབ་འོས་པའི་དཀོན་མཆོག་གི་དགོངས་དོན་ཐད་ལ་ཕན་ཐོགས་ཅི་ཡང་མེད་དོ།།",
      "5": "འོན་ཀྱང༌། བཀའ་འདིའི་དམིགས་དོན་ནི་བྱམས་པ་ཡིན༌ཏེ། རྣམ་པར་དག་པའི་སེམས་དང༌། བསམ་པ་རྣམ་དག གཡོ་ཟོལ་མེད་པའི་དད་སེམས་བཅས་ལས་བྱུང་བ་ཡིན་ནོ།།",
      "6": "ཡང་མི་འགའ་ཤས་ཀྱིས་དོན་འདི་དག་དང་ཁ་བྲལ་ནས་སྙིང་པོ་མེད་པའི་གཏམ་སྨྲ་བར་བྱེད༌ཅིང༌།",
      "7": "བཀའ་ཁྲིམས་ཀྱི་དགེ་རྒན་བྱེད་འདོད༌ཀྱང༌། རང་གིས་ཅི་ཞིག་གླེང་བཞིན་པ་དང་སྤོབས་པའི་ངང་ནས་ཅི་ཞིག་བསྒྲག་པའང་མི་ཤེས༌སོ།།",
      "8": "¶ སུ་ཞིག་གིས་བཀའ་ཁྲིམས་འོས་ཤིང་འཚམ་པར་བཀོལ༌ན། བཀའ་ཁྲིམས་དེ་ནི་ལེགས་པོ་ཡིན་པ་བདག་ཅག་གིས་ཤེས༌སོ།།",
      "9": "བཀའ་ཁྲིམས་ནི་མི་གཞུང་དྲང་རྣམས་ཀྱི་ཆེད་དུ་བཙུགས་པ་མ་ཡིན༌པར། ཁྲིམས་མེད་ལུགས་མེད་དང་བསླབ་བྱར་མི་ཉན༌པ། དཀོན་མཆོག་ལ་དད་གུས་མེད༌པ། སྡིག་པ༌ཅན། དམ་པ་མ་ཡིན་པ་དང་ཐ་མལ་བ་ལ་ཞེན་ཆགས་པ། ཕ་མ་དང་མི་གསོད༌མཁན།",
      "10": "ལོག་གཡེམ་བྱེད་མཁན། ཕོ་ཡིས་ཕོ་ལ་འཁྲིག་པ་སྤྱོད་མཁན། མི་ཚོང་རྒྱག་མཁན། རྫུན་སྨྲ༌མཁན། དམ་བཅའ་རྫུན་མ་འཇོག་མཁན་བཅས༌དང༌། ཡང་དག་པའི་བསྟན་པ་དང་མི་མཐུན་པའི་དོན་གང་ཞིག་གི་ཆེད་དུ་བཙུགས་པ་ནི་བདག་ཅག་གིས་ཀྱང་ཤེས༌པ་ཡིན།",
      "11": "དོན་འདི་ནི་བསྔགས་པར་འོས་པའི་དཀོན་མཆོག་གིས་གཟི་བརྗིད་ལྡན་པའི་འཕྲིན་བཟང་དེ་ཉིད་བདག་ལ་བཅོལ་བ་བཞིན༌ནོ།།",
      "12": "¶ བདག་ལ་མཐུ་སྟོབས་གནང་མཁན་ཏེ་བདག་ཅག་གི་གཙོ་བོ་མཱ་ཤི༌ཀ་ཡེ་ཤུས། བདག་ནི་བློ་སེམས་དཀར་པོ་ཡིན་པ་གཟིགས་ནས་ཁོང་གི་ཞབས་ཕྱི་པར་བསྐོས་པས་ངས་ཁོང་ལ་ཐུགས་རྗེ༌ཆེ་ཞུའོ།།",
      "13": "སྔོན་ཆད་ང་རང་ནི་དཀོན་མཆོག་ལ་སྐུར་བ་འདེབས་མཁན༌དང༌། དད་ལྡན་རྣམས་ལ་གཉའ་གནོན་བྱེད་མཁན༌དང༌མི་གདུག་རྩུབ་ཅན་ཞིག་ཡིན༌མོད། འོན་ཀྱང་དེ་ནི་བདག་ལ་དད་པ་མེད་པ་དང་ཅི་ཡང་མི་ཤེས་པའི་དུས་སུ་བྱས་པ་ཡིན༌པས། དཀོན་མཆོག་གིས་བདག་ལ་ཐུགས་རྗེ་དགོངས་པ༌དང༌།",
      "14": "བདག་ཅག་གི་གཙོ་བོའི་ཐུགས་རྗེ་ནི་ལྷག་ཏུ་ཕུན་སུམ་ཚོགས་པ་ཡིན༌པས། བདག་ལའང་མཱ་ཤི་ཀ་ཡེ་ཤུའི་ནང་དུ་དད་སེམས་དང་བྱམས་པ་ལྡན་པར་གྱུར༌ཏོ།།",
      "15": "¶ མཱ་ཤི་ཀ་ཡེ་ཤུ་ནི་སྡིག་ཅན་རྣམས་སྐྱོབ་པའི༌ཕྱིར། འཇིག་རྟེན་དུ་ཕེབས་པ་ཡིན་ཞེས་པའི་གཏམ་འདི་ལ་ཡིད་རྟོན་རུང་བ་དང་ཧ་ཅང་ཁས་ལེན་འོས་པ་ཞིག་ཡིན་ཞིང་། བདག་ནི་མི་སྡིག་ཅན་རྣམས་ཀྱི་ཁྲོད་དུ་གཏེ་བོ་ཞིག་ཡིན་ནོ།།",
      "16": "འོན་ཀྱང༌། ཡེ་ཤུ་མཱ་ཤི་ཀས་སྡིག་ཅན་རྣམས་ལས་གཏེ་བོ་ང་རང་ལྟ་བུའི་སྟེང་དུའང་ཁོང་གི་བཟོད་པ་ཚད་མེད་གནང་བ༌དང༌། ཕྱིས་སུ་ཁོང་ལ་དད་པ་བྱེད་ཅིང་མཐའ་མེད་པའི་ཚེ་སྲོག་ཐོབ་མཁན་རྣམས་ལ་ང་རང་མིག་དཔེ་རུ་མཛད་པའི༌ཕྱིར། ཁོང་གིས་བདག་ལ་ཐུགས་རྗེ་གནང༌བ་ཡིན་ནོ།།",
      "17": "ཐོག་མཐའ་མེད་པའི་རྒྱལ་པོ༌དང༌། འཇིག་པ་མེད༌པ། མཐོང་རེག་བྲལ་བའི་དཀོན་མཆོག་ཁོ་ན་ཉིད་ལ་རྟག་ཏུ་བཀུར་བསྟི་དང་བསྟོད་པ་འབུལ་བར༌སྨོན། ཨ༌མེན།",
      "18": "¶ བདག་གི་བུ་ཐི་མོ་ཐེ། སྔོན་ཆད་ཁྱོད་ཀྱི་སྐོར་ལ་ལུང་བསྟན་གནང་བ་བཞིན། བདག་གིས་གོང་གི་བཀའ་དེ་ཁྱོད་ལ་གདམས་པར་བྱ༌སྟེ། ཁྱོད་ཀྱིས་ལུང་བསྟན་དེ་དག་ལ་བརྟེན་ནས་འཐབ་འཛིང་བཟང་པོ་བྱེད་པ༌དང༌།",
      "19": "རྒྱུན་དུ་དད་སེམས་དང་བསམ་པ་རྣམ་དག་བཅང་ཐུབ་པའི་ཕྱིར༌རོ།། མི་ལ་ལས་དེ་སྤངས་པ་ནི་མཚོ་གྲུ་བྲག་རྡོ་ལ་ཐོགས་པ་བཞིན་དད་པ་ཉམས་པའོ།།",
      "20": "དེ་དག་གི་ཁྲོད་དུ་ཧི་མེ་ནཱ་ཡུ་དང་ཨ་ལིག་སན་དིར་གཉིས་ཡོད༌དེ། ཁོ་གཉིས་ཀྱིས་དཀོན་མཆོག་ལ་སྐུར་བ་འདེབས་མི་རུང་བ་ཤེས་པའི་ཆེད༌དུ། ངས་དེ་གཉིས་བདུད་སཱ་ཏན་གྱི་ལག་ཏུ་སྤྲད་ཟིན༌ཏོ།།"
    },
    "2": {
      "1": "¶ དེ་བས་ན། བདག་གིས་ཁྱོད་རྣམས་ལ་སྐུལ་བར༌བྱ་སྟེ། བདག་ཅག་གིས་དད་གུས་བྱེད་པ་དང་ཚུལ་མཐུན་ངང་བག་ཕབ་ལྷིང་འཇགས་ཀྱི་འཚོ་བ་རོལ་ཐུབ་པའི་ཕྱིར། ཐོག་མར་ཁྱོད་རྣམས་ཀྱིས་མི་ཐམས་ཅད༌དང༌། རྒྱལ༌པོ། དབང་ཤེད་ཅན་མཐའ་དག་གི་ཆེད༌དུ། དཀོན་མཆོག་ལ་ཞུ་བ་བྱེད་པ་དང༌། གསོལ་བ་འདེབས༌པ། ཚབ་ཞུ་བྱེད༌པ། བཀའ་དྲིན་ཞུ་བ་བཅས་བྱེད་པར༌གྱིས།",
      "3": "དོན་འདི་ནི་བདག་ཅག་གི་སྐྱབས་མགོན་དཀོན་མཆོག་གི་སྤྱན་སྔར་ལེགས༌ཤིང་ཁོང་ཐུགས་དགྱེས༌པ་ཡིན།",
      "4": "ཁོང་གིས་མི་ཐམས་ཅད་ལ་ཐར་པ་འཐོབ་པ་དང་ཀུན་གྱིས་བདེན་པ་ཉིད་རྟོགས་ཐུབ་པར་དགོངས་སོ།།",
      "5": "ཅིའི་ཕྱིར་ཞེ་ན། དཀོན་མཆོག་གཅིག་ཁོ་ན་ཉིད་ལས་གཞན་མེད༌ཅིང༌། ཡང་དཀོན་མཆོག་དང་མིའི་རིགས་ཀྱི་བར་དུ་བར་མི་གཅིག་ལས་གཞན་མེད༌དེ། འཇིག་རྟེན་དུ་མི་རུ་འཁྲུངས་པའི་མཱ་ཤི་ཀ་ཡེ་ཤུ་ཡིན་པའི་ཕྱིར༌རོ།།",
      "6": "ཁོང་གིས་རང་ཉིད་འཇིག་རྟེན་གྱི་མི་ཐམས་ཅད་ལ་བླུ་རིན་དུ་གནང༌ཞིང༌། དུས་ལ་བབས་པ་ན། དོན་འདིར་བདེན་དཔང་བྱས་པ་ཡིན།",
      "7": "བདག་ནི་དོན་དེའི་ཆེད་དུ་ཆོས་སྒྲོག་མཁན༌དང༌སྐུ་ཚབ༌པར་བསྐོས་ཏེ། དད་པ་དང་བདེན་པ་ཉིད་ཀྱི་ཆ་ནས་ཕྱི་ཕྱོགས་པ་རྣམས་ཀྱི་དགེ་རྒན་ཡིན། དེ་ནི་བདག་གིས་བདེན་པར་སྨྲས་པ་ཡིན་གྱི་རྫུན་སྨྲས་པ་མ་ཡིན༌ནོ།།",
      "8": "¶ དེའི༌ཕྱིར། བདག་གིས་སྐྱེས་པ་རྣམས་ཀྱིས་ཞེ་སྡང་དང་རྩོད་གླེང་མེད་པར་རྣམ་པར་དག་པའི་ལག་ཟུང་ཡར་བཏེགས་ནས། གནས་གང་རུང་དུ་གསོལ་བ་འདེབས་པར་བསམས་སོ།།",
      "9": "ཡང་བདག་གིས་བུད་མེད་རྣམས་ནི་ཁྲེལ་ཡོད་བག་ཡོད་ངང་ཚུལ་མཐུན་གྱི་གོས་གྱོན་པ༌ལས། མགོའི་སྐྲ་སླས་པ་དང་གསེར་དང་མུ་ཏིག་དང་གོས་ཆེན་སོགས་ཀྱིས་མི་བརྒྱན་པར༌སྨོན།",
      "10": "དཀོན་མཆོག་ལ་དད་པ་ཡོད་ཟེར་བའི་སྐྱེས་མ་རྣམས་ཀྱིས་ལུས་ལ་དོན་བཟང་པོས་བརྒྱན་ན་འོས་སོ།།",
      "11": "ཡང་བུད་མེད་རྣམས་ལྷོད་འཇགས་ངང་ཆོས་བསླབ་ཅིང་རྒྱུན་དུ་ངག་ལ་ཉན་པ་ཞིག་ཡིན་དགོས༌ཏེ།",
      "12": "བུད་མེད་རྣམས་ལྷོད་འཇགས་སུ་སྡོད་པ་ལས་སྐྱེས་པ་རྣམས་ལ་ཆོས་བཤད་པའམ་མགོ་ཁྲིད་བྱེད་མི་རུང་ཞེས་བདག་གིས་སྨྲས༌པའོ།།",
      "13": "ཅིའི་ཕྱིར་ཞེ་ན། ཐོག་མར་ཨ་དམ་དང་ཕྱིས་སུ་ཧ་ཝཱ་མཛད་པའི་ཕྱིར༌དང༌།",
      "14": "ཡང་ཨ་དམ་བསླུས་པ་མ་ཡིན་པར་བུད་མེད་དེ་བསླུས་ནས་སྡིག་པའི་ནང་དུ་ལྷུང་བའི་ཕྱིར༌རོ།།",
      "15": "འོན༌ཀྱང༌། བུད་མེད་རྣམས་ཀྱིས་རྟག་ཏུ་དད་སེམས་དང་བྱམས་པ་བཅངས་པ༌དང༌། སྤྱོད་ལམ་དྲང་ཞིང་བག་ཡོད་པ་ཡིན༌ན། ཕྲུ་གུ་བཙའ་བའི་དུས་སུ་ཁོ་མོ་རྣམས་ཐར་བར་འགྱུར་རོ།།"
    },
    "3": {
      "1": "¶ སུ་ཞིག་གིས་དོ་དམ་པའི་འགན་འཁུར་འདོད༌ན། དེ་ནི་ལས་བཟང་པོར་ཡིད་སྨོན་ཤོར་བ་ཡིན་ཞེས་པ་ཡིད་རྟོན་རུང་བའི་གཏམ་ཡིན་ནོ།།",
      "2": "དོ་དམ་པ་ནི་ངེས་པར་སྐྱོན་བརྗོད་རྒྱུ་ཅི་ཡང་མེད༌ཅིང༌། ཆུང་མ་གཅིག་ཁོ་ནའི་ཁྱོ་ག་ཡིན་པ༌དང༌། རང་ཚོད་ཟིན༌པ། བག་ཡོད༌པ། ཚུལ་མཐུན་ཡ་རབས་ཡིན༌པ། མགྲོན་པོ་བསུ་བར་དགའ༌བ། ཁྲིད་སྟོན་བྱེད་ནུས༌པ།",
      "3": "ཆང་རག་འཐུང་བར་མི་རྔམ༌པ། མི་ལ་གཅར་རྡུང་མི་བྱེད༌པ། ཞི་ཞིང་དུལ༌བ། འཁྲུག་རྩོད་མི་བྱེད༌པ། རྒྱུ་ནོར་ལ་མི་རྔམ་པ་བཅས་ཡིན་དགོས༌ཤིང༌།",
      "4": "རང་གི་ཁྱིམ་ཚང་བདག་སྐྱོང་ལེགས་པོ་བྱས་ཏེ་བུ་ཕྲུག་རྣམས་ལ་ཡ་རབས་སྤྱོད་བཟང་ཁྲིད་པ་དང་གུས་ལུགས་ཡོད་པ་ཞིག་ཡིན་དགོས།",
      "5": "གལ༌ཏེ། སུ་ཞིག་གིས་རང་གི་ཁྱིམ་ཚང་ཙམ་ཡང་བདག་སྐྱོང་བྱེད་མི་ཤེས༌ན། དཀོན་མཆོག་གི་ཆོས་ཚོགས་ནི་ཇི་ལྟར་སྐྱོང་ནུས༌སམ།",
      "6": "དད་ལྡན་གསར་པ་རྣམས་ནི་དོ་དམ་པ་བྱེད་མི་རུང༌སྟེ། མི་དེ་ནི་རང་རློམ་ཆེ་བར་འགྱུར་བ་དང་བདུད་ཀྱི་ཉེས་ཆད་ནང་དུ་ལྷུང་ཉེན་ཆེ་བས༌སོ།།",
      "7": "ཡང་མི་གཞན་གྱིས་སྐུར་བ་མི་འདེབས་པ༌དང༌། བདུད་ཀྱི་རྙི་རྒྱ་རུ་མི་ཚུད་པའི༌ཕྱིར། དོ་དམ་པ་དེ་ནི་ཕྱི་ཕྱོགས་པ་རྣམས་ཀྱི་ཁྲོད་དུའང་ངེས་པར་མཚན་སྙན་ཅན་ཞིག་ཡིན་དགོས༌སོ།།",
      "8": "¶ ལས་འཛིན་པ་རྣམས་ཀྱང་དེ་བཞིན་ཡིན་ཏེ། ངེས་པར་ཡ་རབས་ཚུལ་དང་མཐུན་ཞིང་ཁ་ཞེ་གཉིས་མེད་ཡིན༌པ། ཆང་རག་མང་པོ་མི་འཐུང༌བ། རྒྱུ་ནོར་མི་གཙང་བ་ལ་མི་རྔམ་པ་བཅས་ཡིན་དགོས་པ༌དང༌།",
      "9": "བསམ་པ་རྣམ་དག་གིས་དད་པའི་སྙིང་པོ་བརྟན་པོར་བསྲུང་དགོས་སོ།།",
      "10": "མི་དེ་རྣམས་ལ་ཐོག་མར་བརྟག་དགོས༌ཤིང༌། སྐྱོན་བརྗོད་རྒྱུ་ཅི་ཡང་མེད་ན་མི་དེ་རྣམས་ལས་འཛིན་པར་བསྐོ་རུང་བ་ཡིན།",
      "11": "བུད་མེད་རྣམས་ཀྱང་དེ་བཞིན་ཡིན་ཏེ། ངེས་པར་ཡ་རབས་ཚུལ་དང་མཐུན་ཞིང་ཕྲ་མ་མི་བྱེད༌པ། རང་ཚོད་ཟིན༌པ། དོན་ཀུན་ལ་བློ་སེམས་དཀར་བ་བཅས་ཡིན་དགོས་སོ།།",
      "12": "ལས་འཛིན་པ་ནི་ངེས་པར་ཆུང་མ་གཅིག་ཁོ་ནའི་ཁྱོ་ག་ཡིན་པ༌དང༌། བུ་ཕྲུག་དང་རང་གི་ཁྱིམ་ཚང་བདག་སྐྱོང་ལེགས་པོ་བྱེད་མཁན་ཞིག་ཡིན་དགོས།",
      "13": "ཅིའི་ཕྱིར་ཞེ་ན། ལས་འཛིན་པས་བྱ་བ་ལེགས་པར་བསྒྲུབས་ན་རང་ཉིད་ཡིད་དུ་འོང་བའི་གནས་སུ་སླེབས་པ༌དང༌། སྤོབས་པ་ཆེན་པོས་མཱ་ཤི་ཀ་ཡེ་ཤུ་ནང་གི་དད་པ་ལ་ཡིད་ཆེས་བརྟན་པོ་བྱེད་པའི་ཕྱིར༌རོ།།",
      "14": "¶ ང་རང་ཁྱོད་ཀྱི་གམ་དུ་མྱུར་བ་མྱུར་བར་འགྲོ་འདོད་ཆེ་བས་སྔོན་ཚུད་ནས་དོན་འདི་རྣམས་ཁྱོད་ལ་ཡི་གེར་འབྲི་བཞིན་ཡོད༌དེ།",
      "15": "ང་རང་དུས་འགྱངས་ནས་མྱུར་དུ་མ་སླེབས་ན། ཁྱོད་ཀྱིས་ཀྱང་དཀོན་མཆོག་གི་ཁྱིམ་ཚང་ནང་དུ་ཇི་ལྟར་བྱེད་འོས་པ་ཤེས་པའི་ཕྱིར༌ཡིན་ཞིང་། ཁྱིམ་ཚང་དེ་ནི་གཏན་དུ་གསོན་པོར་བཞུགས་པའི་དཀོན་མཆོག་གི་ཆོས་ཚོགས༌དང༌། བདེན་པ་ཉིད་ཀྱི་ཀ་རྡོ་དང་རྨང་གཞི་ཡིན་ནོ།།",
      "16": "དད་གུས་ཀྱི་གསང་བ་ནི་རླབས་ཆེ་བ་ཞིག་ཡིན་པ་ཀུན་གྱིས་ཁས་ལེན་པར་གདོན་མི་ཟ༌སྟེ། མི་ཡི་ཤ་གཟུགས་བརྒྱུད་ནས་སྐྱབས་མགོན༌མངོན།། ཐུགས་ཉིད་ཀྱིས་ནི་རྣམ་དག་ཡིན་པ༌བསྟན།། ཕོ་ཉ་རྣམས་ནི་ཁོང་ལ་མཇལ་བ༌ཡིན།། མི་རིགས་དུ་མར་ཁོང་ཉིད་ཡོངས་སུ༌བསྒྲགས།། འཇིག་རྟེན་མི་རྣམས་ཁོང་ལ་དད་པར༌གྱུར།། གཟི་བརྗིད་ལྡན་པའི་ནམ་མཁའི་ཞིང་དུ༌དྲངས།། ཞེས༌པའོ།།"
    },
    "4": {
      "1": "¶ དེ་ཡང་དམ་པའི་ཐུགས་ཉིད་ཀྱིས་འདི་སྐད༌དུ། དུས་ཕྱི༌མར་ཁ་ཅིག་གིས་དད་པ་རིང་དུ་སྤངས༌ཏེ། མི་ལ་བསླུ་བྲིད་བྱེད་པའི་ལོག་སེམས་དང་གདོན་འདྲེའི་ལོག་ལྟ་ལ་བརྟེན་ངེས་ཞེས་གསལ་པོར་གསུངས་སོ།།",
      "2": "དེ་ནི་རྫུན་སྨྲ་མཁན་རྣམས་ཀྱི་ཚུལ་འཆོས་ལས་བྱུང༌ཞིང༌། མི་དེ་རྣམས་ཀྱི་བསམ་པ་ནི་ངར་ལྕགས་ཀྱིས་བསྲེགས་པ་དང་མཚུངས༌པས་སོ།།",
      "3": "མི་དེ་དག་གིས་མནའ་མ་ཚུར་ལེན་ཕར་བསྐྱལ་བྱེད་མི་རུང་བ༌དང༌། ཁ་ཟས་ལ་ལ་བཟའ་མི་རུང་བར་བྱེད། འོན་ཀྱང༌། དད་པ་ཅན་དང་བདེན་པ་ཉིད་རྟོགས་མཁན་རྣམས་ཀྱིས་དྲིན་ལན་ཞུ་བའི་ངང་ནས་ལོངས་སུ་སྤྱོད་པའི༌ཕྱིར། དཀོན་མཆོག་གིས་ཁ་ཟས་དེ་དག་མཛད༌པ་ཡིན་ནོ།།",
      "4": "དཀོན་མཆོག་གིས་བསྐྲུན་པ་ཐམས་ཅད་ནི་ལེགས་པོ་ཡིན༌པས། བཀའ་དྲིན་ཞུ་བའི་ངང་ནས་དང་དུ་བླངས་ན་འདོར་འོས་པ་གཅིག་ཀྱང་མེད༌དེ།",
      "5": "ཅིའི་ཕྱིར་ཞེ་ན། དེ་རྣམས་དཀོན་མཆོག་གི་བཀའ་དང་མི་ཡིས་གསོལ་བ་བཏབ་པའི་དབང་གིས་དམ་པར་གྱུར་པའི་ཕྱིར༌རོ།།",
      "6": "¶ ཡང་ཁྱོད་ཀྱིས་དོན་འདི་དག་སྤུན་ཟླ་རྣམས་ལ་དྲན་སྐུལ་བྱེད༌ན། ཁྱོད་ནི་མཱ་ཤི་ཀ་ཡེ་ཤུའི་ཞབས་ཕྱི་པ་བཟང་པོ་ཞིག་ཡིན༌ཞིང༌། དད་པའི་བཀའ་དང་ཁྱོད་ཀྱིས་སྔར་ནས་དང་ལེན་བྱས་པའི་ཡང་དག་པའི་བསྟན་པ་ལས་ཁྱོད་ལ་སློབ་གསོ་འཐོབ༌པ་ཡིན་ནོ།།",
      "7": "ཡང་འཇིག་རྟེན་པའི་བཤད་རྒྱུན་དང་རྒན་མོ་རྣམས་ཀྱི་ཁུངས་ལུང་མེད་པའི་འཆལ་གཏམ་དག་རིང་དུ་སྤངས༌ཏེ། དད་གུས་ཐད་ལ་རང་ཉིད་སྦྱོང་བརྡར་བྱོས༌ཤིག",
      "8": "ལུས་ཀྱིས་རྩལ་སྦྱོང་བྱས་ན་ཕན་ཐོགས་ཅུང་ཙམ་ཡོད༌ཀྱང༌། དད་གུས་ནི་དོན་ཐམས་ཅད་ལ་ཕན་ཐོགས་ཡོད༌དེ། མི་ཚེ་འདི་དང་མ་འོངས་པའི་ཚེ་སྲོག་གཉིས་ལ་ཞལ་བཞེས་གནང་ཡོད་པས༌སོ།།",
      "9": "གཏམ་འདི་ནི་ཡིད་རྟོན་རུང་བ་དང་ཧ་ཅང་ཁས་ལེན་བྱེད་འོས་པ་ཞིག་ཡིན་ནོ།།",
      "10": "ད་ལྟ་བདག་ཅག་གིས་དོན་དེར་ངལ་བས་བརྩོན་པར༌བྱའོ།། ཅིའི་ཕྱིར་ཞེ་ན། བདག་ཅག་གིས་གཏན་དུ་གསོན་པོར་བཞུགས་པའི་དཀོན་མཆོག་ལ་རེ་སྨོན་བྱེད༌པ་དང༌། ཁོང་ནི་མི་ཐམས་ཅད་ཀྱི་སྐྱབས་མགོན་ཡིན་ཞིང་ལྷག་ཏུ་དད་ལྡན་རྣམས་ཀྱི་སྐྱབས་མགོན་ཡིན་པའི་ཕྱིར༌རོ།།",
      "11": "¶ ཁྱོད་ཀྱིས་དོན་འདི་དག་མི་གཞན་ལ་ཁ་བསྒོ་དང་སློབ་སྟོན་བྱེད་དགོས༌ཤིང༌།",
      "12": "ཁྱོད་ཀྱིས་རང་ཉིད་ལོ་ན་གཞོན་པར་སུ་ལའང་མཐོང་ཆུང་བྱེད་དུ་མི་འཇུག༌པར། སྨྲ་བརྗོད༌དང༌། བྱ༌སྤྱོད། བྱམས༌སེམས། དད༌སེམས། རྣམ་དག་ཡིན་པ་བཅས་ནས་དད་ལྡན་རྣམས་ལ་མིག་དཔེ་སྟོན་པར༌གྱིས།",
      "13": "ང་རང་ཡོང་བའི་བར་དུ་ཁྱོད་ཀྱིས་གསུང་རབ་ཀློག་འདོན་དང༌། སྐུལ་སློང༌། སློབ་སྟོན་བཅས་བྱེད་པ་ལ་བརྩོན་པར་བྱའོ།།",
      "14": "ཁྱོད་ཀྱི་སེམས་ཁོང་དུ་ཡོད་པའི་དམ་པའི་ཐུགས་ཉིད་ཀྱི་གནང་སྦྱིན་ཏེ། དེ་སྔར་ཆོས་ཚོགས་ཀྱི་རྒན་པོ་རྣམས་ཀྱིས་ལུང་བསྟན་བརྒྱུད་ནས་ཁྱོད་ཀྱི་ལུས་ལ་ལག་པ་བཞག་པའི་དུས་སུ་ཐོབ་ཟིན་པ་དེར་མཐོང་ཆུང་མི་བྱའོ།།",
      "15": "མི་ཐམས་ཅད་ཀྱིས་ཁྱོད་རང་ཡར་རྒྱས་སུ་འགྲོ་བ་མཐོང་བར་འགྱུར་བའི་ཕྱིར། ཁྱོད་ཀྱིས་དོན་འདི་རྣམས་ཧུར་ཐག་གིས་བསྒྲུབ་ཅིང་བློ་སེམས་རྩེ་གཅིག་བྱེད་པར༌གྱིས།",
      "16": "ཁྱོད་ཀྱིས་རང་ཉིད་དང་རང་གི་སློབ་སྟོན་ལ་གཟབ་གཟབ་བྱས་ནས་དོན་དེའི་ཐད་ལ་སྙིང་རུས་སྐྱེད༌ཅིག ཅིའི་ཕྱིར་ཞེ་ན། དེ་ལྟར་བྱས་ན་ཁྱོད་དང་ཁྱོད་ཀྱི་གཏམ་ལ་ཉན་མཁན་རྣམས་ཀྱང་བསྐྱབ་ནུས་པའི་ཕྱིར༌རོ།།"
    },
    "5": {
      "1": "¶ དེ་ཡང་ཁྱོད་ཀྱིས་མི་རྒན་པ་ལ་སྐྱོན་བརྗོད་ནན་མོ་མི་བྱེད་པར་རང་གི་ཕ་བཞིན༌དང༌། ན་གཞོན་རྣམས་ལ་སྤུན་བཞིན༌དང༌།",
      "2": "བུད་མེད་རྒན་པ་རྣམས་ལ་མ་བཞིན༌དང༌། བུད་མེད་ན་གཞོན་རྣམས་ལ་ལྕམ་སྲིང་ལྟར་བསམ་པ་རྣམ་དག་གིས་ཁ་ཏ་བྱེད་པར༌གྱིས།",
      "3": "¶ ཡུགས་མོ་དངོས་མ་རྣམས་ལ་བརྩི་བཀུར༌བྱའོ།།",
      "4": "འོན་ཀྱང༌། ཡུགས་མོ་ཞིག་ལ་བུ་ཕྲུག་དང་ཚ་བོའམ་ཚ་མོ་ཡོད༌ན། དེ་དག་གིས་ཐོག་མར་ཡུགས་མོ་ལ་རང་ཁྱིམ་ནས་སྲི་ཞུ་བྱེད་པ་དང༌། རང་གི་ཕ་མར་དྲིན་ལན་འཇལ་ཚུལ་ལ་གོམས་དགོས་པ་ཡིན། ཅིའི་ཕྱིར་ཞེ་ན། དེ་ནི་དཀོན་མཆོག་གི་སྤྱན་སྔར་དོན་བཟང་པོ་ཡིན་པའི་ཕྱིར་རོ།།",
      "5": "ཡུགས་མོ་དངོས་མ་ནི་ཁོ་མོ་གཅིག་པུར་ལུས་ཤིང་རྟེན་ས་གཞན་མེད་པ༌དང༌། དཀོན་མཆོག་ལ་རེ་སྨོན་བྱེད་ཅིང་ཉིན་མཚན་མེད་པར་ཞུ་བ་བྱེད་པ་དང་གསོལ་བ་བཏབ་ནས་སྡོད་པ་ཞིག་ཡིན།",
      "6": "འོན་ཀྱང༌། ལྟོ་གོས་གཏམ་ལ་ཆགས་པའི་ཡུགས་མོ་ནི་གསོན་པོའི་དུས་སུའང་ཤི་བ་དང༌འདྲའོ།།",
      "7": "དེ་རྣམས་ལ་སྐྱོན་བརྗོད་རྒྱུ་ཅི་ཡང་མེད་པར་བྱེད་པའི༌ཕྱིར། ཁྱོད་ཀྱིས་དོན་འདི་དག་གི་སྐོར་ནས་ཡུགས་མོ་རྣམས་ལ་ཁ་བསྒོ་གཏོང་བར༌གྱིས།",
      "8": "གལ༌ཏེ། སུ་ཞིག་གིས་རང་གི་གཉེན་ཉེ་ལ་ལྟ་སྐྱོང་མི་བྱེད་པ༌དང༌། ལྷག་པར་རང་གི་ཁྱིམ་མི་ལའང་ལྟ་སྐྱོང་མི་བྱེད༌ན། མི་དེ་ནི་དད་པ་དང་རིང་དུ་གྱེས༌ཤིང༌། དད་པ་མེད་པའི་མི་ལས་ཀྱང་ངན༌པའོ།།",
      "9": "¶ ཡུགས་མོའི་མིང་ཐོ་ནང་དུ་མིང་འགོད༌ན། ཡུགས་མོ་ནི་ངེས་པར་ལོ་དྲུག་ཅུའི་ཡན་ལ་སླེབས་པ་ཞིག༌དང༌། སྐྱེས་པ་གཅིག་ཁོ་ནའི་ཆུང་མ་བྱས་མྱོང་བ་ཞིག༌དང༌།",
      "10": "དོན་བཟང་བསྒྲུབས་ནས་མཚན་སྙན་ཅན་ཞིག༌སྟེ། བུ་ཕྲུག་སྙོར་སྐྱོང་དང་མགྲོན་པོར་སྣེ་ལེན་བྱས་མྱོང་བ༌དང༌། དད་ལྡན་དམ་པ་རྣམས་ཀྱི་ཞབས་བཀྲུས་པ་དང་དཀའ་ངལ་ཅན་ལ་རོགས་རམ་བྱས་མྱོང༌བ། དོན་བཟང་པོའི་རིགས་ཐམས་ཅད་ཧུར་ཐག་གིས་བསྒྲུབས་མྱོང་བ་ཞིག་ཡིན་དགོས་སོ།།",
      "11": "འོན་ཀྱང༌། ལོ་ན་གཞོན་པའི་ཡུགས་མོ་རྣམས་མིང་ཐོ་ནང་དུ་འགོད་པར་མི༌བྱའོ།། ཅིའི་ཕྱིར་ཞེ་ན། ཡུགས་མོ་རྣམས་སྐྱབས་མགོན་མཱ་ཤི་ཀ་དང་འགལ་ནས་འདོད་ཆགས་རྒྱས་པའི་དུས༌སུ། གཉེན་སྒྲིག་བྱེད་འདོད་པའི་ཕྱིར་ཡིན༌ཏེ།",
      "12": "ཡུགས་མོ་རྣམས་སྔར་གྱི་དམ་བཅའ་དང་འགལ་བས་དེ་དག་ལ་སྐྱོན་འཛུགས་པར་འགྱུར།",
      "13": "ཁོ་མོ་རྣམས་ལེ་ལོའི་དབང་དུ་སོང་སྟེ་ཁྱིམ་ནས་ཁྱིམ་གཞན་རྣམས་སུ་ཉུལ༌ཞིང་། ལེ་ལོ་ཅན་ཡིན་པར་མ༌ཟད། ངག་ནས་མི་བཤད་དགུ་བཤད་དང་དོན་མེད་ཀྱི་བྱ་བར་ཇུས་གཏོགས་བྱེད་པར་དགའ་བ༌དང༌། སྨྲ་མི་འོས་པའི་གཏམ་ཡང༌སྨྲ་བ་ཡིན་ནོ།།",
      "14": "དེའི༌ཕྱིར། བདག་གིས་ལོ་ན་གཞོན་པའི་ཡུགས་མོ་རྣམས་ཀྱིས་ཡང་བསྐྱར་གཉེན་སྒྲིག་བྱས༌ཏེ། བུ་ཕྲུག་བཙའ་ཞིང་ཁྱིམ་སྐྱོང་བར་བསྐུལ་བ༌ཡིན། དེ་ནས་དགྲ་བོར་སྡིགས་དམོད་བྱེད་པའི་གླགས་མི་གཏོང་ངོ་།།",
      "15": "ཅིའི་ཕྱིར་ཞེ་ན། འགའ་ཤས་ཁ་ཕྱིར་འཁོར་ནས་བདུད་སཱ་ཏན་གྱི་རྗེས་སུ་འབྲངས་པའི་ཕྱིར༌རོ།།",
      "16": "ཆོས་ཚོགས་ཀྱིས་རྟེན་ས་མེད་པའི་ཡུགས་མོ་དངོས་མ་རྣམས་ལ་རོགས་རམ་བྱེད་པའི༌ཕྱིར། བུད་མེད་དད་ལྡན་གང་གི་ཁྱིམ་དུ་ཡུགས་མོ་ཡོད༌ན། ཁོ་མོར་རོགས་རམ་བྱེད་འོས་པ་ལས་ཆོས་ཚོགས་ལ་ཁག་འགེལ་མི་རུང༌ངོ་།།",
      "17": "¶ དེ་ཡང་ཆོས་ཚོགས་ལ་བདག་སྐྱོང་ལེགས་པོ་བྱེད་པའི་རྒན་པོ་རྣམས་ལ་བཀུར་སྟི་ཆེན་པོ་བྱ་འོས༌ཤིང༌། དཀའ་སྡུག་ངང་ནས་དཀོན་མཆོག་གི་བཀའ་སྒྲོག་པ་དང་ཁྲིད་སྟོན་བྱེད་མཁན་ལ་དེ་བས་ཀྱང་བརྩི་བཀུར་བྱ་འོས་སོ།།",
      "18": "རྒྱུ་མཚན་ནི་གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། གཡུལ་ཁ་གཅོག་པའི་དུས༌སུ་བ་གླང་གི་མཆུ་ཏོ་མ༌སྡོམ་ཞེས་གསུངས་པ༌དང༌། ཡང་ཇི་སྐད༌དུ། ལས་ཀ་བྱེད་མཁན་རྣམས་ལ་གླ་ཆ་སྟེར་འོས་ཞེས་གསུངས་པའི་ཕྱིར༌ཡིན།",
      "19": "རྒན་པོ་ཞིག་ལ་སྐྱོན་ཡོད་པར་སྨྲ་བའི་དུས༌སུ། བདེན་དཔང་བྱེད་མཁན་གྱི་མི་གཉིས་སམ་གསུམ་མེད་ན་ཁས་ལེན་བྱ་མི་རུང༌ངོ་།།",
      "20": "མི་གཞན་རྣམས་ཀྱང་འཇིགས་པའི༌ཕྱིར། མུ་མཐུད་དུ་སྡིག་པ་བྱེད་མཁན་ལ་མི་ཐམས་ཅད་ཀྱི་མདུན་དུ་སྐྱོན་བརྗོད༌ཅིག",
      "21": "ངས་དཀོན་མཆོག་དང་མཱ་ཤི་ཀ་ཡེ་ཤུ་དང་ཁོང་གིས་བདམས་པའི་ཕོ་ཉ་རྣམས་ཀྱི་སྤྱན་སྔར་ཁྱོད་ལ་གདམས་པར་བྱ༌སྟེ། ཕྱོགས་ལྷུང་མེད་པར་བསླབ་བྱ་འདི་དག་བསྲུང་བར༌གྱིས། ལས་གང་ཞིག་བྱེད་ནའང་ཕྱོགས་རིས་མ་འཛིན༌ཅིག",
      "22": "མི་ཡི་ལུས་ལ་ལག་པ་འཇོག་པར་བྲེལ་འཚབ་མི་ལངས་པར༌གྱིས། མི་གཞན་རྣམས་ཀྱི་སྡིག་པའི་ལས་ལ་མི་ཞུགས་པར་རང་ཉིད་རྣམ་དག་ཏུ་བསྲུང་བར༌གྱིས།",
      "23": "ཁྱོད་ཀྱི་ཕོ་བ་མི་བདེ་ཞིང་བསྟུད་མར་ན་ཚ་བྱུང༌བས་ན། ཕྱིས་སུ་ཆུ་ཁོ་ན་མི་འཐུང་བར་རྒུན་ཆང་ཡང་ཉུང་ཙམ་འཐུང་བར༌གྱིས།",
      "24": "མི་ཁ་ཤས་ཀྱི་སྡིག་པ་ནི་མངོན་གསལ་ཡིན༌ཏེ། སྔོན་ལ་ཁྲིམས་ཐག་གཅོད་སར་སླེབས་པ་ལྟ༌བུ་ཡིན་ནོ།། ཡང་མི་ཁ་ཤས་ཀྱི་སྡིག་པ་ནི་སྡིག་ཅན་དག་གི་རྗེས་སུ་འབྲངས་ནས་སླེབ་ངེས་སོ།།",
      "25": "དེ་བཞིན་དུ་ལས་བཟང་པོ་རྣམས་ཀྱང་མངོན་གསལ་ཡིན༌ཞིང༌། མངོན་གསལ་མ་ཡིན་པ་རྣམས་ཀྱང་སྦ་མི་ནུས༌སོ།།"
    },
    "6": {
      "1": "¶ དེ་ཡང་དཀོན་མཆོག་གི་མཚན་དང་བསྟན་པ་ལ་སྐུར་བ་མི་འདེབས་པའི༌ཕྱིར། གཉའ་ཤིང་གི་འོག་ཏུ་ཡོད་པའི་གཡོག་པོ་ཐམས་ཅད་ཀྱིས་རང་རང་གི་བདག་པོ་རྣམས་ལ་ཕྱོགས་ཀུན་ནས་བརྩི་བཀུར་བྱེད་འོས་པར་རྩིས་ཤིག",
      "2": "གཡོག་པོ་སུ་ཞིག་ལ་དད་པ་དང་ལྡན་པའི་བདག་པོ་ཡོད༌ན། ཁོ་རང་སྤུན་ཟླ་ཡིན་པའི་དབང་གིས་བདག་པོར་མཐོང་ཆུང་མི་བྱེད༌པར། ཞབས་ཕྱི་ལས་ཕན་ཐོགས་པའི་བདག་པོ་རྣམས་ནི་དད་པ་ཅན་དང་གཅེས་སུ་འོས་པའི་མི་ཡིན༌པས། དེ་རྣམས་ལ་ལྷག་པར་ཞབས་ཕྱི་བསྒྲུབ་དགོས། ཁྱོད་ཀྱིས་དོན་དེ་རྣམས་མི་གཞན་དག་ལ་བསླབ་པ་དང་བསྐུལ་བར་བྱའོ།།",
      "3": "¶ གལ༌ཏེ། སུ་ཞིག་གིས་ལྟ་བ་མི་མཐུན་པ་བསྒྲགས་ནས་བདག་ཅག་གི་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀའི་ཡང་དག་པའི་གསུང་དང་དད་གུས་དང་མཐུན་པའི་ཆོས་དེ་ཁས་མི་ལེན༌ན།",
      "4": "མི་དེ་ནི་ང་རྒྱལ་ཆེ་བ་དང་ཅི་ཡང་མི་ཤེས་ཤིང་ནན་འདྲི་བྱེད་པ་དང་ཁ་རྩོད་ཚིག་རྩོད་བྱེད་པ་ཁོ་ནར་དགའ་བ་ཞིག་ཡིན། དེ་ལས་ཕྲག་དོག༌དང༌། རྩོད༌པ། དམོད༌ཚིག དོགས་པ་ངན་པ་བཅས་འབྱུང་བ༌དང༌།",
      "5": "བསམ་པ་ངན་པར་གྱུར་ཅིང་བདེན་པ་ཉིད་དང་བྲལ་བའི་རྩོད་པའང་རྒྱུན་ཆད་མེད་པར་འབྱུང༌། མི་དེ་དག་གིས་དད་གུས་བྱེད་པ་ནི་རྒྱུ་ནོར་འཐོབ་པའི་ཐབས་ལམ་ཡིན་པར་བསམས་སོ།།",
      "6": "འོན་ཀྱང༌། དད་གུས་བྱེད་པ་ལ་འདོད་ཆུང་ཆོག་ཤེས་ལྡན་ན་ཕན་ཐོགས་ཤིན་ཏུ་ཆེའོ།།",
      "7": "རྒྱུ་མཚན་ནི་བདག་ཅག་གིས་འཇིག་རྟེན་འདིར་ཅི་ཡང་ཁྱེར་མ་འོངས༌ལ། འཇིག་རྟེན་ནས་ཀྱང་ཅི་ཡང་འཁྱེར་མི་ནུས་པའི་ཕྱིར༌རོ།།",
      "8": "དེ་བས་ཁ་ལ་ཟས་དང་རྒྱབ་ལ་གོས་ཡོད་ན་ཡིད་ཚིམ་དགོས་སོ།།",
      "9": "འོན་ཀྱང༌། ཕྱུག་པོར་འགྱུར་འདོད་པ་རྣམས་ནི་ཉམས་ཚོད་དང་རྙི་རྒྱ་རུ་ཚུད༌པ་དང༌། བླུན་ཞིང་རྨོངས་པ་དང་གནོད་པ་ཆེ་བའི་འདོད་རྔམ་སྣ་ཚོགས་ཀྱི་ནང་དུ་ལྷུང་སྟེ་རང་ཉིད་བརླག་ཅིང་འཇིག་པར་འགྱུར་རོ།།",
      "10": "ཅིའི་ཕྱིར་ཞེ་ན། རྒྱུ་ནོར་ལ་རྔམ་པ་ནི་ལས་ངན་པ་སྣ་ཚོགས་ཀྱི་འབྱུང་རྩ་ཡིན༌ལ། མི་ཁ་ཤས་རྒྱུ་ནོར་ལ་ཞེན་ཆགས་ཏེ་དད་པ་དང་ཁ་བྲལ་ནས་རང་གིས་རང་ཉིད་སྡུག་བསྔལ་མང་པོས་བརྟོལ་བར་བྱེད་པའི་ཕྱིར་རོ།།",
      "11": "¶ འོན་ཀྱང་། ཁྱོད་ནི་དཀོན་མཆོག་ལ་གཏོགས་པའི་མི་ཡིན་པས་གོང་གི་དོན་འདི་དག་དང་འབྲལ་བར༌གྱིས། དྲང་བདེན་དང་དད་གུས། དད་སེམས། བྱམས༌པ། བཟོད༌བསྲན། ཞི་དུལ་བཅས་བསྙེག་པར་བྱོས།",
      "12": "ཁྱོད་ཀྱིས་དད་པའི་ཆེད་དུ་འཐབ་འཛིང་བཟང་པོ་བྱེད་པ་དང་། མཐའ་མེད་པའི་ཚེ་སྲོག་ཀྱང་གཟུང་བར་གྱིས་ཤིག ཁྱོད་ནི་དེའི་ཆེད་དུ་ཞལ་འབོད་གནང་བ༌དང༌། ཁྱོད་ཀྱིས་ཀྱང་དཔང་པོ་བྱེད་མཁན་མང་པོའི་ཁྲོད་ནས་བདེན་དཔང་བཟང་པོ་བྱས་མྱོང༌བ་ཡིན།",
      "13": "བདག་གིས་སྲོག་ལྡན་ཐམས་ཅད་ལ་ཚེ་སྲོག་གནང་མཁན་དཀོན་མཆོག་གི་སྤྱན་དྲུང༌དང༌། ཕོན་ཏིའུ་པི་ལ་ཏུའི་མདུན༌དུ་བདེན་དཔང་བཟང་པོ་མཛད་མྱོང་མཁན་མཱ་ཤི་ཀ་ཡེ་ཤུའི་སྤྱན་སྔ་ནས་ཁྱོད་ལ་གདམས་པར་བྱ༌སྟེ།",
      "14": "ཁྱོད་ཀྱིས་བདག་ཅག་གི་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀ་མངོན་སུམ་དུ་ཕེབས་ཡོང་བའི་བར༌དུ། བཀའ་དེ་ལ་སྐྱོན་དང་དྲི་མས་མ་གོས་པར་བསྲུང་བར་བྱའོ།།",
      "15": "དུས་ལ་བབས༌པ་ན། དཀོན་མཆོག་གིས་ཐམས་ཅད་མངོན་པར་མཛད་ངེས༌ཡིན་ལ། དཀོན་མཆོག་ནི་བསྟོད་པར་འོས་པ༌དང༌། ཀུན་ལ་དབང་མཛད་མཁན་ཁོ་ན༌ཉིད། རྒྱལ་པོ་རྣམས་ཀྱི་རྒྱལ་པོ་དང་གཙོ་བོ་རྣམས་ཀྱི་གཙོ་བོ༌སྟེ།",
      "16": "ཁོང་ནི་ནམ་ཡང་འཆི་བ་མེད་པ་ཁོ་ན༌ཉིད། མི་རྣམས་ཉེ་སར་ཙམ་ཡང་འགྲོ་ཐབས་མེད་པའི་འོད་ཟེར་ནང་དུ་བཞུགས་པ༌དང༌། མི་སུས་ཀྱང་མཐོང་མ་མྱོང་ཞིང་མཐོང་ཡང་མི་ནུས་པ་དེ་ཉིད་ལགས་སོ།། ཁོང་ལ་བཀུར་བསྟི་དང་རྫོགས་མཐའ་མེད་པའི་མངའ་ཐང་ལྡན་པར༌ཤོག ཨ༌མེན།",
      "17": "¶ ཁྱོད་ཀྱིས་འཇིག་རྟེན་འདིར་ཕྱུག་པོ་ཡིན་པ་རྣམས་ལ་ང་རྒྱལ་མི་བྱེད་པ་དང་མི་རྟག་པའི་རྒྱུ་ནོར་ལ་བློ་མི་གཏོད༌པར། བདག་ཅག་ལ་རྒྱུ་ནོར་ལོངས་སྤྱོད་ཚད་མེད་གནང་མཁན་ཏེ་དཀོན་མཆོག་ཁོ་ནར་བརྟེན་འོས་པའི་བཀའ་བསྒོ་བར་བྱའོ།།",
      "18": "ཡང་ཁོ་རྣམས་ལ་ལས་བཟང་པོ་བྱེད་པ༌དང༌། དོན་བཟང་མང་དུ་བསྒྲུབ༌པ། གཏོང་ཕོད་ཆེ༌བ། མི་གཞན་ལ་སྦྱིན་པ་གཏོང་བར་དགའ་དགོས་པ་དང་།",
      "19": "དེ་བཞིན་དུ་ཚེ་སྲོག་དངོས་མ་དེ་ཉིད་འཛིན་པའི་ཕྱིར། རང་གི་ཆེད་དུ་མ་འོངས་པར་རྨང་གཞི་བརྟན་པོའི་ནོར་བུ་གསོག་དགོས་པ་བཅས་ཀྱི་བཀའ་བསྒོ་བར་བྱའོ།།",
      "20": "¶ ཀྱེ། ཐི་མོ༌ཐེ། ཁྱོད་ལ་བཅོལ་ཞིང་གདམས་པ་རྣམས་བསྲུང་བར་བྱའོ།། འཇིག་རྟེན་གྱི་སྙིང་པོ་མེད་པའི་འཆལ་གཏམ༌དང༌། བདེན་པ་ཉིད་དང་འགལ་ཞིང་ཡོན་ཏན་དུ་རློམ་པའི་འཁྲུལ་ཤེས་བཅས་ལ་ཁ་འབྲལ་བར༌གྱིས།",
      "21": "མི་འགའ་ཞིག་གིས་རང་ཉིད་ལ་ཡོན་ཏན་དེ་ལྟ་བུ་ལྡན་པར་སྨྲ་ཞིང་དད་པ་དང་ཁ་བྲལ་བའོ།། ཐུགས་རྗེ་ནི་རྟག་ཏུ་ཁྱོད་ཅག་དང་མཉམ་དུ་གནས་པར༌སྨོན།། །།"
    }
  }
}
