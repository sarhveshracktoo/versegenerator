{
  "name": "སྟོན་པ།",
  "id": "སྟོན་པ།",
  "order": 21,
  "chapters": {
    "1": {
      "1": "¶ ཡེ་རུ་སཱ་ལེམ་གྱི་རྒྱལ་པོ་སྟེ་དཱ་བིད་ཀྱི་སྲས་སྟོན་པ་ལགས་པའི་གཏམ་ནི་འདི་ལྟ་སྟེ།",
      "2": "སྟོང་པ་དང་ནི་སྟོང་པའི་སྟོང་པ་སྟེ། ། ཐམས་ཅད་སྟོང་པ་ཡིན་ཞེས་སྟོན་པས་གསུངས། །",
      "3": "མི་ཡིས་ཉི་མའི་འོག་ཏུ་སྡུག་མྱངས་ནས། ། དཀའ་བ་སྤྱད་པར་ཕན་ཐོགས་ཅི་ཞིག་ཡོད། །",
      "4": "མི་རབས་འདའ་ཞིང་མི་རབས་འབྱུང་མོད་ཀྱང་། ། ས་གཞིར་འགྱུར་བ་མེད་ཅིང་རྟག་ཏུ་གནས། །",
      "5": "ཉི་མ་འཆར་ཞིང་ཉི་མ་ནུབ་པ་དང་། ། མཇུག་མཐར་ལམ་སང་ཤར་སའི་གནས་སུ་བཞུད། །",
      "6": "རླུང་ནི་ལྷོ་རུ་གཡུག་ཅིང་བྱང་དུ་འཁོར། ། སྐོར་བ་བརྒྱབ་ནས་འཁོར་ཞིང་མཚམས་མི་ཆད།",
      "7": "གཙང་པོ་མཐའ་དག་རྒྱ་མཚོར་ཞུགས་ན་ཡང་། ། རྒྱ་མཚོ་ནམ་ཡང་གང་བར་མ་གྱུར་ཏེ། ། གཙང་པོ་ཐོན་སའི་གནས་སུ་ཕྱིར་ལོག་གོ །",
      "8": "བྱ་བ་ཀུན་གྱིས་མི་ལ་སུན་སྣང་བསྐྱེད། ། དེ་ནི་མི་ཡིས་བརྗོད་གྱིས་མི་ལང་ངོ་། ། མིག་གིས་བལྟས་ཀྱང་ནམ་ཡང་མི་ངོམས་ལ། ། རྣ་བས་མཉན་ཡང་ཚིམ་པ་ཡེ་ནས་མེད། །",
      "9": "སྔར་བྱུང་དོན་རྣམས་ཡང་བསྐྱར་འབྱུང་ངེས་ལ། ། བྱས་ཟིན་དོན་རྣམས་ཡང་བསྐྱར་བྱེད་འགྱུར་བས། ། ཉི་མའི་འོག་ཏུ་གསར་པ་ཅི་ཡང་མེད། །",
      "10": "མི་ཡིས་འདི་ནི་གསར་པ་ཡིན་ནོ་ཞེས། ། སྨྲ་བར་ནུས་པའི་བྱ་བ་ཅི་ཡོད་དམ། ། མ་གཞི་དེ་ནི་རང་ཅག་ཡར་སྔོན་ལ། ། སྔ་མོའི་དུས་ནས་ཡོད་པ་ཡིན་ལགས་སོ། །",
      "11": "འདས་ཟིན་མི་རབས་སུས་ཀྱང་མི་དྲན་ལ། ། མ་འོངས་འབྱུང་འགྱུར་མི་རབས་དག་ཀྱང་ནི། ། རྗེས་མ་རྣམས་ཀྱིས་དྲན་པར་མི་འགྱུར་རོ། །",
      "12": "¶ སྐབས་དེར་སྟོན་པ་བདག་ནི་ཡེ་རུ་སཱ་ལེམ་དུ་ཡེས་ར་ཨེལ་གྱི་རྒྱལ་པོ་བྱེད་དུས།",
      "13": "བདག་གིས་རང་གི་ཤེས་རབ་ཀྱིས་གནམ་འོག་ཏུ་བྱུང་བའི་དོན་ཐམས་ཅད་ལ་སེམས་རྣལ་དུ་ཕབ་ནས་བརྟགས་པ་ན། དཀོན་མཆོག་གིས་མི་ལ་ཁུར་བོ་ལྗིད་པོ་གནང་ནས་ཁོ་ཚོར་དཀའ་སྡུག་མྱང་བར་མཛད་པའོ། །",
      "14": "ངས་ཉི་མའི་འོག་ཏུ་བྱུང་བའི་དོན་ཐམས་ཅད་ལ་བལྟས་པ་ན། ཐམས་ཅད་སྟོང་པ་ཡིན་པ་དང་། རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་ཡིན་པ་རྟོགས།",
      "15": "འཁྱོག་པོ་ཡིན་པ་བསྲང་མི་ནུས་ལ། མེད་པ་དེ་རྩི་བར་ཡང་མི་ནུས།",
      "16": "ངའི་སེམས་སུ་ང་ལ་ཤེས་རབ་ཆེན་པོ་ཐོབ་ཅིང་། ངའི་ཡར་སྔོན་དུ་ཡེ་རུ་སཱ་ལེམ་ལ་དབང་སྒྱུར་མཁན་ཐམས་ཅད་ལས་ཀྱང་ལྷག་པ་ཡིན་ཏེ། ངའི་སེམས་སུ་ཤེས་རབ་དང་ཤེས་བྱ་ཉམས་ལེན་ཐོབ་བྱུང་སྙམ།",
      "17": "བདག་གིས་ཡང་བློ་སེམས་རྩེ་གཅིག་གིས་ཤེས་རབ་དང་ཤེས་བྱ་དང་། ཁེངས་དྲེགས་དང་བླུན་རྨོངས་ཅི་ཡིན་པར་ཞིབ་ཏུ་བརྟགས་པ་ན། ད་གཟོད་དེ་ཡང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་ཡིན་པ་རྟོགས་བྱུང་།",
      "18": "ཅི་ལ་ཞེ་ན། ཤེས་རབ་འཕེལ་ན་སེམས་སྡུག་དེ་ལས་མང་ཞིང་། ཤེས་བྱ་མང་ན་མྱ་ངན་དེ་ལས་ཆེ་བ་འོ། །"
    },
    "2": {
      "1": "¶ ངས་རང་གི་སེམས་ལ་འདི་ལྟར། ཤོག་དང་། ངས་ཁྱོད་ལ་དགའ་སྤྲོས་དཔྱོད་ཅིང་ཕན་ཐོགས་ཅི་ཞིག་ཡོད་པར་བལྟ་རུ་འཇུག་བསམས་ཀྱང་། འདི་ཡང་སྟོང་པ་ཡིན་ཏེ།",
      "2": "གད་མོ་ལ་བདག་གིས་དེ་ནི་ཁེངས་དྲེགས་ཡིན་པར་སྨྲས། ལོངས་སྤྱོད་གླེང་ན་དེར་ཕན་ནུས་ཅི་ཡོད་དམ།",
      "3": "བདག་གིས་མི་ནི་ཅི་འདྲ་ཡིན་པ་གསལ་པོར་ངེས་པ་དང་། གནམ་འོག་ཏུ་མི་ཚེ་ཐུང་ཐུང་གི་ལོ་ཟླའི་ཁྲོད་དུ་དོན་གང་ཞིག་ལེགས་པོ་ཡིན་པ་རྟོགས་པའི་བར་དུ། རྒུན་ཆང་གིས་རང་གི་ལུས་སྐྱིད་པར་བྱས་ནས་བླུན་པོ་ལྟར་སྤྱོད་པར་བསམ་བློ་བཏང་མོད་ཀྱང་། ངའི་ཤེས་རབ་ཀྱིས་ང་ལ་ལམ་བསྟན་ཏོ། །",
      "4": "ངས་ལས་ཀ་ཆེན་པོ་རྣམས་བྱས་ཏེ། རང་གི་ཕྱིར་ཕོ་བྲང་རྣམས་བཞེངས་ནས་རྒུན་ཚལ་རྣམས་བཙུགས།",
      "5": "མེ་ཏོག་ལྡུམ་ར་དང་སྐྱེད་མོས་ཚལ་རྣམས་བཟོས་ཏེ། དེ་དག་གི་ནང་དུ་སིལ་སྡོང་སྣ་ཚོགས་བཙུགས།",
      "6": "ངས་ནགས་ཚལ་གྱི་ལྗང་བུ་རྣམས་ལ་ཆུ་གཏོང་བའི་ཆེད་དུ་རྫིང་བུ་རྣམས་ཀྱང་བཟོས།",
      "7": "ངས་གཡོག་པོ་གཡོག་མོ་གཞན་ཡང་ཉོས་ལ། རང་ཁྱིམ་དུ་སྐྱེས་པའི་བྲན་གཡོག་ཀྱང་ཡོད། ཡང་སྔོན་ཆད་ཡེ་རུ་སཱ་ལེམ་དུ་གནས་པ་ཀུན་ལས་ཀྱང་བདག་ལ་སྒོ་ཕྱུགས་མང་པོ་ཡོད།",
      "8": "ཡང་ངས་གསེར་དངུལ་དང་། རྒྱལ་པོ་དང་སྡེ་རྣམས་ཀྱི་གཏེར་མཛོད་རྣམས་ཀྱང་རང་གི་ཕྱིར་བསགས་པར་མ་ཟད། གླུ་བ་གླུ་མ་རྣམས་དང་། མི་རྣམས་དུང་བའི་དངོས་པོ་དང་། བཙུན་མོ་རྣམས་ཀྱང་རང་གི་ཕྱིར་བསྡུས་པ་ཡིན།",
      "9": "དེ་ལྟར་བདག་ནི་ཉིན་རེར་རྒྱས་པ་དང་། སྔོན་ཆད་ཡེ་རུ་སཱ་ལེམ་དུ་གནས་པ་ཀུན་ལས་ཀྱང་ལྷག་པར་དར་ཏེ། ངའི་ཤེས་རབ་ནི་ད་དུང་ངའི་ནང་དུ་ལུས་སོ། །",
      "10": "ངས་རང་གི་མིག་གིས་མཐོང་འདོད་པ་ཐམས་ཅད་ལ་བལྟས་ཤིང་། སྐྱིད་པར་བསམས་པ་གང་ལས་ཀྱང་རང་གི་སེམས་ནི་མ་བཀག ཅིའི་ཕྱིར་ཞེ་ན། ངའི་སེམས་ནི་རང་གི་དཀའ་ལས་ཐམས་ཅད་ལ་དགའ་ཞིང་། འདི་ནི་ངས་བྱས་པའི་དཀའ་ལས་ཐམས་ཅད་ནས་ཐོབ་པའི་སྐལ་ཡིན་ནོ། །",
      "11": "དེ་ནས་ངས་རང་བྱས་ཀྱི་ལས་དང་དཀའ་ལས་ཀྱི་འབྲས་བུ་ཐམས་ཅད་ལ་བལྟས་པ་དང་། ཀྱེ་ཧོ། དེ་ཐམས་ཅད་ནི་སྟོང་པ་དང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་ཡིན། ཉི་མའི་འོག་ཏུ་དེ་ལ་ཕན་ཐོགས་ཅི་ཡང་མེད།",
      "12": "དེ་ནས་ངས་ཤེས་རབ་དང་ཁེངས་དྲེགས། བླུན་རྨོངས་བཅས་ཀྱི་ཕྱོགས་སུ་བློ་ཁ་བསྒྱུར་པ་ཡིན། སྔར་ནས་བྱས་ཟིན་པ་དེ་ལས་གཞན། རྒྱལ་པོའི་རྗེས་སུ་འབྱུང་བ་རྣམས་ཀྱིས་གཞན་ཅི་ཞིག་བྱེད་ནུས་སམ།",
      "13": "དེ་ནས་འོད་ནི་མུན་པ་ལས་བརྒལ་བ་ལྟར། ཤེས་རབ་ནི་བླུན་རྨོངས་ལས་བརྒལ་བ་ངས་རྟོགས་བྱུང་།",
      "14": "མཁས་པ་ལ་ནི་ཤེས་རབ་ཀྱི་སྤྱན་དང་ལྡན། བླུན་པོ་ནི་མུན་པའི་ནང་དུ་འགྲུལ་བ་ཡིན། འོན་ཀྱང་དེ་གཉིས་ཀྱི་སྔོན་ལས་གཅིག་ཡིན་པ་ངས་རྟོགས་བྱུང་།",
      "15": "ངའི་སེམས་སུ་འདི་ལྟར། བླུན་པོ་ལ་འབྱུང་བ་བཞིན་དུ་བདག་ལའང་འབྱུང་བར་འགྱུར་བས། བདག་རབ་ཏུ་མཁས་པར་འགྱུར་དགོས་དོན་ཅི་ཡོད་སྙམ་པ་དང་། ཡང་ངའི་སེམས་སུ་འདི་ཡང་སྟོང་པ་ཡིན་བསམས་པའོ། །",
      "16": "ཅིའི་ཕྱིར་ཞེ་ན། མཁས་བླུན་གཉིས་ཀ་གཅིག་ཡིན་ཏེ་སུ་ཞིག་གིས་ཀྱང་ཁོ་རྣམས་དུས་རྟག་ཏུ་དྲན་པར་མི་བྱེད་ལ། མ་འོངས་པའི་དུས་སུ་ཐམས་ཅད་བརྗེད་པར་འགྱུར་བས། བླུན་པོ་ནང་བཞིན་མཁས་པ་ཡང་འཆི་བར་ངེས།",
      "17": "དེའི་རྐྱེན་གྱིས་ཉི་མའི་འོག་ཏུ་བྱེད་པའི་ལས་ནི་སྡུག་བསྔལ་དུ་མཐོང་བས་ང་རང་ཚེ་སྲོག་ལ་སྡང་བ་ཡིན། ཐམས་ཅད་སྟོང་པ་ཡིན་པ་དང་། རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་ཡིན་ནོ། །",
      "18": "དེར་མ་ཟད། ཉི་མའི་འོག་ཏུ་བྱས་པའི་དཀའ་ལས་ཐམས་ཅད་ལའང་ང་རང་སྡང་སྟེ། ཅིའི་ཕྱིར་ཞེ་ན། ངས་དེ་རྣམས་མི་རབས་རྗེས་མའི་དོན་དུ་འཇོག་དགོས་པས་སོ། །",
      "19": "ཡང་དེ་ནི་མཁས་པའམ་ཡང་ན་བླུན་པོ་ཡིན་པ་སུས་ཤེས། འོན་ཀྱང་ངས་སྤྱད་པའི་དཀའ་བ་ཐམས་ཅད་དང་། གང་གི་དོན་དུ་ཉི་མའི་འོག་ཏུ་རང་གི་ཤེས་རབ་ལ་བརྟེན་ནས་ཐོབ་པ་ལ་དེས་དབང་བསྒྱུར་བས་ན་འདི་ཡང་སྟོང་པ་ཡིན།",
      "20": "དེའི་ཕྱིར་ཉི་མའི་འོག་ཏུ་ངས་སྤྱད་པའི་དཀའ་བ་ཐམས་ཅད་ལ་ང་རང་ཡིད་ཐང་ཆད་དོ། །",
      "21": "ཅིའི་ཕྱིར་ཞེ་ན། ཤེས་རབ་དང་ཤེས་བྱ། རིག་རྩལ་བཅས་ལ་བརྟེན་ནས་ཐོབ་པའི་རང་གི་ཡོད་ཚད་ནི། མཐར་དཀའ་བ་ཅི་ཡང་མ་སྤྱད་པའི་མི་ལ་ནོར་སྐལ་དུ་འཇོག་དགོས་པའི་ཕྱིར། འདི་ཡང་སྟོང་པ་ཡིན་པ་སྟེ་སེམས་སྡུག་ཆེན་པོ་ཞིག་གོ །",
      "22": "ཉི་མའི་འོག་ཏུ་སེམས་ཁུར་ངང་སྤྱད་པའི་དཀའ་བ་ཐམས་ཅད་ནས་མི་ལ་ཅི་ཞིག་འཐོབ་པ་ཡིན་ནམ།",
      "23": "ཁོས་ཉིན་རེར་སྡུག་བསྔལ་མྱངས་པས། ཁོའི་དཀའ་ངལ་སེམས་སྡུག་ཏུ་གྱུར་ཏེ། ཁོའི་སེམས་ནི་མཚན་མོར་ཡང་ལྷོད་ལ་མ་བབས་པས། འདི་ཡང་སྟོང་པ་ཡིན་ནོ། །",
      "24": "བཟའ་བཏུང་དང་རང་གི་དཀའ་ལས་ཀྱི་ནང་དུ་ཡིད་ཚིམ་པ་ལས་ལྷག་པ་ཞིག་མི་ལ་མེད་དེ། དེ་ཡང་དཀོན་མཆོག་གི་ཕྱག་གིས་གནང་བ་ངས་མཐོང་ངོ་། །",
      "25": "བཟའ་བཏུང་དང་ལོངས་སྤྱོད་གླེང་ན། སུ་ཞིག་བདག་ལས་ལྷག་པ་ཡིན་ནམ།",
      "26": "དཀོན་མཆོག་སུ་ལ་ཐུགས་མཉེས་ན་ཁོང་གིས་དེ་ལ་ཤེས་རབ་དང་ཤེས་བྱ། དགའ་སྤྲོ་བཅས་གནང་བ་དང་། སྡིག་ཅན་ལ་ཅི་གནང་ཞེ་ན། དཀའ་སྡུག་གནང་བར་མ་ཟད། དེ་རྣམས་ཀྱིས་བསགས་པའི་རྒྱུ་ནོར་ཐམས་ཅད་ཀྱང་དཀོན་མཆོག་ཐུགས་མཉེས་པ་ལ་ནོར་སྐལ་དུ་གཏོང་ངོ་། །འདི་ཡང་སྟོང་པ་ཡིན་པ་དང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་ལས་མ་འདས་སོ། །"
    },
    "3": {
      "1": "¶ བྱ་བ་ཀུན་ལ་དུས་ཤིག་ཡོད་པ་དང་། ། གནམ་འོག་དོན་རེར་དུས་ཤིག་ཡོད་པ་སྟེ། །",
      "2": "སྐྱེ་བའི་དུས་ཤིག་འཆི་བའི་དུས་ཤིག་ཡོད། ། འཛུགས་པའི་དུས་ཤིག་འབལ་བའི་དུས་ཤིག་ཡོད།",
      "3": "གསོད་པའི་དུས་ཤིག་གསོ་བའི་དུས་ཤིག་ཡོད། ། བཤིག་པའི་དུས་ཤིག་བསྐྲུན་པའི་དུས་ཤིག་ཡོད། །",
      "4": "ངུ་བའི་དུས་ཤིག་དགོད་པའི་དུས་ཤིག་ཡོད། ། མྱ་ངན་དུས་ཤིག་གར་རྩེད་དུས་ཤིག་ཡོད། །",
      "5": "རྡོ་བ་འཕེན་པའི་དུས་ཤིག་ཡོད་པ་དང་། ། རྡོ་བ་སྤུང་བའི་དུས་ཤིག་ཀྱང་ནི་ཡོད། ། འཐམ་པའི་དུས་ཤིག་མི་འཐམ་དུས་ཤིག་ཡོད། །",
      "6": "འཚོལ་བའི་དུས་ཤིག་སྤང་བའི་དུས་ཤིག་ཡོད། ། འཇོག་པའི་དུས་ཤིག་འཕེན་པའི་དུས་ཤིག་ཡོད། །",
      "7": "དབྲལ་བའི་དུས་ཤིག་འཚེམ་པའི་དུས་ཤིག་ཡོད། ། ཁ་ཁུ་སིམ་པོར་སྡོད་པའི་དུས་ཤིག་དང་། ། ངག་ནས་སྐད་ཆ་སྨྲ་བའི་དུས་ཤིག་ཡོད། །",
      "8": "བརྩེ་བའི་དུས་ཤིག་སྡང་བའི་དུས་ཤིག་ཡོད། ། འཐབ་མོའི་དུས་ཤིག་ཞི་བདེའི་དུས་ཤིག་ཡོད། །",
      "9": "¶ དེས་ན་ལས་ཀ་བྱེད་པའི་མི་ལ་རང་གི་དཀའ་ལས་ཀྱི་ནང་ནས་ཕན་ཐོགས་ཅི་ཞིག་འཐོབ་བམ།",
      "10": "དཀོན་མཆོག་གིས་མི་རྣམས་ལ་ལས་ཀ་གནང་སྟེ་ཁོ་ཚོ་དེ་ལ་བྲེལ་བ་ངས་མཐོང་བྱུང་ངོ་། །",
      "11": "དཀོན་མཆོག་གིས་ཐམས་ཅད་བཀོད་པ་དང་། ཁོང་ཉིད་ཀྱི་དུས་སུ་དངོས་པོ་ཐམས་ཅད་མཛེས་པར་བཀོད་ཅིང་། ཐོག་མཐའ་མེད་པའི་འདུ་ཤེས་ཀྱང་དེ་དག་གི་སེམས་སུ་བཞག་པར་མཛད་ནའང་། དཀོན་མཆོག་གི་ཐོག་མཐའ་བར་གསུམ་གྱི་མཛད་པ་ནི་མི་རྣམས་ཀྱིས་རྟོགས་མི་ནུས་སོ། །",
      "12": "མི་རྣམས་ཚེ་གང་པོར་དགའ་ཞིང་དགེ་བ་སྒྲུབ་པ་ལས་ལྷག་པ་ཞིག་མེད་པ་ངས་རྟོགས་བྱུང་།",
      "13": "མི་རྣམས་ཀྱིས་བཟའ་བཏུང་སྤྱོད་པ་དང་། རང་གི་དཀའ་ལས་ཐམས་ཅད་ཀྱི་འབྲས་བུ་ལོངས་སུ་སྤྱོད་པ་ནི་དཀོན་མཆོག་གི་གནང་སྦྱིན་ལགས་སོ། །",
      "14": "དཀོན་མཆོག་གིས་ཅི་མཛད་ཐམས་ཅད་རྟག་ཏུ་གནས་ཏེ། དེའི་ནང་དུ་ཅི་ཡང་བསྣོན་པར་མི་ནུས་ལ་ཅི་ཡང་འཕྲི་བར་མི་འཇོན། དེ་ནི་མི་རྣམས་དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པའི་ཆེད་དུ་ཁོང་གིས་དེ་བཞིན་བསྒྲུབས་པ་ངས་རྟོགས་བྱུང་།",
      "15": "ད་ལྟ་ཡོད་པ་དེ་སྔར་ནས་བྱུང་ཟིན་པ་དང་། འབྱུང་འགྱུར་གྱི་དོན་རྣམས་ཀྱང་སྔར་ནས་བྱུང་བ་ཡིན་ཏེ། དཀོན་མཆོག་གིས་འདས་ཟིན་རྣམས་ཡང་བསྐྱར་འབྱུང་བར་མཛད་དོ། །",
      "16": "¶ ཡང་དེར་མ་ཟད་ངས་ཉི་མའི་འོག་ཏུ་ཁྲིམས་ཐག་གཅོད་སར་གཡོ་སྒྱུ་ལྡན་པ་དང་། དྲང་བདེན་ཡིན་སར་གཡོ་སྒྱུ་ཡོད་པའང་རྟོགས་བྱུང་།",
      "17": "ངས་རང་གི་སེམས་སུ། བྱ་བ་རེ་རེ་དང་ལས་དོན་ཐམས་ཅད་ལ་དུས་ཤིག་ཡོད་པས། དཀོན་མཆོག་གིས་མི་དྲང་བདེན་དང་མི་ངན་པ་གཉིས་ལ་ལེགས་ཉེས་འབྱེད་པར་འགྱུར་སྙམ་དུ་བསམས་བྱུང་།",
      "18": "ཡང་ངས་རང་གི་སེམས་སུ། འཇིག་རྟེན་མི་བུ་རྣམས་ལ་མཚོན་ན་དཀོན་མཆོག་གིས་དེ་དག་ལ་བརྟག་པར་མཛད་ཅིང་། མི་རྣམས་ལ་རང་ཉིད་ནི་དུད་འགྲོ་ལྟ་བུ་ཡིན་པ་རྟོགས་སུ་འཇུག་སྙམ་པ་ཡིན།",
      "19": "ཅི་ལ་ཞེ་ན། མི་བུ་རྣམས་ལ་བྱུང་བ་དེ་རྣམས་དུད་འགྲོ་ལའང་འབྱུང་ལ། དེ་གཉིས་ཀའི་སྔོན་ལས་ནི་གཅིག་ཡིན་ཏེ། འདི་ཅི་ལྟར་འཆི་བ་ཡིན་ན་དེ་ཡང་དེ་ལྟར་དུ་འཆི་བ་ཡིན། དེ་གཉིས་ཀྱིས་དབུགས་ལེན་པའང་གཅིག་ཡིན་པས། མི་ནི་དུད་འགྲོ་ལས་རྩ་ཆེན་མ་ཡིན་ལ་ཐམས་ཅད་སྟོང་པ་ཡིན།",
      "20": "ཐམས་ཅད་གནས་གཅིག་ཏུ་འགྲོ་བ་སྟེ། ཐམས་ཅད་ས་རྡུལ་ལས་བྱུང་ཞིང་། ཐམས་ཅད་སླར་ཡང་ས་རྡུལ་དུ་འགྱུར་བ་ཡིན།",
      "21": "མི་ཡི་རྣམ་ཤེས་ཡར་འཕག་པ་དང་། དུད་འགྲོའི་རྣམ་ཤེས་ནི་མར་ལྷུང་བ་སུ་ཡིས་ཤེས་སམ།",
      "22": "དེ་བས། མི་ལ་རང་གི་ལས་རྣམས་ནས་དགའ་སྤྲོ་ཐོབ་པ་ལས་ལྷག་པ་ཞིག་མེད་པ་ངས་མཐོང་བྱུང་། དེ་ནི་ཁོའི་ཐོབ་སྐལ་ཡིན་པས་སོ། །སུ་ཞིག་གིས་ཁོའི་རྗེས་སུ་འབྱུང་བ་དེ་ཁོ་ལ་སྟོན་ནུས་སམ།"
    },
    "4": {
      "1": "¶ ཡང་ཉི་མའི་འོག་ཏུ་གཉའ་གནོན་གྱི་བྱ་བ་རྣམས་བྱུང་བ་ངས་མཐོང་སོང་། གཉའ་གནོན་ཐེབས་མཁན་རྣམས་ངུས་ཀྱང་སེམས་གསོ་བྱེད་མཁན་སུ་ཡང་མེད་དེ། དེ་དག་ལ་གཉའ་གནོན་བྱེད་མཁན་རྣམས་དབང་ཆེ་བས། དེ་དག་ལ་སེམས་གསོ་བྱེད་མཁན་མེད་དོ། །",
      "2": "དེ་བས། ངས་ད་ལྟ་གསོན་པོར་གནས་པའི་གསོན་པོ་རྣམས་ལས་སྔར་ནས་འདས་ཟིན་པའི་གཤིན་པོ་རྣམས་ལ་ལྷག་པར་བསྟོད་པ་ཡིན།",
      "3": "འོན་ཀྱང་དེ་གཉིས་ཀ་ལས་ཀྱང་། ཉི་མའི་འོག་ཏུ་བྱས་པའི་ལས་ངན་པ་མ་མཐོང་བའི་ད་དུང་སྐྱེས་མེད་པ་དག་ནི་སྐྱིད་པར་བསམས།",
      "4": "མི་རྣམས་ཀྱིས་སྤྱད་པའི་དཀའ་བ་དང་གྲུབ་འབྲས་ཐམས་ཅད་ཀྱང་ཕན་ཚུན་བར་གྱི་ཕྲག་དོག་ལས་བྱུང་བ་ངས་མཐོང་བྱུང་། འདི་ཡང་སྟོང་པ་ཡིན་པ་དང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་མོ། །",
      "5": "བླུན་པོས་ལག་པར་ལག་པ་རུམ་ནས་རང་ཤ་རང་གིས་ཟ་བ་ཡིན།",
      "6": "དཀའ་ལས་ངང་རླུང་ལ་ཞགས་པ་འཕེན་པའི་སྤར་བ་གཉིས་ལས། སེམས་ལྷོད་པོའི་སྤར་བ་གང་དེ་ལེགས་སོ། །",
      "7": "དེ་ནས་ངས་སླར་ཡང་ཉི་མའི་འོག་གི་སྙིང་པོ་མེད་པའི་དོན་ཞིག་མཐོང་བ་ནི།",
      "8": "མི་ལ་ལ་གྲོགས་མེད་ཁེར་རྐྱང་ཡིན་ལ། བུ་ཡང་མེད། སྤུན་ཟླ་ཡང་མེད། འོན་ཀྱང་དེའི་འབད་བརྩོན་ལ་རྫོགས་མཐའ་མེད་ཅིང་། དེའི་མིག་ཟུང་ཡང་ནོར་གྱིས་མི་ཚིམ། དེ་ན་རེ། ངས་དཀའ་ལས་ཡོད་ཚད་སུའི་དོན་དུ་བྱེད་ཅིང་། ཅི་ལ་རང་གི་སེམས་བདེ་བ་ལས་འབྲལ་བར་བྱེད་དམ་ཟེར། འདི་ཡང་སྟོང་པ་ཡིན་ལ་ཁུར་བོ་ཤིན་ཏུ་ལྗིད་པོ་ཡིན་ནོ། །",
      "9": "མི་ཁེར་རྐྱང་ལས་མི་གཉིས་ཡིན་ན་དགའ། གང་ལ་ཞེ་ན། དེ་དག་ལ་དཀའ་ལས་ཀྱི་རྔན་པ་ལེགས་པར་འཐོབ་སྟེ།",
      "10": "གཅིག་འགྱེལ་ན་གཞན་དེས་རང་གི་གྲོགས་པོ་སློང་བར་བྱ། འོན་ཀྱང་གཅིག་པུ་ཡིན་པ་དེ་འགྱེལ་ན། ཁོ་རང་སློང་མཁན་མེད་པས་མི་དེར་ཆག་སྒོ་ཡིན་ནོ། །",
      "11": "ཡང་མི་གཉིས་མཉམ་དུ་ཉལ་ན་དྲོན་པོ་ཡིན་མོད། འོན་ཀྱང་མི་ཁེར་རྐྱང་ནི་ཅི་ལྟར་དྲོ་བར་འགྱུར།",
      "12": "ཡང་མི་ཁེར་རྐྱང་ནི་དགྲ་ངོར་འཕམ་ཞིང་མི་གཉིས་ཀྱིས་ཐུབ་པར་འགྱུར། ཐག་པ་སུམ་རྐྱ་ནི་མྱུར་དུ་མི་ཆད།",
      "13": "ཞལ་གདམས་ལ་མི་ཉན་པའི་རྒྱལ་པོ་བླུན་པོ་ཞིག་ལས། ན་གཞོན་དབུལ་པོ་མཁས་པ་ཞིག་ལེགས།",
      "14": "ན་གཞོན་དེ་ནི་རྒྱལ་སྲིད་ཀྱི་ནང་དུ་དབུལ་པོར་སྐྱེས་པ་དང་། བཙོན་ར་ནས་ཐོན་ཏེ་རྒྱལ་སྲིད་འཛིན་དུ་འོངས་པའོ། །",
      "15": "ཡང་ཉི་མའི་འོག་ཏུ་གསོན་པོར་གནས་པ་ཐམས་ཅད་རྒྱལ་པོ་རྒན་པ་དེའི་ཚབ་ཏུ་རྒྱལ་སྲིད་འཛིན་དུ་འོངས་པའི་ན་གཞོན་དེའི་རྗེས་སུ་འབྲངས་ནས།",
      "16": "ཁོས་སྐྱོང་བའི་མི་རྣམས་ཏེ་འབངས་མི་ཐམས་ཅད་བགྲང་ལས་འདས་ཀྱང་། དེའི་རྗེས་སུ་ཐོན་པ་རྣམས་དེ་ལ་ཡང་དགའ་བར་མ་གྱུར་པས། འདི་ཡང་སྟོང་པ་ཡིན་པ་དང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་མོ། །"
    },
    "5": {
      "1": "¶ ཁྱོད་རང་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་འགྲོ་དུས་སུ་རང་གི་གོམ་སྟབས་ལ་གཟབ་གཟབ་གྱིས་ཤིག ཉེ་སར་བཏུད་ནས་དཀོན་མཆོག་གི་བཀའ་ལ་ཉན་པ་ནི་བླུན་པོ་ཞིག་གིས་སྦྱིན་སྲེག་འབུལ་བ་ལས་ལེགས་ཏེ། ཁོ་ཚོས་རང་གིས་ལས་ངན་པ་བྱས་པའང་མི་ཤེས་སོ། །",
      "2": "དཀོན་མཆོག་གི་དྲུང་དུ་ཁྱོད་བབ་ཅོལ་ཅན་བྱས་ནས་གཏམ་སྨྲ་བར་ཁ་མ་མགྱོགས་ཤིག གང་ལ་ཞེ་ན། དཀོན་མཆོག་ནི་ནམ་མཁར་བཞུགས་ཤིང་ཁྱོད་ས་ལ་ཡོད་པས། གཏམ་ཉུང་ཉུང་བརྗོད་པར་གྱིས་ཤིག",
      "3": "དོན་བྱ་མང་ན་རྨི་ལམ་འབྱུང་བ་དང་། སྨྲ་བརྗོད་མང་བ་བླུན་པོའི་རྟགས།",
      "4": "ནམ་ཞིག་ཁྱོད་ཀྱིས་དཀོན་མཆོག་ལ་དམ་བཅས་པ་ཡིན་ན་དེ་བསྒྲུབ་པར་དུས་འགྱང་མ་བྱེད། ཅི་ལ་ཞེ་ན། བླུན་པོ་རྣམས་ལ་ཁོང་ཐུགས་མི་མཉེས་པས། དམ་བཅའ་དེ་ཅི་ནས་ཀྱང་བསྒྲུབ་དགོས།",
      "5": "དམ་བཅས་ནས་མི་བསྒྲུབ་པ་ལས་དམ་མ་བཅས་ན་ལེགས།",
      "6": "ཁྱོད་ཀྱིས་རང་གི་སྨྲ་སྒོའི་རྐྱེན་གྱིས་རང་ཉིད་ཉེས་པར་ལྷུང་དུ་འཇུག་མི་རུང་། ཕོ་ཉའི་མདུན་དུ་ངས་མ་ཤེས་པར་དམ་བཅས་ནས་ནོར་སོང་ཞེས་མ་ཞུས་ཤིག ཁྱོད་ཀྱི་སྐད་ཀྱིས་དཀོན་མཆོག་ལ་ཐུགས་ཁྲོ་བསླངས་ནས་ཁྱོད་ཀྱི་ལག་གི་ལས་ཀ་མེད་པར་མཛད་དུ་འཇུག་དོན་ཅི་ཡོད།",
      "7": "རྨི་ལམ་མང་བ་དང་གཏམ་མང་བ་ཐམས་ཅད་སྟོང་པ་ཡིན་པས། ཁྱོད་ཀྱིས་དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པར་གྱིས།",
      "8": "¶ ཇི་སྟེ་ཁྱོད་ཀྱིས་ཡུལ་ཞིག་ཏུ་དབུལ་པོ་ལ་གཉའ་གནོན་ཐེབས་པ་དང་། ཁྲིམས་ལོག་དང་གཤགས་ལོག་བྱེད་པ་མཐོང་ན་དེར་ཧ་ལས་མི་དགོས་ཏེ། ཅིའི་ཕྱིར་ཞེ་ན། མཐོ་ཤོས་རྣམས་ལས་ཀྱང་མཐོན་པོ་ཡིན་པ་དེས་ལྟ་སྐྱོང་བྱེད་ཅིང་། དེ་དག་ལས་ཀྱང་མཐོ་བ་ཞིག་ཡོད་དོ། །",
      "9": "དེར་མ་ཟད་ས་གཞིའི་ཁེ་བཟང་ནི་ཀུན་གྱི་ཕྱིར་ཡིན་ཏེ། རྒྱལ་པོ་ཡིན་ནའང་ཞིང་གིས་དེ་ལ་ཕན་ཐོགས་སོ། །",
      "10": "དངུལ་འདོད་ཅན་ཞིག་དངུལ་གྱིས་ཆོག་པར་མི་འགྱུར། ནོར་འདོད་ཅན་ཞིག་འཕེལ་བས་ཀྱང་ཆོག་པར་མི་འགྱུར། འདི་ཡང་སྟོང་པ་ཡིན།",
      "11": "ནོར་འཕེལ་དུས་ལོངས་སྤྱོད་བྱེད་མཁན་ཡང་འཕེལ་བས། ནོར་གྱི་བདག་པོ་ལ་མིག་གིས་ལྟ་བ་ལས་ཕན་ཐོགས་ཅི་ཡོད་དམ།",
      "12": "ལས་བྱེད་མཁན་གྱིས་མང་ཉུང་ཅི་ཟ་ཡང་དེའི་གཉིད་སྐྱིད་མོད། འོན་ཀྱང་ནོར་མང་པོས་ཕྱུག་པོ་གཉིད་དུའང་མི་འཇུག་གོ །",
      "13": "ངས་ཉི་མའི་འོག་ཏུ་སེམས་སྡུག་པའི་རྐྱེན་ངན་ཆེན་པོ་ཞིག་མཐོང་སྟེ། གང་ཡིན་ཞེ་ན། རྒྱུ་ནོར་གྱིས་བདག་པོ་རང་ལ་གནོད་བསྐྱལ་ཏོ། །",
      "14": "ཁོ་ལ་གནོད་འཚེ་ཐེབས་པས་རྒྱུ་ནོར་ཟད་པ་དང་། བུ་ཞིག་སྐྱེས་ན་ཡང་དེའི་ལག་ཏུ་ཅི་ཡང་མེད་དེ།",
      "15": "གཅེར་བུར་མངལ་ནས་ཐོན་པ་ལྟར་ཕྱིར་ཡང་དེ་ལྟར་འགྲོ་བ་སྟེ། དེས་དཀའ་བ་སྤྱད་པའི་ཐོབ་བྱ་དག་ནི་ཅི་ཡང་མཉམ་དུ་འཁྱེར་མི་ནུས།",
      "16": "ཁོ་ཅི་ལྟར་འོངས་པ་དེ་ལྟར་འགྲོ་དགོས་ཏེ། ལས་དོན་གྱི་ཆེད་དུ་འབད་ཀྱང་ཁོ་ལ་ཕན་ཅི་ཐོགས། འདི་ཡང་སེམས་སྡུག་པའི་རྐྱེན་ངན་ཆེན་པོ་ཞིག་གོ །",
      "17": "དེའི་ཚེ་གང་པོ་ནི་མུན་ནག་དང་སྡུག་བསྔལ་ནང་དུ་རོལ་བ་དང་། སེམས་ཁྲལ་མང་ཞིང་ན་ཚ་ཕོག་ནས་ཁོང་ཁྲོ་ཟའོ། །",
      "18": "ངས་ལེགས་ཤིང་ཡིད་དུ་འོང་བར་མཐོང་བའི་དོན་ནི། མི་ཡིས་དཀོན་མཆོག་གིས་གནང་བའི་ཚེ་གང་པོར་བཟའ་བཏུང་སྤྱོད་པ་དང་། ཉི་མའི་འོག་ཏུ་སྤྱད་པའི་དཀའ་བ་ཐམས་ཅད་ནས་ཐོབ་པའི་འབྲས་བུ་ལོངས་སུ་སྤྱད་དེ་སྐྱིད་པོ་བྱེད་པ་དེ་ཡིན་ལ། ཅིའི་ཕྱིར་ཞེ་ན། འདི་ནི་ཁོ་ལ་ཐོབ་འོས་པ་ཡིན་ནོ། །",
      "19": "དེར་མ་ཟད། དཀོན་མཆོག་གིས་མི་ལ་ནོར་དང་ལོངས་སྤྱོད་གནང་ཞིང་། དེ་ལས་བཟའ་བ་དང་རང་གི་ཐོབ་སྐལ་བླངས་ནས་རང་གི་དཀའ་ལས་ཁྲོད་དགའ་མགུ་བྱེད་པའི་དབང་ཡང་གནང་བ་ལགས། འདི་ནི་དཀོན་མཆོག་གི་གནང་སྦྱིན་ཡིན་ནོ། །",
      "20": "དཀོན་མཆོག་གིས་དེའི་སེམས་སུ་དགའ་སྤྲོ་གནང་བས། དེས་རང་གི་ཚེ་གང་པོའི་དོན་རྣམས་མང་དུ་དྲན་པར་མི་བྱའོ། །"
    },
    "6": {
      "1": "¶ ངས་ཉི་མའི་འོག་ཏུ་སྡུག་བསྔལ་ཞིག་མཐོང་བ་དང་། དེ་ནི་མི་ལ་ལྗིད་པོ་ཡིན་ཏེ།",
      "2": "དཀོན་མཆོག་གིས་མི་ལ་ཁོའི་འདོད་པ་བཞིན་དུ་རྒྱུ་ནོར་ལོངས་སྤྱོད་དང་ཐོབ་གོ་ས་གནང་ཡང་། ཁོ་ལ་ལོངས་སུ་སྤྱོད་པའི་དབང་ཐང་མ་གནང་བས། མི་ཆ་མེད་ཀྱིས་དེ་ལོངས་སུ་སྤྱོད་པ་སྟེ། འདི་ཡང་སྟོང་པ་ཡིན་པ་དང་སེམས་སྡུག་པའི་རྐྱེན་ངན་ཞིག་གོ །",
      "3": "ཇི་སྟེ་མི་ཞིག་ལ་བུ་བརྒྱ་སྐྱེས་ནས་ཚེ་ཐག་ཤིན་ཏུ་རིང་ཡང་། ཁོའི་སེམས་སུ་ད་དུང་ཡིད་མ་ཚིམ་པ་དང་། དེའི་བེམ་པོ་ཡང་དུར་ལ་འཇུག་པར་མ་གྱུར་ན། མངལ་དུ་ཤི་བའི་བུ་ནི་ཁོ་ལས་ལྷག་པ་ཡིན་ཞེས་ངས་སྨྲའོ། །",
      "4": "ཅིའི་ཕྱིར་ཞེ་ན། མངལ་ལས་བྱུང་བ་དེ་ནི་ཕན་ཐོགས་མེད་པར་ཐོན་པ་དང་མུན་པའི་ནང་དུ་འགྲོ་བས། དེའི་མིང་ནི་མུན་པའི་ནང་དུ་ནུབ་པར་གྱུར།",
      "5": "དེས་ཉི་མ་མཐོང་མ་མྱོང་ལ་ཅི་ཡང་མ་ཤེས་པས། མི་དེ་ལས་འདི་ལ་ངལ་གསོ་ཡོད།",
      "6": "དེར་མ་ཟད། གལ་ཏེ་མི་དེ་ནི་ལོ་ངོ་ཉིས་སྟོང་ལ་གསོན་པོར་གནས་ཀྱང་བདེ་སྐྱིད་ལ་རོལ་མ་ཐུབ་ན། མཐར་ཚང་མ་གནས་གཅིག་ཏུ་འགྲོ་བ་མ་ཡིན་ནམ།",
      "7": "མིའི་དཀའ་ལས་ཐམས་ཅད་རང་གི་ལྟོ་བཅུད་ཀྱི་དོན་དུ་ཡིན་པ་ལས་ཡིད་ཚིམ་པ་མེད་དོ། །",
      "8": "དེ་ཅིའི་ཕྱིར་ཞེ་ན། མཁས་པ་ལ་བླུན་པོ་ལས་ལྷག་པའི་དགེ་མཚན་ཅི་ཡོད་དམ། སྡུག་བསྔལ་ཅན་གྱིས་མི་རྣམས་ཀྱི་མདུན་དུ་ཅི་ལྟར་བྱེད་པ་ཤེས་ཀྱང་དེར་ཕན་ཐོགས་ཅི་ཡོད།",
      "9": "སེམས་སུ་དྲན་པ་ལས་མིག་གིས་མཐོང་བ་ལེགས། འདི་ཡང་སྟོང་པ་ཡིན་པ་དང་རླུང་ལ་ཞགས་པ་འཕེན་པ་ཙམ་མོ། །",
      "10": "སྔར་ཡོད་པ་ལ་སྔ་མོ་ནས་མིང་བཏགས་ཡོད་དེ། མི་ཡིས་རང་ནི་ཅི་འདྲ་ཡིན་པ་དང་། རང་ལས་སྟོབས་ཆེ་བ་དང་འགྲན་མི་ནུས་པ་རྟོགས་ཡོད།",
      "11": "གཏམ་མང་ན་སྙིང་པོ་མེད་པ་དེ་ལས་མང་བས། དེ་དག་མི་ལ་ཕན་ཐོགས་ཅི་ཡོད་དམ།",
      "12": "སྟོང་ཟད་དུ་བཏང་བའི་གྲིབ་མ་ལྟ་བུའི་མི་ཚེ་ནི་རང་ལ་ཕན་ཐོགས་ཅི་ཡོད་པ་སུ་ཡིས་རྟོགས། རྗེས་སུ་ཉི་མའི་འོག་ཏུ་ཅི་འབྱུང་བར་འགྱུར་བ་སུས་འཆད་ནུས་སམ།"
    },
    "7": {
      "1": "¶ ཕུལ་དུ་བྱུང་བའི་བྱུག་སྣུམ་ལས། ། མཚན་དང་སྙན་གྲགས་རྒྱས་པ་ལེགས། ། སྐྱེས་དུས་ལས་ནི་འཆི་དུས་ལེགས། །",
      "2": "སྟོན་མོའི་ཁྱིམ་དུ་འགྲོ་བ་ལས། ། མྱ་ངན་བྱེད་སར་འགྲོ་བ་ལེགས། ། གང་ལ་ཞེ་ན་འཆི་བ་ནི། ། མི་བུ་ཀུན་གྱི་མཐའ་འབྲས་ཡིན། ། གསོན་པོ་རྣམས་ཀྱིས་དོན་དེ་ཉིད། ། རྟག་ཏུ་ཡིད་ལ་ངེས་དགོས་སོ། །",
      "3": "དགའ་བ་ལས་ནི་སྐྱོ་བ་ལེགས། ། རྒྱུ་མཚན་སྐྱོ་བའི་ངོ་གདོང་གིས། ། མི་ཡི་སེམས་ལ་ཕན་ཐོགས་སོ། །",
      "4": "མཁས་པའི་སེམས་ནི་མྱ་ངན་ཁྱིམ་དུ་ཡོད། ། བླུན་པོའི་སེམས་ནི་སྤྲོ་སྐྱིད་ཁྱིམ་དུ་ཡོད། །",
      "5": "བླུན་པོའི་བསྟོད་གླུར་ཉན་པ་ལས། ། མཁས་པའི་བཀའ་བཀྱོན་ཐོས་ན་ལེགས། །",
      "6": "བླུན་པོ་གད་མོ་དགོད་པའི་སྒྲ། ། ཚེར་མ་མེ་ལ་བསྒྲོན་དང་མཚུངས། ། དེ་ལ་སྙིང་པོ་གང་ཡང་མེད། །",
      "7": "བཙན་འཕྲོག་གིས་ནི་མཁས་པ་བླུན་པོར་བསྒྱུར། ། ལྐོག་རྔན་གྱིས་ནི་མི་སེམས་བརླག་པར་བྱེད། །",
      "8": "དོན་གྱི་ཐོག་མ་ལས་ནི་ཕུགས་འབྲས་ལེགས། ། ང་རྒྱལ་ལས་ནི་བཟོད་སྒོམ་བྱེད་པ་ལེགས། །",
      "9": "ཁོང་ཁྲོ་བླུན་པོའི་སེམས་སུ་གནས་པས་ན། ། རང་སེམས་རང་དགར་ཁྲོ་བར་མི་བྱ་འོ། །",
      "10": "ཁྱོད་ཀྱིས་སྔ་མའི་དུས་ནི་ད་ལྟ་ལས། ། ལེགས་པ་ཅི་ཞིག་ཡིན་ནམ་མ་ཟེར་ཞིག ། དེ་བཞིན་འདྲི་བ་མཁས་རྟགས་མ་ཡིན་ནོ། །",
      "11": "ཤེས་རབ་དང་ནི་ནོར་སྐལ་གཉིས་ཀ་བཟང་། ། ཉི་མ་མཐོང་བ་དག་ལ་ཕན་ཐོགས་ཆེ། །",
      "12": "རྒྱུ་ཡིས་མི་ནི་སྲུང་བ་ལྟར། ། ཤེས་རབ་ཀྱིས་ཀྱང་བསྲུང་བར་མཛད། ། དེ་ཡང་ཤེས་རབ་འབའ་ཞིག་གིས། ། ཤེས་རབ་དང་ནི་ལྡན་པ་ཡི། ། ཚེ་སྲོག་གཅེས་སྲུང་མཛད་ནུས་ཤིང་། ། དེ་ནི་ཤེས་བྱའི་ཕན་ཡོན་ཡིན། །",
      "13": "དཀོན་མཆོག་མཛད་པར་ཞིབ་ཏུ་ལྟོས། ། ཁོང་གིས་གང་ཞིག་བཀུག་པ་དེ། ། སུ་ཡིས་བསྲང་བར་བྱ་ནུས་སམ། །",
      "14": "བདེ་བླག་ཡིན་པའི་དུས་སུ་དགའ་བར་གྱིས། ། དཀའ་སྡུག་མྱོང་བའི་དུས་སུ་བསམ་བློ་ཐོངས། ། དཀོན་མཆོག་ཉིད་ཀྱིས་འདི་གཉིས་འབྱུང་བར་མཛད། ། མི་ཡིས་འབྱུང་འགྱུར་མི་ཤེས་ཆེད་དུ་ཡིན། །",
      "15": "¶ དྲང་བདེན་ཅན་ནི་དྲང་བདེན་ནང་དུ་འཆི་བ་དང་། ངན་པས་སྡིག་པའི་ནང་དུ་མི་ཚེ་བཏང་ནས་ཚེ་ལོ་མཐར་ཕྱིན་པ་ཐམས་ཅད་ངས་སྙིང་པོ་མེད་པའི་མི་ཚེ་ལ་རོལ་བའི་དུས་སུ་མཐོང་བྱུང་།",
      "16": "དྲང་བདེན་ཚད་ལས་བརྒལ་དུ་མ་འཇུག སྤྱང་གྲུང་ཚད་ལས་བརྒལ་དུའང་མ་འཇུག རང་གིས་རང་ཉིད་འཕུང་བར་ཅི་ལ་བྱེད།",
      "17": "ཚོད་མེད་པར་སྤྱོད་ངན་མ་བྱེད། བླུན་པོར་མ་གྱུར་ཅིག དུས་མ་སླེབས་པར་འཆི་དགོས་དོན་ཅི་ཡོད།",
      "18": "འདི་བསྲུང་བར་མ་ཟད་གཞན་དེ་ཡང་ལག་པས་མ་ལྷོད་ཅིག ཅི་ལ་ཞེ་ན། དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པ་རྣམས་ནི་འདི་གཉིས་ལ་གཡོལ་ངེས་ཡིན།",
      "19": "ཤེས་རབ་ཀྱིས་ནི་གྲོང་ཁྱེར་ལ་ཡོད་པའི་འགོ་དཔོན་བཅུ་ལས་མཁས་པ་ལ་ནི་ལྷག་པར་སྟོབས་དང་ལྡན་པར་བྱེད།",
      "20": "ས་སྟེང་དུ་རྟག་ཏུ་བཟང་པོ་བྱེད་ཅིང་ཉེས་པ་གང་ཡང་མི་བྱེད་པའི་མི་དྲང་པོ་ནི་གཅིག་ཀྱང་མེད།",
      "21": "གཏམ་ཐམས་ཅད་ལ་དོ་སྣང་མ་བྱེད་ཅིག ཇི་སྟེ་བྱས་ན་གཡོག་པོས་ཁྱོད་ལ་ངན་སྨྲ་བ་ཐོས་པར་འགྱུར།",
      "22": "དེ་ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱིས་ཀྱང་ལན་དུ་མར་གཞན་ལ་དེ་བཞིན་དུ་ངན་སྨྲས་པ་ནི་ཁྱོད་རང་གི་སེམས་ཀྱིས་ཤེས་སོ། །",
      "23": "ངས་དེ་སྔར་འདི་ཐམས་ཅད་ལ་ཤེས་རབ་ཀྱི་སྒོ་ནས་དཔྱད་པ་ཡིན། ང་མཁས་པར་འགྱུར་འདོད་ཅེས་སྨྲས་ཀྱང་། དེ་ནི་ང་དང་རྒྱང་རིང་དུ་མཆིས་ཏེ།",
      "24": "བྱ་བ་ཡོད་ཚད་རབ་ཏུ་རྒྱང་རིང་ཞིང་ཤིན་ཏུ་གཏིང་ཟབ་པས། སུ་ཞིག་གིས་དེ་རྟོགས་ནུས་སམ།",
      "25": "ངས་རང་གི་བློ་ཁ་བསྒྱུར་ཏེ། སེམས་གཏིང་ནས་ཤེས་རབ་དང་བྱ་བ་ཡོད་ཚད་ཀྱི་འབྱུང་རྐྱེན་རྟོགས་འདོད་པ་དང་དཔྱོད་འདོད་པ། བཙལ་འདོད་པ་ཡིན། ཡང་བླུན་པོའི་ལུགས་ནི་ངན་པ་དང་། ཁེངས་དྲེགས་ནི་བླུན་རྨོངས་ཡིན་པ་རྟོགས་འདོད་པ་ཡིན།",
      "26": "ཡང་ངས་བུད་མེད་ལ་ལ་ནི་འཆི་བ་ལས་ཀྱང་ཁ་ཏིག་ཡིན་པ་དང་། སེམས་ནི་རྙི་རྒྱ་དང་ལག་པ་ནི་ལྕགས་ཐག་ལྟ་བུ་ཡིན་པ་རྟོགས་ཤིང་། དཀོན་མཆོག་ཐུགས་མཉེས་པ་རྣམས་ནི་མོ་ལས་ཐར་བ་དང་། སྡིག་ཅན་རྣམས་ནི་མོས་འཛིན་པར་འགྱུར།",
      "27": "ཀྱེ་ཧོ་སྟོན་པས་འདི་སྐད་དུ། ངས་མཐར་ཐུག་དེ་རྟོགས་པའི་དོན་དུ་རེ་རེ་བཞིན་བསྡུར་ནས་བརྩད་ཆོད་པ་ནི། བྱ་བ་ཡོད་ཚད་ཀྱི་འབྱུང་རྐྱེན་ཤེས་འདོད་པ་ཡིན་ཏེ།",
      "28": "ད་ཙམ་གྱི་བར་དུ་ངའི་སེམས་ཀྱིས་བཙལ་ཡང་མ་ཐོབ། སྐྱེས་པ་སྟོང་ཕྲག་གི་ནང་ནས་གཞུང་དྲང་གཅིག་རང་ངས་རྙེད་ཀྱང་། བུད་མེད་ཐམས་ཅད་ལས་གཞུང་དྲང་གཅིག་ཀྱང་རྙེད་མ་བྱུང་།",
      "29": "དཀོན་མཆོག་གིས་མི་ནི་དྲང་པོར་བཀོད་ཀྱང་། དེ་དག་གིས་བྱུས་ངན་མང་པོ་བཙལ་ཡོད་པ་ཁོ་ན་ངས་རྙེད་པ་ཡིན་ནོ། །"
    },
    "8": {
      "1": "¶ མཁས་པ་དང་འདྲ་བ་སུ་ཡོད་དམ། དོན་ཐམས་ཅད་སུ་ཞིག་གིས་འགྲེལ་ནུས་སམ། ཤེས་རབ་ཀྱིས་མིའི་ངོ་མདངས་གསལ་བར་བྱེད་ལ། དེའི་ངོ་མདངས་རྩུབ་མོ་ཡང་འགྱུར་བར་བྱེད།",
      "2": "¶ དཀོན་མཆོག་དཔང་དུ་བཙུགས་ནས་དམ་བཅས་པའི་རྐྱེན་གྱིས་རྒྱལ་པོའི་བཀའ་བརྩི་དགོས་པ་ངས་ཁྱོད་ལ་བསྐུལ་ཏེ།",
      "3": "རྒྱལ་པོའི་མདུན་ནས་འགྲོ་བར་མ་བྲེལ་ཞིག སྤྱོད་ངན་ནང་དུའང་བསྲེ་བར་མ་བྱེད་ཅིག ཅིའི་ཕྱིར་ཞེ་ན། ཁོང་གིས་ཉིད་ཀྱི་ཐུགས་དགོངས་བཞིན་དུ་བྱེད་པས་སོ། །",
      "4": "རྒྱལ་པོའི་བཀའ་ལ་དབང་ཆེན་པོ་ལྡན་ཏེ། ཁྱེད་ཀྱིས་ཅི་བྱེད་པ་ཡིན་ནམ་ཞེས་སུ་ཞིག་གིས་ཞུ་བར་ནུས་སམ།",
      "5": "བཀའ་ལ་ཉན་མཁན་གྱིས་རྐྱེན་ངན་མཐོང་བར་མི་འགྱུར་ཏེ། མཁས་པའི་སེམས་ཀྱིས་དུས་དང་གཏན་སྲོལ་གཉིས་ཀ་ཤེས།",
      "6": "དེ་ཅིའི་ཕྱིར་ཞེ་ན། མི་ཡི་སྟེང་དུ་སྡུག་གི་ཁུར་བོ་ལྕི་ནའང་། དོན་རེ་རེ་ལ་དུས་དང་གཏན་སྲོལ་ཡོད་པའོ། །",
      "7": "འབྱུང་འགྱུར་གྱི་དོན་རྣམས་ཁོས་མི་ཤེས་ཏེ། ཕྱིས་སུ་གང་ཞིག་འབྱུང་བར་འགྱུར་བ་སུས་ཁོ་ལ་འཆད་ནུས་སམ།",
      "8": "མི་སུས་ཀྱང་རླུང་ལ་ཁ་ལོ་བསྒྱུར་ནས་དེ་འགོག་མི་ཐུབ་ལ། ཡང་འཆི་དུས་ལ་དབང་ཡོད་པའི་མི་སུ་ཡང་མེད། འཐབ་མོ་འདི་ལ་ཞུགས་མི་དགོས་པ་སུ་ཡང་མེད། ངན་པས་ཀྱང་ངན་པ་བྱེད་མཁན་རྣམས་སྐྱོབ་པར་མི་ནུས།",
      "9": "འདི་དག་ཐམས་ཅད་ངས་མཐོང་སྟེ། ཉི་མའི་འོག་ཏུ་བྱུང་བའི་དོན་ཐམས་ཅད་ལ་སེམས་ཞིབ་མོས་བརྟགས་པ་ན། མི་གཅིག་གིས་གཞན་ལ་སྲིད་བྱེད་པའི་ངང་ནས་རང་ལ་རྐྱེན་ངན་འགུག་པའི་དུས་ཀྱང་འདུག་གོ །",
      "10": "¶ དེ་ལྟར་ངས་མི་སྡིག་ཅན་དུར་ཁུང་དུ་བསྐུངས་པ་མཐོང་། སྔར་དེ་རྣམས་དམ་པའི་གནས་སུ་འགྲོ་འོང་བྱེད་ཅིང་། དེ་དག་གིས་སྤྱད་པ་སྤྱོད་སའི་གྲོང་ཁྱེར་ནང་གི་མི་རྣམས་ཀྱིས་བརྗེད་པ་སྟེ། འདི་ཡང་སྟོང་པ་ཡིན་ནོ། །",
      "11": "དེ་ཡང་སྤྱོད་ངན་ལ་མྱུར་དུ་ཆད་པ་མ་བཅད་པས། མི་རྣམས་ཀྱི་སེམས་སུ་ལས་ངན་པ་བྱེད་པའི་བསམ་བློས་ཁེངས།",
      "12": "ཇི་སྟེ་ངན་པས་ལན་བརྒྱ་ལ་ལས་ངན་པ་བྱས་ཀྱང་ཚེ་རིང་བར་གྱུར་ན། དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པའི་མི་སྟེ་ཁོང་གི་དྲུང་དུ་གུས་ཞུམ་གྱི་སེམས་དང་ལྡན་པ་དག་གིས་སྐྱིད་ལ་རོལ་བ་ངས་ལེགས་པར་ཤེས་སོ། །",
      "13": "འོན་ཀྱང་ངན་པར་ནམ་ཡང་བདེ་སྐྱིད་མི་འཐོབ་ལ་ཚེ་ཐག་ཀྱང་མི་རིང་སྟེ། ཁོས་དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པར་མི་བྱེད་པས། དེའི་མི་ཚེ་ནི་གྲིབ་མ་ལྟ་བུ་ཡིན་ནོ། །",
      "14": "ས་སྟེང་དུ་སྙིང་པོ་མེད་པའི་དོན་ཞིག་ཡོད་པ་ནི་དྲང་པོར་ངན་པས་ཅི་བྱས་བཞིན་ལན་འཐོབ་ཅིང་། ངན་པར་དྲང་པོས་ཅི་བྱས་བཞིན་ལན་འབྱུང་བ་སྟེ། ངས་འདི་ཡང་སྟོང་པ་ཡིན་ཞེས་སྨྲས་པའོ། །",
      "15": "བཟའ་བཏུང་སྤྱད་ནས་སྐྱིད་ལ་རོལ་བ་ལས་ལེགས་པ་ཞིག་ཉི་མའི་འོག་ཏུ་མི་ལ་གཞན་གང་ཡང་མེད་པས་ངས་བདེ་སྐྱིད་ལ་བསྟོད་པ་ཡིན། དེ་ཅིའི་ཕྱིར་ཞེ་ན། དཀོན་མཆོག་གིས་མི་ལ་ཉི་མའི་འོག་ཏུ་གནང་བའི་ཚེ་གང་པོའི་དཀའ་ལས་ཀྱི་འབྲས་བུ་ནི་དེ་དང་ལྷན་ཅིག་ཏུ་གནས་པར་འགྱུར་རོ། །",
      "16": "ངས་སེམས་པ་རྩེ་གཅིག་གིས་ཡེ་ཤེས་རྟོགས་འདོད་པ་དང་ས་གཞིའི་སྟེང་དུ་བྱེད་པའི་ལས་ཐམས་ཅད་ལ་བལྟས་པའི་ཚེ། ཞག་གང་པོར་གཉིད་མི་ཁུག་པའི་མི་ཡང་ཡོད་པ་རེད།",
      "17": "དཀོན་མཆོག་གིས་སའི་སྟེང་དུ་མཛད་པའི་འཕྲིན་ལས་ཐམས་ཅད་མི་ཡིས་རྟོགས་མི་ནུས་པ་མཐོང་། མི་ཡིས་ཉི་མའི་འོག་གི་ལས་རྣམས་རྟོགས་པའི་ཕྱིར་དཀའ་བ་སྤྱད་མོད་རྟོགས་པར་མི་འགྱུར། དེར་མ་ཟད་མཁས་པས་ངས་དེ་རྟོགས་སོ་བསམས་ཀྱང་ཁོས་དེ་ནམ་ཡང་རྟོགས་པར་མ་གྱུར་ཏོ། །"
    },
    "9": {
      "1": "¶ ངས་དོན་འདི་ཐམས་ཅད་སེམས་ལ་བཟུང་ཞིང་ཞིབ་ཏུ་བརྟགས་པ་ན། མི་དྲང་བདེན་དང་མཁས་པ་དག་གི་ལས་རྣམས་དཀོན་མཆོག་གི་ཕྱག་ཏུ་ཡོད་ཅིང་། མི་སུ་ཞིག་གིས་ཀྱང་རང་གི་སྔུན་དུ་ཡོད་པའི་ཆགས་སྡང་གང་ཡིན་ཡང་དེ་རྟོགས་མི་ནུས།",
      "2": "མི་ཐམས་ཅད་ཀྱི་སྔོན་ལས་ནི་གཅིག་མཚུངས་ཡིན་ཏེ། མི་དྲང་བདེན་དང་སྡིག་ཅན་གཉིས་དང་། མི་བཟང་པོ་དང་ངན་པ་གཉིས། གཙང་བ་དང་མི་གཙང་བ་གཉིས། མཆོད་པ་འབུལ་མཁན་དང་མཆོད་པ་མི་འབུལ་མཁན་གཉིས་བཅས་ཐམས་ཅད་ཀྱི་མྱོང་ཚུལ་གཅིག་འདྲ་ཡིན་ཏེ། མི་བཟང་པོ་ཅི་ལྟར་ཡིན་ན་སྡིག་ཅན་ཡང་དེ་ལྟར་ཡིན་ལ། མནའ་སྐྱེལ་མཁན་ཅི་ལྟར་ཡིན་ན་མནའ་བསྐྱལ་བར་འཇིགས་པའི་མི་ཡང་དེ་ལྟར་ཡིན།",
      "3": "ཉི་མའི་འོག་ཏུ་འབྱུང་བའི་དོན་ཐམས་ཅད་ལས་རྐྱེན་ངན་ཞིག་ཡོད་པ་ནི། མི་ཐམས་ཅད་ཀྱི་སྔོན་ལས་གཅིག་པར་མ་ཟད་མི་རྣམས་ཀྱི་སེམས་སུ་ངན་པས་གང་སྟེ། གསོན་པའི་སྐབས་སུ་ཁེངས་དྲེགས་བསྐྱེད་ཅིང་མཐར་གཤིན་པོའི་ཁྲོད་དུ་འགྲོ་བའོ། །",
      "4": "དེ་ལྟར་གསོན་པོ་ཀུན་དང་འབྲེལ་བ་རྣམས་ལ་རེ་བ་ཡོད་དེ། སེང་གེ་ཤི་རོ་ཞིག་ལས་ཁྱི་གསོན་པོ་ཞིག་གིས་དགའ།",
      "5": "ཅིའི་ཕྱིར་ཞེ་ན། གསོན་པོ་རྣམས་ཀྱིས་རང་ཉིད་འཆི་བར་འགྱུར་བ་ཤེས་ཀྱང་གཤིན་པོས་ཅི་ཡང་མི་ཤེས་ཏེ། དེ་དག་ལ་རྔན་པ་གང་ཡང་མི་འཐོབ་ལ་ཁོ་ཚོ་བརྗེད་པར་གྱུར་པ་ཡིན།",
      "6": "དེ་དག་གི་ཆགས་སྡང་དང་ཕྲག་དོག་ཀྱང་མེད་པར་གྱུར་ཅིང་། དེ་རྣམས་ལ་ཉི་མའི་འོག་གི་ལས་གང་རུང་ནས་ནམ་ཡང་ཐོབ་སྐལ་ཅི་ཡང་མེད་དོ། །",
      "7": "ཁྱོད་ཀྱི་ལས་རྣམས་དཀོན་མཆོག་གི་ཐུགས་ལ་ལྡན་པས་ན། དགའ་དགའ་སྤྲོ་སྤྲོས་རང་གི་ཁ་ཟས་སྤྱོད་ཅིང་བློ་བདེ་བག་ཕབ་ངང་རྒུན་ཆང་བཏུང་བར་གྱིས་ཤིག",
      "8": "རྒྱུན་དུ་རྒྱན་གོས་གྱོན་ཏེ་སྐྲ་ལ་སྣུམ་གྱིས་བྱུགས་ཤིག",
      "9": "ཁྱོད་ཀྱི་མི་ཚེའི་སྙིང་པོ་མེད་པའི་ལོ་ཟླ་རྣམས་ཏེ། དཀོན་མཆོག་གིས་ཉི་མའི་འོག་ཏུ་ཁྱོད་ལ་གནང་བའི་སྙིང་པོ་མེད་པའི་ལོ་ཟླའི་ནང་དུ། ཁྱོད་ཀྱིས་དགའ་སྤྲོའི་ངང་རང་གི་གཅེས་སུ་འཛིན་པའི་ཆུང་མ་དང་ལྷན་ཅིག་འཚོ་བ་རོལ་དགོས་ཏེ། དེ་ནི་ཁྱོད་ཀྱིས་ཉི་མའི་འོག་ཏུ་ཚེ་གང་པོར་དཀའ་བ་སྤྱད་ནས་ཐོབ་པའི་སྐལ་ཡིན་ནོ། །",
      "10": "ཁྱོད་རང་འགྲོ་སའི་གཤིན་པོའི་གནས་སུ་ལས་ཀ་མེད་ལ། འབྱུང་རྐྱེན་ཡང་མེད། ཤེས་བྱ་ཡང་མེད། ཤེས་རབ་ཀྱང་མེད་པས། རང་གིས་བསྒྲུབ་འོས་པའི་ལས་ནི་སྟོབས་ཤུགས་ཡོད་རྒུ་བཏོན་ནས་བསྒྲུབ་པར་གྱིས་ཤིག",
      "11": "ཡང་ངས་བལྟས་པ་ལ་ཉི་མའི་འོག་ཏུ་མགྱོགས་མྱུར་ཅན་ཡིན་ཡང་བང་རྩལ་གྱིས་མི་རྒྱལ། དཔའ་བོ་ཡིན་ཡང་འཐབ་མོར་མི་རྒྱལ། ཤེས་རབ་ཅན་ཡིན་ཡང་ཁ་ཟས་མི་རྙེད། བློ་ལྡན་ཡིན་ཡང་རྒྱུ་ནོར་མི་རྙེད། མཁས་པ་ཡིན་ཡང་མི་ཡི་བརྩི་མཐོང་མི་འབྱུང་སྟེ། དེ་དག་ཐམས་ཅད་དུས་དང་སྔོན་ལས་བཞིན་དུ་འབྱུང་བས་སོ། །",
      "12": "དྲ་བའི་ནང་དུ་ཚུད་པའི་ཉ་ལྟར་རམ། རྙི་རྒྱ་རུ་ཚུད་པའི་བྱ་ལྟར། མི་ཡིས་ཀྱང་རང་གི་དུས་མི་ཤེས་པས། མི་རྣམས་ཀྱི་སྟེང་ལ་གློ་བུར་ཉིད་ལ་རྐྱེན་ངན་འབྱུང་བའི་ཚེ་དེའི་ནང་དུ་ལྷུང་བར་འགྱུར་རོ། །",
      "13": "¶ ཉི་མའི་འོག་ཏུ་ཤེས་རབ་ཅིག་ཡོད་པ་ངས་མཐོང་སྟེ། བདག་གིས་དོན་སྙིང་ཆེན་པོ་ལྡན་པར་སྙམ།",
      "14": "དེ་ཡང་མི་གྲངས་ཉུང་བའི་གྲོང་ཁྱེར་ཆུང་ངུ་ཞིག་ཡོད་དེ། ཡང་དེ་ལ་རྒྱལ་པོ་ཆེན་པོ་ཞིག་གིས་དམག་དྲངས་ཏེ་མཐའ་ནས་བསྐོར་ཞིང་། འཛིང་རགས་ཆེན་པོ་རྣམས་བརྩིགས་ནས་གྲོང་ཁྱེར་ལ་རྒོལ་ཡང་།",
      "15": "གྲོང་ཁྱེར་དེའི་ནང་དུ་མཁས་པ་དབུལ་པོ་ཞིག་ཡོད་པས། བློ་རིག་པར་བརྟེན་ནས་གྲོང་ཁྱེར་དེ་བསྐྱབས་པ་ཡིན་མོད། འོན་ཀྱང་མི་སུ་ཞིག་གིས་ཀྱང་མི་དེར་རྗེས་དྲན་མ་བྱས་སོ། །",
      "16": "མཁས་པ་དབུལ་པོ་དེ་ལ་མི་ཡིས་མཐོང་ཆུང་བྱས་ནས་ཁོའི་གཏམ་ལ་མ་མཉན་རུང་། དྲག་ཤུགས་ལས་ཤེས་རབ་ལེགས་སོ་ཞེས་ངས་སྨྲས་པ་ཡིན།",
      "17": "བླུན་པོ་རྣམས་ལ་སྲིད་བྱེད་པའི་མི་ཡི་ཀི་སྒྲ་ལས། མཁས་པས་གསུངས་པའི་འཇམ་པོ་ཚིག་ལ་མང་དུ་ཉོན།",
      "18": "འཐབ་མོའི་མཚོན་ཆ་ལས་ཤེས་རབ་ལེགས་མོད། འོན་ཀྱང་སྡིག་ཅན་གཅིག་གིས་དོན་བཟང་པོ་མང་ཙམ་སྟོངས་སུ་འཇུག་གོ །"
    },
    "10": {
      "1": "¶ སྦྲང་བུ་ཤི་རོས་དྲི་ཞིམ་སྦྱོར་བྱེད་ཀྱི། ། སྣུམ་ལ་དྲི་ངན་འཐུལ་དུ་འཇུག་པ་ལྟར། ། བླུན་པོའི་གླེན་རྟགས་ཕྲན་བུ་ཞིག་གིས་ཀྱང་། ། ཤེས་རབ་དང་ནི་གཟི་བརྗིད་གནོན་པར་བྱེད། །",
      "2": "མཁས་པའི་སྙིང་ནི་གཡས་སུ་ཕྱོགས་པ་དང་། ། བླུན་པོའི་སྙིང་ནི་གཡོན་དུ་བསེགས་ནས་ཡོད། །",
      "3": "བླུན་པོས་ལམ་དུ་སྐྱོད་པའི་དུས་སུ་ཡང་། ། རང་ལ་ཤེས་རབ་མེད་པ་སྟོན་བྱེད་ཅིང་། ། ཀུན་ལ་རང་ཉིད་བླུན་པོ་ཡིན་པ་མངོན། །",
      "4": "སྲིད་དབང་སྐྱོང་མཁན་ཁྱོད་ལ་ཁྲོས་གྱུར་ན། ། ཁྱོད་ནི་རང་གི་གནས་དང་མ་འབྲལ་ཞིག ། གང་ལ་ཞེ་ན་ཞི་བའི་ངང་ཚུལ་གྱིས། ། ཉེས་པ་ཆེན་པོ་རྣམས་ཀྱང་ཞི་བར་བྱེད། །",
      "5": "ཉི་མའི་འོག་ཏུ་རྐྱེན་ངན་ཞིག་ཡོད་པ། ། བདག་གིས་མཐོང་ཞིང་དེ་ནི་དབང་སྒྱུར་བའི། ། འགལ་འཛོལ་ལས་ནི་བྱུང་བ་འདྲ་ཡིན་ཏེ། །",
      "6": "བླུན་པོ་རྣམས་ལ་གོ་ས་མཐོན་པོ་སྤྲད། ། འབྱོར་ལྡན་རྣམས་ནི་དམན་སར་སྡོད་པ་ཡིན། །",
      "7": "བྲན་གཡོག་རྣམས་ནི་རྟ་ལ་ཞོན་པ་དང་། ། རྒྱལ་སྲས་རྣམས་ནི་བྲན་གཡོག་ནང་བཞིན་གྱིས། ། ས་ལ་རྐང་འགྲོས་བྱེད་པ་བདག་གིས་མཐོང་། །",
      "8": "ས་དོང་འབྲུ་མཁན་རང་ཉིད་དེའི་ནང་ལྷུང་། ། རྩིག་པ་བཤིག་ན་སྦྲུལ་གྱིས་སོ་བཏབ་ཡོང་། །",
      "9": "གཏེར་རྡོ་འདོན་མཁན་རྡོ་ཡིས་རྨས་བྱེད་ཅིང་། ། ཤིང་དུམ་གཤག་མཁན་ལ་ནི་ཉེན་ཁ་ཆེ། །",
      "10": "སྟ་རེ་རྟུལ་པོར་རྣོ་རྩེ་མ་བཏོན་ན། ། ཤ་ཤེད་མང་དུ་གཏོང་དགོས་འབྱུང་བ་དང་། ། འོན་ཀྱང་ཤེས་རབ་ཀྱིས་ནི་རྒྱལ་བར་བྱེད། །",
      "11": "སྔགས་མ་བརྒྱབ་པར་སྦྲུལ་གྱིས་སོ་བཏབ་ན། ། སྔགས་པར་ཕན་ཐོགས་ཅི་ཡང་ཡོད་མ་ཡིན། །",
      "12": "མཁས་པའི་ཞལ་ནས་ལེགས་བཤད་གསུང་བ་དང་། ། བླུན་པོའི་མཆུ་ཡིས་རང་ཉིད་མིད་པར་བྱེད། །",
      "13": "བླུན་པོའི་གཏམ་གྱི་ཐོག་མ་བླུན་བཤད་དང་། ། མཐའ་མ་ཁེངས་དྲེགས་དང་ནི་ངན་པ་ཡིན། །",
      "14": "བླུན་པོར་སྨྲ་བ་ཤིན་ཏུ་མང་ན་ཡང་། ། ཕྱིས་སུ་ཅི་འབྱུང་སུས་ཀྱང་མི་ཤེས་ལ། ། འཆི་བའི་རྗེས་སུ་ཅི་ཞིག་འབྱུང་ངེས་པ། ། འཆད་པར་ནུས་པ་སུ་ཡང་ཡོད་མ་ཡིན། །",
      "15": "བླུན་པོས་གྲོང་ཁྱེར་ལམ་ཡང་མི་ཤེས་ལ། ། རེ་རེ་རང་གི་ལས་ཀྱིས་དུབ་པར་བྱེད། །",
      "16": "ཀྱེ་ཀྱེ་རྒྱལ་ཁམས་ཁྱོད་ཀྱི་རྒྱལ་པོ་ནི། ། བྱིས་པ་ཡིན་ཞིང་ཁྱོད་ཀྱི་བློན་པོ་ཚོས། ། ཞོགས་པར་བཟའ་བཏུང་བག་མེད་སྤྱད་ན་ནི། ། ཁྱོད་ལ་ཆག་སྒོ་འབྱུང་བར་གདོན་མི་ཟ། །",
      "17": "ཀྱེ་ཀྱེ་རྒྱལ་ཁམས་ཁྱོད་ཀྱི་རྒྱལ་པོ་ནི། ། སྐུ་དྲག་སྲས་ནི་ཡིན་ཞིང་བློན་པོ་ཚོས། ། བཟི་བར་མིན་གྱིས་རང་ལ་སྟོབས་བསྐྱེད་ཕྱིར། ། དུས་ལྟར་བཟའ་བཏུང་སྤྱད་ན་ཁྱོད་བདེ་འོ། །",
      "18": "ལེ་ལོ་ཡིན་པས་ཁང་ཀླད་རྡིབ་པ་དང་། ། ལག་པ་དལ་བས་ཁང་པར་ཐིགས་ཆུ་ཡོང་། །",
      "19": "གད་མོའི་ཕྱིར་དུ་གསོལ་སྟོན་གཤོམ་པ་དང་། ། རྒུན་ཆང་གིས་ནི་མི་ལ་དགའ་སྣང་བསྐྱེད། ། འོན་ཀྱང་དངུལ་གྱིས་དོན་ཀུན་འགྲུབ་པར་བྱེད། །",
      "20": "རྒྱལ་པོར་སྨོན་ལོག་འདེབས་པར་མ་བསམ་ཞིག ། ཡང་ན་རང་གི་གཟིམ་ཁང་ནང་རོལ་ལ། ། ཕྱུག་པོར་དམོད་མོ་ཡང་ནི་མ་བྱེད་ཅིག ། རྒྱུ་མཚན་ནམ་མཁའི་བྱ་ཡིས་སྐད་འཁྱེར་ཞིང་། ། གཤོག་ལྡན་གྱིས་ནི་གཏམ་དེ་འཆད་པར་འགྱུར། །"
    },
    "11": {
      "1": "¶ རང་གི་འབྲུ་རིགས་ཆུ་ཁར་གཏོར་ཞིག་དང་། ། ཡུན་རིང་འདས་རྗེས་སླར་ཡང་རྙེད་པར་འགྱུར། །",
      "2": "ས་སྟེང་ཆག་སྒོ་ཅི་འབྱུང་མི་ཤེས་པས། ། བདུན་གྱིས་མ་ཚད་བརྒྱད་ལ་སྐལ་བྱིན་ཅིག །",
      "3": "ཇི་སྟེ་སྤྲིན་པ་ཆུ་ཡིས་གང་གྱུར་ན། ། དེ་ལས་ས་ལ་ཆར་བ་གཤོ་བར་འགྱུར། ། ཤིང་སྡོང་ལྷོ་བྱང་གང་དུ་འགྱེལ་ན་ཡང་། ། གང་ནས་འགྱེལ་ན་དེ་རུ་ལུས་པ་ཡིན། །",
      "4": "རླུང་ལ་ལྟ་མཁན་དེས་ནི་སོན་མི་འདེབས། ། སྤྲིན་ལ་ལྟ་མཁན་གྱིས་ཀྱང་ཞིང་མི་རྔ། །",
      "5": "ཁྱོད་ཀྱིས་རླུང་རྒྱུ་བའི་ལམ་དང་མངལ་གྱི་ནང་དུ་རུས་པ་ཇི་ལྟར་སྐྱེ་བ་མི་ཤེས་པ་བཞིན། ཐམས་ཅད་མཛད་པའི་དཀོན་མཆོག་གི་འཕྲིན་ལས་ནི་ཁྱོད་ཀྱིས་དེ་ལས་ཀྱང་མི་ཤེས་སོ། །",
      "6": "ཞོགས་པར་རང་གི་ས་བོན་གཏོར་ལ། དགོང་མོ་ཡང་ལག་པ་དལ་བར་མ་བྱེད། ཅིའི་ཕྱིར་ཞེ་ན། ཞོགས་པར་གཏོར་བའམ་ཡང་ན་དགོང་མོ་བཏབ་པ་གཉིས་ལས་གང་ཞིག་ལེགས་པོ་འབྱུང་བའམ། ཡང་ན་དེ་གཉིས་ཀ་ཁྱད་མེད་པར་ལེགས་པོ་འབྱུང་བ་ཁྱོད་ཀྱིས་མི་ཤེས་པས་སོ། །",
      "7": "འོད་ནི་བཟང་པོ་ཡིན་ཏེ། མིག་གིས་ཉི་འོད་མཐོང་བ་ནི་སྐྱིད་ཡིན།",
      "8": "ཇི་སྟེ་མི་ཞིག་ལོ་མང་པོར་གསོན་ན་དེ་ཐམས་ཅད་ཀྱི་ནང་དུ་དགའ་བར་འོས་མོད། འོན་ཀྱང་མུན་པའི་ཉིན་མོ་རྣམས་ཀྱང་དྲན་པར་གྱིས། ཅིའི་ཕྱིར་ཞེ་ན། དེ་འདྲའི་ཉིན་མོ་མང་ཙམ་ཡོད་པར་འགྱུར་ཏེ། འབྱུང་འགྱུར་ཐམས་ཅད་སྟོང་པ་ཡིན་ནོ། །",
      "9": "¶ ཀྱེ་ན་གཞོན་ཚོ། རང་ཉིད་ན་གཞོན་ཡིན་དུས་དགའ་མགུར་སྤྱོད་དང་། རང་གི་ལོ་ན་གཞོན་པའི་ཉིན་མོ་རྣམས་ལ་སེམས་སྐྱིད་པར་བྱོས། ཡང་རང་གི་སེམས་ནས་གང་ཞིག་བསྒྲུབ་འདོད་པ་དང་། མིག་གིས་ཅི་ལ་བལྟ་འདོད་པ་བཞིན་བྱོས་དང་། ཡིན་ནའང་དོན་དེ་ཐམས་ཅད་ཀྱི་ཕྱིར་དུ་དཀོན་མཆོག་གིས་ཁྱོད་ལ་འདྲི་གཅོད་བྱེད་ངེས་པ་ཤེས་དགོས།",
      "10": "རང་སེམས་ཀྱི་སྡུག་བསྔལ་དོར་ནས་རང་གི་ལུས་ནས་དཀའ་ངལ་བསལ་བར་གྱིས། ཅིའི་ཕྱིར་ཞེ་ན། གཞོན་དུས་དང་དར་དུས་གང་ཡིན་ཡང་སྟོང་པ་ཡིན་ནོ། །"
    },
    "12": {
      "1": "¶ ཁྱོད་ལོ་ན་གཞོན་པ་དང་རྒས་པའི་ཉིན་མོ་སྟེ། ང་ལ་དགའ་སྤྲོ་གང་ཡང་མེད་ཟེར་བའི་ཉིན་དེ་ད་དུང་མ་སླེབས་པའི་སྔོན་ལ། རང་ཉིད་མཛད་མཁན་གཙོ་བོ་དྲན་པར་འོས།",
      "2": "ཉི་མ་དང་འོད། ཟླ་བ་དང་སྐར་མ་བཅས་འགྲིབ་པ་དང་། ཆར་བའི་རྗེས་སུ་སྤྲིན་རྣམས་ཕྱིར་འཁོར་བའི་བར་དུ་མ་སྒུག་ཅིག",
      "3": "སྐབས་དེར་ཁང་པ་སྲུང་མཁན་འདར་ཞིང་སྟོབས་ཅན་རྣམས་མགོ་བསྒུར་བ་དང་། རང་འཐག་སྐོར་མཁན་རྣམས་ཀྱིས་མི་ཉུང་བའི་རྐྱེན་གྱིས་ལས་མཚམས་འཇོག་ཅིང་། དཀར་ཁུང་ལས་ཕར་ལྟ་མཁན་རྣམས་ཀྱི་མིག་མདངས་ཀྱང་ཉམས་པར་འགྱུར་ཏེ།",
      "4": "སྲང་ལམ་གྱི་སྒོ་རྣམས་བརྒྱབ་པ་དང་རང་འཐག་གི་སྒྲ་ཡང་ཆུང་སྟེ། བྱ་ཡིས་སྐད་འབྱིན་དུས་མི་རྣམས་ཡར་ལང་ཞིང་། གླུ་མ་ཐམས་ཅད་རྒུད་པའོ། །",
      "5": "མི་རྣམས་མཐོ་སར་འཇིགས་ཏེ་ལམ་ལ་འཇིགས་སྐྲག་རྣམས་འོང་ཞིང་། སྟར་སྡོང་གི་མེ་ཏོག་བཞད་པ་དང་། ཆ་ག་འབུ་རྣམས་ཁྱར་ཁྱོར་དུ་སྐྱོད་ཅིང་། འདོད་པ་རྣམས་ཡལ་བར་འགྱུར། ཅིའི་ཕྱིར་ཞེ་ན། མི་ནི་རང་གི་དུས་གཏན་གྱི་སྡོད་གནས་སུ་འགྲོ་བས། མྱ་ངན་ཞུ་མཁན་རྣམས་སྲང་ལམ་དུ་རྒྱུ་བར་འགྱུར་རོ། །",
      "6": "ཡང་དངུལ་ཐག་ཆད་ཅིང་གསེར་ཕོར་ཆག་པ་དང་། བུམ་པ་ཆུ་མིག་གི་རྩར་ཆག་ནས་འཁོར་ལོ་ཆུ་དོང་གི་རྩར་ཆག་པར་འགྱུར།",
      "7": "ས་རྡུལ་ནི་ཕྱིར་ས་ལ་འཐིམ་པ་དང་སེམས་ཉིད་ནི་དེ་གནང་མཁན་གྱི་དཀོན་མཆོག་གི་དྲུང་དུ་ལོག་པར་འགྱུར་རོ། །",
      "8": "སྟོང་པའི་སྟོང་པ། ཡོད་ཚད་སྟོང་པ་ཡིན་ཞེས་སྟོན་པས་གསུངས་སོ། །",
      "9": "¶ སྟོན་པར་ཤེས་རབ་ལྡན་པས། མི་རྣམས་ལ་རིག་པ་མང་དུ་བསླབས་ཏེ། དེས་བསམ་བློ་ཞིབ་པར་བཏང་ནས་བརྟག་དཔྱད་བྱས་པ་དང་། ལེགས་བཤད་མང་པོ་རིམ་པར་བཀོད་པ་ཡིན་ནོ། །",
      "10": "སྟོན་པས་ཡིད་དུ་འོང་བའི་ཚིག་རྣམས་བཙལ་ཞིང་། བློ་དྲང་པོས་བདེན་ཚིག་ལ་བརྟེན་ནས་བྲིས་པ་ཡིན།",
      "11": "མཁས་པའི་གཏམ་ནི་དབྱུག་ལྕག་དང་། ལེགས་བཤད་འདི་དག་ནི་བརྡབས་པའི་འཛེར་མ་དང་མཚུངས་ཏེ། དེ་རྣམས་རྫི་བོ་གཅིག་གིས་གནང་བའོ། །",
      "12": "དེ་བས་ན་ངའི་བུ་ལགས། གདམས་ངག་འདི་དང་དུ་ལོངས་ཤིག གཞུང་མང་པོ་རྩོམ་པར་རྫོགས་མཐའ་མེད། སློབ་སྦྱོང་མང་བས་ལུས་དུབ་ཏུ་འཇུག",
      "13": "ཐོས་པར་གྱུར་པ་ཐམས་ཅད་ཀྱི་མཐར་ཐུག་ནི་འདི་ལྟ་སྟེ། དཀོན་མཆོག་ལ་གུས་ཤིང་འཇིགས་པ་དང་ཁོང་གི་བཀའ་རྒྱ་རྣམས་སྲུངས་ཤིག འདི་ནི་མི་རྣམས་ཀྱིས་བསྒྲུབ་དགོས་པའི་འོས་འགན་དེ་ཡིན་ནོ། །",
      "14": "ཅིའི་ཕྱིར་ཞེ་ན། ལས་ཐམས་ཅད་དེ་ཐ་ན་གསང་བའི་དོན་ཡོད་ཚད་བཟང་ངན་གང་ཞིག་ཡིན་རུང་། དཀོན་མཆོག་གིས་དེར་འདྲི་གཅོད་གནང་བར་འགྱུར་རོ།། །།"
    }
  }
}
