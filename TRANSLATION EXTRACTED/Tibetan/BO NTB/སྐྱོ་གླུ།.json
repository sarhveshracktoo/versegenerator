{
  "name": "སྐྱོ་གླུ།",
  "id": "སྐྱོ་གླུ།",
  "order": 25,
  "chapters": {
    "1": {
      "1": "¶ གནའ་དུས་མི་ཡིས་ཁེངས་པའི་གྲོང་ཁྱེར་དེ། ། ད་ལྟའི་དུས་སུ་ཅིའི་ཕྱིར་གཅིག་པུར་ལུས། ། གནའ་དུས་རྒྱལ་ཁམས་ཁྲོད་དུ་ཆེ་བ་དེ། ། ད་ལྟའི་དུས་སུ་ཅིའི་ཕྱིར་ཡུགས་མོ་བཞིན། ། གནའ་དུས་རྒྱལ་ཁམས་ཁྲོད་ཀྱི་སྲས་མོ་ དེ། ། ད་ལྟའི་དུས་སུ་བྲན་གཡོག་ཅིག་དང་འདྲ། །",
      "2": "ཁོ་མོ་མཚན་མོར་ངུས་ཤིང་མཁུར་ཚོས་མཆི་མས་བརླན། ། དགའ་རོགས་ཁྲོད་དུ་ཁོ་མོར་སེམས་གསོ་བྱེད་མཁན་དབེན། ། ཁོ་མོའི་གྲོགས་པོ་ཀུན་གྱིས་གཡོ་སྒྱུས་མོ་འཛིན་ཞིང་། ། གྲོགས་པོ་ཐམས་ཅད་ཁོ་མོའི་དགྲ་ཟླར་གྱུར་པ་ཡིན། །",
      "3": "ཡ་ཧུ་དཱ་པས་དཀའ་སྡུག་ཚད་མེད་མྱངས་མ་ཟད། ། ངལ་ལས་ཞུགས་ཏེ་ནམ་རྒྱུན་ཕྱི་ཕྱོགས་ཡུལ་དུ་འཁྱམ། ། རྒྱལ་ཁམས་ཁྲོད་དུ་ཁོ་མོས་བདེ་བ་བཙལ་མ་རྙེད། ། འདེད་མཁན་དག་གིས་གུ་དོག་གནས་སུ་ཁོ་མོ་ཟིན། །",
      "4": "དུས་ཆེན་སྲུང་བའི་མི་དབེན་པས། ། ཛ་ཡན་བརྒྱུད་པའི་ལམ་སྡུག་ཅིང་། ། ཁོ་མོའི་སྒོ་ཆེན་དག་སྟོངས་ཤིང་། ། མཆོད་དཔོན་རྣམས་ཀྱིས་ཤུགས་རིང་འབྱིན། ། ཁོ་མོའི་མོ་གསར་ཡིད་སྐྱོ་ཞིང་། ། ཁོ་མོས་སྡུག་བསྔལ་ཚད་མེད་མྱངས། །",
      "5": "ཁོ་མོའི་དགྲ་བོ་གཙོ་བོར་གྱུར། ། ཁོ་མོའི་དགྲ་ཟླ་བདེ་ལ་བབས། ། ཁོ་མོའི་སྡིག་པ་མང་དྲགས་པས། ། ཡ་ཝཱེས་ཁོ་མོ་སྡུག་ལ་སྦྱར། ། ཁོ་མོའི་བྱིས་པ་དེ་དག་ནི། ། དགྲ་བོའི་མདུན་ནས་བཙོན་དུ་ཁྲིད། །",
      "6": "ཛ་ཡན་བུ་མོའི་བཀུར་འོས་གཟི་བརྗིད་ཐམས་ཅད་ནི། ། ཁོ་མོའི་མི་སྡེ་རྣམས་དང་ཡོངས་སུ་བྲལ་བར་གྱུར། ། ཁོ་མོའི་མངའ་བདག་རྩྭ་ས་མ་རྙེད་ཤྭ་བ་བཞིན། ། འདེད་མཁན་རྣམས་ཀྱི་མདུན་ནས་ཐར་བའི་སྟོབས་ཤུགས་ཟད། །",
      "7": "ཡེ་རུ་སཱ་ལེམ་དཀའ་སྡུག་ཁྲོད་དུ་འཁྱམ་པའི་དུས། ། སྔར་གྱི་འདོད་ཡོན་ལོངས་སྤྱོད་སྣ་ཚོགས་ཀུན་ནས་དྲན། ། ཁོ་མོའི་མི་སྡེ་དགྲ་བོའི་ལག་ཏུ་ཤོར་བའི་དུས། ། ཁོ་མོར་རོགས་རམ་བྱེད་མཁན་གཅིག་ཀྱང་མ་བྱུང་སྟེ། ། དགྲ་བོས་ཁོ་མོར་བྱུང་བའི་དོན་རྣམས་མཐོང་བ་ན། ། ཁོ་མོའི་ཉམ་ཐག་ལ་ནི་འཕྱ་དགོད་བྱས་པ་འོ། །",
      "8": "ཡེ་རུ་སཱ་ལེམ་གྲོང་གིས་སྡིག་པ་ཆེན་པོ་བསགས་པས་ན། ། མི་གཙང་དངོས་པོར་གྱུར་ཅིང་ཁོ་མོར་བཀུར་མཁན་དག་གིས་ཀྱང་། ། ཁོ་མོ་གཅེར་བུ་ཡིན་པ་མཐོང་ནས་སྨད་ཅིང་མཐོང་ཆུང་བྱེད། ། ཁོ་མོས་ཀྱང་ནི་ཤུགས་རིང་གཏོང་བཞིན་ཁ་ཕྱིར་འཁོར་ནས་ཡིབ། །",
      "9": "ཁོ་མོའི་སྨད་གཡོག་ནག་ནོག་དྲི་མས་ཀུན་ནས་སྦགས་ན་ཡང་། ། ཁོ་མོས་རང་གི་མཐའ་མའི་འབྲས་བུ་ཡེ་ནས་དྲན་མ་བྱུང་། ། དེའི་ཕྱིར་ཁོ་མོ་ཡ་མཚན་ཉམས་ཀྱང་སེམས་གསོ་བྱེད་མཁན་བྲལ། ། ཡ་ཝཱེ་ཁྱེད་ཀྱིས་བདག་གི་སྡུག་བསྔལ་ཀུན་ལ་གཟིགས་པར་མཛོད། ། དགྲ་བོས་རང་ཉིད་མཐུ་སྟོབས་ཆེ་བར་མངོན་ཞེས་ཁོ་མོས་ཞུས། །",
      "10": "དགྲ་བོས་ལག་པ་བརྐྱངས་ཏེ་ཁོ་མོའི་གཅེས་ནོར་བཙན་གྱིས་ཕྲོགས། ། ཁོ་མོས་ཕྱི་ཕྱོགས་པ་རྣམས་གནས་མཆོག་ལ་ནི་འཛུལ་བ་མཐོང་། ། ཁྱེད་ཀྱིས་ཕྱི་ཕྱོགས་པ་རྣམས་ཉིད་ཀྱི་ཚོགས་ལ་ཞུགས་པ་དགག །",
      "11": "ཁོ་མོའི་འབངས་ཀྱིས་ཤུགས་ནར་འབྱིན་ཞིང་ཁ་ཟས་འཚོལ། ། སྲོག་འཚོའི་ཕྱིར་དུ་ཁོ་ཚོས་གཅེས་ནོར་འབྲུ་རིགས་བརྗེས། ། དེ་ཡང་མི་ཡིས་ང་ལ་མཐོང་ཆུང་བྱས་པས་ན། ། ཡ་ཝཱེ་ཁྱེད་ཀྱིས་ང་ལ་གསན་ཞིང་གཟིགས་པར་མཛོད། །",
      "12": "¶ ཁྱོད་ཅག་ལམ་འགྲོ་དག་གིས་དོན་འདི་མི་མཐོང་ངམ། ། བདག་གི་སྟེང་དུ་བྱུང་བའི་སྡུག་བསྔལ་འདི་ལྟ་བུ། ། ཡོད་དང་མེད་ལ་ཁྱོད་ཚོས་ཞིབ་ཏུ་བལྟ་བར་གྱིས། ། དེ་ནི་ཡ་ཝཱེ་ཁོང་ཉིད་ཐུགས་ཁྲོའི་ཉིན་མོ་ལ། ། ང་ལ་སྡུག་བསྔལ་མྱངས་སུ་བཅུག་པའི་དོན་དེ་འོ། །",
      "13": "ཁོང་གིས་མཐོན་པོའི་གནས་ནས་མེ་ཕུང་ཆེན་པོ་འཕངས་གྱུར་ཏེ། ། ང་ཡི་རུས་པའི་གཏིང་དུ་ཟུག་ཅིང་ང་ནི་ཡོངས་སུ་བཅུན། ། ཁོང་གིས་རྙི་རྒྱ་བཏབ་སྟེ་ང་ཡི་རྐང་པ་དེའི་ནང་ཟིན། ། ང་ཡིས་ཁ་ཕྱོགས་བསྒྱུར་ནས་གཏན་དུ་སྐྱོ་ཞིང་ཉམས་པར་མཛད། །",
      "14": "ང་ཡི་ཉེས་པའི་གཉའ་ཤིང་ཁོང་གིས་དངོས་སུ་བསྡམས་པར་མཛད། ། དེ་ནི་ང་ཡི་སྡིག་པའི་གཉའ་ཤིང་སྐེ་ལ་བཏེགས་པ་བཞིན། ། ཁོང་གིས་ང་ཡི་ལུས་ཀྱི་སྟོབས་ཤུགས་ཐམས་ཅད་ཉམས་མཛད་དེ། ། གཙོ་བོས་ང་ནི་རྒྱལ་བར་དཀའ་བའི་དགྲ་ཡི་ལག་ཏུ་སྤྲད། །",
      "15": "གཙོ་བོས་ང་ཡི་འཁོར་གྱི་དཔའ་བོ་ཐམས་ཅད་དོར། ། ཁོང་གིས་མི་ཚོགས་བསྡུས་ཏེ་ང་ལ་རྒོལ་བཅུག་སྟེ། ། ང་ཡི་ན་གཞོན་དག་ལ་རྒོལ་བར་གྱུར་པ་དང་། ཁོང་གིས་རྒུན་འབྲུམ་འཚིར་གཞོང་བརྫིས་པ་ནང་བཞིན་དུ། ། ཡ་ཧུ་དཱ་ཡི་བུ་མོའི་ནང་གི་མོ་གསར་སྨད། །",
      "16": "དོན་དེའི་ཕྱིར་དུ་ང་ནི་ངུས་ཤིང་མིག་ལས་མཆི་མ་བཞུར། ། སེམས་གསོ་བྱས་ནས་ཚེ་སྲོག་སྐྱོབ་མཁན་ང་དང་རིང་དུ་གྱེས། ། ང་ཡི་བུ་དང་བུ་མོ་ཁེར་རྐྱང་ངང་ནས་ཡིད་སེམས་སྐྱོ། ། དེ་ནི་དགྲ་ཟླ་ཐམས་ཅད་རྣམ་པར་རྒྱལ་བའི་ཕྱིར་ཡིན་ནོ། །",
      "17": "ཛ་ཡན་མི་ཡིས་ལག་ཟུང་བརྐྱངས་ཀྱང་སེམས་གསོ་བྱེད་མཁན་མེད། ། ཡ་ཝཱེ་ཁོང་གིས་ཡ་ཀོབ་སྐོར་ལ་བཀའ་དག་གནང་ཟིན་ཞིང་། ། མཐའ་ནས་བསྐོར་བ་ཐམས་ཅད་ཁོ་ཡི་དགྲ་རུ་ལངས་གྱུར་ཏེ། ། དེ་དག་ཁྲོད་དུ་ཡེ་རུ་སཱ་ལེམ་མི་གཙང་རྫས་སུ་གྱུར། །",
      "18": "¶ ང་རང་ཁོང་གི་བཀའ་དང་འགལ་བས་ན། ། དྲང་བདེན་ཡ་ཝཱེས་ང་ལ་དེ་ལྟར་མཛད། ། ཀྱེ་ཀྱེ་མི་ཚོགས་ང་ཡི་གཏམ་ལ་གསོན། ། ང་ཡི་སྡུག་བསྔལ་ལ་ནི་གཟིགས་པར་གྱིས། ། ང་ཡི་ན་ཆུང་མ་དང་གཞོན་ནུ་དག ། ཡོངས་སུ་བཙོན་དུ་ཁྲིད་པར་གྱུར་པ་འོ། །",
      "19": "ང་ཡིས་རང་གི་དགའ་རོགས་རྣམས་ལ་སྐྱབས་ཞུས་ཀྱང་། ། དེ་དག་གིས་ནི་ང་ལ་མགོ་སྐོར་བཏང་བ་དང་། ། ང་ཡི་མཆོད་དཔོན་དང་ནི་རྒན་པོ་དག་གིས་ཀྱང་། ། འཚོ་བར་འགྱུར་ཆེད་ཁ་ཟས་འཚོལ་བའི་དུས་དེ་ལ། ། གྲོང་ཁྱེར་ནང་དུ་དབུགས་རྒྱུན་ཆད་དེ་འཆི་བར་གྱུར། །",
      "20": "ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཀྱིས་གཟིགས་པར་མཛོད། ། དཀའ་སྡུག་ང་ཡི་སྟེང་ལ་བབས་པས་སོ། ། ང་ཡི་སེམས་ནི་སྐྱོ་ཞིང་ཡིད་ནི་འཁྲུགས། ། དེ་ནི་ང་ཡིས་ལོག་སྤྱོད་བྱས་པའི་ཕྱིར། ། ཕྱི་རུ་རལ་གྲི་ཐོགས་པས་བུ་ཤོར་ཅིང་། ། ཁྱིམ་གྱི་ནང་དུ་འཆི་བ་ཉིད་ནི་སླེབས། །",
      "21": "ང་ཡི་ཤུགས་སྐད་ཐོས་ཀྱང་བདག་ལ་སེམས་གསོ་བྱེད་མཁན་མེད། ། ང་ཡི་དགྲ་ཟླ་རྣམས་ཀྱིས་ང་ཡི་རྐྱེན་ངན་ཐོས་པར་གྱུར། ། ཁྱེད་ཀྱིས་དེ་ལྟར་མཛད་པས་དགྲ་ཟླ་རྣམས་ནི་དགའ་བར་གྱུར། ། ཁྱེད་ཀྱིས་ཉིད་ཀྱི་དུས་ནི་ངེས་པར་འོང་ཞེས་བསྒྲགས་པའི་དུས། ། དགྲ་ཟླ་དེ་དག་མ་ལུས་ང་དང་ཀུན་ནས་མཚུངས་པར་འགྱུར། །",
      "22": "ཁོ་ཚོའི་སྤྱོད་ངན་ཐམས་ཅད་ཁྱེད་ཀྱི་སྤྱན་སྔར་མངོན་གྱུར་ཅིག ། ཁྱེད་ཀྱིས་ང་ཡི་ཉེས་པར་ལན་ནི་ཇི་ལྟར་འཇལ་བ་བཞིན། ། དེ་དག་ལ་ཡང་དེ་ལྟར་ལན་ནི་འཇལ་བར་མཛོད། ། དེ་ནི་ངའི་སེམས་སྡུག་ཅིང་ཡིད་ནི་སྐྱོ་ཕྱིར་རོ། །"
    },
    "2": {
      "1": "¶ གཙོ་བོས་ཁྲོས་པའི་སྤྲིན་གྱིས་ཛ་ཡན་བུ་མོ་བསྒྲིབས་པར་གྱུར། ། ཁོང་གིས་ཡེས་ར་ཨེལ་གྱི་གཟི་བརྗིད་གནམ་ནས་ས་རུ་འཕངས། ། ཁོང་ཉིད་ཁྲོས་པའི་ཉིན་མོའི་ནང་དུ་ཡང་། ། རང་གི་ཞབས་སྟེགས་ ནམ་ཡང་དྲན་མ་གྱུར། །",
      "2": "གཙོ་བོས་ཡ་ཀོབ་ཁོ་ཡི་གནས་ཀུན་ནི། ། ཁྱུར་མིད་བཏང་ཡང་ཐུགས་ནི་ཡེ་མི་འགྱོད། ། ཁོང་གིས་ཉིད་ཀྱི་ཐུགས་ཁྲོ་ཆེན་པོའི་ནང་། ། ཡ་ཧུ་དཱ་ཡི་མི་སྡེའི་མཁར་རྣམས་བཤིག ། ཁོང་གིས་རྒྱལ་ཁབ་དང་ནི་འགོ་དཔོན་རྣམས། ། ས་ལ་བརྡབས་ཏེ་ངོ་ཚ་ཐེབས་པར་མཛད། །",
      "3": "ཁོང་ཉིད་ཁྲོས་པས་ཡེས་ར་ཨེལ་གྱི་རྭ་ཅོ་ཐམས་ཅད་བཅད། ། ཁོང་གི་དགྲ་ཟླའི་མདུན་ནས་ཉིད་ཀྱི་གཡས་ཕྱག་ཚུར་འཁུམས་ཤིང་། ། ཁོང་ནི་ཕྱོགས་བཞིའི་དངོས་པོ་བསྲེག་པའི་མེ་ལྕེ་བཞིན། ། ཡ་ཀོབ་ཁོ་ཡི་ནང་དུ་ཁྱུར་མིད་བཏང་བ་འོ། །",
      "4": "ཁོང་ནི་དགྲ་ཟླས་འཐེན་པའི་གཞུ་བཞིན་དུ། ། གཡས་ཕྱག་གིས་ནི་གྲ་སྒྲིག་བྱས་ཟིན་ཏེ། ། ཁོང་ནི་དགྲ་ཟླས་མིག་ནང་ལྷུང་བ་ཐམས་ཅད་བསད་པ་བཞིན། ། ཁོང་གི་ཐུགས་ཁྲོ་མེ་ལྟར་ཛ་ཡན་སྦྲ་གུར་སྟེང་དུ་བླུགས། །",
      "5": "གཙོ་བོ་དགྲ་ཟླ་བཞིན་དུ་གྱུར་པ་དང་། ། ཁོང་གིས་ཡེས་ར་ཨེལ་དང་དེའི་ཕོ་བྲང་། ། ཁྱུར་མིད་བཏང་ཞིང་བཙན་པོའི་མཁར་ཡོངས་བཤིག ། ཁོང་གིས་ཡ་ཧུ་དཱ་ཡི་མི་སྡེའི་ནང་། ། སྡུག་བསྔལ་དང་ནི་ངུ་འབོད་བསྣན་པར་མཛད། །",
      "6": "ཁོང་གིས་ཉིད་ཀྱི་བཞུགས་གནས་ཡོངས་སུ་བརླགས། ། ལྡུམ་ར་ཇི་བཞིན་ཉིད་ཀྱི་ཚོགས་ར་གཏོར། ། ཡ་ཝཱེའི་སྲུང་བྱའི་དུས་དང་ངལ་གསོའི་དུས། ། ཛ་ཡན་ཡུལ་དུ་མ་ལུས་བརྗེད་པར་མཛད། ། ཁོང་གིས་ཉིད་ཀྱི་ཐུགས་ཁྲོ་ཆེན་པོའི་ནང་། ། རྒྱལ་པོ་དང་ནི་མཆོད་དཔོན་དོར་བར་མཛད། །",
      "7": "གཙོ་བོས་ཉིད་ཀྱི་མཆོད་ཁྲི་སྤངས་ཤིང་གནས་མཆོག་དོར། ། ཁོང་གིས་ཕོ་བྲང་དེ་ཡི་ལྕགས་རི་དགྲ་ལག་གཏད། ། དུས་ཆེན་ཞིག་ལ་དགའ་བའི་རྟེན་འབྲེལ་ཞུ་བ་བཞིན། ། ཡ་ཝཱེའི་བཞུགས་གནས་ནང་དུ་དེ་ཚོས་འུར་སྒྲ་བསྒྲགས། །",
      "8": "ཡ་ཝཱེས་ཛ་ཡན་མི་སྡེའི་མཁར་རྣམས་བརླག་པར་དགོངས། ། ཁོང་གིས་ཐིག་སྐུད་ འཐེན་ནས་ཕྱག་ཟུང་མ་འཁུམས་ཤིང་། ། ཁོང་གིས་བཙན་མཁར་དེ་དག་གཏོར་བར་མཛད་ཕྱིར་དུ། ། བཙན་རྫོང་དང་ནི་མཁར་གྱང་མཉམ་དུ་སྡུག་ལ་སྦྱར། །",
      "9": "ཛ་ཡན་ཡུལ་གྱི་མཁར་སྒོ་ཐམས་ཅད་ས་རུ་ནུབ་པ་དང་། ། གཙོ་བོས་ཁོ་མོའི་སྒོ་གཏན་དག་ཀྱང་དུམ་བུར་མཛད་གྱུར་ཅིང་། ། ཁོ་མོའི་རྒྱལ་པོ་དང་ནི་འགོ་དཔོན་ཡུལ་ཁམས་སོ་སོར་ཐོར། ། དེ་ནས་ཛ་ཡན་ཡུལ་དུ་བཀའ་ཁྲིམས་གཏན་ནས་མེད་གྱུར་ཅིང་། ། ཡ་ཝཱེའི་ཞལ་གཟིགས་ལུང་སྟོན་པ་ཚོར་ནམ་ཡང་ཐོབ་མ་གྱུར། །",
      "10": "ཛ་ཡན་ཡུལ་གྱི་རྒན་པོ་མཐའ་དག་ས་རུ་ཁ་རོག་བསྡད། ། ཁོ་ཚོས་ཐལ་བ་མགོ་ལ་གཏོར་ཅིང་སྐེད་པར་སོ་རས་བཅིངས། ། ཡེ་རུ་སཱ་ལེམ་ཡུལ་གྱི་མོ་གསར་ཐམས་ཅད་མགོ་སར་བཏུད། །",
      "11": "ང་ཡི་མིག་ལས་མཆི་མ་བཞུར་བས་ལོང་བར་གྱུར་པ་དང་། ། ང་ཡི་སེམས་པ་སྐྱོ་ཞིང་ལུས་ཟུངས་ཡོངས་སུ་ཉམས་པར་གྱུར། ། དེ་དག་ཐམས་ཅད་ང་ཡི་མི་སྡེ་སྡུག་ལ་སྦྱར་བ་དང་། ། བྱིས་པ་དང་ནི་ཕྲུ་གུ་གྲོང་གི་ལམ་ནང་འགྱེལ་བའི་ཕྱིར། །",
      "12": "དེ་དག་མཚོན་ཆས་རྨས་པའི་མི་ལྟར་གྲོང་ཁྱེར་སྲང་ལམ་འགྱེལ། ། དེ་དག་རང་གི་མ་ཡི་པང་དུ་འཆི་ལ་ཉེ་བའི་དུས། ། ཟས་དང་རྒུན་ཆང་གང་དུ་ཡོད་ཅེས་མ་ལ་དྲིས་དང་མཚུངས། །",
      "13": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་ཡུལ་གྱི་མི་སྡེ་རྣམས། ། བདག་གིས་ཁྱོད་ལ་བདེན་དཔང་ཅི་ལྟར་བྱེད་དགོས་སམ། ། བདག་གིས་ཁྱོད་དང་ཅི་ལྟར་བསྡུར་བར་འགྱུར་ནུས་སམ། ། ཀྱེ་ཀྱེ་ཛ་ཡན་ཡུལ་གྱི་མི་སྡེ་ངས་ཁྱོད་ལ། ། སེམས་གསོ་བྱ་ཕྱིར་ཅི་ཞིག་གིས་ནི་ཁྱོད་དང་བསྡུར། ། ཁྱོད་ཀྱི་རྨ་ཁ་མཚོ་བཞིན་ཡངས་པས་སུ་ཡིས་གསོ། །",
      "14": "ཁྱོད་ཀྱི་ལུང་སྟོན་པ་ཡིས་ཁྱོད་དོན་དུ། ། མཐོང་བའི་ཞལ་གཟིགས་གཡོ་ཟོལ་བླུན་རྨོངས་ཡིན། ། ཁྱོད་ཀྱི་ཚེ་སྲོག་ཡང་བསྐྱར་དྲངས་པའི་ཕྱིར། ། དེ་ཚོས་ཁྱོད་ཀྱི་ཉེས་སྡིག་ཕྱིར་མ་མངོན། ། ཁྱོད་ཕྱིར་དེ་ཚོར་ཐོབ་པའི་བཀའ་ལུང་ནི། ། རྫུན་དང་མི་རྣམས་ལོག་ལམ་ཁྲིད་བྱེད་ཡིན། །",
      "15": "ཁྱོད་རང་མཐོང་བའི་ལམ་འགྲོ་པ་རྣམས་ཀྱིས། ། ལག་པ་བརྡབས་ནས་ཁྱོད་ལ་འཕྱས་པ་དང་། ། དེ་ཚོས་ཡེ་རུ་སཱ་ལེམ་ཡུལ་གྱི་མི་སྡེར་མགོ་གཡུགས་ནས། ། ཀུན་གྱིས་སྨྲ་བར་བརྗོད་པའི་སྐྱོན་བྲལ་ཡོན་ཏན་ཀུན་རྫོགས་ཤིང་། ། ཐམས་ཅད་དགའ་བྱེད་གྲོང་ཁྱེར་འདི་ནི་ཨེ་ཡིན་ནམ་ཞེས་སྨྲས། །",
      "16": "ཁྱོད་ཀྱི་དགྲ་བོས་ཁྱོད་ལ་རྒོལ་ཕྱིར་ཁ་གདངས་ཤིང་། ། ཁྱོད་ལ་འཕྱ་དམོད་བྱེད་ཀྱིན་སོ་ཡང་འཆོས་ནས་ནི། ། ངེད་ཅག་རྣམས་ཀྱིས་དེ་ནི་མེད་པར་མཛད་གྱུར་ཅིང་། ། དེ་ནི་ང་ཚོས་རེ་སྒུག་བྱེད་པའི་ཉིན་མོ་སྟེ། ། ངེད་ཀྱིས་མིག་གིས་དངོས་སུ་མཐོང་ངོ་ཞེས་སྨྲས་སོ། །",
      "17": "ཁོང་གིས་ཁྱོད་ནི་གཏོར་ཡང་སྙིང་རྗེས་གཟིགས་པ་མེད། ། ཁོང་གིས་དགྲ་ཟླ་ཁྱོད་ལས་རྒྱལ་བས་དགའ་བར་མཛད། ། ཁོང་གིས་ཁྱོད་ཀྱི་དགྲ་བོའི་རྭ་ནི་མཐོན་པོར་མཛད། ། ཡ་ཝཱེས་ཉིད་ཀྱི་ཐུགས་དགོངས་བཞིན་དུ་མཛད་པ་དང་། ། ཁོང་གིས་སྔར་ནས་གསུངས་པ་བཞིན་དུ་མཛད་པར་གྱུར། །",
      "18": "ཛ་ཡན་ཡུལ་གྱི་མི་སྡེའི་མཁར་གྱང་རྣམས། ། ཁྱོད་ཀྱིས་བློ་སེམས་གཅིག་གིས་གཙོ་བོར་ཞུས། ། ཁྱོད་ཀྱི་མིག་ཆུ་གཙང་པོ་ཇི་བཞིན་དུ། ། ཉིན་མཚན་དབྱེ་བ་མེད་པར་བཞུར་ནས་ནི། ། རང་ལ་ངལ་གསོ་ནམ་ཡང་ཐོབ་མི་བྱ། ། མིག་འབྲས་གཉིས་ལ་ངལ་གསོ་མེད་པར་ཤོག །",
      "19": "མཚན་མོ་ཐུན་མཚམས་དང་པོའི་དུས་སུ་བབས་པ་ན། ། ཁྱོད་ནི་ཡར་ལ་ལངས་ཏེ་བོས་ནས་ཞུས་ཤིག་དང་། ། གཙོ་བོའི་དྲུང་དུ་ཁྱོད་ཀྱི་སྙིང་གཏམ་ལྷུག་པོར་བརྗོད་དགོས་ཤིང་། ། ཁྱོད་ཀྱི་བྱིས་པ་རྣམས་ནི་ལམ་བར་དག་ཏུ་བཀྲེས་ཤིང་བརྒྱལ། ། ཁྱོད་ཀྱིས་བྱིས་པ་རྣམས་ཀྱི་ཚེ་སྲོག་བསྐྱབ་པའི་ཕྱིར། ། ལག་པ་ཡར་ལ་བརྐྱངས་ཏེ་གཙོ་བོར་གསོལ་བ་ཐོབས། །",
      "20": "ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཀྱིས་གཟིགས་དང་གཟིགས་པར་མཛོད། ། ཁྱེད་ཀྱིས་སྔོན་ཆད་འདི་ལྟར་སུ་ལ་ལན་འཇལ་ལམ། ། བུད་མེད་ཅིག་གིས་རང་གིས་བཙས་ནས་སྐྱོང་བ་ཡི། ། ཕྲུ་གུ་ཟ་ཞིང་བཟའ་བར་ཕོད་པ་སུ་ཡོད་དམ། ། གཙོ་བོའི་གནས་མཆོག་ལ་ནི་མཆོད་དཔོན་དང་ནི་ལུང་སྟོན་པ། ། གདུག་རྩུབ་ནག་པོའི་ལས་ཀྱིས་དམར་གསོད་བྱེད་ཅིང་བྱ་འོས་སམ། །",
      "21": "སྲང་བར་དག་ཏུ་རྒན་གཞོན་ཐམས་ཅད་ས་རུ་འགྱེལ་ནས་ཤི ། བདག་གི་བུ་མོ་དང་ནི་གསར་བུ་ཐམས་ཅད་གྲི་ཁར་འགྱེལ། ། ཁྱེད་རང་ཁྲོས་པའི་ཉིན་ལ་དེ་རྣམས་ཐམས་ཅད་གསོད་པར་མཛད། ། ཁྱེད་ཀྱིས་དེ་རྣམས་བསད་ཀྱང་སྙིང་རྗེ་ཅི་ཡང་མ་གནང་ངོ་། །",
      "22": "¶ ཁྱེད་ཀྱིས་ཕྱོགས་བཞི་བསྡུས་ཏེ་ང་རང་སྐྲག་པར་མཛད་པ་ནི། ། དུས་ཆེན་རོལ་བའི་ཉིན་ལ་མི་ཚོགས་མང་པོ་བསྡུས་དང་མཚུངས། ། ཡ་ཝཱེ་ཐུགས་ཁྲོའི་དུས་སུ་ཐར་ཏེ་གསོན་མཁན་གཅིག་ཀྱང་མེད། ། བདག་གིས་བཙས་ཤིང་ཆེ་བར་བསྐྱངས་པའི་ཕྲུ་གུ་རྣམས། ། དགྲ་ཟླས་ཐམས་ཅད་བསད་དེ་གཅིག་ཀྱང་མ་ལྷག་གོ །"
    },
    "3": {
      "1": "¶ བདག་ནི་ཡ་ཝཱེའི་དབྱུག་པའི་འོག་ཏུ་སྡུག་བསྔལ་མྱངས་པའི་མི་ཡིན་ཏེ། །",
      "2": "ཁོང་གིས་བདག་ནི་མུན་པའི་ནང་དུ་ཁྲིད་ཀྱང་འོད་ནང་མ་ཁྲིད་དོ། །",
      "3": "ཁོང་གིས་དངོས་གནས་ཉིན་གང་བདག་ལ་ཡང་ཡང་རྒོལ་བ་དང་། །",
      "4": "ཁོང་གིས་བདག་གི་ཤ་པགས་ཉམས་ཤིང་རུས་པ་བཅག་པར་མཛད། །",
      "5": "ཁོང་གིས་བཙན་རྫོང་བརྩིགས་ཏེ་བདག་གི་མཐའ་ནས་བསྐོར། ། གནོད་པ་དང་ནི་དཀའ་སྡུག་ང་ལ་བསྐོར་བར་མཛད། །",
      "6": "ཁོང་གིས་ང་རང་མུན་པར་སྡོད་བཅུག་སྟེ། ། ཤི་ནས་ཡུན་རིང་འགོར་བའི་མི་ལྟར་མཛད། །",
      "7": "ཁོང་གིས་མཁར་རྣམས་བརྩིགས་ཏེ་བདག་བསྐོར་བས། ། བདག་ནི་དེ་ལས་ཐར་བར་མ་མཛད་དེ། ། ཁོང་གིས་བདག་གི་ལྕགས་སྒྲོག་ལྗིད་དུ་བཏང་། །",
      "8": "ཐ་ན་བདག་གིས་ཁོང་ལ་ཞུས་ནས་འོ་དོད་འབོད་དུས་ཀྱང་། ། ཁོང་གིས་སྙན་ཅོག་བཀབ་སྟེ་ང་ཡི་གསོལ་འདེབས་མ་གསན་ཏོ། །",
      "9": "ཁོང་གིས་རྡོ་བ་བཟོས་མས་བདག་གི་ལམ་བུ་བཀག ། ཁོང་གིས་བདག་གི་འགྲོ་ལམ་ཀྱག་ཀྱོག་ཏུ་མཛད་དོ། །",
      "10": "ཁོང་ཉིད་བདག་ལ་མཚོན་ན་ནི། ། འཇབ་སྒུག་བྱེད་པའི་དྲེད་མོང་དང་། ། གསང་བའི་གནས་ཀྱི་སེང་གེ་བཞིན། །",
      "11": "ཁོང་གིས་བདག་ནི་དྲང་པོའི་ལམ་དང་ཕྲལ། ། སིལ་བུར་གཏོར་ནས་དབེན་སར་བསྐྱུར་བ་ཡིན། །",
      "12": "ཁོང་གིས་ཉིད་ཀྱི་གཞུ་འཐེན་ཏེ། ། བདག་ནི་མདའ་ཡི་འབེན་དུ་མཛད། །",
      "13": "ཁོང་གིས་ཉིད་ཀྱི་མདའ་ཤུབས་ནང་གི་མདའ། ། ང་ཡི་སྙིང་ཁོང་རུས་པའི་གཏིང་དུ་བསྣུན། །",
      "14": "བདག་ནི་མི་སྡེ་ཀུན་གྱིས་འཕྱ་དམོད་བྱེད་སར་གྱུར། ། འཕྱ་དགོད་གླུ་རུ་གྱུར་ཏེ་ཀུན་གྱིས་ཉིན་གང་འཕྱས། །",
      "15": "ཁོང་གིས་བདག་ལ་སྡུག་བསྔལ་ཆེན་པོ་བཟོས། ། མཁན་པའི་ཁ་ཏིག་ཉམས་སུ་མྱོང་བར་མཛད། །",
      "16": "ཁོང་གིས་ཟེགས་མས་བདག་གི་སོ་ནི་ཆག་པར་མཛད། ། ཁོང་གིས་བདག་ནི་ས་རྡུལ་ནང་དུ་སྡོད་པར་མཛད། །",
      "17": "ཁྱེད་ཀྱིས་བདག་ལ་ཞི་བདེ་མེད་པར་མཛད་པ་དང་། ། བདག་གིས་དགའ་སྤྲོ་བྱིན་རླབས་ཅི་ཞིག་ཡིན་པ་བརྗེད། །",
      "18": "དེ་བས་བདག་གིས་ང་ཡི་སྟོབས་ཤུགས་ཡོངས་སུ་རྫོགས་པ་དང་། ། ཡ་ཝཱེ་ཁོང་ལས་ཐོབ་པའི་རེ་བ་བདག་དང་བྲལ་ཞེས་སྨྲས། །",
      "19": "¶ བདག་གི་ཉམ་ཐག་ཡུལ་འཁྱམ་དྲན་དུས་སུ། ། དེ་ནི་མཁན་པ་དང་ནི་མཁྲིས་ཁུ་བཞིན། །",
      "20": "ནམ་རྒྱུན་བདག་གིས་འདས་པའི་དོན་དྲན་དུས། ། བདག་གི་སེམས་ནང་སྐྱོ་བས་ཁེངས་པ་འོ། །",
      "21": "ཡིན་ཡང་བདག་གིས་དོན་ཞིག་དྲན་དུས་སུ། ། བདག་གི་ཡིད་སེམས་ནང་དུ་རེ་བ་ཡོད། །",
      "22": "དེ་ནི་ཡ་ཝཱེའི་བྱམས་བརྩེ་ནམ་ཡང་འཇིག་ཡེ་མེད། ། ཁོང་གི་སྙིང་རྗེ་ཇི་སྲིད་བར་དུ་བཞུགས་པར་འགྱུར། །",
      "23": "ཞོགས་པ་རེ་རེར་གསར་པ་ཡིན་པ་བཞིན། ། ཁྱེད་ནི་ཧ་ཅང་བློ་གཏོད་རུང་བ་འོ། །",
      "24": "ང་ཡི་སེམས་སུ་ཡ་ཝཱེ་ཁོང་ནི་བདག་གི་ནོར་སྐལ་ཡིན། ། དེ་བས་བདག་གིས་ཁོང་ལ་རེ་སྒུག་བྱེད་ངེས་ཡིན་ཞེས་སྨྲ། །",
      "25": "¶ ཁོང་ཉིད་འཚོལ་ཞིང་སེམས་ནས་སྒུག་མཁན་ལ། ། ཡ་ཝཱེས་ཐུགས་རྗེ་གནང་བར་འགྱུར་བ་དང་། །",
      "26": "ལྷིང་འཇགས་ངང་ནས་ཡ་ཝཱེའི་སྐྱབས་ལ་ནི། ། སྒུག་པའི་དོན་དེ་ཅི་འདྲའི་བཟང་བ་ལ། །",
      "27": "མི་ཡིས་ལོ་ན་གཞོན་པའི་དུས་སྐབས་སུ། ། རང་གི་གཉའ་ཤིང་འཁུར་བ་ཅི་འདྲའི་ལེགས། །",
      "28": "ཁོ་རང་གཅིག་པུ་ཁ་རོག་སྡོད་ཅིང་སྨྲ་བ་མེད་པ་དེ། ། ཡ་ཝཱེ་ཁོང་གིས་དེ་ཡི་ལུས་སྟེང་བཞག་པའི་ཕྱིར་ཡིན་ནོ། །",
      "29": "དེ་ཡིས་རང་གི་སྨྲ་སྒོ་ས་རྡུལ་ནང་། ། སྦས་པར་གྱུར་ན་རེ་བ་ཡོད་ཀྱང་སྲིད། །",
      "30": "དེ་ཡིས་གཞན་པར་རང་ལ་འགྲམ་ལྕག་གཞུ་བཅུག་སྟེ། ། རང་ལ་བརྙས་བཅོས་ཚད་མེད་མྱོང་བར་འཇུག་པ་དང་། །",
      "31": "གཙོ་བོས་མི་རྣམས་རྒྱུན་ནས་རྒྱུན་དུ་འདོར་བར་མི་འགྱུར་ཏེ། །",
      "32": "ཡ་ཝཱེ་ཁོང་གིས་མི་ལ་སྐྱོ་བ་བསྐྱེད་པར་མཛད་ན་ཡང་། ། བྱམས་བརྩེ་ཆེན་པོ་ལྡན་པས་མི་ལ་ཐུགས་རྗེ་གནང་འགྱུར་རོ། །",
      "33": "དེ་ནི་ཁོང་གི་ཐུགས་ལས་མི་ལ་དཀའ་སྡུག་མི་འབྱུང་ཞིང་། ། ཡང་ན་འཇིག་རྟེན་མི་ལ་སྐྱོ་བ་མི་འབྱུང་དགོངས་པའི་ཕྱིར། །",
      "34": "ས་སྟེང་བཙོན་པ་ཐམས་ཅད་རྡོག་བརྫིས་གཏོང་བ་འམ། །",
      "35": "ཡང་ན་བླ་མེད་དྲུང་དུ་དྲང་པོར་བསྙོན་འཛུགས་པ། །",
      "36": "ཞུ་གཏུག་དོན་ཐོག་དཀར་ནག་ལྡོག་གྱུར་ན། ། གཙོ་བོས་ཐམས་ཅད་གཟིགས་པ་མ་ཡིན་ནམ། །",
      "37": "གཙོ་བོའི་ཐུགས་དགོངས་མིན་པར་སུ་ཡིས་སྨྲ་ཞིང་བསྒྲུབ་ནུས་སམ། །",
      "38": "བདེ་སྡུག་ཐམས་ཅད་བླ་མེད་ཞལ་ལས་འོང་བ་མ་ཡིན་ནམ། །",
      "39": "གསོན་པོས་རང་ཉེས་ཁྲིམས་ཆད་འཁུར་ཕྱིར་སྨྲེ་སྔགས་ཅི་ལ་འདོན། །",
      "40": "རང་ཅག་རྣམས་ཀྱིས་སོ་སོའི་སྤྱོད་ལམ་ཡང་ཡང་དུ། ། ཞིབ་བཤེར་ཚོད་ལྟ་བྱས་རྗེས་ཡ་ཝཱེའི་ཕྱོགས་སུ་འཁོར། །",
      "41": "རང་ཅག་རྣམས་ཀྱིས་ལྷག་བསམ་རྣམ་དག་གིས། ། ནམ་མཁར་བཞུགས་པའི་དཀོན་མཆོག་ཁོང་ཕྱོགས་སུ། ། ལག་པ་ཡར་ལ་བཀྱགས་ནས་གསོལ་བ་འདེབས། །",
      "42": "ངེད་ཀྱིས་སྡིག་པ་སྤྱད་ནས་ངོ་ལོག་བྱས་པ་ལ། ། ཁྱེད་ཀྱིས་ཉེས་པ་དེ་དག་སེལ་བར་མི་མཛད་དེ། །",
      "43": "ཁྱེད་རང་ཐུགས་ཁྲོས་བཀབ་པའི་ཕྱིར། ། སྙིང་རྗེ་ཅི་ཡང་མེད་པའི་ངང་། ། ངེད་ཅག་བདས་ཤིང་བསད་པ་འོ། །",
      "44": "ཁྱེད་ཀྱིས་སྤྲིན་ནག་ཕུང་བོས་རང་ཉིད་ཡོངས་སུ་བསྒྲིབས་མཛད་པས། ། ངེད་ཀྱི་ཞུ་གསོལ་ཉིད་ཀྱི་སྙན་ལམ་དུ་ནི་སླེབ་མི་སྲིད། །",
      "45": "ཁྱེད་ཀྱིས་ངེད་རྣམས་མི་སྡེ་ཁྲོད་དུ་སྙིགས་མ་དང་ནི་ཟོག་རོར་མཛད། །",
      "46": "ངེད་ཀྱི་དགྲ་བོ་ཀུན་གྱིས་ངེད་ཅག་ཕྱོགས་སུ་རྒོལ་བར་ཁ་གདངས་པས། །",
      "47": "འཇིགས་སྐྲག་རྒྱ་རྙི་རྩ་མེད་གཏོང་བ་དང་། ། གཏོར་བརླག་བཅས་ནི་ངེད་ཀྱི་སྟེང་ལ་སླེབས། །",
      "48": "བདག་གི་མི་སྡེ་བརླགས་པས་ང་ཡི་མཆི་མ་ཆུ་ལྟར་བཞུར། །",
      "49": "བདག་གི་མིག་ལས་མཆི་མ་བཞུར་བ་རྒྱུན་ཆད་མེད་པར་གྱུར། །",
      "50": "ཡ་ཝཱེས་ནམ་མཁའི་དབྱིངས་ནས་གཟིགས་ཤིང་གཟིགས་པའི་བར་དུ་བཞུར། །",
      "51": "བདག་གི་གྲོང་ཁྱེར་མི་སྡེར་བྱུང་བའི་སྡུག་བསྔལ་མཐོང་བས་ན། ། བདག་གི་སེམས་སུ་སྡུག་བསྔལ་མང་དུ་བསྐྱེད་པར་གྱུར་པ་ཡིན། །",
      "52": "བྱ་དང་བྱིའུ་དེད་ནས་འཛིན་པ་ཇི་བཞིན་དུ། ། དོན་མེད་བདག་གི་དགྲ་ཟླར་གྱུར་པས་ངའི་རྗེས་དེད། །",
      "53": "སྲོག་དང་ཕྲལ་ཕྱིར་དེ་ཚོས་བདག་ནི་དོང་ནང་འཕངས། ། ད་དུང་བདག་གི་ལུས་སྟེང་ཕ་བོང་ཆེན་པོས་མནན། །",
      "54": "ཆུ་ཡིས་མགོ་ནས་བསྣུབས་པས་ང་ནི་འཆིའོ་ཞེས་ངས་སྨྲས། །",
      "55": "¶ ཀྱེ་ཀྱེ་ཡ་ཝཱེ་བདག་གིས་དོང་གི་ཞབས་ངོས་སུ། ། ཁྱེད་ཀྱི་མཚན་ནི་ཡང་ཡང་བརྗོད་ནས་ཞུས་པ་དང་། །",
      "56": "དེ་སྔོན་ཁྱེད་ཀྱིས་བདག་གི་འབོད་སྐད་གསན་ཞིང་གསན་གྱུར་པས། ། ཁྱེད་ཀྱིས་ང་ཡི་སྐྱབས་འཇུག་ཞུ་བའི་སྐད་ལ་གསན་པར་མཛོད། །",
      "57": "ནམ་ཡང་བདག་གིས་ཁྱེད་ཀྱི་ཕྱོགས་སུ་ཞུ་བའི་དུས་སྐབས་སུ། ། ཁྱེད་ཉིད་བདག་གི་ཉེ་སར་ཕེབས་ཏེ་འཇིགས་པར་མི་དགོས་གསུངས། །",
      "58": "གཙོ་བོ་ཁྱེད་ཀྱིས་བདག་ལ་དག་འབུད་མཛད་དེ་ངའི་སྲོག་བསྐྱབས་པ་ཡིན། །",
      "59": "ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཀྱིས་བདག་གི་ཉེས་འགེལ་གཟིགས་གྱུར་པས། ། ཁྱེད་ཀྱིས་བདག་གི་ཕྱིར་དུ་དྲང་བདེན་ཅན་གྱི་ལམ་མཛོད་ཅིག །",
      "60": "ཁྱེད་ཀྱིས་དེ་ཚོའི་སྡང་ཟུག་སྣ་ཚོགས་གཟིགས་གྱུར་ཅིང་། ། ད་དུང་བདག་ལ་གནོད་པའི་ཇུས་ངན་ཐམས་ཅད་གཟིགས། །",
      "61": "ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཀྱིས་དེ་ཚོའི་ངན་སྨྲས་རྣམས་གསན་ཞིང་། ། ད་དུང་བདག་ལ་གནོད་པའི་ཇུས་ངན་ཐམས་ཅད་གསན་པར་གྱུར། །",
      "62": "བདག་ལ་རྒོལ་བའི་མི་ཚོའི་སྨྲ་བརྗོད་ཁྱེད་ཀྱིས་གསན་གྱུར་ཅིང་། ། དེ་ཚོས་ཉིན་རེར་བདག་ལ་རྒོལ་བའི་ངན་ཇུས་ཁྱེད་ཀྱིས་མཁྱེན། །",
      "63": "དེ་རྣམས་ས་རུ་འདུག་པའམ་ཡར་ལ་ལང་བ་གང་བྱས་ཀྱང་། ། བདག་ནི་ཀུན་གྱིས་འཕྱ་དགོད་གླུ་ཚིག་གྱུར་པ་ཁྱེད་ཀྱིས་གཟིགས། །",
      "64": "ཡ་ཝཱེ་ཁྱེད་ཀྱིས་ཁོ་ཚོའི་ལག་པས་སྤྱད་པ་བཞིན། ། དེ་དག་ཀུན་ལ་ཉེས་པའི་ལན་ཞིག་འཇལ་བར་མཛོད། །",
      "65": "ཁྱེད་ཀྱིས་ཁོ་ཚོའི་སེམས་ནི་གྱོང་པོར་མཛོད་ཅིག་དང་། ། ཁྱེད་ཀྱི་དམོད་མོ་དེ་དག་སྟེང་དུ་ཐེབས་པར་ཤོག །",
      "66": "ཁྱེད་ཀྱིས་ཁྲོ་གཏུམ་ཆེན་པོས་དེ་དག་བདའ་བར་མཛོད་ཅིག་དང་། ། ཡ་ཝཱེས་སྐྱོང་བའི་གནམ་འོག་ཀུན་ནས་དེ་དག་བརླག་པར་མཛོད། །"
    },
    "4": {
      "1": "¶ གསེར་འོད་ཉམས་ཤིང་ལྷད་མེད་གསེར་རྐྱང་ཁ་མདོག་འགྱུར་བ་ཅི། ། དམ་པའི་གནས་ཀྱི་རྡོ་དག་སྲང་ལམ་སོ་སོར་གཏོར་ཏེ་ཡོད། །",
      "2": "ཛ་ཡན་ཡུལ་གྱི་གུས་པར་འོས་པའི་མི་སྡེ་རྣམས། ། སྔོན་ལ་གསེར་རྐྱང་བཞིན་དུ་རྩ་ཆེན་ཡིན་པ་དང་། ། ད་ལྟ་ཅིའི་ཕྱིར་མི་ཡིས་རྫ་ཆས་བཞིན་དུ་ལྟ། ། རྫ་མཁན་ལག་པས་བཟོས་པའི་རྫ་སྣོད་འདྲ་བ་ཅི། །",
      "3": "ཁྱི་སྤྱང་དག་གིས་ནུ་མ་བཏོན་ཏེ་ཕྲུ་གུ་སྐྱོང་ཤེས་ཀྱང་། ། བདག་གི་མི་སྡེ་དབེན་སྟོང་ཡུལ་གྱི་རྔ་བྱ་ཇི་བཞིན་དུ། ། ཅི་འདྲའི་གདུག་རྩུབ་ཆེ་ཞིང་སྙིང་རྗེ་མེད་པར་གྱུར་པ་ཡིན། །",
      "4": "ཕྲུ་གུ་དམར་འབྱར་སྐོམ་ནས་ལྕེ་རྩེ་རྐན་ལ་འབྱར། ། བྱིས་པས་བག་ལེབ་བསླངས་ཀྱང་སྦྱིན་མཁན་གཅིག་ཀྱང་མེད། །",
      "5": "སྔོན་ཆད་མངར་བའི་ཟས་ལ་རོལ་མཁན་ད་ལྟ་ལམ་གྱི་སྤྲང་པོར་གྱུར། ། སྔོན་ཆད་མཚལ་ཁའི་ལྭ་བ་གྱོན་མཁན་ད་ལྟ་སྙིགས་རོ་ནང་དུ་ཉལ། །",
      "6": "བདག་གི་མི་སྡེ་ཀུན་གྱི་སྡིག་པ་ནི། ། སཱ་དོམ་ལས་ཀྱང་ཤིན་ཏུ་ཆེ་བ་དང་། ། སཱ་དོམ་སྐད་ཅིག་ཙམ་དུ་ཕམ་པར་གྱུར། ། དེ་ལ་རོགས་རམ་བྱེད་མཁན་ཡོད་མ་གྱུར། །",
      "7": "དེ་སྔ་ཛ་ཡན་ཡུལ་གྱི་སྐུ་དྲག་ཐམས་ཅད་ནི། ། ཁ་བ་ལས་ཀྱང་གཙང་ལ་འོ་མ་ལས་ཀྱང་དཀར། ། ལུས་པོ་པདྨ་རཱ་ག་ལས་ཀྱང་བཀྲག་མདངས་རྒྱས། ། ཞལ་རས་རིན་ཆེན་སྔོན་པོ་བཞིན་དུ་མཛེས་ཤིང་མཛེས། །",
      "8": "འོན་ཀྱང་ད་ལྟ་དེ་ཚོའི་ངོ་མདོག་སོལ་བ་ལས་ཀྱང་ནག ། སྲང་ལམ་ནང་དུ་དེ་དག་ཤེས་མཁན་གཅིག་ཀྱང་མ་བྱུང་སྟེ། ། དེ་རྣམས་སྐྱི་མོ་རུས་པར་འབྱར་ཏེ་ཤིང་སྐམ་ཇི་བཞིན་གྱུར། །",
      "9": "ལྟོགས་ཤི་ཐེབས་པར་བསྡུར་ན་རལ་གྲིས་བསད་པ་ལེགས་པར་འདུག ། བཀྲེས་ནས་ཤི་བ་དག་ནི་ཞིང་སར་ཐོན་རྫས་མ་བྱུང་བར། ། ལུས་པོ་རིམ་གྱིས་རིད་ཅིང་མཐའ་མར་ཡོངས་སུ་འཇིག་པའི་ཕྱིར། །",
      "10": "བདག་གི་མི་སྡེར་གནོད་པ་ཐེབས་པའི་དུས། ། བྱམས་སེམས་ལྡན་པའི་བུད་མེད་རང་ཉིད་ཀྱིས། ། དངོས་སུ་རང་གི་ཕྲུ་གུ་བཙོས་པ་དང་། ། ཕྲུ་གུ་རྣམས་ནི་ཨ་མའི་ཟས་སུ་གྱུར། །",
      "11": "དེ་ནས་ཡ་ཝཱེ་ཤིན་ཏུ་ཐུགས་ཁྲོས་ཏེ། ། ཉིད་ཀྱི་ཁྲོ་གཏུམ་དེ་དག་སྟེང་དུ་བླུགས། ། ཁོང་གིས་ཛ་ཡན་ཡུལ་དུ་མེ་སྦར་ནས། ། དེ་ཡི་རྩ་བ་ཡོངས་སུ་གཏོར་བ་འོ། །",
      "12": "ས་སྟེང་རྒྱལ་པོ་དང་ནི་ཡུལ་གྱི་མངའ་འབངས་ཐམས་ཅད་ཀྱིས། ། ཡེ་རུ་སཱ་ལེམ་མཁར་སྒོར་དགྲ་བོ་འཛུལ་བར་ཡིད་མ་ཆེས། །",
      "13": "¶ ཛ་ཡན་ལུང་སྟོན་པ་ཡི་སྡིག་པ་དང་། ། མཆོད་དཔོན་དག་གི་ཉེས་པ་ཐམས་ཅད་དེ། ། གྲོང་ཁྱེར་ནང་དུ་དྲང་བདེན་མི་ཀུན་གྱི། ། སྐུ་ཁྲག་བཞུར་དུ་བཅུག་པ་དེའི་རྐྱེན་གྱིས། །",
      "14": "དེ་རྣམས་ལོང་བ་སྲང་ལམ་འཁྱམ་པ་བཞིན། ། དེ་དག་ཁྲག་གིས་བཙོག་པར་བཟོས་པས་ན། ། དེ་ཚོའི་ལྭ་བར་རེག་མཁན་གཅིག་ཀྱང་མེད། །",
      "15": "མི་རྣམས་དག་གིས་ཁོ་ཚོ་ལ། ། མི་གཙང་མི་གཙང་ཁྱོད་ཅག་རྣམས། ། ཕར་སོང་ཕར་སོང་ཞེས་པ་དང་། ། ང་ལ་མ་རེག་ཅེས་ཟེར་ཞིང་། ། དེ་དག་བྲོས་ཤིང་འཁྱམ་པའི་དུས། ། ཡུལ་ཁམས་ཀུན་གྱི་མི་རྣམས་ཀྱིས། ། དེ་དག་ད་ནི་གནས་འདི་རུ། ། སྡོད་པར་མི་རུང་ཞེས་སུ་སྨྲ། །",
      "16": "ཡ་ཝཱེ་ཁོང་གིས་དེ་དག་གཏོར་བར་མཛད། ། དེ་ནས་ཁོ་ཚོར་གཟིགས་སྐྱོང་མ་མཛད་ཅིང་། ། མི་ཡིས་མཆོད་དཔོན་དག་ལ་མ་བཀུར་ཏེ། ། རྒན་པོ་རྣམས་ཀྱང་དྲིན་གྱིས་མ་བསྐྱངས་སོ། །",
      "17": "མིག་གི་དབང་བོ་ཉམས་པར་འགྱུར་བའི་བར། ། རང་ཅག་གིས་ནི་དོན་མེད་རམ་འདེགས་སྒུག ། རང་ཅག་གིས་ནི་རྒྱང་ལྟའི་མཐོ་སྟེགས་སུ། ། བསྐྱབ་ནུས་མེད་པའི་རྒྱལ་ཁབ་ཅིག་ལ་སྒུག །",
      "18": "དགྲ་ཟླས་རང་རེའི་རྗེས་སུ་བསྙེགས་པས་ན། ། བདག་ཅག་རང་གི་སྲང་ལམ་བསྐྱོད་མ་ཕོད། ། བདག་ཅག་མཇུག་འབྲས་དང་ནི་དུས་ཉེ་ཞིང་། ། རང་ཅག་རྣམས་ཀྱི་མཇུག་འབྲས་དངོས་སུ་སླེབས། །",
      "19": "རང་ཅག་སྙེག་མཁན་ནམ་མཁའི་གླག་ལས་མགྱོགས་ཤིང་མྱུར། ། རི་བོ་རྣམས་སུ་ཁོ་ཚོས་རང་རེའི་རྗེས་དེད་ཅིང་། ། ཐང་རྒོད་ཀུན་ཏུ་ཡིབ་ནས་རང་ཅག་རྣམས་ལ་རྒོལ། །",
      "20": "ཡ་ཝཱེས་བྱུགས་པ་རང་རེའི་སྣ་ཁུང་དབུགས། ། དེ་ཚོའི་དོང་རྙི་ནང་དུ་ཚུད་པ་དང་། ། རང་ཅག་ངེས་པར་ཁོང་གི་བསིལ་གྲིབ་འོག ། ཡུལ་ཁམས་ནང་དུ་གསོན་ཞེས་རང་རེས་སྨྲས། །",
      "21": "ཨེ་དོམ་པ་དང་ཨུ་ཟཱའི་འབངས་མི་རྣམས། ། དགའ་མགུ་དང་ནི་སྤྲོ་བར་གྱིས་ཤིག་དང་། ། ཕོར་བ་ དེ་ནི་ཁྱོད་ཀྱི་གམ་དུ་བརྒྱུད་འོང་ཞིང་། ། ཁྱོད་ནི་ངེས་པར་བཟི་ཞིང་ལུས་པོ་སྒྲེན་མོར་འགྱུར། །",
      "22": "¶ ཀྱེ་ཀྱེ་ཛ་ཡན་ཡུལ་གྱི་བུ་མོ་ལགས། ། ཁྱོད་ལ་ཉེས་ཆད་ཐེབས་པ་རྫོགས་གྱུར་ཏེ། ། ཡ་ཝཱེས་ད་ནི་ཁྱོད་རང་འཁྱམ་མི་འཇུག ། ཀྱེ་ཀྱེ་ཨེ་དོམ་ཡུལ་གྱི་འབངས་མི་རྣམས། ། ཁོང་གིས་ཁྱོད་ཀྱི་སྡིག་པར་ཉེས་ཆད་གཅོད། ། ཁྱོད་ཀྱི་ཉེས་པ་མངོན་པར་འགྱུར་མཛད་དོ། །"
    },
    "5": {
      "1": "¶ ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཀྱིས་ངེད་ཅག་སྡུག་བསྔལ་དྲན་པར་མཛོད། ། ངེད་ཅག་རྣམས་ཀྱི་ངོ་ཚ་སྣང་མེད་མི་བསྐྱུར་གཟིགས་སུ་གསོལ། །",
      "2": "ངེད་ཀྱི་ནོར་སྐལ་ཕྱི་པར་དབང་བ་དང་། ། ངེད་ཀྱི་ཁང་པ་དེ་ཡང་ཕྱི་པར་དབང་། །",
      "3": "ངེད་རྣམས་ཕ་མེད་དྭ་ཕྲུག་བཞིན་དུ་ལུས། ། ངེད་ཀྱི་མ་རྣམས་ཡུགས་མོ་ཡིན་ཚོད་འདུག །",
      "4": "ངེད་ཀྱིས་ཆུ་རིན་སྤྲད་ནས་ཆུ་འཐུང་ཞིང་། ། ངེད་ཀྱི་བུད་ཤིང་གཞན་གྱིས་བཙོང་བ་ཡིན། །",
      "5": "ངེད་ཀྱི་སྐེ་ལ་གཉའ་ཤིང་ལྕི་མོ་ཁུར་བའི་ཕྱིར། ། ངེད་ཅག་ཤིན་ཏུ་ལུས་ཐང་ཆད་ཀྱང་ངལ་གསོ་མེད། ། ད་དུང་མི་ཡིས་ངེད་ཀྱི་རྗེས་སུ་འདེད་པར་གྱུར། །",
      "6": "ངེད་ཅག་ཟས་ཀྱིས་འགྲང་ཕྱིར་ཨེ་ཅིབ་དང་། ། ཨ་སུར་པ་ཡི་ཕྱོགས་སུ་མགོ་བོ་བསྒུར། །",
      "7": "ངེད་ཀྱི་མེས་པོས་སྡིག་པ་བྱས་ན་ཡང་། ། དེ་རྣམས་སྔར་ནས་འདས་ཤིང་མི་འདུག་གོ ། དེ་ཚོའི་ཉེས་པ་ཐམས་ཅད་ངེད་ཀྱིས་ཁུར། །",
      "8": "བྲན་གཡོག་དག་གིས་ངེད་ལ་ཚོད་བཟུང་སྟེ། ། ངེད་རྣམས་དེ་ལས་སྐྱོབ་མཁན་སུ་ཡང་མེད། །",
      "9": "དབེན་སྟོང་ཡུལ་གྱི་རལ་གྲི་རྣོ་དྲགས་པས། ། ངེད་ཀྱིས་རང་སྲོག་བསྡོས་ཏེ་ཁ་ཟས་ཐོབ། །",
      "10": "བཀྲེས་སྐོམ་ཕྱིར་དུ་ངེད་ཀྱི་ལུས་པོར་ཚ་རྒྱས་ཤིང་། ། ངེད་ཀྱི་སྐྱི་མོ་མེ་ཐབ་བཞིན་དུ་ཚ་གདུག་ཆེ། །",
      "11": "བུད་མེད་རྣམས་ལ་ཛ་ཡན་ཡུལ་དུ་བརྙས་བཅོས་ཐེབས་པ་དང་། ། ཡ་ཧུ་དཱ་ཡི་གྲོང་དུ་མོ་གསར་དག་ལ་བཙན་གཡེམ་བྱས། །",
      "12": "འགོ་དཔོན་རྣམས་ནི་མི་ཡིས་མར་དཔྱངས་ཏེ། ། རྒན་པོ་རྣམས་ལ་གུས་བཀུར་མ་ཐོབ་བོ། །",
      "13": "ན་གཞོན་རྣམས་ཀྱིས་འཐག་རྡོ་བསྐོར་བས་སྡུག་མྱངས་ཤིང་། ། བྱིས་པ་དག་གིས་བུད་ཤིང་ཁུར་བས་སར་འགྱེལ་ཏོ། །",
      "14": "རྒན་རབས་དག་ནི་མཁར་སྒོར་མི་སྡོད་ཅིང་། ། ན་གཞོན་རྣམས་ཀྱི་གླུ་ལེན་གར་རྩེད་མེད། །",
      "15": "ངེད་ཅག་སེམས་ཀྱི་དགའ་མགུ་ཡལ་བ་དང་། ། བྲོ་གར་འཁྲབ་པ་སྐྱོ་གདུང་རང་དུ་གྱུར། །",
      "16": "ངེད་ཀྱི་ཅོད་པན་མགོ་ནས་ས་ལ་ལྷུང་། ། སྡིག་པ་བསགས་པས་ངེད་ལ་ཆག་སྒོ་བྱུང་། །",
      "17": "དེའི་ཕྱིར་ངེད་ཀྱི་སེམས་ནི་རྒུད་པར་གྱུར། ། ངེད་ཀྱི་མིག་ཟུང་ཡང་ནི་རབ་རིབ་གྱུར། །",
      "18": "ཛ་ཡན་རི་བོ་སྟོངས་ཤིང་སྟོང་གྱུར་པས། ། ཝ་མོ་དག་ཀྱང་རི་བོའི་སྟེང་དུ་རྒྱུགས། །",
      "19": "¶ ཀྱེ་ཀྱེ་ཡ་ཝཱེ་ཁྱེད་ཉིད་གཏན་དུ་རྒྱལ་པོར་བཞུགས། ། ཁྱེད་ཀྱི་བཞུགས་ཁྲི་མི་རབས་ཀུན་ཏུ་གནས་པར་འགྱུར། །",
      "20": "ཁྱེད་ཀྱིས་ངེད་ཅག་ནམ་ཡང་བརྗེད་དོན་ཅི། ། ཁྱེད་ཀྱིས་ངེད་ཅག་ཡུན་རིང་བསྐྱུར་དོན་ཅི། །",
      "21": "ཀྱེ་ཀྱེ་ངེད་ཀྱིས་ཡ་ཝཱེ་ཁྱེད་ལ་ཞུ། ། ཁྱེད་ཀྱིས་ངེད་ཅག་ཡོངས་སུ་བསྐྱུར་བ་འམ། ། ངེད་ཕྱོགས་རབ་ཏུ་ཁྲོས་པ་མ་ཡིན་ཚེ། ། ཁྱེད་ཀྱིས་ངེད་རྣམས་ཁྱེད་ཕྱོགས་བསྐོར་བར་མཛོད། ། ངེད་རྣམས་ཁྱེད་ཕྱོགས་འཁོར་ཞིང་འཁོར་བར་ངེས། ། ངེད་ཀྱི་ཉིན་མོ་གནའ་ལྟར་མཛད་གསོལ་ལོ།། །།"
    }
  }
}
