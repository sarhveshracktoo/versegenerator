{
  "name": "ཡ་ཀོབ།",
  "id": "ཡ་ཀོབ།",
  "order": 59,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་དཀོན་མཆོག་དང་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀའི་ཞབས་ཕྱི་པ་ཡ་ཀོབ་བདག་གིས་ཐར་ཐོར་དུ་གནས་པའི་ཚོ་པ་བཅུ་གཉིས་ལ་འཕྲིན་ཡིག་སྤྲིངས་ཤིང༌། ཁྱོད་རྣམས་ལ་འཚམས་འདྲི༌ཞུའོ།།",
      "2": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་དཀའ་སྡུག་སྣ་ཚོགས་ལ་འཕྲད༌དུས། དེ་ནི་དགའ་སྤྲོ་ཆེན་པོར་བརྩི་བར་བྱའོ།།",
      "3": "ཅིའི་ཕྱིར་ཞེ་ན། རང་གི་དད་པར་ཚོད་བརྟག་བྱས་པ་བརྒྱུད་ནས་བཟོད་སེམས་འབྱུང་བ་ནི་ཁྱོད་ཅག་གིས་ཀྱང་ཤེས་པས༌སོ།།",
      "4": "ཁྱོད་ཅག་ནི་མ་ཚང་བ་མེད༌པར་ཡང་དག་པ་དང་ཕུལ་དུ་བྱུང་བར་འགྱུར་བའི་ཕྱིར། བཟོད་པའང་ཡོངས་སུ་རྫོགས་དགོས།",
      "5": "ཁྱོད་རྣམས་ལས་སུ་ཞིག་ལ་ཤེས་རབ་མི་ཚང་ན། བཀའ་བཀྱོན་མི་མཛད་ཅིང་མི་ཐམས་ཅད་ལ་གཏོང་ཕོད་ཆེ་བའི་དཀོན་མཆོག་ཁོང་ལ་ཞུས༌དང༌། ཁོང་གིས་གནང་བར་འགྱུར།",
      "6": "འོན༌ཀྱང༌། ཞུ་བ་བྱེད་པའི་དུས༌སུ། ཐེ་ཚོམ་སྤུ་ཙམ་ཡང་མེད་པར་དད་པའི་སྒོ་ནས་ཞུ་དགོས། ཅིའི་ཕྱིར་ཞེ་ན། མི་ཐེ་ཚོམ་ཅན་ནི་རྒྱ་མཚོའི་རྦ་རླབས་རླུང་གིས་དེད་ནས་དགུང་དུ་འཕྱུར་བ་དང་མཚུངས་པའི་ཕྱིར༌རོ།།",
      "7": "མི་འདི་ལྟ་བུས་གཙོ་བོ་ནས་ཅི་ཡང་འཐོབ་པར་བསམ་མི་དགོས༌ཏེ།",
      "8": "མི་བློ་གཉིས་ཅན་ནི་རང་གིས་སྒྲུབ་པའི་ལས་ཀུན་ལའང་བརྟན་པོ་མ་ཡིན་ནོ།།",
      "9": "¶ སྤུན་ཟླ་གཉོམ་ཆུང་དེ་གོ་ས་འཕར་བར་དགའ་འོས༌ཤིང༌།",
      "10": "ཕྱུག་པོ་དེ་དམན་སར་ལྷུང་བ་ལའང་དགའ་འོས༌སོ། །ཅིའི་ཕྱིར་ཞེ་ན། དེ་ནི་རྩྭ་མགོའི་མེ་ཏོག་དང་མཚུངས་པར་ཡལ་ངེས་ཏེ།",
      "11": "ཉི་མ་ཤར་བ་དང་ཚ་རླུང་གཡུགས་ནས་རྩྭ་སྔོན་སྐམས་ཤིང་མེ་ཏོག་སར་ལྷུང་བས་མཛེས་སྡུག་ཐམས་ཅད་ཡལ་བར་འགྱུར་བའི་ཕྱིར༌ཡིན། དཔེ་དེ་བཞིན་དུ་ཕྱུག་པོ་དེ་ཡང་རང་དོན་སྒྲུབ་བཞིན་པའི་སྐབས་སུ་ཉམས་པར་འགྱུར་རོ།།",
      "12": "¶ ཚོད་བགམ་ལ་བཟོད་བསྲན་ཐུབ་པའི་མི་ནི་བྱིན་རླབས་ཅན་ཡིན། ཅིའི་ཕྱིར་ཞེ་ན། ཚོད་བགམ་བྱས་པའི་རྗེས་སུ། དཀོན་མཆོག་གིས་ཁོང་ཉིད་གཅེས་པར་འཛིན་པ་རྣམས་ལ་ཞལ་བཞེས་གནང་བའི་ཚེ་སྲོག་གི་ཅོད་པན་གནང་བར་འགྱུར་བའི་ཕྱིར༌རོ།།",
      "13": "ཉམས་ཚོད་ལ་འཕྲད་པའི་དུས༌སུ། དཀོན་མཆོག་གིས་བདག་ལ་ཉམས་ཚོད་ལེན་བཞིན་གདའ་ཞེས་སུ་ཞིག་གིས་ཀྱང་སྨྲ་མི་རུང༌། ཅིའི་ཕྱིར་ཞེ་ན། ངན་པས་དཀོན་མཆོག་ལ་ཉམས་ཚོད་བྱ་མི་ནུས༌ལ། དཀོན་མཆོག་གིས་ཀྱང་སུ་ཞིག་ལའང་ཉམས་ཚོད་མི་མཛད་པས༌སོ།།",
      "14": "འོན༌ཀྱང༌། མི་རེ་རེ་རང་གི་འདོད་ཆགས་ཀྱིས་དྲངས་ཏེ་བསླུས་ན་ཉམས་ཚོད་འབྱུང་།",
      "15": "འདོད་ཆགས་མངལ་དང་ལྡན་པར་གྱུར་ན་སྡིག་པ་སྐྱེས༌ཤིང༌། སྡིག་པ་བྱས་ན་འཆི་བ་འབྱུང་ངོ་།།",
      "16": "¶ བདག་གི་སྙིང་ནས་བརྩེ་བའི་སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་བསླུ་བྲིད་འོག་ཏུ་མི་ཚུད་པར་གྱུར༌ཅིག",
      "17": "གནང་སྦྱིན་ལེགས་ཤིང་ཕུལ་དུ་བྱུང་བ་ཐམས་ཅད་ནི་སྟེང་ནས་བྱུང་བ༌དང༌། དེ་ནི་འོད་ཟེར་ཀུན་གྱི་མངའ་བདག་སྟེ་ཡབ་ལས་བྱུང༌ཞིང༌། ཁོང་ལ་འགྱུར་ལྡོག་མེད་ཅིང་འགུལ་སྐྱོད་ཀྱི་གྲིབ་མ་ཙམ་ཡང་མེད་དོ།།",
      "18": "བདག་ཅག་ནི་ཁོང་གིས་བསྐྲུན་པ་ཐམས་ཅད་ལས་ཐོག་མར་སྨིན་པའི་འབྲས་བུ་ལྟ་བུར་འགྱུར་བའི༌ཕྱིར། ཁོང་གིས་རང་ཉིད་ཀྱི་ཐུགས་དགོངས་བཞིན་བདེན་པ་ཉིད་ཀྱི་བཀའ་བརྒྱུད་ནས་བདག་ཅག་སྐྱེ་བར་མཛད་པ་ལགས༌སོ།།",
      "19": "¶ བདག་གི་སྙིང་ནས་བརྩེ་བའི་སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་གིས་ཤེས་གསལ༌ལྟར། ཁྱོད་རྣམས་མི་རེ་རེ་ནི་རྣ་བས་ཉན་པ་ལ་མྱུར་དགོས༌ཤིང༌། ངག་ནས་སྨྲ་བ་དང་སེམས་ནས་ཁྲོ་བ་ལ་དལ་དགོས་སོ།།",
      "20": "ཅིའི་ཕྱིར་ཞེ་ན། མིའི་ཁོང་ཁྲོས་དཀོན་མཆོག་གི་རྣམ་པར་དག་པའི་ལས་བསྒྲུབ་མི་ནུས་པའི་ཕྱིར༌རོ།།",
      "21": "དེ་བས་ཁྱོད་ཅག་གིས་མི་གཙང་བ་དང་ངན་པས་གང་བ་ཐམས་ཅད་སྤངས༌ཏེ། ཞི་ཞིང་དུལ་བའི་སེམས་བཅངས་ནས་ཁྱོད་ཅག་གི་ནང་དུ་བཙུགས་ཡོད་པ་དང་ཁྱོད་ཅག་གི་བླ་སྲོག་སྐྱོབ་ནུས་པའི་བཀའ་དེ་ཁས་ལེན་དགོས།",
      "22": "ཁྱོད་རྣམས་ནི་རང་མགོ་རང་གིས་གཡོག་ཅིང་བཀའ་ལ་ཉན་མཁན་ཁོ་ནར་མི་འགྱུར་བར་བཀའ་བཞིན་དུ་སྒྲུབ་མཁན་དུ་གྱུར༌ཅིག",
      "23": "རྒྱུ་མཚན་ནི་སུ་ཞིག་གིས་བཀའ་ལ་ཉན་པ་ལས་བཀའ་ལྟར་མི་སྒྲུབ་པ་ནི་མི་ཞིག་གིས་མེ་ལོང་ལས་རང་གི་ངོ་གདོང་མཐོང་བ་དང་མཚུངས༌ལ།",
      "24": "མིག་གིས་མཐོང་ཞིང་ཕར་སོང་མ་ཐག་རང་ཉིད་ཀྱི་བཞིན་རས་ཇི་འདྲ་ཡིན་པ་བརྗེད་པ་ཡིན་ནོ།།",
      "25": "འོན༌ཀྱང༌། སུ་ཞིག་གིས་ཕུལ་དུ་བྱུང་བ་དང་རང་དབང་འཐོབ་པར་བྱེད་པའི་བཀའ་ཁྲིམས་ལ་རྒྱུན་དུ་ཞིབ་ལྟ་བྱས་ནས་བརྩི་སྲུང་བྱེད་ན། བཀའ་ལ་ཉན་མ་ཐག་བརྗེད་པ་མིན་པར་དངོས་སུ་དེ་ལྟར་བསྒྲུབས༌པས། ཁོས་སྒྲུབ་པའི་དོན་ཐམས་ཅད་ལ་བྱིན་རླབས་འཐོབ་པར་འགྱུར་ངེས༌སོ།།",
      "26": "¶ གལ༌ཏེ། སུ་ཞིག་གིས་རང་ཉིད་ཆོས་སེམས་ཅན་ཡིན་པར་བསམས་ཀྱང༌། རང་གི་སྨྲ་ལྕེ་ལ་བདག་མི་བྱེད་པར། རང་མགོ་རང་གིས་གཡོག་པར་བྱེད༌ན། མི་དེའི་ཆོས་ལ་སྙིང་པོ་མེད་དོ།།",
      "27": "བདག་ཅག་གི་ཡབ་དཀོན་མཆོག་གི་སྤྱན༌སྔར། ཡང་དག་ཅིང་དྲི་མས་མ་གོས་པའི་ཆོས་ནི་དཀའ་སྡུག་གིས་ཁེངས་པའི་དྭ་ཕྲུག་དང་ཡུགས་མོ་ལ་བདག་སྐྱོང་བྱེད་པ་དང༌། འཇིག་རྟེན་གྱི་དྲི་མ་རང་ཉིད་ལ་མི་འགོས་པར་སྲུང་བ་དེའོ།།"
    },
    "2": {
      "1": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། ཁྱོད་རྣམས་ཀྱིས་བདག་ཅག་གི་གཟི་བརྗིད་ཆེ་བའི་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀ་ལ་དད་པ་བྱེད་པས་མི་གཞན་ལ་ཕྱོགས་རིས་འཛིན་མི་རུང་ངོ༌།།",
      "2": "གལ༌ཏེ། གསེར་གྱི་མཛུབ་དཀྲིས་དང་གོས་ཆེན་གྱོན་པའི་མི་ཞིག་ཁྱོད་ཅག་གི་ཚོགས་རའི་ནང་དུ་ཡོང༌བ་དང༌། གོས་ཧྲུལ་གྱོན་པའི་དབུལ་པོ་ཞིག་ཀྱང་ཡོང་བ་ཡིན༌ན།",
      "3": "ཁྱོད་ཅག་གིས་གོས་ཆེན་གྱོན་མཁན་ལ་བརྩི་མཐོང་བྱས༌ཏེ། ཁྱེད་རང་གྲལ་མགོ་ནས་བཞུགས་རོགས་མཛོད་ཅེས་སྨྲ་བ༌དང༌། དབུལ་པོ་དེ་ལ་ཁྱོད་རང་གནས་དེར་ལངས་ནས་སྡོད་ཅིག་ཅེས་སྨྲ་བའམ། ཡང་ན་བདག་གི་ཞབས་སྟེགས་ཀྱི་གམ་དུ་སྡོད་ཅིག་ཅེས་སྨྲ་བར་འགྱུར།",
      "4": "དེ་ནི་ཁྱོད་ཅག་གིས་མི་ལ་ཕྱོགས་རིས་བཟུང་ཞིང༌། ངན་སེམས་བཅངས་ནས་མི་ལ་ཁ་ཚོན་གཅོད་མཁན་དུ་གྱུར་པ་མ་ཡིན༌ནམ།",
      "5": "བདག་གི་སྙིང་ནས་བརྩེ་བའི་སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་གིས་ཉོན༌དང༌། དཀོན་མཆོག་གིས་འཇིག་རྟེན་གྱི་དབུལ་པོ་རྣམས་བདམས་ཏེ་དད་པའི་ཕྱོགས་ནས་ཕྱུག་པོར་མཛད་པར་མ༌ཟད། ཁོང་ཉིད་གཅེས་པར་འཛིན་མཁན་རྣམས་ཁོང་གིས་ཞལ་བཞེས་གནང་བའི་རྒྱལ་སྲིད་འཛིན་མཁན་དུ་བདམས་པ་མ་ཡིན༌ནམ།",
      "6": "འོན༌ཀྱང༌། ཁྱོད་ཅག་གིས་དབུལ་པོ་རྣམས་ལ་མཐོང་ཆུང་བྱས་ཤིང་། ཕྱུག་པོ་རྣམས་ཀྱིས་ཁྱོད་ཅག་ལ་གཉའ་གནོན་བྱས་ནས་ཁྲིམས་རར་འདྲུད་པ་མ་ཡིན༌ནམ།",
      "7": "ཕྱུག་པོ་རྣམས་ཀྱིས་ཁྱོད་ཅག་ལ་ཐོགས་པའི་དམ་པའི་མཚན་ལ་སྐུར་བ་བཏབ་པ་མ་ཡིན༌ནམ།",
      "8": "¶ གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། ཁྱོད་ཀྱིས་ཁྱིམ་མཚེས་ལ་རང་དང་འདྲ་བར་གཅེས་ཤིག་ཅེས་གསུངས་ཤིང་། གལ༌ཏེ། ཁྱོད་ཅག་གིས་དངོས་གནས་བླ་ན་མེད་པའི་བཀའ་ཁྲིམས་དེ་བཞིན་དུ་བྱེད༌ན། ཁྱོད་རྣམས་ཀྱིས་ལེགས་པོར་བྱས་པ་ཡིན་ནོ།།",
      "9": "འོན༌ཀྱང༌། ཁྱོད་ཅག་གིས་མི་ལ་ཕྱོགས་རིས་བཟུང་ན་དེ་ནི་སྡིག་པ་བྱས་པ་ཡིན༌ཏེ། བཀའ་ཁྲིམས་ལྟར་ཁྱོད་ཅག་ནི་བཀའ་ཁྲིམས་དང་འགལ་མཁན་དུ་བརྩིས༌སོ།།",
      "10": "ཅིའི་ཕྱིར་ཞེ་ན། སུ་ཞིག་གིས་བཀའ་ཁྲིམས་ཐམས་ཅད་བསྲུངས༌ནའང༌། དེ་ལས་གཅིག་དང་འགལ༌ན། དེ་ནི་བཀའ་ཁྲིམས་ཐམས་ཅད་ལ་འགལ་བའི་ཕྱིར༌རོ།།",
      "11": "མ་གཞི་ལོག་གཡེམ་མ་བྱེད་ཅེས་གསུང་མཁན་གྱིས་མི་མ་གསོད་ཅེས་ཀྱང་གསུངས་པ་ཡིན། ཁྱོད་ཀྱིས་ལོག་གཡེམ་མི་བྱེད་ནའང་མི་གསོད་པ་ཡིན༌ན། ཁྱོད་ནི་བཀའ་ཁྲིམས་དང་འགལ་བ་ཡིན༌ནོ།།",
      "12": "¶ མི་ལ་རང་དབང་འཐོབ་པར་བྱེད་པའི་བཀའ་ཁྲིམས་ཀྱིས་ཁྱོད་ཅག་ལ་ལེགས་ཉེས་ཀྱི་ཁྲིམས་ཐག་གཅོད༌ངེས་པས། ཁྱོད་རྣམས་ཀྱིས་ཀྱང་རང་གི་སྨྲ་བརྗོད་དང་སྤྱོད་ལམ་ནི་བཀའ་ཁྲིམས་དེ་བཞིན་དུ་བྱ་འོས་སོ།།",
      "13": "རྒྱུ་མཚན་ནི་མི་གཞན་ལ་སྙིང་རྗེ་མི་བྱེད་མཁན་ལ་སྙིང་རྗེ་མེད་པའི་ཁྲིམས་ཆད་ཕོག་པར་འགྱུར་བའི་ཕྱིར༌ཡིན། ཐུགས་རྗེ་ནི་ཉེས་ཆད་ལས་རྣམ་པར་རྒྱལ་བ་ཡིན༌ནོ།།",
      "14": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། མི་ཞིག་གིས་རང་ཉིད་ལ་དད་པ་ཡོད་ཅེས་སྨྲས༌ཀྱང༌། དེ་དང་མཐུན་པའི་སྤྱོད་བཟང་མེད༌ན། དེ་ལ་ཕན་ཐོགས་ཅི་ཡོད༌དམ། དད་པ་དེ་ལྟ་བུས་ཁོ་རང་སྐྱོབ་ནུས༌སམ།",
      "15": "གལ༌ཏེ། སྤུན་ཟླའམ་ལྕམ་སྲིང་ཞིག་ལ་གྱོན་གོས་མེད་ལ་ཉིན་རེ་བཞིན་ཁ་ཟས་ཀྱང་མེད༌ན།",
      "16": "ཁྱོད་རྣམས་ལས་གཅིག་གིས་དེ་ལ་འདི༌ལྟར། བདེ་བའི་ངང་ཕྱིར་སོང་དང༌། ཁྱོད་རང་གི་ལུས་རྒྱབ་དྲོ་ཞིང་ལྟོ་བ་འགྲང་བར་སྨོན་ཞེས་སྨྲས༌ནའང༌། མི་དེའི་ལུས་ལ་གང་ཞིག་མཁོ་བ་མ་སྦྱིན༌ཚེ། དེ་ལ་ཕན་ཐོགས་ཅི་ཡོད༌དམ།",
      "17": "དེ་བཞིན་དུ་སྤྱོད་བཟང་མེད་པའི་དད་པ་ནི་འཆི་བ་ཡིན་ནོ།།",
      "18": "¶ མི་གཞན་ཞིག་ན༌རེ། ཁྱོད་ལ་དད་པ་ཡོད་ལ། བདག་ལ་སྤྱོད་བཟང་ཡོད། ཁྱོད་ཀྱིས་བདག་ལ་སྤྱོད་བཟང་མེད་པའི་དད་པ་སྟོན༌དང༌། བདག་གིས་རང་གི་སྤྱོད་བཟང་བརྒྱུད་ནས་རང་གི་དད་པ་ཁྱོད་ལ་སྟོན་པར༌བྱའོ་ཞེས་སྨྲ་ངེས་སོ།།",
      "19": "ཁྱོད་ཀྱིས་དཀོན་མཆོག་གཅིག་རང་ཡིན་པ་ལ་དད་པ་བྱེད་པས། ཁྱོད་ཀྱི་དད་པ་དེ་ནི་ལེགས༌པོ་མ་ཡིན་ནམ། གདོན་འདྲེ་དག་གིས་ཀྱང་དཀོན་མཆོག་ལ་ཡིད་ཆེས༌བྱེད་ཀྱང༌། ཁོང་ལ་འཇིགས་ཤིང་སྐྲག་སྟེ་འདར་བ་ཡིན་ནོ།།",
      "20": "བླུན་པོ་ཁྱོད་ཀྱིས་སྤྱོད་བཟང་མེད་པའི་དད་པ་ནི་འཆི་བ་ཡིན་པ་ཤེས་འདོད༌དམ།",
      "21": "བདག་ཅག་གི་མེས་པོ་ཨབ་ར་ཧམ་གྱིས་རང་གི་བུ་ཨི་སཱག་མཆོད་ཁྲིའི་སྟེང་དུ་མཆོད་པར་ཕུལ་ཞིང༌། སྤྱོད་བཟང་དེ་ལ་བརྟེན་ནས་ཁོང་ནི་མི་རྣམ་དག་ཏུ་བརྩིས་པ་མ་ཡིན༌ནམ།",
      "22": "དད་པ་དང་སྤྱོད་བཟང་གཉིས་མཉམ་དུ་གནས་པར་མ༌ཟད། ཁོང་གི་དད་པ་ནི་སྤྱོད་བཟང་ལ་བརྟེན་ནས་ཆ་ཡོངས་སུ་རྫོགས་ཡོད་པ་རྟོགས་ནུས་སོ།།",
      "23": "གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད༌དུ། ཨབ་ར་ཧམ་གྱིས་དཀོན་མཆོག་ལ་དད་པ་བྱས་པ་དང་དཀོན་མཆོག་གིས་ཀྱང་ཁོང་ནི་མི་རྣམ་དག་ཏུ་བརྩིས་པ་ཡིན་ཞེས་གསུངས་པ་བཞིན་དུ་གྲུབ་པ༌དང༌། ཨབ་ར་ཧམ་ནི་དཀོན་མཆོག་གི་མཛའ་གྲོགས་སུ་འབོད་པར་གྱུར་ཏོ།།",
      "24": "དེའི༌ཕྱིར། མི་ཞིག་རྣམ་དག་ཏུ་བརྩི་བ་ནི་དད་པ་འབའ་ཞིག་ལ་བརྟེན་པ་མ་ཡིན་པར་སྤྱོད་བཟང་ལའང་རག་ལས་པ་རྟོགས་ནུས་སོ།།",
      "25": "དེ་བཞིན༌དུ། སྨད་འཚོང་མ་རཱ་ཧབ་ཀྱིས་བང་ཆེན་རྣམས་ལ་སྣེ་ལེན་བྱས༌ཤིང༌། ཡང་བང་ཆེན་རྣམས་ལམ་གཞན་བརྒྱུད་ནས་ཕྱིར་བཏང་བས། སྤྱོད་བཟང་ལ་བརྟེན་ནས་ཁོ་མོ་ནི་མི་རྣམ་དག་ཏུ་བརྩིས་པ་མ་ཡིན༌ནམ།",
      "26": "དེའི༌ཕྱིར། ལུས་པོ་ནི་རྣམ་ཤེས་དང་ཁ་བྲལ་ན་བེམ་པོ་ཡིན་པ༌བཞིན། དད་པའང་སྤྱོད་བཟང་དང་ཁ་བྲལ་ན་འཆི་བ་ཡིན༌ནོ།།"
    },
    "3": {
      "1": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། ངེད་ཅག་ལ་མི་གཞན་ལས་ལེགས་ཉེས་ཀྱི་ཁྲིམས་ཐག་ལྷག་པར་ནན་མོ་གཅོད་ངེས༌པས། ཁྱོད་རྣམས་ལས་མི་མང་པོ་ཞིག་སློབ་དཔོན་བྱེད་པར་མི༌བྱའོ།།",
      "2": "མ་གཞི་བདག་ཅག་ལ་ལས་སྣ་ཚོགས་ཀྱི་ཆ་ནས་ནོར་འཁྲུལ་ཡོད་པ་ཡིན། གལ༌ཏེ། སུ་ཞིག་ལ་སྨྲ་བརྗོད་ཀྱི་ཆ་ནས་ནོར་འཁྲུལ་མེད༌ན། མི་དེ་ནི་ཕུལ་དུ་བྱུང་ཞིང་རང་ལུས་ཧྲིལ་པོའང་གཅུན་ནུས་སོ།།",
      "3": "བདག་ཅག་གིས་རྟ་རྒོད་འདུལ་བའི་ཆེད་དུ་རྟའི་ཁ་ནང་དུ་ལྕགས་བཞག་པ་ན་དེའི་ལུས་ཧྲིལ་པོར་ཁ་ལོ་བསྒྱུར་ནུས༌པ་ཡིན།",
      "4": "ལྟོས༌དང༌། གྲུ་གཟིངས་ནི་ཤིན་ཏུ་ཆེ་ཞིང་རླུང་ཆེན་དྲག་པོས་དེད༌ཀྱང༌། དེད་དཔོན་གྱིས་གྲུ་སྐྱ་ཆུང་ངུར་བརྟེན་ནས་གང་དུ་སྐྱོད་འདོད་པ་བཞིན་གྲུ་གཟིངས་ལ་ཁ་ལོ་བསྒྱུར་ནུས་སོ།།",
      "5": "དེ་བཞིན༌དུ། ལྕེ་ནི་ལུས་ཀྱི་ཆ་ཤས་ཆུང་ངུ་ཞིག་ཡིན༌ཡང༌། ལྕེ་ཡིས་ཁ་ཕོ་ཆེན་པོ་སྨྲ་བར་བྱེད། ལྟོས༌དང༌། མེ་ལྕེ་ཆུང་ངུ་ཞིག་གིས་ནགས་ཚལ་ཆེན་པོ་བསྲེག་ནུས་པ་ཡིན།",
      "6": "ལྕེ་ནི་མེ་ཡིན༌ཏེ། སྡིག་པས་ཁེངས་པའི་འཇིག་རྟེན་ཞིག་ཀྱང་ཡིན༌ལ། བདག་ཅག་གི་ལུས་ཀྱི་ཆ་ཤས་གཞན་དག་ཁྲོད་ནས་མིའི་ལུས་ཧྲིལ་པོ་མི་གཙང་བར་བྱེད༌ཅིང༌། བདེ་སྐྱིད་ཀྱི་འཚོ་བ་ཡོངས་སུ་བསྲེགས་པར་མ༌ཟད། དམྱལ་བའི་གནས་ལས་ཀྱང་བསྲེག་པར་འགྱུར༌རོ།།",
      "7": "རི་དྭགས༌དང༌། འདབ༌ཆགས། ལྟོ་འགྲོའི༌རིགས། རྒྱ་མཚོའི་སྲོག་ལྡན་ཐམས་ཅད་མི་ཡིས་འདུལ་ནུས་ཤིང་བཏུལ་བའང་ཡིན༌མོད།",
      "8": "འོན་ཀྱང་སྨྲ་ལྕེ་འདུལ་ཐུབ་མཁན་གཅིག་ཀྱང་མེད༌ལ། དེ་ནི་རྒྱུན་ཆད་མེད་པར་འབྱུང་བའི་ནག་ཉེས༌དང༌། འཆི་ལམ་དུ་གཏོད་བྱེད་དུག་གི་རླངས་པས་ཁྱབ་པ་ཞིག༌ཡིན།",
      "9": "བདག་ཅག་གིས་ལྕེ་ལ་བརྟེན་ནས་གཙོ་བོ་དང་ཡབ་ལ་བསྟོད་བསྔགས་བརྗོད༌ཅིང༌། ཡང་ལྕེ་ལ་བརྟེན་ནས་དཀོན་མཆོག་གི་སྣང་བརྙན་བཞིན་དུ་བཟོས་པའི་མི་རྣམས་ལ་སྡིགས་དམོད་བྱེད།",
      "10": "ཁ་གཅིག་ལས་བསྔགས་བརྗོད་དང་སྡིགས་དམོད་གཉིས་ཀ་འོང་བ་ཡིན། བདག་གི་སྤུན་ཟླ༌རྣམས། དོན་འདི་ནི་མི་འོས་སོ།།",
      "11": "ཆུ་མིག་གཅིག་ལས་ཆུ་མངར་མོ་དང་ཁ་ཏིག་གཉིས་ཀ་འབྱུང་སྲིད༌དམ།",
      "12": "བདག་གི་སྤུན་ཟླ༌རྣམས། བསེ་ཡབ་ཤིང་ལས་སྐྱུ་རུ་རའི་ཤིང་ཏོག་འབྱུང་སྲིད༌དམ། རྒུན་འབྲུམ་ཤིང་ལས་བསེ་ཡབ་ཀྱི་ཤིང་ཏོག་འབྱུང་སྲིད༌དམ། ཚྭ་ཆུ་ལས་ཆུ་མངར་མོ་འབྱུང་སྲིད་དམ་ཞེ་ན་མི་སྲིད་དོ།།",
      "13": "¶ ཁྱོད་ཅག་གི་ཁྲོད་དུ་སུ་ཞིག་མི་ཤེས་རབ་ཅན་དང་ཐོས་རྒྱ་ཅན་ཡིན༌ན། མི་དེས་སྤྱོད་ལམ་བཟང་པོའི་སྒོ་ནས་རང་གི་ལས་དེ་རྣམས་ཤེས་རབ་དང་ཞི་ཞིང་དུལ་བའི་ངང་སྟོན་པར་བྱ་དགོས་སོ།།",
      "14": "ཁྱོད་རྣམས་ཀྱི་སེམས་སུ་ཕྲག་དོག་ཁ་ཏིག་ཅན་དང་སྒེར་སེམས་ཡོད༌ན། རང་བསྟོད་མི་བྱེད༌ཅིང་། བདེན་པ་ཉིད་ལ་རྫུན་ཡང་སྨྲ་བར་མི༌བྱའོ།།",
      "15": "ཤེས་རབ་དེ་ལྟ་བུ་ནི་སྟེང་ནས་བྱུང་བ་མ་ཡིན༌པར། དེ་ནི་འཇིག་རྟེན༌དང༌། ཤ་ཁྲག གདོན་འདྲེ་བཅས་ཀྱི་རིགས་སུ་གཏོགས།",
      "16": "གནས་གང་དུ་ཕྲག་དོག་དང་སྒེར་སེམས་ཡོད༌ན། གནས་དེ་རུ་ཟིང་འཁྲུག་དང་ལས་ངན་པ་སྣ་ཚོགས་ཡོད་པ་ཡིན༌ནོ།།",
      "17": "¶ འོན༌ཀྱང༌། སྟེང་ནས་བྱུང་བའི་ཤེས་རབ་ནི་ཐོག་མར་ཡང་དག་པ་དང་ཕྱི་མར་ཞི་ཞིང་དུལ་བ། དེ་ནས་གཤིས་རྒྱུད་འཇམ༌པ། གནས་ལུགས་བརྩི་བ། སྙིང་རྗེ་དང་འབྲས་བུ་བཟང་པོས་ཁེངས་ཡོད་པ། ཕྱོགས་རིས་མེད༌པ། ཚུལ་འཆོས་མེད་པ་བཅས་ཡིན་ནོ།།",
      "18": "གཞན་ཡང༌། དྲང་བདེན་གྱི་འབྲས་བུ་ནི་འདུམ་སྒྲིག་པ་རྣམས་ཀྱིས་ཞི་བདེའི་ངང་ནས་འདེབས༌པའོ།།"
    },
    "4": {
      "1": "¶ ཁྱོད་ཅག་ཁྲོད་ཀྱི་འཁོན་འཛིང་དང་འཁྲུག་རྩོད་ནི་གང་ནས་བྱུང༌ངམ། དེ་ནི་ཁྱོད་རྣམས་ཀྱི་རྒྱུད་དུ་ཡོད་པའི་འཁྲུག་རྩོད་ཀྱི་འདོད་ཆགས་ལས་བྱུང་བ་མ་ཡིན༌ནམ།",
      "2": "ཁྱོད་ཅག་འདོད་རྔམ་ཆེ་ཡང་ཅི་ཡང་མ་ཐོབ༌པས། ཁྱོད་རྣམས་ཀྱིས་མི་གསོད་པ་ཡིན། ཁྱོད་རྣམས་ཀྱིས་བརྣབ་སེམས་བྱེད་ཀྱང་ཅི་ཡང་མ་ཐོབ་པས། འཁྲུག་རྩོད་དང་འཁོན་འཛིང་བྱེད་པ་ཡིན། ཁྱོད་ཅག་གིས་དཀོན་མཆོག་ལ་ཞུ་བ་མི་བྱེད་པས་ཁྱོད་རྣམས་ལ་ཅི་ཡང་མ་ཐོབ།",
      "3": "ཁྱོད་ཅག་གིས་རང་རང་གི་འདོད་པ་ལྟར་ཆུད་ཟོས་སུ་གཏོང་བའི་ཕྱིར། ཀུན་སློང་ངན་པས་དཀོན་མཆོག་ལ་ཞུ་བ་ཞུས་ཀྱང་ཅི་ཡང་མ་ཐོབ༌བོ།།",
      "4": "¶ ཀྱེ། ལོག་གཡེམ་པ༌རྣམས། འཇིག་རྟེན་གྲོགས་སུ་གྱུར་པ་ནི་དཀོན་མཆོག་གི་དགྲ་རུ་ལངས་པ་མི་ཤེས༌སམ། དེའི་ཕྱིར། སུ་ཞིག་འཇིག་རྟེན་གྱི་གྲོགས་སུ་འགྱུར་འདོད་ན་དེ་ནི་དཀོན་མཆོག་གི་དགྲ་རུ་ལངས་པ་ཡིན་ནོ།།",
      "5": "གསུང་རབ་ཀྱི་མདོ་ལས་ཇི་སྐད་དུ། དཀོན་མཆོག་ནི་བདག་ཅག་གི་རྒྱུད་དུ་བཞུགས་པར་མཛད༌པའི་ཐུགས་ཉིད་ལ་ཤིན་ཏུ་དུངས་ཞིང་ཕྲག་དོག་སྐྱེས་པའི་ཚད་དུ་སླེབས་པ་ཡིན་ཞེས་གསུངས་པ་དེ་ནི་ཁྱོད་རྣམས་ཀྱིས་དོན་མེད་པར་འདོད༌དམ།",
      "6": "འོན༌ཀྱང༌། དཀོན་མཆོག་གིས་བདག་ཅག་ལ་དེ་ལས་ལྷག་པའི་ཐུགས་རྗེ་ཆེན་པོ་གནང༌བས། ཇི་སྐད༌དུ། དཀོན་མཆོག་ཉིད་ཀྱིས་ང་རྒྱལ་ཅན་ལ༌རྒོལ།། ཁེངས་སྐྱུང་མི་ལ་ཁོང་གིས་ཐུགས་རྗེ༌གནང༌། །ཞེས་གསུངས༌པའོ།།",
      "7": "¶ དེའི༌ཕྱིར། ཁྱོད་ཅག་གིས་དཀོན་མཆོག་ལ་བསྟུན་དགོས་སོ།། བདུད་ལ་རྒོལ་བར་གྱིས༌དང༌། བདུད་ནི་ཁྱོད་ཅག་དང་བྲལ་ནས་འབྲོ་བར༌ངེས།",
      "8": "ཁྱོད་རྣམས་དཀོན་མཆོག་དང་ཉེ་བར་གཅོར་ཅིག ཁོང་ཡང་ཁྱོད་རྣམས་དང་ཉེ་བར་གཅར་ངེས་ཡིན། སྡིག་ཅན་ཁྱོད་ཅག་གིས་རང་གི་ལག་པ་གཙང་མར་ཁྲུས༌དང༌། བློ་གཉིས་འགལ་ཅན་ཁྱོད་རྣམས་ཀྱིས་རང་གི་སེམས་གཙང་མར་ཁྲུས༌ཤིག",
      "9": "ཁྱོད་རྣམས་ཀྱིས་ཡིད་སྐྱོ་བ་དང་མྱ་ངན་བྱས་ནས་ངུ་བར༌གྱིས་ཤིག རང་གི་དགོད་སྒྲ་ནི་སྡུག་བསྔལ༌དང༌དགའ་སྤྲོ་ནི་སྐྱོ་གདུང་དུ་སྒྱུར༌ཅིག",
      "10": "ཁྱོད་ཅག་གིས་གཙོ་བོའི་སྤྱན་སྔར་དམན་སེམས་བཅང་དགོས་པ་དང་། ཁོང་གིས་ཀྱང་ཁྱོད་རྣམས་མཐོན་པོར་བསྒྲེང་ངེས་སོ།།",
      "11": "¶ སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་གིས་ཕན་ཚུན་ལ་ཚིག་ངན་སྨྲ་བར་མི༌བྱའོ།། སུ་ཞིག་གིས་སྤུན་ཟླ་ལ་ཚིག་ངན་སྨྲ་ཞིང་ཁ་ཚོན་གཅོད་ན། དེ་ནི་བཀའ་ཁྲིམས་ལ་ཚིག་ངན་སྨྲས་ཤིང་ཁ་ཚོན་བཅད་པ་ཡིན། སུ་ཞིག་གིས་བཀའ་ཁྲིམས་ལ་ཁ་ཚོན་བཅད༌ན། དེ་ནི་བཀའ་ཁྲིམས་སྲུང་མཁན་མ་ཡིན་པར། བཀའ་ཁྲིམས་ཀྱི་ཁྲིམས་དཔོན་ཡིན་ཏེ།",
      "12": "མ་གཞི་བཀའ་ཁྲིམས་གནང་མཁན་དང་ཁྲིམས་དཔོན་ཆེན་པོ་གཅིག་ཁོ་ན་སྟེ། ཁོང་ནི་འཇིག་རྟེན་གྱི་མི་རྣམས་སྐྱོབ་ནུས་ཤིང་འཇོམས་ཡང་ནུས་པ་དེ་ཉིད་ལགས་སོ།། འོན༌ཀྱང༌ཁྱོད་ཀྱིས་རང་གི་ཁྱིམ་མཚེས་ལ་ཁ་ཚོན་གཅོད་པས་ཁྱོད་ནི་སུ་ཞིག་ཡིན་འདོད༌དམ།",
      "13": "¶ ཉོན༌དང༌། ཁྱོད་ཅག་ལས་མི་འགའ་ཞིག་ན༌རེ། དེ་རིང་ངམ་སང་ཉིན་ངེད་ཅག་གྲོང་ཁྱེར་ག་གེ་མོ་ཞིག་ལ་སོང་ནས་ལོ་གཅིག་རིང་བསྡད༌དེ། ཚོང་ལས་བྱས་ནས་ཁེ་སྤོགས་ལེན་པར་བྱའོ་ཞེས༌སྨྲ་བ་ཡིན།",
      "14": "དོན་དམ་དུ་སང་ཉིན་དོན་ཅི་ཞིག་འབྱུང་བ་ནི་ཁྱོད་ཅག་གིས་མི་ཤེས། ཁྱོད་ཅག་གི་ཚེ་སྲོག་ནི་ཅི་ཞིག་ཡིན༌ནམ། མ་གཞི་ཁྱོད་ཅག་ནི་སྨུག་པ་ལྟ་བུ་ཡིན་པས་ཡུད་ཙམ་གྱིས་ཡལ་བར་འགྱུར།",
      "15": "དེ་ལས་ལྡོག་སྟེ། ཁྱོད་ཅག་གིས་གཙོ་བོ་ཐུགས་མཉེས་ན། བདག་ཅག་གསོན་པོར་གནས༌ཤིང༌། བདག་ཅག་གིས་དོན་འདི་དང་འདི་ཟེར་བ་ཞིག་བསྒྲུབ་ནུས་པ་ཡིན་ཞེས་སྨྲས་ན་ལེགས་སོ།།",
      "16": "འོན༌ཀྱང༌། ད་ལྟ་ཁྱོད་རྣམས་ཀྱིས་ང་རྒྱལ་བཅངས་ནས་ཁ་ཕོ་བྱེད་པས། དེ་ལྟར་ཁ་ཕོ་བྱེད་པ་ཐམས་ཅད་ནི་ངན་པ་ཡིན།",
      "17": "དེ་བས་སུ་ཞིག་གིས་ལས་བཟང་པོ་བསྒྲུབ་དགོས་པ་ཤེས་བཞིན་དུ་དེ་ལྟར་མི་བྱེད༌ན། མི་དེས་སྡིག་པ་བྱས་པའོ།།"
    },
    "5": {
      "1": "¶ ཀྱེ། ཁྱོད་ཅག་ཕྱུག་པོ་རྣམས་ཀྱིས་ཉོན༌ཅིག ཁྱོད་ཅག་ལ་སྡུག་བསྔལ་འབྱུང་ངེས་པའི༌ཕྱིར། ཁྱོད་རྣམས་ངུས་ཤིང་ངུ་འབོད་བྱེད་པར༌གྱིས།",
      "2": "ཁྱོད་ཅག་གི་རྒྱུ་ནོར་ཟད་ཅིང་གྱོན་གོས་འབུ་ཡིས་ཟོས་སོ།།",
      "3": "ཁྱོད་ཅག་གི་གསེར་དངུལ་བཙའ་ཡིས་ཟོས༌ཤིང༌། བཙའ་ཡིས་ཁྱོད་ཅག་གི་ཉེས་སྐྱོན་ལ་དཔང་པོ་བྱེད་པ༌དང༌། མེ་ཡིས་བསྲེགས་པ་བཞིན་ཁྱོད་ཅག་གི་ལུས་པོ་ནི་བཟའ་བར་འགྱུར། ཁྱོད་ཅག་གིས་མཐའ་མའི་ཉིན་མོ་དག་ལ་ཡང་ནོར་རྫས་བསགས་པ་ཡིན་ནོ།།",
      "4": "ལྟོས༌དང༌། གླ་བ་རྣམས་ཀྱིས་ཁྱོད་ཅག་ལ་ཞིང་བྲེགས་ནའང་གླ་ཆ༌ཆད་པས། གླ་ཆ་ཡིས་འབོད་སྐད་སྒྲོག༌ཅིང༌། ཞིང་འབྲེག་མཁན་རྣམས་ཀྱི་ངུ་འབོད་ནི་སྔར་ནས་དཔུང་ཚོགས་ཀུན་གྱི་གཙོ་བོའི་སྙན་ལམ་དུ་སླེབས་པ་ཡིན།",
      "5": "ཁྱོད་རྣམས་ཀྱིས་འཇིག་རྟེན་དུ་འདོད་ཡོན་ལོངས་སུ་སྤྱད་དེ་བདེ་བའི་འཚོ་བ་རོལ་བའོ།། འོན༌ཀྱང༌། ཁྱོད་རྣམས་ཀྱིས་ཉེས་ཆད་གཅོད་པའི་ཉིན་མོའི་ཆེད༌དུ། རང་གིས་རང་ཉིད་ངན་ལང་དུ་གཏོང༌བ་ཡིན།",
      "6": "ཁྱོད་ཅག་གིས་མི་གཞུང་དྲང་ལ་ཉེས་པ་བཙུགས་ནས་བསད་ཀྱང་དེས་ཁྱོད་རྣམས་ལ་ངོ་རྒོལ་མ་བྱས་སོ།།",
      "7": "¶ སྤུན་ཟླ༌རྣམས། དེ་ལྟར་ཡིན་པས། ཁྱོད་ཅག་གིས་གཙོ་བོ་ཕེབས་ཡོང་བའི་བར་དུ་བཟོད་བསྲན་བྱེད་པར་གྱིས། ཞིང་པས་ཇི་ལྟར་ས་ཞིང་ནས་རྨད་དུ་བྱུང་བའི་འབྲས་བུ་འཐོབ་པའི་ཆེད༌དུ། སྟོན་ཆར་དཔྱིད་ཆར་འབབ་པར་བཟོད་བསྲན་གྱིས་སྒུག་པར་ལྟོས༌དང༌།",
      "8": "གཙོ་བོ་ཕེབས་ཡོང་བའི་དུས་དེ་ཉེ་བར་སླེབས༌པས། ཁྱོད་རྣམས་ཀྱིས་ཀྱང་ངང་རྒྱུད་རིང་ཞིང་ཡིད་སེམས་བརྟན་པོས་སྒུག་པར་བྱའོ།།",
      "9": "སྤུན་ཟླ༌རྣམས། ཁྱོད་ཅག་ལ་ཉེས་ཆད་མི་འཕོག་པའི༌ཕྱིར། ཁྱོད་རྣམས་ཀྱིས་ཕན་ཚུན་ལ་འཁང་ར་མ་བྱེད༌ཅིག ལྟོས༌དང༌། ཁྲིམས་དཔོན་ཆེན་པོ་དེ་ཉིད་སྒོ་མདུན་དུ་བཞེངས་འདུག་པའོ།།",
      "10": "¶ སྤུན་ཟླ༌རྣམས། སྔོན་ཆད་གཙོ་བོའི་མཚན་གྱི་སྒོ་ནས་བཀའ་གསུངས་པའི་ལུང་སྟོན་པ་རྣམས་ཀྱིས་སྡུག་བསྔལ་མྱོང་ཐུབ་པ་དང་བཟོད་བསྲན་བྱ་ནུས་པ་དེ་ཁྱོད་ཅག་གིས་མིག་དཔེ་རུ་འཛིན་པར་གྱིས།",
      "11": "བདག་ཅག་གིས་སྔོན་ཆད་བཟོད་བསྲན་བྱས་མྱོང་བ་དག་ནི་མི་བྱིན་རླབས་ཅན་དུ་བརྩིས༌པ་དང་། ཁྱོད་རྣམས་ཀྱིས་ཨེས་ཡོབ་ཀྱི་སྙིང་རུས་ནི་ཅི་ལྟ་བུ་ཞིག་ཡིན་པ་ཐོས་མྱོང༌ཞིང༌། གཙོ་བོས་ཁོ་རང་ལ་མཐའ་འབྲས་ཅི་གནང་བའང་ཤེས༌ཏེ། གཙོ་བོ་ནི་བྱམས་སྙིང་རྗེ་དང་ཐུགས་རྗེ་ཆེན་པོ་ཅན་ཡིན་པ་རྟོགས༌སོ།།",
      "12": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། ཆེས་གལ་ཆེ་བ་ནི་མནའ་བསྐྱལ་མི་རུང་བ་དེ་ཡིན་ནོ།། ནམ་མཁའི་ཞིང་ཁམས་དཔང་དུ་བཙུགས་ནས་མནའ་བསྐྱལ་མི་རུང༌ལ། ས་གཞི་དཔང་དུ་བཙུགས་ནས་ཀྱང་མནའ་བསྐྱལ་མི་རུང་། ཅིས་ཀྱང་མནའ་བསྐྱལ་མི་རུང༌། ཁྱོད་ཅག་ཉེས་ཆད་འོག་ཏུ་མི་ལྷུང་བའི༌ཕྱིར། ཁྱོད་རྣམས་ཀྱིས་ཕན་ཚུན་ལ་གཏམ་སྨྲ་བའི་ཚེ། ཡིན་ན་ཡིན་དང༌། མིན་ན་མིན་ཞེས་སྨྲ་བར་བྱའོ།།",
      "13": "¶ ཁྱོད་རྣམས་ལས་སུ་ཞིག་གིས་སྡུག་བསྔལ་མྱོང་བ་ཡིན༌ན་དཀོན་མཆོག་ལ་གསོལ་བ་འདེབས་འོས་སོ།། སུ་ཞིག་ལ་དགའ་སྤྲོ་ཡོད༌ན་དཀོན་མཆོག་ལ་བསྟོད་དབྱངས་འབུལ་དགོས་སོ།།",
      "14": "ཁྱོད་རྣམས་ལས་སུ་ཞིག་ལ་ན་ཚ་བྱུང༌ན། ཆོས་ཚོགས་ཀྱི་རྒན་པོ་རྣམས་བོས༌ཏེ། ཁོང་རྣམས་ཀྱིས་གཙོ་བོའི་མཚན་གྱི་སྒོ་ནས་ནད་པ་དེ་ལ་སྣུམ་གྱིས་བྱུགས་ནས་གསོལ་བ་འདེབས་དགོས་ལ།",
      "15": "རྒན་པོ་རྣམས་ཀྱིས་དད་པའི་སྒོ་ནས་གསོལ་བ་བཏབ་སྟེ་ནད་པ་གསོ་བར་བྱེད༌ཅིང༌། གཙོ་བོས་ནད་པ་དེ་ཡར་བསླང་བར་མ༌ཟད། ནད་པ་དེས་སྡིག་པ་བྱས་ཡོད་ན་སྡིག་པའང་བསལ་ངེས༌སོ།།",
      "16": "དེ་བས་ཁྱོད་ཅག་གིས་རང་རང་གི་སྡིག་ཉེས་ཕན་ཚུན་ལ་ཁས་ལེན་ཞིང༌། ཕན་ཚུན་གྱི་ཆེད་དུ་དཀོན་མཆོག་ལ་གསོལ་བ་བཏབ་ན་ཁྱོད་རྣམས་སོས་པར༌འགྱུར། མི་གཞུང་དྲང་གི་སྨོན་ལམ་ལ་ཕན་ནུས་ཆེན་པོ་ལྡན༌ནོ།།",
      "17": "¶ ཨེ་ལི་ཡཱ་ནི་བདག་ཅག་དང་རང་གཤིས་གཅིག་མཚུངས་ཡིན༌ལ། ཁོང་གིས་ཆར་བ་མི་འབབ་པའི་ཕྱིར། བློ་སེམས་རྩེ་གཅིག་གིས་གསོལ་བ་བཏབ་པ༌ན། ལོ་གསུམ་དང་ཕྱེད་ཀའི་རིང་ས་ལ་ཆར་བ་མ་བབས་སོ།།",
      "18": "ཡང་ཁོང་གིས་གསོལ་བ་བཏབ་པ༌ན། གནམ་ནས་ཆར་བ་བབས་ཤིང་ས་ནས་ལོ་ཏོག་སྐྱེས༌སོ།།",
      "19": "¶ བདག་གི་སྤུན་ཟླ༌རྣམས། ཁྱོད་རྣམས་ལས་མི་ཞིག་བདེན་པ་ཉིད་དང་ཁ་བྲལ་བ༌དང༌། གཞན་ཞིག་གིས་མི་དེ་ཕྱིར་ཁྲིད་ཡོང་བ་ཡིན༌ན།",
      "20": "ཕྱིར་ཁྲིད་མཁན་གྱི་མི་དེས་མི་སྡིག་ཅན་ཞིག་ལོག་ལམ་ནས་ཕྱིར་ཁྲིད་ཡོང་བ༌དང༌། མི་དེ་འཆི་བ་ལས་བསྐྱབས་པར་མ༌ཟད། མི་དེའི་སྡིག་པ་མང་པོའང་བསལ་བའི་རྒྱུ་རུ་འགྱུར་བར་ཤེས་འོས་སོ།། །།"
    }
  }
}
