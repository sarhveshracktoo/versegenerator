{
  "name": "ཨེས་སི་ཐེར།",
  "id": "ཨེས་སི་ཐེར།",
  "order": 17,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་དོན་འདི་ནི་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡི་དུས་སྐབས་སུ་བྱུང་བ་ཡིན་ལ། ཨ་ཧཱ་ཝེ་རོ་ཡིས་རྒྱ་གར་ནས་གུ་ཤ་བྱ་བའི་ཡུལ་གྱི་བར་དུ་ལྗོངས་བརྒྱ་དང་ཉེར་བདུན་ལ་དབང་བྱས་པ་ཡིན།",
      "2": "ཁོང་ཉིད་སོའུ་སཱན་མཁར་ཆེན་གྱི་རྒྱལ་ཁྲིའི་སྟེང་དུ་བཞུགས་པའི་དུས་ཏེ།",
      "3": "ཁོང་གིས་རྒྱལ་སྲིད་སྐྱོང་བའི་ལོ་གསུམ་པ་ལ། དཔོན་རིགས་དང་འཁོར་གཡོག་ཐམས་ཅད་ལ་གསོལ་སྟོན་བཤམས་ཤིང་། ཏ་ཟིག་དང་མཱ་ཏི་ཡུལ་གྱི་དམག་དཔོན་རྣམས་དང་། ལྗོངས་སོ་སོའི་སྐུ་དྲག་དང་འགོ་དཔོན་བཅས་ཐམས་ཅད་ཁོང་གི་དྲུང་དུ་འཛོམས་པ་རེད།",
      "4": "རྒྱལ་པོས་རང་གི་རྒྱལ་སྲིད་ཀྱི་རྒྱུ་འབྱོར་བའི་གཟི་དཔལ་དང་། རང་གི་བརྗིད་ཉམས་རབ་ཏུ་འཕགས་པ་རྣམས་ཁོ་རྣམས་ལ་ཉིན་མང་པོར་བསྟན་ཞིང་བསྡོམས་པས་ཉིན་བརྒྱ་དང་བརྒྱད་ཅུའོ། །",
      "5": "¶ དུས་དེ་རྫོགས་ནས་རྒྱལ་པོས་སོའུ་སཱན་མཁར་ཆེན་དུ་གནས་པའི་མི་མཆོག་དམན་ཐམས་ཅད་ལ་ཕོ་བྲང་གི་སྐྱེད་ཚལ་ཐང་ནས་ཉིན་བདུན་ལ་གསོལ་སྟོན་བཤམས་སོ། །",
      "6": "དེར་གོས་ཡུག་དཀར་ལྗང་སྔོ་གསུམ་ལ་རས་རྒྱ་སྨུག་དང་སོ་རས་གཉིས་མཉམ་སྦྲེལ་གྱི་ཐག་པས་དངུལ་གྱི་ཨ་ལོང་ལ་བཏགས་ཏེ་རྡོ་ཀ་མ་རུའི་ཀ་ཆེན་རྣམས་ལ་མདུད་ཡོད་ཅིང་། གསེར་དངུལ་གྱི་འབོལ་ཁྲི་རྣམས་རྡོ་ཀ་མ་རུ་དཀར་དམར་སེར་ནག་བཅས་ཀྱིས་གྲུབ་པའི་པང་གཅལ་སྟེང་དུ་བཀྲམས་པའོ། །",
      "7": "རྒུན་ཆང་འབུལ་བྱེད་ཀྱི་གསེར་ཕོར་རྣམས་ནི་རེ་རེ་མི་འདྲ་ཞིང་། རྒུན་ཆང་ཧ་ཅང་མོད་པོ་ཡོད་པ་དེས་རྒྱལ་པོ་གཏོང་ཕོད་ཆེ་བ་ཡོངས་སུ་མཚོན་པ་རེད།",
      "8": "ཡང་རྒུན་ཆང་འཐུང་བར་ལུགས་སྲོལ་ཡོད་ལ་ནན་གྱིས་བཏང་མི་ཆོག་པ་སྟེ། རྒྱལ་པོས་རང་གི་ཕོ་བྲང་གི་ལས་སྣེ་པ་རྣམས་ལ། མི་རེ་རེར་རང་རང་གི་འདོད་པ་བཞིན་སྤྱོད་དུ་འཇུག་དགོས་པའི་བཀའ་གནང་བས་སོ། །",
      "9": "¶ རྒྱལ་མོ་ཝཱ་སི་ཏི་ཡིས་ཀྱང་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡི་ཕོ་བྲང་ནང་དུ་བུད་མེད་རྣམས་ལ་གསོལ་སྟོན་བཤམས་ཤིང་།",
      "10": "ཉིན་བདུན་པ་ལ་རྒྱལ་པོའི་ཐུགས་ནི་རྒུན་ཆང་གིས་སྤྲོ་བར་གྱུར་པའི་ཚེ། ཁོང་གིས་རང་ཉིད་ཀྱི་དྲུང་དུ་ཞབས་ཕྱི་བྱེད་པའི་མེ་ཧུ་མན་དང་པིས་ཐཱ། ཧར་པོ་ནཱ། པིག་ཐཱ། ཨ་བག་ཐཱ། ཙེ་ཐར། ཀར་ཀ་སི་བཅས་ཉུག་རུམ་པ་བདུན་ལ།",
      "11": "རྒྱལ་མོ་ཝཱ་སི་ཏི་ཡིས་རྒྱལ་མོའི་ཅོད་པན་གསོལ་ནས་རྒྱལ་པོའི་མདུན་དུ་ཡོང་དགོས་པའི་བཀའ་གནང་སྟེ། དེ་ནི་ཁོ་མོ་བྱད་གཟུགས་ཡིད་དུ་འོང་བ་ཞིག་ཡིན་པས། མི་རིགས་སོ་སོའི་ཡུལ་མི་དང་ས་གནས་དཔོན་རིགས་རྣམས་ལ་ཁོ་མོའི་བཞིན་རས་སྟོན་པའི་ཕྱིར་ཡིན་ནོ། །",
      "12": "འོན་ཀྱང་ཁོ་མོ་ཉུག་རུམ་པ་རྣམས་ཀྱིས་སྦྲན་པའི་རྒྱལ་པོའི་བཀའ་བཞིན་མ་འོངས་པས། རྒྱལ་པོ་ཤིན་ཏུ་ཁྲོས་ནས་ཞེ་སྡང་གི་མེ་ལྕེ་འབར་བར་གྱུར་ཏོ། །",
      "13": "¶ རྒྱལ་པོའི་ལུགས་སྲོལ་ལྟར་ན། དོན་ཐམས་ཅད་བསྒྲུབ་པར་སྔོན་ལ་ཁྲིམས་སྲོལ་དང་བཀའ་རྒྱ་ཤེས་པའི་མི་ལ་བློ་འདྲི་བ་ཡིན། སྐབས་དེར་རྒྱལ་པོས་དུས་སྐར་ཤེས་པའི་མཁས་པ་རྣམས་དང་གྲོས་བཏབ་སྟེ།",
      "14": "དེ་དག་ནི་ཀར་ཤེ་ནཱ་དང་སི་ཐཱར། ཨད་མ་ཐཱ། ཐཱར་ཞིས། མེ་རེས། མཱར་སེ་ནཱ། མེ་མུ་ཀན་བཅས་ཏ་ཟིག་དང་མཱ་ཏི་ཡུལ་གྱི་བློན་ཆེན་བདུན་པོ་དེ་ཡིན་ཞིང་། རྟག་ཏུ་རྒྱལ་པོའི་ཞལ་མཇལ་མཁན་དང་། རྒྱལ་ཁམས་ཀྱི་ནང་དུ་གྲལ་མགོ་འཛིན་མཁན་ཡང་ཡིན་ནོ། །",
      "15": "རྒྱལ་པོས་དེ་རྣམས་ལ། རྒྱལ་མོ་ཝཱ་སི་ཏི་ལ་ཉུག་རུམ་པ་ཚོས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་བཀའ་སྦྲན་ཀྱང་ཉན་མ་བྱུང་བས། ཁྲིམས་སྲོལ་ལྟར་ན་ད་ནི་ཅི་བྱེད་པར་རིགས་སམ་ཞེས་གསུངས་པ་དང་།",
      "16": "མེ་མུ་ཀན་གྱིས་རྒྱལ་པོ་དང་ས་གནས་དཔོན་པོ་རྣམས་ཀྱི་མདུན་དུ་འདི་ལྟར། རྒྱལ་མོ་ཝཱ་སི་ཏི་ཡི་བྱ་སྤྱོད་འདི་ནི་རྒྱལ་པོ་དང་འགལ་བར་མ་ཟད། རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་ལྗོངས་སོ་སོའི་དཔོན་འབངས་སྤྱི་ལའང་གནོད་པར་འདུག",
      "17": "ཅི་ལ་ཞེ་ན། རྒྱལ་མོའི་དོན་འདི་བུད་མེད་ཐམས་ཅད་ཀྱི་རྣ་བར་བརྒྱུད་ན། དེ་དག་གིས་ཀྱང་རང་རང་གི་ཁྱོ་གར་དམའ་འབེབས་བྱེད་ཅིང་ན་རེ། རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་རྒྱལ་མོ་ཝཱ་སི་ཏི་ཁོང་གི་དྲུང་དུ་བོས་ནའང་ཁོ་མོ་དེར་མ་ཕྱིན་ཏོ་ཞེས་སྨྲ་བར་འགྱུར།",
      "18": "ད་ནི་ཏ་ཟིག་དང་མཱ་ཏི་ཡུལ་གྱི་བཙུན་མོ་རྣམས་ཀྱིས་རྒྱལ་མོའི་བྱ་སྤྱོད་དེ་ཐོས་ན། རྒྱལ་པོའི་བློན་ཆེན་ཐམས་ཅད་ལ་དེ་ལྟར་སྨྲ་བ་དང་། དེ་ལྟར་བྱས་ཚེ་དམའ་འབེབས་དང་ཞེ་སྡང་རྫོགས་མེད་འབྱུང་བར་འགྱུར་རོ། །",
      "19": "གལ་ཏེ་རྒྱལ་པོའི་ཐུགས་དང་འཕྲོད་ན། དོན་འདི་འགྱུར་བ་མེད་པའི་ཁྲིམས་སུ་ཕོབས་ལ། ཏ་ཟིག་དང་མཱ་ཏི་ཡུལ་དུ་རྒྱལ་པོའི་བཀའ་ཤོག་ཅིག་སྤྲིང་བར་མཛོད། དེའི་ནང་དུ་ཝཱ་སི་ཏི་ནི་དེང་ཕྱིན་ཆད་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡི་དྲུང་དུ་ཡོང་མི་ཆོག་པ་དང་། རྒྱལ་མོའི་གོ་ས་ཁོ་མོ་ལས་ལྷག་པའི་བཙུན་མོ་ཞིག་ལ་གནང་བར་བྱའོ། །",
      "20": "རྒྱལ་ཁམས་ཀྱི་མངའ་ཁོངས་ནི་ཅི་འདྲའི་རྒྱ་ཆེ་ཡང་། རྒྱལ་པོའི་བཀའ་མཆིད་རྒྱལ་ཁམས་ཡོངས་ལ་ཁྱབ་པའི་དུས་སུ། ཆུང་མ་རྣམས་ཀྱིས་རང་རང་གི་ཁྱོ་ག་མཆོག་དམན་སུ་ཞིག་ཡིན་རུང་དེ་ལ་བཀུར་བསྟི་བྱེད་ངེས་སོ་ཞེས་ཞུས་པ་ལ།",
      "21": "གཏམ་འདི་ལ་རྒྱལ་པོ་དང་ས་གནས་དཔོན་རིགས་ཐམས་ཅད་ཤིན་ཏུ་དགྱེས་ཤིང་། རྒྱལ་པོས་མེ་མུ་ཀན་གྱི་གཏམ་བཞིན་དུ་བྱས་སོ། །",
      "22": "དེ་ནས་ཁོང་གིས་རྒྱལ་པོའི་ལྗོངས་ཐམས་ཅད་དུ་མི་རིགས་རེ་རེའི་སྐད་རིགས་དང་ཡི་གེ་བཞིན་དུ། སྐྱེས་པ་ཀུན་གྱིས་སོ་སོའི་ཁྱིམ་ནང་དུ་བདག་པོ་བྱེད་པ་དང་བཟའ་མི་རྣམས་ལ་རང་མི་རིགས་ཀྱི་སྐད་ཆ་སྨྲ་བར་འོས་ཞེས་བཀའ་རྒྱ་ཞིག་བཀྲམས་སོ། །"
    },
    "2": {
      "1": "¶ དོན་དེའི་རྗེས་སུ་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་ཁོང་ཁྲོ་ཞི་བར་གྱུར་ནས། ཝཱ་སི་ཏི་དང་ཁོ་མོས་ཅི་བྱས་པ་དང་རང་གིས་དེའི་སྐོར་ལ་བཀའ་ཅི་གནང་བའང་དྲན་པ་རེད།",
      "2": "དེ་ནས་ཞབས་ཕྱི་པ་རྣམས་ཀྱིས་རྒྱལ་པོ་ལ། ཁྱེད་ཀྱིས་རང་ཉིད་ཀྱི་ཆེད་དུ་མི་མངགས་ནས་ན་ཆུང་བུ་མོ་རྣམས་འཚོལ་དུ་བཅུག་ན་འོས་ཤིང་།",
      "3": "ལྗོངས་ཀུན་ཏུ་འགོ་དཔོན་བསྐོས་ཏེ། ན་ཆུང་བུ་མོ་ཐམས་ཅད་སོའུ་སཱན་མཁར་ཆེན་གྱི་སྐྱེས་མའི་གླིང་ག་རུ་བསྡུ་དགོས་པ་དང་། ཁོ་མོ་རྣམས་རྒྱལ་པོས་བུད་མེད་རྣམས་ལ་བདག་སྐྱོང་བྱེད་པར་བསྐོས་པའི་ཉུག་རུམ་པ་ཧེ་ག་ཨི་ཡི་ལག་ཏུ་གཏད་ནས། དེ་དག་ལ་མཁོ་བའི་བྱུག་སྣུམ་སྣ་ཚོགས་ཡང་སྟེར་བ་དང་།",
      "4": "དེ་ནས་རྒྱལ་པོས་ཐུགས་དང་ལྡན་པའི་ན་ཆུང་མ་ཞིག་ཝཱ་སི་ཏི་ཡི་ཚབ་ཏུ་རྒྱལ་མོར་མཛད་རོགས་ཞེས་ཞུ་བ་ཞུས་པ་ལ། རྒྱལ་པོས་ཐུགས་སུ་འཕྲོད་ནས་དེ་ལྟར་དུ་མཛད་དོ། །",
      "5": "¶ སོའུ་སཱན་མཁར་ཆེན་དུ་མིང་ལ་མོར་དོ་ཀཱ་ཨི་ཞེས་བྱ་བའི་ཡ་ཧུ་དཱ་པ་ཞིག་ཡོད་ལ། ཁོ་ནི་པེན་ཡཱ་མེན་པ་ཁི་སིའི་ཡང་ཚ་དང་། ཤིམ་ཨི་ཡི་ཚ་བོ་དང་། ཡཱ་ཨིར་གྱི་བུ་ཡིན་ནོ། །",
      "6": "དེ་སྔོན་པཱ་པེལ་ལོན་གྱི་རྒྱལ་པོ་ནེ་བོ་ཀད་ནེ་ཙར་གྱིས། ཡ་ཧུ་དཱའི་རྒྱལ་པོ་ཡེ་ཀོན་ཡཱ་དང་བཅས་པ་ཡེ་རུ་སཱ་ལེམ་གྲོང་ཁྱེར་ནས་བཙན་ཁྲིད་བྱས་ནས་ཡོང་དུས། མོར་དོ་ཀཱ་ཨི་ཡང་དེའི་ཁྲོད་ཀྱི་གཅིག་ཡིན།",
      "7": "ཁོས་རང་གི་ཁུ་བོའི་བུ་མོ་ཧ་དས་སཱའམ་ཨེས་སི་ཐེར་བྱ་བ་སྙོར་སྐྱོང་བྱས་པ་ཡིན་ཏེ། གང་ལ་ཞེ་ན། དེ་ལ་ཕ་མ་གཉིས་ཀ་མེད་པ་དང་། ཁོ་མོ་ནི་བྱད་གཟུགས་ཡིད་དུ་འོང་བ་ཞིག་ཡིན་ལ། ཕ་མ་ཤི་བའི་ཚེ་མོར་དོ་ཀཱ་ཨི་ཡིས་དེ་རང་གི་བུ་སྐལ་དུ་བསྙོར་བ་རེད།",
      "8": "¶ རྒྱལ་པོའི་བཀའ་མཆིད་ཁྱབ་བསྒྲགས་བྱས་པ་ན། ན་ཆུང་བུ་མོ་མང་པོ་སོའུ་སཱན་མཁར་ཆེན་དུ་བསྡུས་པ་དང་། བུད་མེད་རྣམས་ལ་བདག་སྐྱོང་བྱེད་མཁན་ཉུག་རུམ་པ་ཧེ་ག་ཨི་ལ་སྤྲད་ཅིང་། ཨེས་སི་ཐེར་ཡང་རྒྱལ་པོའི་ཕོ་བྲང་དུ་བསྐྱལ་ནས་ཧེ་ག་ཨི་ལ་གཏད།",
      "9": "ཧེ་ག་ཨི་ནི་ཨེས་སི་ཐེར་ལ་ཧ་ཅང་བརྩེ་ཞིང་ཁོ་མོ་བྱམས་ཀྱིས་བསྐྱངས་ནས། མྱུར་དུ་ཁོ་མོར་བྱུག་སྣུམ་དང་འབབ་འོས་པའི་སྐལ་ཡང་སྤྲད་དོ། །དེར་མ་ཟད་ཕོ་བྲང་ནས་ཁོ་མོ་ལ་ཞབས་ཞུ་བྱེད་པར་ཞལ་ཏ་མ་བདུན་ཡང་མངགས་པ་དང་། ཁོ་མོ་དང་ཞལ་ཏ་མ་རྣམས་སྐྱེས་མའི་གླིང་གའི་ཁྱིམ་ལེགས་ཤོས་དེར་གནས་སྤར་ཏོ། །",
      "10": "¶ ཨེས་སི་ཐེར་གྱིས་རང་གི་གདུང་རྒྱུད་དང་རིགས་རུས་མི་གཞན་པར་གཏན་ནས་མ་བཤད་དོ། །ཅིའི་ཕྱིར་ཞེ་ན། མོར་དོ་ཀཱ་ཨི་ཡིས་སུ་ལའང་ཤེས་སུ་མི་འཇུག་པར་གདམས་ཡོད་པས་སོ། །",
      "11": "ཡང་མོར་དོ་ཀཱ་ཨི་ནི་ཨེས་སི་ཐེར་བདེ་མིན་དང་ཁོ་མོའི་འཚོ་བ་ཇི་ལྟར་ཡིན་པ་ཤེས་པའི་ཕྱིར་དུ། ཉིན་རེ་བཞིན་སྐྱེས་མའི་གླིང་གའི་མདུན་དུ་ཕར་འགྲོ་ཚུར་འགྲོ་བྱས་སོ། །",
      "12": "¶ ལུགས་སྲོལ་ལྟར་དུ། ན་ཆུང་བུ་མོ་རྣམས་ཀྱིས་སྔོན་ལ་ཟླ་བ་བཅུ་གཉིས་རིང་ལ་ལུས་པོར་སྣུམ་བསྐུ་བར་བྱ་བ་སྟེ། ཟླ་བ་དྲུག་གི་རིང་ལ་གུ་གུལ་གྱི་སྣུམ་བསྐུ་ཞིང་། ཡང་ཟླ་བ་དྲུག་ལ་སྤོས་སྣུམ་དང་བྱུག་སྣུམ་འབྱུག་དགོས་པ་དང་། དེ་ནས་སྟ་གོན་མཇུག་རྫོགས་པ་ལ་ན་ཆུང་བུ་མོ་རེ་རེ་རིམ་བཞིན་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་དྲུང་དུ་འགྲོ་བ་ཡིན་ནོ། །",
      "13": "ན་ཆུང་བུ་མོ་རྣམས་རྒྱལ་པོའི་ཕོ་བྲང་དུ་འགྲོ་ལུགས་ནི་འདི་ལྟ་སྟེ། སྐྱེས་མའི་གླིང་ག་ནས་རྒྱལ་པོའི་དྲུང་དུ་འགྲོ་བའི་དུས་སུ། དེ་ལ་ཅི་ཞིག་མཁོ་བ་ཐམས་ཅད་སྤྲད་ནས་ནང་དུ་ཁྱེར་ཆོག་པ་དང་།",
      "14": "མཚན་མོར་རྒྱལ་པོའི་དྲུང་དུ་སོང་ནས་ཕྱི་ཉིན་སྔ་མོར་སྐྱེས་མའི་གླིང་ག་གཞན་པར་ལོག་དགོས་ཤིང་། བཙུན་མོ་རྣམས་ལ་བདག་སྐྱོང་བྱེད་མཁན་ཉུག་རུམ་པ་སཱ་ཨས་ག་སིའི་ལག་ཏུ་སྤྲོད་པ་དང་། རྒྱལ་པོ་ཁོ་མོར་དགའ་ཞིང་མོས་པ་དང་སླར་ཡང་མིང་བཏོན་ནས་བོས་ན་མ་གཏོགས་ཕྱིན་ཆད་རྒྱལ་པོའི་གམ་དུ་འགྲོ་བ་མིན་ནོ། །",
      "15": "¶ དེ་ནས་མོར་དོ་ཀཱ་ཨིས་བུ་སྐལ་དུ་བྱས་པའི་རང་གི་ཁུ་བོ་ཨ་བི་ཧ་ཡིལ་གྱི་བུ་མོ་ཨེས་སི་ཐེར་ཡང་། རིམ་པ་བཞིན་རྒྱལ་པོའི་དྲུང་དུ་འགྲོ་བའི་རེས་ལ་བབས་པ་ན། བུད་མེད་རྣམས་ལ་བདག་སྐྱོང་བྱེད་མཁན་ཉུག་རུམ་པ་ཧེ་ག་ཨི་ཡིས་བཀོད་སྒྲིག་བྱས་པ་མ་གཏོགས་གཞན་གང་ཡང་མ་ཞུས་སོ། །ཨེས་སི་ཐེར་མཐོང་བ་ཐམས་ཅད་ཁོ་མོར་མཉེས་པར་གྱུར་ཏོ། །",
      "16": "དེར་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་སྲིད་སྐྱོང་བའི་ལོ་བདུན་པའི་ཟླ་བཅུ་པ་སྟེ་ཐཱེ་བེད་ཟླ་བ་ལ། ཨེས་སི་ཐེར་ཡང་ཕོ་བྲང་ནང་རྒྱལ་པོའི་དྲུང་དུ་ཁྲིད་དོ། །",
      "17": "རྒྱལ་པོ་ནི་བུད་མེད་གཞན་ཐམས་ཅད་ལས་ཨེས་སི་ཐེར་ལ་དགའ་བར་གྱུར་ཅིང་། རྒྱལ་པོའི་དྲུང་དུ་ན་ཆུང་བུ་མོ་ཀུན་ལས་ཁོ་མོར་བརྩེ་བ་ཆེན་པོ་ཐོབ་པས། རྒྱལ་པོ་ཡིས་རྒྱལ་མོའི་ཅོད་པན་ཁོ་མོའི་མགོ་ལ་བསྐོན་པ་དང་། ཁོ་མོ་ཝཱ་སི་ཏིའི་ཚབ་ཏུ་རྒྱལ་མོར་བསྐོས་སོ། །",
      "18": "རྒྱལ་པོས་ཨེས་སི་ཐེར་གྱི་རྐྱེན་གྱིས་ས་གནས་དཔོན་རིགས་དང་འཁོར་གཡོག་ཐམས་ཅད་ལ་གསོལ་སྟོན་གཟབ་རྒྱས་བཤམས་ཤིང་། ལྗོངས་སོ་སོར་གུང་གསེང་གནང་བར་མ་ཟད། མི་ཐམས་ཅད་ལ་གཏོང་ཕོད་ཆེན་པོས་གསོལ་རས་ཀྱང་བསྩལ་ཏོ། །",
      "19": "¶ ཡང་ཐེངས་གཉིས་པར་ན་ཆུང་བུ་མོ་རྣམས་བསྡུ་བའི་ཚེ། མོར་དོ་ཀཱ་ཨི་རྒྱལ་པོའི་ཕོ་བྲང་གི་སྒོ་ཁར་བསྡད།",
      "20": "ཨེས་སི་ཐེར་གྱིས་མོར་དོ་ཀཱ་ཨིས་བསྒོས་པ་བཞིན་དུ་རང་གི་གདུང་རྒྱུད་དང་རིགས་རུས་གཞན་ལ་མ་བཤད། སྔོན་ཆད་མོར་དོ་ཀཱ་ཨིས་རང་ཉིད་སྐྱོང་བའི་དུས་སུ་ཇི་ལྟར་ཁོང་གི་ཁ་ལ་མཉན་པ་བཞིན་དུ། ཁོ་མོས་ཁོང་གི་བཀའ་བཞིན་བྱས་པ་རེད།",
      "21": "དེའི་ཚེ་མོར་དོ་ཀཱ་ཨི་རྒྱལ་པོའི་ཕོ་བྲང་གི་སྒོ་ཁར་བསྡད་པ་ལ། ཉུག་རུམ་པའི་ཁྲོད་དུ་པིག་ཐན་དང་ཐེ་རེ་སི་ཞེས་བྱ་བའི་ནང་སྒོ་སྲུང་མཁན་མི་གཉིས་ཡོད་པ་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ལ་རབ་ཏུ་ཁྲོས་ཤིང་། ཁོང་ལྐོག་གསོད་བྱེད་པའི་རེ་ངན་བཅངས་པ་དང་།",
      "22": "མོར་དོ་ཀཱ་ཨི་ཡིས་དོན་དེ་ཤེས་ནས་རྒྱལ་མོ་ཨེས་སི་ཐེར་ལ་བཤད་པ་དང་། ཨེས་སི་ཐེར་གྱིས་མོར་དོ་ཀཱ་ཨིའི་ངོ་ཚབ་བྱས་ནས་རྒྱལ་པོར་ཞུས་སོ། །",
      "23": "རྒྱལ་པོས་བྱ་བ་དེ་ལ་ཞིབ་བཤེར་གནང་སྟེ་དོན་དངོས་ཡིན་པ་ཤེས་ནས། མི་དེ་གཉིས་གདུང་མའི་སྟེང་དུ་དཔྱངས་པ་དང་། ཡང་གནས་ཚུལ་འདི་རྒྱལ་པོའི་དྲུང་གི་ལོ་རྒྱུས་ཀྱི་དེབ་ཐེར་ནང་དུ་བཀོད་དོ། །"
    },
    "3": {
      "1": "¶ དོན་དེའི་རྗེས་སུ་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་ཨ་གག་པ་ཧམ་མེ་དཱ་ཐའི་བུ་ཧ་མཱན་ཞེས་བྱ་བ་ཆེན་པོར་བརྩིས་ནས་བསྐོ་འཐེན་བྱས་ཤིང་། དེའི་གོ་གནས་ནི་ཁོ་དང་མཉམ་དུ་ཡོད་པའི་དཔོན་རིགས་ཀུན་ལས་མཐོ་བར་བྱས།",
      "2": "ཡང་རྒྱལ་པོའི་ཕོ་བྲང་གི་སྒོ་ཁར་ཡོད་པའི་འཁོར་གཡོག་རྣམས་ཀྱིས་ཧ་མཱན་ལ་མགོ་བསྒུར་ནས་ཕྱག་བཙལ་ཏོ། །ཅིའི་ཕྱིར་ཞེ་ན། རྒྱལ་པོས་དེ་ལྟ་བུའི་བཀའ་གནང་ཡོད་པ་ཡིན། འོན་ཀྱང་། མོར་དོ་ཀཱ་ཨི་ཡིས་ཧ་མཱན་ལ་མགོ་མ་སྒུར་ཕྱག་ཀྱང་མ་བཙལ་ཏོ། །",
      "3": "དེ་ནས་རྒྱལ་པོའི་ཕོ་བྲང་གི་སྒོ་ཁར་ཡོད་པའི་འཁོར་གཡོག་རྣམས་ཀྱིས་མོར་དོ་ཀཱ་ཨི་ལ། ཁྱོད་རང་ཅིའི་ཕྱིར་རྒྱལ་པོའི་བཀའ་དང་འགལ་ལམ་ཞེས་སྨྲས་ཤིང་།",
      "4": "དེ་དག་གིས་ཉིན་རེ་བཞིན་ཁོ་ལ་སྐུལ་འདེབས་བྱས་ཀྱང་། ཁོས་སྔར་བཞིན་མ་མཉན་པ་རེད། དེ་བས་མོར་དོ་ཀཱ་ཨི་ཡིས་རང་ཉིད་ཡ་ཧུ་དཱ་པ་ཡིན་ ཟེར་བའི་གཏམ་དེ་དོན་ལ་གནས་མིན་ལ་བལྟ་བའི་ཆེད་དུ། དེ་དག་གིས་ཧ་མཱན་ལ་སྨྲས་སོ། །",
      "5": "མོར་དོ་ཀཱ་ཨི་ཡིས་མགོ་མི་སྒུར་ལ་ཕྱག་ཀྱང་མི་འཚལ་བ་མཐོང་ནས་ཧ་མཱན་ཤིན་ཏུ་ཁྲོས་སོ། །",
      "6": "དེ་རྣམས་ཀྱིས་མོར་དོ་ཀཱ་ཨི་ཡི་རིགས་རྒྱུད་ཅི་ཡིན་པ་ཧ་མཱན་ལ་སྨྲས་པས། ཁོའི་བསམ་པར་མོར་དོ་ཀཱ་ཨི་གཅིག་པུ་གསོད་པ་ནི་དོན་ཆུང་ངུ་ཡིན་པས། མོར་དོ་ཀཱ་ཨི་ཡི་མི་མང་སྟེ། རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་རྒྱལ་ཁམས་སུ་གནས་པའི་ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་རྩ་མེད་དུ་གཏོང་དགོས་པར་འདོད་དོ། །",
      "7": "¶ རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་སྲིད་སྐྱོང་བའི་ལོ་བཅུ་གཉིས་པའི་ཟླ་བ་དང་པོ་སྟེ་ནེ་སཱན་ཟླ་བར། དེ་དག་གིས་ཟླ་ཚེས་ཐག་གིས་གཅོད་པའི་ཆེད་དུ་ཉིན་རེ་བཞིན་དང་ཟླ་རེ་བཞིན་ཧ་མཱན་གྱི་མདུན་ནས་པུར་ཞེས་པའི་རྒྱན་བླངས་པ་ལ་ཟླ་བཅུ་གཉིས་པ་སྟེ་ཨ་དཱར་ཟླ་བ་ལ་བབས་སོ། །",
      "8": "¶ དེ་ནས་ཧ་མཱན་གྱིས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ལ། ཁྱེད་ཀྱི་རྒྱལ་ཁམས་ནང་དུ་མི་རིགས་གཅིག་ནི་ལྗོངས་སོ་སོའི་མི་རིགས་ཁྲོད་ཁ་འཐོར་དུ་གནས་པ་དང་། དེའི་ལུགས་སྲོལ་ནི་མི་ཐམས་ཅད་ཀྱི་ལུགས་སྲོལ་དང་མི་མཐུན་ལ། རྒྱལ་པོའི་ཁྲིམས་སྲོལ་ཡང་མི་བསྲུང་བས། དེ་རྣམས་སྐྱོང་བ་ནི་རྒྱལ་པོར་ཕན་ཐོགས་མེད་པ་རེད།",
      "9": "དེ་བས་རྒྱལ་པོ་ཁྱེད་རང་ཐུགས་དགྱེས་ན། དེ་རྣམས་རྩ་མེད་གཏོང་བའི་བཀའ་མཆིད་གནང་བར་མཛོད་དང་། བདག་གིས་རྒྱལ་པོའི་གཏེར་མཛོད་ཁང་གི་བདག་གཉེར་བྱེད་མཁན་རྣམས་ཀྱི་ལག་ཏུ་དངུལ་གྱི་རྡོ་ཚད་ཆིག་ཁྲི་འབུལ་བར་བྱའོ་ཞེས་ཞུས་པས།",
      "10": "རྒྱལ་པོས་རང་ཉིད་ཀྱི་ཕྱག་གི་ཐམ་ག་དང་ལྡན་པའི་མཛུབ་དཀྲིས་ཕུད་ནས། ཡ་ཧུ་དཱ་པ་རྣམས་ལ་བཙན་གནོན་གཏོང་མཁན་ཨ་གག་པ་ཧམ་མེ་དཱ་ཐའི་བུ་ཧ་མཱན་ལ་གནང་སྟེ།",
      "11": "ཧ་མཱན་ལ། དངུལ་ནི་ཁྱོད་ལ་གནང་བ་དང་། མི་འདི་རྣམས་ཀྱང་ཁྱོད་ལ་སྤྲད་པ་ཡིན། དེ་དག་ལ་ཁྱོད་ཀྱིས་གང་དགར་གྱིས་ཤིག་ཅེས་གསུངས་སོ། །",
      "12": "¶ དེ་ནས་ཟླ་བ་དང་པོའི་ཚེས་བཅུ་གསུམ་ཉིན་ལ། རྒྱལ་པོའི་དྲུང་ཡིག་དག་བོས་ཡོང་སྟེ། ཧ་མཱན་གྱིས་བསྒོས་པ་བཞིན་དུ་ལྗོངས་སོ་སོའི་ཡི་གེ་དང་མི་རིགས་སོ་སོའི་སྐད་ཀྱིས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་མིང་ལ་བརྟེན་ནས་བཀའ་མཆིད་བྲིས་ཤིང་། ཡང་རྒྱལ་པོའི་མཛུབ་དཀྲིས་ཀྱིས་ཕྱག་རྒྱ་བཏབ་ནས། རྒྱལ་པོའི་སྤྱི་དཔོན་དང་ལྗོངས་སོ་སོའི་འགོ་བདག་དང་། མི་རིགས་རེ་རེའི་དཔོན་རིགས་སོགས་ལ་བསྒྲགས།",
      "13": "ཟླ་བ་བཅུ་གཉིས་པ་སྟེ་ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་གསུམ་པ་ལ། ཡ་ཧུ་དཱ་པའི་སྐྱེས་པ་རྒན་གཞོན་ཐམས་ཅད་བུད་མེད་བྱིས་པ་དང་བཅས་པ་ཉིན་གཅིག་ཏུ་ཡོངས་རྫོགས་བསད་ནས་ཚར་གཅོད་པར་མ་ཟད། དེ་དག་གི་རྒྱུ་ནོར་ཡང་འཕྲོག་པའི་བཀའ་ཤོག་དེ་བང་ཆེན་བརྒྱུད་ནས་རྒྱལ་པོའི་ལྗོངས་སོ་སོར་བསྐྱལ།",
      "14": "བཀའ་ཤོག་དེ་ནི་འདྲ་བཤུས་བགྱིས་ཏེ་ལྗོངས་ཐམས་ཅད་ཀྱི་ཁྲིམས་སུ་ཕབ་ནས། ཉིན་དེར་གྲ་སྒྲིག་བྱེད་པའི་དོན་དུ་མི་རིགས་ཀུན་ལ་ཁྱབ་བསྒྲགས་བྱས་སོ། །",
      "15": "¶ བང་ཆེན་རྣམས་རྒྱལ་པོའི་བཀའ་བཞིན་མྱུར་དུ་ལམ་ལ་ཆས་པ་དང་། སོའུ་སཱན་མཁར་ཆེན་ཧྲིལ་པོར་བཀའ་མཆིད་ཁྱབ་བསྒྲགས་བྱས་སོ། །རྒྱལ་པོས་ཧ་མཱན་དང་མཉམ་དུ་ཆང་བཞེས་ནས་བསྡད་མོད། སོའུ་སཱན་མཁར་ཆེན་གྱི་འབངས་མི་རྣམས་འཁྲུགས་པར་གྱུར་ཏོ། །"
    },
    "4": {
      "1": "¶ མོར་དོ་ཀཱ་ཨི་ཡིས་དོན་ཐམས་ཅད་ཤེས་པ་ན་རང་གི་གོས་གཤགས་ཏེ་རྩིད་རས་གྱོན་ཞིང་། མགོ་ལ་ཐལ་བ་གཏོར་ནས་གྲོང་ཁྱེར་ནང་དུ་འགྲོ་སྐྱོད་བྱས་པ་དང་། སྐད་ཆེན་པོ་བརྒྱབ་ནས་དྲག་ཏུ་ངུས་སོ། །",
      "2": "རྩིད་རས་གྱོན་མཁན་སུ་ཡང་རྒྱལ་པོའི་མཁར་སྒོའི་ནང་དུ་འཛུལ་མི་ཆོག་པས། ཁོ་རང་རྒྱལ་པོའི་མཁར་སྒོའི་མདུན་དུ་སླེབས་ནས་འགྲོ་མཚམས་བཞག",
      "3": "ཡང་རྒྱལ་པོའི་བཀའ་ཤོག་སླེབས་པའི་ལྗོངས་སོ་སོ་དང་ཡུལ་སོ་སོའི་ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་སྡུག་བསྔལ་ཆེན་པོས་མནར་ཞིང་། སྨྱུང་གནས་བསྲུངས་ཏེ་ངུས་པ་དང་། སྐྱོ་གདུང་གི་སྐད་ཆེན་པོ་བཏོན་ནས། མི་མང་པོས་རྩིད་རས་དང་ཐལ་བ་བཏིངས་ནས་དེའི་ནང་དུ་ཉལ་ཏོ། །",
      "4": "¶ དེ་ནས་རྒྱལ་མོ་ཨེས་སི་ཐེར་གྱི་ཞལ་ཏ་མ་དང་ཉུག་རུམ་པ་རྣམས་ཀྱིས་དོན་དེ་ཁོ་མོར་བཤད་པ་དང་། ཁོ་མོའི་སེམས་ཤིན་ཏུ་སྡུག་སྟེ། མོར་དོ་ཀཱ་ཨི་ལ་རྩིད་རས་འདོར་དགོས་པར་ཞུས་ནས་གོས་གཞན་ཞིག་གསོལ་དུ་བསྐུར་ཡང་ཁོས་དེ་མ་བླངས་སོ། །",
      "5": "ཨེས་སི་ཐེར་གྱིས་སྔར་རྒྱལ་པོས་ཁོ་མོར་ཞབས་ཞུ་བྱེད་པར་མངགས་པའི་ཉུག་རུམ་པ་ཧ་ཐག་ཅེས་བྱ་བ་བོས་ནས། དོན་དམ་དུ་ཅི་བྱུང་བ་དང་དེ་ལྟར་བྱེད་དགོས་དོན་ཅི་ཡིན་ཤེས་པའི་ཕྱིར། དེ་མོར་དོ་ཀཱ་ཨིའི་རྩར་མངགས་པས།",
      "6": "ཧ་ཐག་རྒྱལ་པོའི་མཁར་སྒོ་མདུན་གྱི་ཐང་ཆེན་དུ་མོར་དོ་ཀཱ་ཨི་ལ་འཕྲད་པར་སོང་ངོ་། །",
      "7": "¶ དེར་མོར་དོ་ཀཱ་ཨིས་རང་ལ་ཅི་བྱུང་བ་ཐམས་ཅད་དང་། ཧ་མཱན་གྱིས་ཡ་ཧུ་དཱ་པ་རྣམས་རྩ་མེད་གཏོང་ཕྱིར་རྒྱལ་པོའི་གཏེར་མཛོད་དུ་འབུལ་གྲབས་ཡོད་པའི་རྒྱལ་དངུལ་གྱི་གྲངས་ཀ་ཡང་ཧ་ཐག་ལ་བཤད།",
      "8": "གཞན་ཡང་སོའུ་སཱན་མཁར་ཡོངས་སུ་ཁྱབ་པ་དང་ཡ་ཧུ་དཱ་པ་རྣམས་རྩ་མེད་གཏོང་བའི་བཀའ་ཤོག་གི་འདྲ་བཤུས་ཀྱང་ཧ་ཐག་ལ་སྤྲད་ནས། ཨེས་སི་ཐེར་ལ་གཟིགས་འབུལ་ཞུ་བ་དང་དེའི་སྐོར་སྨྲ་བར་མ་ཟད། ད་དུང་ཨེས་སི་ཐེར་རྒྱལ་པོའི་སྐུ་མདུན་དུ་སོང་སྟེ་རྒྱལ་པོར་ཞུ་བ་འབུལ་བ་དང་། རང་གི་མི་རྣམས་ཀྱི་ཆེད་དུ་རྒྱལ་པོའི་དྲུང་ནས་སྐྱབས་བཅོལ་ཞུ་དགོས་པའི་དོན་ཧ་ཐག་ལ་ནན་གྱིས་གཏད་དོ། །",
      "9": "དེ་ནས་ཧ་ཐག་ཕྱིར་སོང་ནས། མོར་དོ་ཀཱ་ཨིའི་གཏམ་ཐམས་ཅད་ཨེས་སི་ཐེར་ལ་ཞུས་སོ། །",
      "10": "ཨེས་སི་ཐེར་གྱིས་སླར་ཡང་ཧ་ཐག་ལ་མོར་དོ་ཀཱ་ཨི་ལ་འདི་ལྟར་ཞུ་བའི་བཀའ་བསྒོས་པ་སྟེ།",
      "11": "ཞལ་འབོད་མ་གནང་བར་ཚོམས་ཆེན་ནང་དུ་ཕོ་མོ་སུ་ཞིག་རྒྱལ་པོར་མཇལ་དུ་ཕྱིན་ན། རྒྱལ་པོས་དེ་ལ་གསེར་གྱི་འཁར་བ་བརྐྱངས་ན་མ་གཏོགས་གསོན་མི་ཐུབ་པའི་ཁྲིམས་སྲོལ་གཅིག་རང་ཡོད་པ་ནི། འཁོར་གཡོག་དང་ལྗོངས་སོ་སོའི་ཡུལ་མི་ཀུན་གྱིས་ཤེས་ལ། བདག་ཀྱང་ཁོང་གི་དྲུང་དུ་མ་བོས་པར་ཞག་མ་སུམ་ཅུ་ཙམ་འགོར་ཡོད་ཅེས་པའོ། །",
      "12": "¶ དེ་དག་གིས་ཨེས་སི་ཐེར་གྱི་གཏམ་མོར་དོ་ཀཱ་ཨི་ལ་བཤད་པ་དང་།",
      "13": "མོར་དོ་ཀཱ་ཨིས་དེ་རྣམས་བརྒྱུད་ནས་ཨེས་སི་ཐེར་ལ་ལན་དུ། ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་ཀྱི་ནང་ནས་ཁྱོད་གཅིག་པུ་རྒྱལ་པོའི་ཕོ་བྲང་དུ་ཡོད་པའི་དབང་གིས། རྐྱེན་ངན་འདི་ལས་རང་ཉིད་ཐར་ཐུབ་པར་མ་སེམས་ཤིག",
      "14": "གལ་ཏེ་ཁྱོད་རང་སྐབས་འདིར་ཁ་རོག་བསྡད་ན། ཡ་ཧུ་དཱ་པ་སྐྱོབ་མཁན་ཕྱོགས་གཞན་ནས་འབྱུང་ལ་ཐར་བར་འགྱུར། ཁྱོད་ནི་རང་གི་ཁྱིམ་རྒྱུད་དང་བཅས་མེད་པར་འགྱུར་རོ། །དུས་སྐབས་འདིའི་ཆེད་དུ་ཁྱོད་རང་རྒྱལ་མོའི་གོ་སར་སླེབས་པ་ཡིན་ཡང་སྲིད་ཅེས་སྨྲས་པ་དང་།",
      "15": "ཨེས་སི་ཐེར་གྱིས་དེ་དག་བརྒྱུད་ནས་མོར་དོ་ཀཱ་ཨི་ལ་ལན་བཏབ་པ་ནི།",
      "16": "ཁྱོད་རང་སོང་ནས་སོའུ་སཱན་མཁར་ཆེན་དུ་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་བསྡུས་ཏེ། ཉིན་ཞག་གསུམ་ལ་ཅི་ཡང་མི་བཟའ་མི་འཐུང་བར་བདག་གི་ཆེད་དུ་སྨྱུང་གནས་སྲུངས་ཤིག ང་རང་དང་ངའི་ཞལ་ཏ་མ་རྣམས་ཀྱིས་ཀྱང་དེ་བཞིན་དུ་སྨྱུང་གནས་བསྲུང་བར་བྱ། དེ་ནས་ཁྲིམས་དང་འགལ་ནའང་བདག་རྒྱལ་པོའི་དྲུང་དུ་འགྲོ་བར་བྱ་སྟེ། གལ་ཏེ་ང་རང་ཤི་ནའང་མི་འཕངས་ཞེས་པས།",
      "17": "མོར་དོ་ཀཱ་ཨི་ཕར་སོང་ནས་ཨེས་སི་ཐེར་གྱིས་བསྒོས་པ་བཞིན་དུ་ཐམས་ཅད་བསྒྲུབས་སོ། །"
    },
    "5": {
      "1": "¶ དེ་ནས་ཉིན་གསུམ་པ་ལ། ཨེས་སི་ཐེར་གྱིས་རྒྱལ་མོའི་ན་བཟའ་གསོལ་ཏེ། ཕོ་བྲང་གི་ཚོམས་ཆེན་ནང་རྒྱལ་པོའི་ཕོ་བྲང་གི་དྲང་ཐད་དུ་ལངས་ནས་བསྡད་པ་དང་། རྒྱལ་པོ་ཡང་ཕོ་བྲང་གི་སྒོའི་དྲང་ཐད་ཀྱི་ཁྲི་སྟེང་དུ་བཞུགས་ཡོད་པ་ལ།",
      "2": "རྒྱལ་མོ་ཨེས་སི་ཐེར་ཚོམས་ཆེན་ནང་དུ་ལངས་འདུག་པ་མཐོང་བ་དང་། ཁོ་མོར་ཐུགས་རྗེས་གཟིགས་ཏེ། རྒྱལ་པོས་གསེར་གྱི་འཁར་བ་ཨེས་སི་ཐེར་གྱི་ཕྱོགས་སུ་བཏེགས་པ་ལ། ཨེས་སི་ཐེར་ཉེ་བར་བཅར་ནས་འཁར་བའི་མགོ་ལ་རེག་པའོ། །",
      "3": "དེ་ནས་རྒྱལ་པོས་འདི་ལྟར། རྒྱལ་མོ་ཨེས་སི་ཐེར་ཁྱོད་ལ་ཅི་དགོས་སམ། ཁྱོད་ཀྱིས་གང་ཞིག་ཞུས་ཀྱང་རྒྱལ་སྲིད་ཀྱི་ཕྱེད་ཀ་ཡིན་ཡང་ཁྱོད་ལ་སྦྱིན་པར་བྱའོ་ཞེས་གསུངས་པ་དང་།",
      "4": "ཨེས་སི་ཐེར་གྱིས། གལ་སྲིད་རྒྱལ་པོ་ལགས་ཐུགས་དགྱེས་པ་ཡིན་ན། ཁྱེད་ཉིད་ཧ་མཱན་དང་ལྷན་དུ་བདག་གིས་དེ་རིང་བཤམས་པའི་གསོལ་སྟོན་དུ་ཕེབས་རོགས་མཛོད་ཅེས་ཞུས་པ་ལ།",
      "5": "རྒྱལ་པོ་ན་རེ། ཧ་མཱན་ལ་མྱུར་དུ་ཨེས་སི་ཐེར་གྱི་ངག་བཞིན་བསྒྲུབ་ཏུ་ཆུག་ཅེས་གསུངས་པ་དང་། ཧ་མཱན་ཁྲིད་ནས་ཨེས་སི་ཐེར་གྱིས་བཤམས་པའི་གསོལ་སྟོན་ལ་ཕེབས་སོ། །",
      "6": "ཡང་གསོལ་སྟོན་གྱི་སྐབས་སུ་རྒྱལ་པོས་སླར་ཡང་ཨེས་སི་ཐེར་ལ། ཁྱོད་ལ་ཅི་དགོས་ན་གནང་བར་བྱ། ཁྱོད་ཀྱིས་གང་ཞིག་ཞུས་ཀྱང་སྟེར་ངེས་ལ། རྒྱལ་སྲིད་ཀྱི་ཕྱེད་ཀ་ཡིན་ཡང་ཁྱོད་ལ་སྦྱིན་ངེས་ཡིན་ཞེས་གསུངས་པའི་ལན་དུ།",
      "7": "ཨེས་སི་ཐེར་གྱིས་བདག་གིས་ཞུ་འདོད་པ་ནི།",
      "8": "གལ་ཏེ་རྒྱལ་པོའི་དྲུང་དུ་བདག་ལ་ཐུགས་རྗེ་ཐོབ་ཅིང་། རྒྱལ་པོས་བདག་གི་རེ་འདོད་ཐམས་ཅད་བསྒྲུབ་པར་བྱེད་ན། རྒྱལ་པོ་ཁྱེད་ཉིད་ཧ་མཱན་དང་མཉམ་དུ་སླར་ཡང་བདག་གིས་བཤམས་པའི་གསོལ་སྟོན་ལ་ཕེབས་རོགས་མཛོད་དང་། སང་ཉིན་བདག་གིས་རྒྱལ་པོའི་དྲི་བ་ལ་ལན་གདབ་བོ་ཞེས་ཞུས་སོ། །",
      "9": "¶ ཉིན་དེ་ལ་ཧ་མཱན་བློ་བདེ་ཞིང་སེམས་དགའ་སྟེ་སོང་མོད། འོན་ཀྱང་མོར་དོ་ཀཱ་ཨི་རྒྱལ་པོའི་མཁར་སྒོར་ཡར་མི་ལངས་ལ་སྐྲག་པའི་སྣང་བ་ཙམ་ཡང་མེད་པ་མཐོང་ནས་མོར་དོ་ཀཱ་ཨི་ལ་ཤིན་ཏུ་ཁྲོས་ནའང་།",
      "10": "ཁོང་ཁྲོ་ཁོག་ལ་བཅུག་ནས་ཁྱིམ་དུ་ལོག་ཅིང་། གྲོགས་པོ་རྣམས་དང་རང་གི་ཆུང་མ་ཙེ་རེ་ཟི་འབོད་དུ་བཏང་ངོ་། །",
      "11": "དེ་ནས་ཧ་མཱན་གྱིས་དེ་དག་ལ། རང་གི་རྒྱུ་འབྱོར་བའི་གཟི་དཔལ་དང་བུ་ཕྲུག་མང་པོ་ཡོད་པ་དང་། རྒྱལ་པོས་ཁོའི་གོ་ས་ཇི་ཙམ་བཏེགས་ཚུལ་དང་། དཔོན་རིགས་དང་རྒྱལ་པོའི་འཁོར་གཡོག་ཀུན་ལས་མཐོ་བར་མཛད་པ་ཐམས་ཅད་སྨྲས་པ་དང་།",
      "12": "ཡང་ཧ་མཱན་གྱིས། འོ། རྒྱལ་མོ་ཨེས་སི་ཐེར་གྱིས་བཤམས་པའི་གསོལ་སྟོན་ལ་ང་མ་གཏོགས་རྒྱལ་པོ་དང་ལྷན་དུ་སུ་ཡང་སོང་མི་ཆོག སང་ཉིན་ཡང་ང་རང་རྒྱལ་པོ་དང་མཉམ་དུ་སྐུ་མགྲོན་ལ་བོས་པ་ཡིན།",
      "13": "འོན་ཀྱང་ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་རྒྱལ་པོའི་མཁར་སྒོར་མཐོང་ཐེངས་རེར། འདི་ཐམས་ཅད་བདག་ལ་མཚོན་ན་དོན་སྙིང་ཅི་ཡང་མེད་དོ་ཞེས་སྨྲས་སོ། །",
      "14": "¶ དེ་ནས་ཁོའི་ཆུང་མ་ཙེ་རེ་ཟི་དང་གྲོགས་པོ་རྣམས་ཀྱིས་ཧ་མཱན་ལ། ཁྲུ་ལྔ་བཅུ་ཅན་གྱི་འཕྱར་ཤིང་ཞིག་བཟོ་རུ་ཆུག་ལ། སང་ཉིན་ཞོགས་པར་མོར་དོ་ཀཱ་ཨི་དེའི་སྟེང་དུ་དཔྱང་བའི་ཕྱིར་རྒྱལ་པོར་ཞུས་ཤིག་དང་། དེ་ནས་ཁྱོད་རང་སེམས་དགའ་བའི་ངང་ནས་རྒྱལ་པོ་དང་མཉམ་དུ་མགྲོན་ལ་སོང་ཆོག་ཅེས་སྨྲས་པ་ན། ཧ་མཱན་ནི་གཏམ་དེ་ལ་དགའ་བས་འཕྱར་ཤིང་བཟོ་རུ་བཅུག་གོ །"
    },
    "6": {
      "1": "¶ མཚན་མོ་དེར་རྒྱལ་པོ་མནལ་མ་ཁུགས་པས་མི་གཞན་ལ་ལོ་རྒྱུས་ཀྱི་དེབ་ཐེར་འཁྱེར་འོང་བའི་བཀའ་གནང་བ་དང་། དེ་ལ་ཀློག་ཏུ་བཅུག་ནས་ཁོང་གིས་མཉན་ཏོ། །",
      "2": "སྟེས་དབང་གིས་དཔེ་ཆ་དེའི་ནང་དུ་རྒྱལ་པོའི་ཉུག་རུམ་པའི་ཁྲོད་དུ་པིག་ཐན་དང་ཐེ་རེ་སི་ཞེས་པའི་སྒོ་སྲུང་པ་གཉིས་ཡོད་ཅིང་། དེ་གཉིས་ཀྱིས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ལ་གནོད་བསྐྱལ་བསམས་ཀྱང་། མོར་དོ་ཀཱ་ཨི་ཡིས་དོན་དེ་སྨྲས་བྱུང་ཞེས་བྲིས་པ་དང་ཕྲད་པས།",
      "3": "དེར་རྒྱལ་པོས་འདི་ལྟར། དོན་དེའི་ཕྱིར་མོར་དོ་ཀཱ་ཨི་ལ་མཚན་སྙན་གྲགས་དང་ཐོབ་གོ་ས་ཅི་ཞིག་གནང་བ་ཡིན་ཞེས་དྲིས་པ་ལ། ཞབས་ཕྱི་པ་རྣམས་ཀྱིས། དེ་ལ་ཅི་ཡང་མ་གནང་ངོ་ཞེས་ཞུས་སོ། །",
      "4": "ཡང་རྒྱལ་པོས། ཚོམས་ཆེན་ཕྱི་རུ་སུ་ཞིག་ཡོད་དམ་ཞེས་དྲིས་ཤིང་། ཏག་ཏག་སྐབས་དེར་ཧ་མཱན་ཚོམས་ཆེན་ཕྱི་རུ་སླེབས་ཏེ། རང་གིས་གྲ་སྒྲིག་བྱས་པའི་འཕྱར་ཤིང་གི་སྟེང་དུ་མོར་དོ་ཀཱ་ཨི་དཔྱང་བའི་ཕྱིར་རྒྱལ་པོར་ཞུ་བར་སྒུག་ཡོད་པ་ལ།",
      "5": "གཞོན་ནུ་རྣམས་ཀྱིས། གཟིགས་དང་། ཧ་མཱན་ར་བའི་ནང་དུ་ལངས་འདུག་ཅེས་ཞུས་པས། རྒྱལ་པོས་ཁོ་རང་ནང་དུ་བོས་ཤོག་ཅེས་བཀའ་བསྒོས་སོ། །",
      "6": "དེ་ནས་ཧ་མཱན་ནང་དུ་འོངས་པ་དང་། རྒྱལ་པོས་འདི་ལྟར། རྒྱལ་པོ་དགའ་ཞིང་གོང་བཀུར་བྱེད་པའི་མི་ལ་ཅི་བྱེད་པར་རིགས་སམ་ཞེས་དྲིས་པ་ན། ཧ་མཱན་གྱི་སེམས་སུ། རྒྱལ་པོ་མཉེས་ཤིང་གོང་བཀུར་བྱེད་པ་ནི་ང་རང་ལས་གཞན་སུ་ཡོད་དམ་སྙམ་སྟེ།",
      "7": "ཧ་མཱན་གྱིས་རྒྱལ་པོ་ལ། རྒྱལ་པོ་མཉེས་ཤིང་གོང་བཀུར་བྱེད་པའི་མི་དེ་ལ་ནི།",
      "8": "རྒྱལ་པོས་མནབས་པའི་ན་བཟའ་དང་། རྒྱལ་པོ་འཆིབས་པའི་ཆིབས་ཆེན་དང་དེའི་པྲོག་ཞུ་དང་བཅས་པ་བཏོན་ཏེ།",
      "9": "ན་བཟའ་དང་ཆིབས་ཆེན་ནི་དཔོན་རིགས་ཀུན་ལས་ཆེས་བཀུར་འོས་པ་དེ་ལ་གཏོད་པ་དང་། དེས་རྒྱལ་པོ་མཉེས་ཤིང་གོང་བཀུར་བྱེད་པའི་མི་ལ་ན་བཟའ་བསྐོན་ནས། ཆིབས་པར་བསྐྱོན་ཏེ། གྲོང་ཁྱེར་གྱི་ཁྲོམ་སྲང་ཡོངས་ལ་འཁྲིད་པ་དང་། སུ་ཞིག་ལ་རྒྱལ་པོ་མཉེས་ཤིང་གོང་བཀུར་བྱེད་ན། དེ་ལ་འདི་ལྟར་མཛད་དོ་ཞེས་མི་དེའི་མདུན་ནས་བསྒྲག་དགོས་ཞེས་ཞུས་སོ། །",
      "10": "¶ དེ་ནས་རྒྱལ་པོས་ཧ་མཱན་ལ། ཁྱོད་ཀྱིས་སྨྲས་པའི་གཏམ་བཞིན་དུ། ན་བཟའ་ཁྱེར་ནས་ཆིབས་ཆེན་ཁྲིད་དེ་རྒྱལ་པོའི་མཁར་སྒོར་སྡོད་པའི་ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་ལ་མྱུར་དུ་སྒྲུབས་ཤིག ཁྱོད་ཀྱིས་སྨྲས་པའི་ཚིག་ཀུན་ལས་ཆད་ལུས་གཅིག་ཀྱང་ཡོད་མི་ཆོག་ཅེས་གསུངས་པས།",
      "11": "ཧ་མཱན་གྱིས་ན་བཟའ་ཁྱེར་ནས་ཆིབས་ཆེན་ཁྲིད་འོངས་ཏེ། མོར་དོ་ཀཱ་ཨི་ལ་བསྐོན་ཞིང་ཆིབས་པར་བསྐྱོན་པ་དང་གྲོང་ཁྱེར་གྱི་ཐང་ཆེན་བརྒྱུད་ནས། རྒྱལ་པོ་མཉེས་ཤིང་གོང་བཀུར་བྱེད་པའི་མི་ལ་འདི་ལྟར་མཛད་དོ་ཞེས་མོར་དོ་ཀཱ་ཨི་ཡི་མདུན་དུ་བསྒྲགས་སོ། །",
      "12": "ཡང་མོར་དོ་ཀཱ་ཨི་སྔར་བཞིན་རྒྱལ་པོའི་མཁར་སྒོར་ཕྱིར་འོངས་པ་དང་། ཧ་མཱན་ནི་མྱ་ངན་དང་བཅས་མགོ་བཏུམས་ཏེ་མགྱོགས་པོར་རང་ཁྱིམ་དུ་ལོག",
      "13": "དེར་ཧ་མཱན་གྱིས་རང་གི་ཆུང་མ་ཙེ་རེ་ཟི་དང་གྲོགས་པོ་ཐམས་ཅད་ལ། རང་གི་མགོར་ཅི་ཡོང་བ་ཐམས་ཅད་བཤད་པ་དང་། ཁོའི་གྲོགས་པོའི་ཁྲོད་ཀྱི་ཤེས་རབ་ཅན་དག་དང་ཆུང་མ་ཙེ་རེ་ཟི་ཡིས། ཁྱོད་རང་མོར་དོ་ཀཱ་ཨིའི་མདུན་ནས་ཉམས་བཞིན་འདུག ཁོ་རང་ཡ་ཧུ་དཱ་པའི་རྒྱུད་ནས་ཆད་པ་ཡིན་ན་ཁྱོད་རང་ཁོའི་འགྲན་ཡར་མི་འོང་། དེའི་མདུན་དུ་ཁྱོད་རང་ཉམས་ངེས་ཡིན་ཞེས་སྨྲས་སོ། །",
      "14": "¶ དེ་དག་གི་གཏམ་མཇུག་མ་རྫོགས་པར་རྒྱལ་པོའི་ཉུག་རུམ་པ་རྣམས་སླེབས་ནས། ཧ་མཱན་མྱུར་དུ་ཨེས་སི་ཐེར་གྱིས་བཤམས་པའི་གསོལ་སྟོན་ལ་ཞུགས་པར་བསྐུལ་ཏོ། །"
    },
    "7": {
      "1": "¶ རྒྱལ་པོས་ཧ་མཱན་ཁྲིད་ནས་རྒྱལ་མོ་ཨེས་སི་ཐེར་གྱི་གསོལ་སྟོན་ལ་ཕེབས་ཤིང་།",
      "2": "ཉིན་གཉིས་པའི་སྐྱེམས་མགྲོན་གྱི་སྟེང་དུ་རྒྱལ་པོས་ཡང་བསྐྱར་རྒྱལ་མོ་ཨེས་སི་ཐེར་ལ། ལྕམ་ཨེས་སི་ཐེར་ལགས། ཁྱོད་ལ་ཅི་དགོས་ན་གནང་བར་བྱ། ཁྱོད་ཀྱིས་གང་ཞིག་ཞུས་ཀྱང་རྒྱལ་སྲིད་ཀྱི་ཕྱེད་ཀ་ཡིན་ཡང་ཁྱོད་ལ་གནང་བར་བྱའོ་ཞེས་གསུངས་པ་ལ།",
      "3": "ཨེས་སི་ཐེར་གྱིས་ལན་དུ། རྒྱལ་པོ་ལགས། བདག་ལ་ཁྱེད་ཀྱིས་སྙིང་རྗེས་གཟིགས་ཤིང་ཁྱེད་རང་ཐུགས་དགྱེས་ན། བདག་གི་སྲོག་སྐྱོབ་པ་ནི་ངའི་རེ་བ་ཡིན། བདག་གི་མི་མང་གི་དོན་དུ་ངས་ཞུ་བ་འབུལ།",
      "4": "མི་ཞིག་གིས་བདག་དང་བདག་གི་མི་རྣམས་ཚར་གཅོད་པ་དང་། འགུམ་པ་དང་། མེད་པར་བྱ་བའི་ཕྱིར་གཡོ་འཚོང་བྱས་ཚར་འདུག གལ་ཏེ་ངེད་རྣམས་གཞན་ལ་གཡོག་པོ་དང་གཡོག་མོར་བཙོངས་ན། བདག་ཀྱང་ཁ་རོག་འདུག་མོད། འོན་ཀྱང་བདག་ཅག་གི་སྡུག་བསྔལ་ནི་རྒྱལ་པོའི་གྱོང་གུད་དང་བསྡུར་ན་ཅི་ཡང་མ་ཡིན་ཞེས་ཞུས་པར།",
      "5": "རྒྱལ་པོ་ན་རེ། འདི་ལྟར་སྒྲུབ་ཕོད་པའི་སྙིང་སྟོབས་ཅན་དེ་ནི་སུ་ཡིན། གང་དུ་ཡོད་ཅེས་དྲིས་པ་ན།",
      "6": "ཨེས་སི་ཐེར་གྱིས། བཙན་གནོན་གཏོང་མཁན་དང་དགྲ་ནག་མི་ངན་དེ་ནི་ཧ་མཱན་འདི་ཡིན་ཞུས་པས། ཧ་མཱན་ནི་རྒྱལ་པོ་དང་རྒྱལ་མོའི་དྲུང་དུ་རྦད་དེ་སྐྲག་པར་གྱུར་ཏོ། །",
      "7": "¶ དེ་ནས་རྒྱལ་པོ་ཐུགས་ཤིན་ཏུ་ཁྲོས་ཤིང་། གསོལ་སྟོན་དང་ཁ་བྲལ་ནས་ཕོ་བྲང་གི་སྐྱེད་ཚལ་དུ་ཕྱིན། ཧ་མཱན་གྱིས་རྒྱལ་པོས་རང་ཉིད་ལ་ནག་ཉེས་འགེལ་རྒྱུའི་ཐུགས་ཐག་བཅད་པ་ཤེས་པ་དང་། དེར་བསྡད་ནས་རང་སྲོག་སྐྱོབ་ཕྱིར་རྒྱལ་མོ་ཨེས་སི་ཐེར་ལ་ཞུ་བ་ཕུལ་ཏོ། །",
      "8": "དེ་ནས་རྒྱལ་པོ་ཕོ་བྲང་གི་སྐྱེད་ཚལ་ནས་གསོལ་སྟོན་གྱི་གནས་སུ་ཕྱིར་ཕེབས་པ་དང་། ཨེས་སི་ཐེར་ཡོད་པའི་འབོལ་ཁྲིའི་ཁར་ཧ་མཱན་ཁ་སྦུབ་ཏུ་ལོག་ཡོད་པ་ལ། རྒྱལ་པོས་འདི་ལྟར། ཁོས་ཕོ་བྲང་ནང་ངའི་མདུན་དུ་རྒྱལ་མོར་བརྙས་བཅོས་བྱེད་ཕོད་དམ་ཞེས་གསུངས་མ་ཐག་ཏུ། མི་འགའ་ཞིག་གིས་ཧ་མཱན་གྱི་གདོང་བཀབ་བོ། །",
      "9": "དེ་ནས་ཉུག་རུམ་པའི་ཁྲོད་ཀྱི་རྒྱལ་པོར་ཞབས་ཕྱི་སྒྲུབ་མཁན་ཧར་པོ་ནཱ་ཟེར་བ་ན་རེ། གཟིགས་དང་། རྒྱལ་པོར་སྙན་ཞུ་ཕུལ་ཞིང་རྒྱལ་པོའི་སྲོག་སྐྱོབ་མཁན་མོར་དོ་ཀཱ་ཨིའི་ཕྱིར་དུ། མཐོ་ཚད་ཁྲུ་ལྔ་བཅུ་ཅན་གྱི་འཕྱར་ཤིང་ཞིག་ཧ་མཱན་གྱིས་རང་ཁྱིམ་དུ་བསླངས་འདུག་ཅེས་ཞུས་པ་ལ། རྒྱལ་པོས། ཧ་མཱན་དེའི་སྟེང་དུ་དཔྱང་བར་གྱིས་ཤིག་ཅེས་བཀའ་བསྒོས་པ་དང་།",
      "10": "དེ་ནས་མི་འགའ་ཞིག་གིས་མོར་དོ་ཀཱ་ཨིའི་ཆེད་དུ་གྲ་སྒྲིག་བྱས་པའི་འཕྱར་ཤིང་སྟེང་དུ་ཧ་མཱན་དཔྱངས་པ་ན། རྒྱལ་པོའི་ཐུགས་ཁྲོ་ད་གཟོད་ཞི་བར་གྱུར་ཏོ། །"
    },
    "8": {
      "1": "¶ ཉིན་མོ་དེ་ལ་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ་བཙན་གནོན་གཏོང་མཁན་ཧ་མཱན་གྱི་ཁྱིམ་གཞིས་ནི་རྒྱལ་མོ་ཨེས་སི་ཐེར་ལ་སྤྲད་དོ། །མོར་དོ་ཀཱ་ཨི་ཡང་རྒྱལ་པོའི་དྲུང་དུ་སླེབས། ཅི་ལ་ཞེ་ན། ཨེས་སི་ཐེར་གྱིས་མོར་དོ་ཀཱ་ཨི་དང་རང་ཉིད་ཀྱི་འབྲེལ་བ་ཅི་ཡིན་པ་རྒྱལ་པོར་ཞུས་པས་སོ། །",
      "2": "ཡང་རྒྱལ་པོས་ཧ་མཱན་གྱི་ལག་ནས་ཕྱིར་བླངས་པའི་ཉིད་ཀྱི་ཕྱག་གི་ཐམ་ག་དང་ལྡན་པའི་མཛུབ་དཀྲིས་ཕུད་ནས་དེ་མོར་དོ་ཀཱ་ཨི་ལ་གནང་ཞིང་། ཨེས་སི་ཐེར་གྱིས་ཧ་མཱན་གྱི་ཁྱིམ་གཞིས་མོར་དོ་ཀཱ་ཨི་ལ་བདག་གཉེར་བྱེད་དུ་བཅུག་གོ །",
      "3": "¶ ཨེས་སི་ཐེར་གྱིས་སླར་ཡང་རྒྱལ་པོའི་ཞབས་དྲུང་དུ་བཏུད་ནས། སྤྱན་ཆབ་བཞུར་བཞིན་སྨྲེ་སྔགས་བཏོན་ཅིང་། ཨ་གག་པ་ཧ་མཱན་གྱིས་ཡ་ཧུ་དཱ་པ་ལ་གནོད་བསྐྱལ་བའི་གྲོས་ངན་དེ་མེད་པར་མཛད་ཕྱིར་ནན་གྱིས་ཞུས་སོ། །",
      "4": "དེ་ནས་རྒྱལ་པོས་ཨེས་སི་ཐེར་གྱི་ཕྱོགས་སུ་གསེར་གྱི་འཁར་བ་བཏེགས་པས། ཨེས་སི་ཐེར་རྒྱལ་པོའི་དྲུང་དུ་ཡར་ལངས་ནས་འདི་ལྟར།",
      "5": "གལ་ཏེ་རྒྱལ་པོ་ཐུགས་དགྱེས་ཏེ་བདག་ལ་སྙིང་རྗེས་གཟིགས་པ་དང་། ཞུ་བ་འདི་རྒྱལ་པོས་ལུགས་དང་མཐུན་པར་དགོངས་ཤིང་རྒྱལ་པོ་བདག་ལ་མོས་ན། ཨ་གག་པ་ཧམ་མེ་དཱ་ཐའི་བུ་ཧ་མཱན་གྱིས་རྒྱལ་པོའི་ལྗོངས་སོ་སོའི་ཡ་ཧུ་དཱ་པ་རྣམས་ཚར་གཅོད་པར་བཀྲམས་པའི་ལྐོག་ཇུས་ཀྱི་བཀའ་ཤོག་དེ་མེད་པར་བཟོ་ཆེད། སླར་ཡང་བཀའ་མཆིད་གནང་བར་མཛོད།",
      "6": "བདག་གི་མི་རྣམས་ལ་འབྱུང་བར་འགྱུར་བའི་གནོད་འཚེ་དེར་ངས་ཇི་ལྟར་བལྟ་ནུས་སམ། བདག་གི་རུས་རྒྱུད་རྣམས་མེད་པར་བྱེད་པ་དེ་ངས་ཇི་ལྟར་བཟོད་ནུས་སམ་ཞེས་ཞུས་སོ། །",
      "7": "དེར་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་རྒྱལ་མོ་ཨེས་སི་ཐེར་དང་། ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་གཉིས་ལ་འདི་ལྟར། ལྟོས་ཤིག ཧ་མཱན་གྱིས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ་གནོད་བསྐྱལ་བསམས་པས། ངས་ཁོའི་ཁྱིམ་གཞིས་ཨེས་སི་ཐེར་ལ་སྤྲད་པ་དང་། ཧ་མཱན་ཡང་འཕྱར་ཤིང་སྟེང་དུ་དཔྱངས་པ་ཡིན།",
      "8": "ད་ལྟ་ཁྱོད་གཉིས་ཀྱིས་རང་གི་འདོད་མོས་བཞིན། རྒྱལ་པོ་ངའི་མིང་ལ་བརྟེན་ནས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ་བཀའ་མཆིད་ཕྲིས་ལ། བདག་གི་མཛུབ་དཀྲིས་ཀྱི་ཕྱག་རྒྱ་ཐོབས་ཤིག ཅིའི་ཕྱིར་ཞེ་ན། རྒྱལ་པོའི་མིང་ལ་བརྟེན་ནས་བྲིས་ཤིང་རྒྱལ་པོའི་མཛུབ་དཀྲིས་ཀྱི་ཕྱག་རྒྱ་བཏབ་པའི་བཀའ་ཤོག་ནི་མེད་པར་བཟོ་མི་ནུས་སོ་ཞེས་གསུངས་སོ། །",
      "9": "¶ དེ་ནས་ཟླ་བ་གསུམ་པ་སྟེ་སི་ཝཱན་ཟླ་བའི་ཚེས་ཉེར་གསུམ་ལ། རྒྱལ་པོའི་དྲུང་ཡིག་པ་རྣམས་བོས་ཡོང་ནས། མོར་དོ་ཀཱ་ཨིའི་བཀའ་བཞིན་དུ་ལྗོངས་སོ་སོའི་ཡི་གེ་དང་མི་རིགས་སོ་སོའི་སྐད་དང་། ཡ་ཧུ་དཱ་པའི་སྐད་དང་ཡི་གེ་ནང་བཀའ་མཆིད་བྲིས་ཏེ། རྒྱ་གར་ནས་གུ་ཤ་བྱ་བའི་ཡུལ་གྱི་བར་དུ་ཡོད་པའི་ལྗོངས་བརྒྱ་དང་ཉེར་བདུན་གྱི་ནང་དུ་གནས་པའི་ཡ་ཧུ་དཱ་པ་དང་། སྤྱི་དཔོན་རྣམས་དང་། འགོ་བདག་དང་དཔོན་རིགས་རྣམས་ལ་བསྒྲགས་སོ། །",
      "10": "མོར་དོ་ཀཱ་ཨི་ཡིས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་མཚན་ལ་བརྟེན་ནས་བྲིས་པའི་བཀའ་ཤོག་ལ་རྒྱལ་པོའི་མཛུབ་དཀྲིས་ཀྱིས་ཕྱག་རྒྱ་བཏབ་ཅིང་། འགྲོས་མྱུར་བའི་ཆིབས་ཆེན་ཞོན་མཁན་ལ་བསྐུར་ནས་ཡུལ་སོ་སོར་བཏང་ངོ་། །",
      "11": "¶ དེའང་རྒྱལ་པོས་ལྗོངས་དང་གྲོང་ཁྱེར་སོ་སོའི་ཡ་ཧུ་དཱ་པ་ཚང་མ་ཉིན་གཅིག་གི་རིང་། ཟླ་བ་བཅུ་གཉིས་པ་སྟེ་ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་གསུམ་ལ་འཚོག་དགོས་ཤིང་། རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་ལྗོངས་སོ་སོར་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་རང་སྲོག་སྐྱོབ་པ་དང་། ལྗོངས་དང་གྲོང་ཁྱེར་སོ་སོའི་ནང་དུ་ཡ་ཧུ་དཱ་པར་རྒོལ་བར་འགྱུར་བའི་དམག་དཔུང་དང་། དེ་དག་གི་བུད་མེད་དང་བུ་ཕྲུག་བཅས་པ་ཚར་གཅོད་པ་དང་། འགུམ་པ་དང་། མེད་པར་བྱེད་པ་དང་། དེ་དག་གི་རྒྱུ་ནོར་འཕྲོག་བཅོམ་བཏང་ཆོག་པའི་དགོངས་འཁྲོལ་གནང་ཡོད་པ་ཡིན་ནོ། །",
      "13": "བཀའ་ཤོག་འདྲ་བཤུས་བགྱིས་ནས་ལྗོངས་སོ་སོར་བཀྲམས་པ་དང་མི་མང་སོ་སོར་ཁྱབ་བསྒྲགས་བྱས་ཤིང་། ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་དགྲ་ནག་ལ་ཤ་འཁོན་ལེན་པའི་ཉིན་དེར་བསྒུག་ཅིང་སྟ་གོན་བྱེད་པའི་ཕྱིར་ཡིན།",
      "14": "དེ་ནས་འགྲོས་མྱུར་བའི་ཆིབས་ཆེན་ལ་ཞོན་པའི་བང་ཆེན་པ་རྣམས་རྒྱལ་པོའི་བཀའ་བཞིན་དུ་ཇི་མྱུར་གྱིས་སོང་བ་དང་། བཀའ་མཆིད་དེ་སོའུ་སཱན་མཁར་ཆེན་དུ་བསྒྲགས་སོ། །",
      "15": "¶ མོར་དོ་ཀཱ་ཨིས་རྒྱལ་པོའི་ན་བཟའ་དཀར་ལ་སྔོ་བ་ཞིག་གྱོན་པ་དང་། མགོ་ལ་གསེར་གྱི་ཅོད་པན་ཆེན་པོ་ཞིག་དང་། སོ་རས་སྲབ་བུའི་ལྭ་རིང་རྒྱ་སྨུག་ཅིག་གྱོན་ཏེ། རྒྱལ་པོའི་མདུན་ནས་ཕྱི་རོལ་ཏུ་སོང་བ་ན། སོའུ་སཱན་མཁར་ཆེན་གྱི་མི་རྣམས་ཀྱིས་དགའ་མགུ་རང་བའི་འབོད་སྒྲ་བསྒྲགས།",
      "16": "ཡ་ཧུ་དཱ་པ་རྣམས་ལ་གཟི་བརྗིད་ཐོབ་ཅིང་། དགའ་དགའ་སྐྱིད་སྐྱིད་ཀྱིས་བཀུར་བསྟི་ཡང་རེག་གོ །",
      "17": "རྒྱལ་པོའི་བཀའ་སླེབས་པའི་ལྗོངས་དང་གྲོང་ཁྱེར་རེ་རེའི་ནང་དུ། ཡ་ཧུ་དཱ་པ་རྣམས་དགའ་ཞིང་གསོལ་སྟོན་བཤམས་པ་དང་། ཉིན་དེ་ནི་དུས་ཆེན་དུ་གཏན་འཁེལ་བྱས་ལ། ཡ་ཧུ་དཱ་པ་ལ་སྐྲག་ནས་རྒྱལ་ཁབ་དེའི་མི་མང་པོ་ཡང་ཁོ་ཚོའི་གྲས་སུ་ཞུགས་སོ། །"
    },
    "9": {
      "1": "¶ དེ་ནས་ཟླ་བ་བཅུ་གཉིས་པ་སྟེ་ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་གསུམ་ལ། རྒྱལ་པོའི་བཀའ་ལག་བསྟར་བྱེད་པའི་དུས་ལ་སླེབས་ཏེ། དགྲ་བོས་ཡ་ཧུ་དཱ་པ་རྣམས་དབང་དུ་བསྡུ་བར་རེ་སྒུག་བྱས་ནའང་། དེ་ལས་ལྡོག་སྟེ། ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་རང་ལ་སྡང་བའི་མི་རྣམས་དབང་དུ་བསྡུས་སོ། །",
      "2": "ཡ་ཧུ་དཱ་པ་རྣམས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་ལྗོངས་སོ་སོའི་གྲོང་ཁྱེར་ནང་དུ་འཚོགས་པ་དང་། ཁོ་རྣམས་ལ་གནོད་སྐྱེལ་མཁན་ཐམས་ཅད་བསད་ཅིང་། མི་ཐམས་ཅད་དེ་དག་ལ་འཇིགས་པས་སུས་ཀྱང་འགོག་རྒོལ་བྱེད་མ་ནུས་སོ། །",
      "3": "དེ་ནས་ལྗོངས་སོ་སོའི་དཔོན་རིགས་དང་སྤྱི་དཔོན། འགོ་དཔོན། རྒྱལ་པོའི་ལས་གཉེར་པ་ཀུན་མོར་དོ་ཀཱ་ཨི་ལ་སྐྲག་པའི་རྐྱེན་གྱིས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ་དཔུང་གྲོགས་བྱས་སོ། །",
      "4": "ཡང་མོར་དོ་ཀཱ་ཨི་ནི་རྒྱལ་པོའི་ཕོ་བྲང་དུ་ཆེན་པོར་གྱུར་ཏེ། ཁོའི་སྙན་གྲགས་ལྗོངས་སོ་སོར་ཁྱབ་ཅིང་། ཁོའི་དབང་ཤུགས་ཉིན་རེ་ནས་ཉིན་རེར་ཆེ་རུ་རྒྱས་སོ། །",
      "5": "ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་དགྲ་ནག་ཐམས་ཅད་རལ་གྲིས་བརྒྱབ་ནས་བསད་ཅིང་མེད་པར་བྱས་པ་དང་། རང་ལ་སྡང་བ་ཀུན་ལ་འདོད་པ་ལྟར་དུ་བྱས་སོ། །",
      "6": "¶ ཡ་ཧུ་དཱ་པས་སོའུ་སཱན་མཁར་དུ་མི་ལྔ་བརྒྱ་བསད་ནས་མེད་པར་བྱས་སོ། །",
      "7": "ཁོ་རྣམས་ཀྱིས་པཱར་ཤན་དཱ་ཐ་དང་། དལ་ཕོན། ཨ་སི་པཱ་ཐཱ།",
      "8": "ཕོ་ར་ཐཱ། ཨ་དཱལ་ཡ། ཨ་རི་དཱ་ཐ།",
      "9": "པར་མས་ཏཱ། ཨ་རི་ས་ཨི། ཨ་རི་དཱ་ཨི། ཝ་ཡེ་ཟ་ཐཱ་བཅས་བསད།",
      "10": "དེ་བཅུ་པོ་ནི་ཧམ་མེ་དཱ་ཐའི་ཚ་བོ་དང་། ཡ་ཧུ་དཱ་པ་རྣམས་ལ་བཙན་གནོན་གཏོང་མཁན་ཧ་མཱན་གྱི་བུ་ཡིན། འོན་ཀྱང་ཡ་ཧུ་དཱ་པ་ཚོས་ཁོ་ཚོའི་རྒྱུ་ནོར་ལ་ལག་པས་མ་རེག་གོ །",
      "11": "¶ ཉིན་དེར། སོའུ་སཱན་མཁར་དུ་བསད་པའི་མིའི་བསྡོམས་གྲངས་ནི་རྒྱལ་པོའི་དྲུང་དུ་རྩིས་སྤྲོད་ཞུས་སོ། །",
      "12": "རྒྱལ་པོས་རྒྱལ་མོ་ཨེས་སི་ཐེར་ལ། ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་སོའུ་སཱན་མཁར་དུ་མི་ལྔ་བརྒྱ་བསད་པ་དང་། ཧ་མཱན་གྱི་བུ་བཅུ་པོའང་བསད་དེ་མེད་པར་བྱས་པས། ལྗོངས་གཞན་རྣམས་སུ་དེ་དག་གིས་ཅི་བྱས་མི་ཤེས། ཁྱོད་ལ་ད་དུང་ཅི་དགོས་ནའང་ངས་གནང་བར་བྱ། ད་དུང་ཞུ་བ་ཅི་ཞིག་ཡོད་ཀྱང་བདག་གིས་བསྒྲུབ་པར་བྱའོ་ཞེས་སྨྲས་སོ། །",
      "13": "དེ་ནས་ཨེས་སི་ཐེར་གྱིས། གལ་ཏེ་རྒྱལ་པོའི་ཐུགས་དགྱེས་ན། སོའུ་སཱན་མཁར་དུ་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ལ། སང་ཉིན་ཡང་དེ་རིང་གི་བཀའ་བཞིན་བྱེད་དུ་འཇུག་པ་དང་། ད་དུང་ཧ་མཱན་གྱི་བུ་བཅུ་པོའི་བེམ་པོ་འཕྱར་ཤིང་སྟེང་དཔྱང་བར་མཛོད་ཅེས་ཞུས་པས།",
      "14": "རྒྱལ་པོས་ཆོག་མཆན་གནང་ནས་བཀའ་ཤོག་སོའུ་སཱན་ཡོངས་ལ་ཁྱབ་ཅིང་། ཧ་མཱན་གྱི་བུ་བཅུ་པོའི་བེམ་པོ་ཡང་འཕྱར་ཤིང་སྟེང་དཔྱངས་པ་རེད།",
      "15": "དེ་ནས་སོའུ་སཱན་མཁར་དུ་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་བཞི་ལའང་གནས་དེར་འདུས་ཏེ། མི་སུམ་བརྒྱ་བསད་ཅིང་རྒྱུ་ནོར་འཕྲོག་བཅོམ་མ་བྱས་སོ། །",
      "16": "ཡང་རྒྱལ་པོའི་ལྗོངས་སོ་སོར་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་གཞན་རྣམས་ཀྱང་འདུས་ཏེ། རང་གི་ཚེ་སྲོག་ལ་སྲུང་སྐྱོབ་བྱས་ཤིང་། དགྲ་ལས་ཐར་ཏེ་ཞི་བར་གནས་པ་དང་། རང་ལ་སྡང་བ་རྣམས་ལས་ཁྲི་བདུན་དང་སྟོང་ལྔ་བསད། འོན་ཀྱང་རྒྱུ་ནོར་འཕྲོག་བཅོམ་མ་བྱས་སོ། །",
      "17": "¶ ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་གསུམ་ལ་དེ་ལྟར་བྱས་ཤིང་ཚེས་བཅུ་བཞི་ལ་ངལ་གསོ་བྱས་པ་དང་། ཉིན་མོ་དེ་ནི་དགའ་སྤྲོའི་དུས་ཆེན་ལ་གཏན་འཁེལ་བྱས་སོ། །",
      "18": "¶ ཡིན་ནའང་། སོའུ་སཱན་མཁར་དུ་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ཚེས་བཅུ་གསུམ་དང་བཅུ་བཞི་གཉིས་པོར་འདུས་ནས། ཚེས་བཅོ་ལྔ་ལ་ངལ་གསོ་བྱས་ཤིང་། ཉིན་མོ་དེ་ནི་དགའ་སྤྲོའི་དུས་ཆེན་ལ་གཏན་འཁེལ་བྱས་སོ། །",
      "19": "དེའི་ཕྱིར། མཁར་གྱང་མེད་པའི་ཡུལ་ཚོའམ་གྲོང་རྡལ་ལ་གནས་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས། ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་བཞི་ནི་གསོལ་སྟོན་བཤམས་ནས་སྤྲོ་སྐྱིད་གཏོང་བའི་ཉིན་བཟང་དུ་གཏན་འཁེལ་བྱས་ཤིང་། གཅིག་གིས་གཅིག་ལ་ལེགས་སྐྱེས་རྫོང་བའོ། །",
      "20": "¶ མོར་དོ་ཀཱ་ཨི་ཡིས་དོན་དེ་རྣམས་ཟིན་ཐོར་བཀོད་ནས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་ལྗོངས་སོ་སོ་སྟེ་ཐག་ཉེ་རིང་གང་སར་གནས་པའི་ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་ལ་ཡི་གེ་བསྐུར་ཞིང་།",
      "21": "ཨ་དཱར་ཟླ་བའི་ཚེས་བཅུ་བཞི་དང་བཅོ་ལྔ་གཉིས་པོ་ལོ་ལྟར་དུ་བརྩི་སྲུང་བྱེད་དགོས་པ་དང་།",
      "22": "ཉིན་དེ་གཉིས་ནི་ཡ་ཧུ་དཱ་པ་རྣམས་རང་གི་དགྲ་བོ་ལས་ཐར་ནས་ཞི་བདེ་ཐོབ་པ་དང་། སྡུག་བསྔལ་ནས་དགའ་སྤྲོ་དང་། མྱ་ངན་ནས་བདེ་སྐྱིད་དུ་གྱུར་པའི་ཉིན་བཟང་པོར་བརྩི་བར་མ་ཟད། ཉིན་དེ་གཉིས་ལ་གསོལ་སྟོན་བཤམས་ནས་སྤྲོ་སྐྱིད་གཏོང་བ་དང་། གཅིག་གིས་གཅིག་ལ་ལེགས་སྐྱེས་རྫོང་བ། དབུལ་ཕོངས་ལ་སྦྱིན་པ་གཏོང་བར་བསྒོས་སོ། །",
      "23": "དེ་ནས་ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་མོར་དོ་ཀཱ་ཨིས་ཁོ་རང་ཚོར་བྲིས་པའི་ཡི་གེ་བཞིན་དུ་བྱེད་པ་དང་། ཐོག་མར་ཇི་ལྟར་བསྲུངས་པ་བཞིན་ཉིན་མོ་དེ་གཉིས་བསྲུང་བར་ཁས་བླངས་སོ། །",
      "24": "¶ ཅིའི་ཕྱིར་ཞེ་ན། ཡ་ཧུ་དཱ་པ་རྣམས་ལ་བཙན་གནོན་གཏོང་མཁན་ཏེ་ཨ་གག་པ་ཧམ་མེ་དཱ་ཐའི་བུ་ཧ་མཱན་གྱིས། ཡ་ཧུ་དཱ་པ་རྣམས་མེད་པར་བྱེད་ཆེད་གྲོས་ངན་བཏབ་ཅིང་པུར་བྱ་བའི་རྒྱན་བླངས་ནའང་།",
      "25": "གྲོས་ངན་དེ་རྒྱལ་པོར་ཞུས་པ་ལ། རྒྱལ་པོས་བཀའ་མཆིད་བསྩལ་ནས་བཀའ་བསྒོས་པ་དང་། ཡ་ཧུ་དཱ་པ་རྣམས་མེད་པར་བཟོ་བའི་ཧ་མཱན་གྱི་གྲོས་ངན་དེ་ཁོ་རང་གི་མགོ་ལ་བབས་ཤིང་། ཁོ་དང་ཁོའི་བུ་ཐམས་ཅད་འཕྱར་ཤིང་སྟེང་དཔྱངས་པ་རེད།",
      "26": "དེའི་ཕྱིར། ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་པུར་གྱི་མིང་ལྟར་ཉིན་འདི་གཉིས་ལ་པུ་རིམ་ཞེས་བཏགས་སོ། །དེ་ཡང་ཡི་གེ་དེའི་ཚིག་དང་། ཁོ་ཚོ་རང་གིས་མཐོང་བ་དང་། ཁོ་ཚོ་རང་ཉིད་ཕྲད་པ་ལ་བརྟེན་ནས།",
      "27": "རང་ཉིད་དང་རང་གི་བུ་རྒྱུད་དང་། རང་གི་ཁྲོད་དུ་འདྲེས་པ་ཐམས་ཅད་ཀྱིས་ལོ་རེ་བཞིན་ཡིག་ཐོག་ཏུ་བཀོད་པ་ལྟར་དུ། དུས་ལྟར་ཉིན་དེ་གཉིས་ཀ་བསྲུང་བར་ཁས་བླངས་ཤིང་ནམ་ཡང་མ་ཆད་དོ། །",
      "28": "ལྗོངས་དང་གྲོང་ཁྱེར་སོ་སོ་དང་། དུས་རབས་རེ་རེ་དང་། ཁྱིམ་ཚང་རེ་རེ་བཅས་ཐམས་ཅད་ཀྱིས་ཉིན་མོ་འདི་གཉིས་དྲན་གསོ་བྱས་ཤིང་བསྲུངས་པ་དང་། པུ་རིམ་གྱི་ཉིན་མོ་འདི་གཉིས་ཡ་ཧུ་དཱ་པའི་ཁྲོད་དུ་ནམ་ཡང་ཆད་མི་རུང་བ་དང་། ཁོ་ཚོའི་མི་རབས་རྗེས་མ་རྣམས་ཀྱིས་ཀྱང་གཏན་ནས་བརྗེད་མི་ཆོག་པར་མཛད་དོ། །",
      "29": "¶ དེ་ནས་ཨ་བི་ཧ་ཡིལ་གྱི་བུ་མོ་སྟེ་རྒྱལ་མོ་ཨེས་སི་ཐེར་དང་། ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་གཉིས་ཀྱིས་དབང་ཆ་ཡོངས་རྫོགས་སྤྱད་ནས་པུ་རིམ་གྱི་སྐོར་ལ་འཕྲིན་ཡིག་གཉིས་པ་བྲིས་ཤིང་།",
      "30": "ཞི་དུལ་ཟོལ་མེད་ཀྱི་ཚིག་གིས་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོའི་རྒྱལ་ཁམས་སུ་ལྗོངས་བརྒྱ་དང་ཉེར་བདུན་གྱི་ནང་དུ་ཡོད་པའི་ཡ་ཧུ་དཱ་པ་ཐམས་ཅད་ལ་ཡི་གེ་བསྐུར་ནས།",
      "31": "ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་དང་རྒྱལ་མོ་ཨེས་སི་ཐེར་གཉིས་ཀྱི་གཏན་ཁེལ་བཞིན་དུ། དུས་ལྟར་པུ་རིམ་ཞེས་པའི་ཉིན་མོ་འདི་གཉིས་བརྩི་སྲུང་བྱེད་དགོས་པ་དང་། ཡང་ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱིས་རང་ཉིད་དང་བུ་རྒྱུད་རྣམས་ལ་ཁས་བླངས་པ་བཞིན་དུ། སྨྱུང་གནས་བསྲུང་བ་དང་ཞུ་འབོད་བྱེད་པར་བསྐུལ་ཏོ། །",
      "32": "ཡང་ཨེས་སི་ཐེར་གྱིས་པུ་རིམ་ཞེས་པའི་དུས་ཆེན་བསྲུང་དགོས་པའི་སྲོལ་ཡིག་གཏན་ལ་ཕབ་ཅིང་། དོན་དེ་ཡང་དེབ་ཐེར་ནང་དུ་བཀོད་ཡོད་དོ། །"
    },
    "10": {
      "1": "¶ དེ་ཡང་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ཡིས་སྐམ་ས་དང་རྒྱ་མཚོའི་གླིང་ཕྲན་རྣམས་ལ་དཔྱ་ཁྲལ་བཞག་གོ །",
      "2": "ཡང་ཁོང་གིས་དབང་དང་མཐུ་སྟོབས་ལ་བརྟེན་ནས་མཛད་པ་ཐམས་ཅད་དང་། ཁོང་གིས་མོར་དོ་ཀཱ་ཨི་ཆེན་པོར་མཛད་དེ་གོ་ས་གནང་བའི་ལོ་རྒྱུས་ནི། མཱ་ཏི་དང་ཏ་ཟིག་གི་རྒྱལ་པོ་རྣམས་ཀྱི་རྒྱལ་རབས་ཀྱི་དེབ་ཐེར་ནང་དུ་བྲིས་ཡོད་པ་མ་ཡིན་ནམ།",
      "3": "ཡ་ཧུ་དཱ་པ་མོར་དོ་ཀཱ་ཨི་ཡི་གོང་དུ་རྒྱལ་པོ་ཨ་ཧཱ་ཝེ་རོ་ལས་མེད་དེ། ཡ་ཧུ་དཱ་པའི་ཁྲོད་དུ་ཆེན་པོ་ཡིན་པ་དང་། རང་གི་མི་རྣམས་ཀྱི་ནང་དུ་འདང་ཆེན་ཞིག་ཡིན་ལ། དེས་རང་གི་མི་རྣམས་ཀྱི་ཕན་ཁེ་སྤེལ་བར་བརྩོན་ཏེ། མི་རབས་རྗེས་མ་ཐམས་ཅད་ཀྱི་དོན་དུ་བདེ་སྐྱིད་བསྙེགས་པའོ།། །།"
    }
  }
}
