{
  "name": "སྙན་མགུར།",
  "id": "སྙན་མགུར།",
  "order": 22,
  "chapters": {
    "1": {
      "1": "¶ སོ་ལོ་མོན་གྱིས་མཛད་པའི་མགུར་མཆོག་ཏུ་གྱུར་པ།",
      "2": "བརྩེ་སེམས་བདུད་རྩི་ལས་ཀྱང་མངར་བས་ན། ། ཁོང་གིས་ང་ལ་མཆུ་སྒྲོས་འོ་མཛད་ཤོག །",
      "3": "ཁྱེད་ཀྱི་སྤོས་ཀྱི་དྲི་བསུང་སྣ་ལ་ཞིམ། ། ཉིད་ཀྱི་མཚན་ནི་སྤོས་བཟང་བླུགས་འདྲ་ཡིན། ། དེའི་ཕྱིར་ལང་ཚོ་མ་རྣམས་ཁྱེད་ལ་དུངས། །",
      "4": "ཁྱེད་ཀྱིས་ངའི་སེམས་བཀུག་ནས་འགུག་གྱུར་ཅིག ། ངེད་གཉིས་ཁྱེད་ཀྱི་རྗེས་སུ་འབྲངས་ནས་རྒྱུག ། རྒྱལ་པོས་ང་རང་གཟིམས་ཁང་ནང་དུ་ཁྲིད། །",
      "5": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་བུ་མོ་རྣམས། ། བདག་གི་ཤ་མདངས་ནག་ཀྱང་མཛེས་སྡུག་ལྡན། ། དེ་ནི་ཀེ༌དཱར་གྱི་ནི་གུར་དང་མཚུངས། ། སོ་ལོ་མོན་གྱི་ཡོལ་བ་ལྟར་དུ་ཡིན། །",
      "6": "ངའི་གདོང་ཉི་མས་ཚིག་ནས་ནག་པོར་གྱུར། ། མཐོང་ཆུང་མིག་གིས་ང་ལ་མ་བལྟ་རོགས། ། མ་གཅིག་སྤུན་རྣམས་བདག་ལ་རབ་ཏུ་ཁྲོས། ། རྒུན་ཚལ་བསྲུང་དུ་ང་རང་བསྐོས་པ་དང་། ། ང་ཡི་རྒུན་ཚལ་བསྐྱུར་ནས་བདག་མེད་ལུས། །",
      "7": "ཀྱེ་ཀྱེ་ང་ཡི་བྱམས་པ་ལགས། ། ཁྱེད་ཀྱིས་གང་དུ་ལུག་འཚོ་འམ། ། ཉིན་གུང་ལུག་ཁྱུ་གང་དུ་གསོ། ། ཐམས་ཅད་བདག་ལ་སྨྲ་བར་མཛོད། ། ཁྱེད་ཀྱི་གྲོགས་པོའི་ལུག་ཁྱུ་འགྲམ། ། གདོང་ཁེབས་ཅན་ལྟར་འགྱུར་དོན་ཅི། །",
      "8": "མཛེས་མའི་མཆོག་ཁྱེད་རྒྱུས་མེད་ན། ། ལུག་ཁྱུའི་རྐང་རྗེས་དེད་ནས་སོང་། ། རྫི་བོའི་གུར་གྱི་ཉེ་འཁོར་དུ། ། རང་གི་རེའུ་རྣམས་འཚོ་བར་མཛོད། །",
      "9": "ཀྱེ་ཀྱེ་ང་ཡི་སྙིང་སྡུག་ཁྱེད་རང་ནི། ། ཕཱར་ཨོལ་ཤིང་རྟའི་རྒོད་མ་བཞིན་དུ་མཛེས། །",
      "10": "ཁྱེད་ཀྱི་མཁུར་ཚོས་ལན་བུ་དག་གིས་མཛེས། ། ཁྱེད་ཀྱི་མགུལ་ནི་རིན་པོ་ཆེ་ཡིས་བརྒྱན། །",
      "11": "ང་ཚོས་དངུལ་གྱིས་བརྒྱན་པ་ཡི། ། གསེར་གྱི་རྣ་ལོང་ཁྱེད་ལ་བཟོ། །",
      "12": "རྒྱལ་པོ་ཁོང་ཉིད་འབོལ་ཁྲི་ལ་བཞུགས་དུས། ། ང་ཡི་ནཱར་དི་སྤོས་ཀྱི་དྲི་བསུང་འཐུལ། །",
      "13": "ང་ཡི་དགའ་གྲོགས་གུ་གུལ་ཐུམ་གཅིག་འདྲ། ། ཁོང་ནི་ནམ་རྒྱུན་ང་ཡི་བྲང་ཁར་ཡོད། །",
      "14": "ང་ཡི་དགའ་གྲོགས་ཨེན་གེ་དི་ཡུལ་གྱི། ། རྒུན་ཚལ་ནང་གི་མེ་ཏོག་གླང་སྣ་བཞིན། །",
      "15": "ཀྱེ་ཀྱེ་ང་ཡི་སྙིང་སྡུག་ལགས། ། ཁྱེད་ཀྱི་བྱད་གཟུགས་རབ་ཏུ་མཛེས། ། ཁྱེད་ཀྱི་བྱད་གཟུགས་རབ་ཏུ་མཛེས། ། ཕུག་རོན་སྤྱན་ཟུང་ཁྱེད་ལ་ལྡན། །",
      "16": "ཀྱེ་ཀྱེ་གཟིགས་དང་ང་ཡི་དགའ་གྲོགས་ལགས། ། ཁྱེད་ཀྱི་ཞལ་རས་མཚར་ཞིང་ཡིད་དུ་འོང་། ། མཛེས་སྡུག་སྤང་ལྗོངས་ང་ཚོའི་མལ་ཁྲི་ཡིན། །",
      "17": "ངེད་ཀྱི་ཁང་པའི་གདུང་མ་ཐང་ཤིང་དང་། ། ཁང་པའི་ལྕམ་གདུང་ལ་ནི་གསོམ་ཤིང་ཡོད། །"
    },
    "2": {
      "1": "¶ ང་ནི་ཤཱ་རོན་ཡུལ་གྱི་རྒྱ་སེ་དང་། ། ལུང་པའི་ནང་གི་མེ་ཏོག་ཀུ་མུད་ཡིན། །",
      "2": "ཚེར་མའི་ཁྲོད་ཀྱི་མེ་ཏོག་ཀུ་མུད་ལྟར། ། ང་ཡི་སྙིང་སྡུག་བུ་མོ་ཀུན་ལས་མཆོག །",
      "3": "ནགས་ལ་སྐྱེས་པའི་ཀུ་ཤུ་ཤིང་བཞིན་དུ། ། ང་ཡི་དགའ་གྲོགས་སྐྱེས་པའི་ཁྲོད་དུ་ཡོད། ། བདག་ནི་དགའ་ཞིང་ཁོང་གི་གྲིབ་བསིལ་འོག ། བསྡད་དེ་ཁོང་གི་ཤིང་ཏོག་མངར་མོར་རོལ། །",
      "4": "ཁོང་གིས་བདག་ནི་གསོལ་སྟོན་ཁང་ལ་ཁྲིད། ། ང་ཡི་སྟེང་དུ་བརྩེ་བའི་དར་ཆ་བསྒྲེངས། །",
      "5": "བདག་ནི་དུངས་སེམས་དབང་གིས་རབ་གདུངས་པས། ། རྒུན་འབྲུམ་སྐམ་པོས་བདག་ལ་སྟོབས་བཅུག་ནས། ། ཀུ་ཤུས་བདག་གི་སེམས་ལ་བདེ་བ་སྩོལ། །",
      "6": "ཁོང་ཕྱག་གཡོན་པས་བདག་གི་མགོ་བོ་སྐྱོར། ། ཁོང་ཕྱག་གཡས་པས་བདག་གི་ལུས་ཡོངས་འཁྱུད། །",
      "7": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་བུ་མོ་རྣམས། ། ང་ཡི་དགའ་གྲོགས་དགྱེས་ཏེ་མ་བཞེངས་བར། ། ཁྱེད་ཚོས་ཁོང་ཉིད་མནལ་ལས་མི་སློང་ཕྱིར། ། བདག་གིས་དགོ་དང་ཐང་གི་ཡུ་མོ་གཉིས། ། དཔང་དུ་བཙུགས་ནས་ཁྱེད་ཚོར་མནའ་འགེལ་ལོ། །",
      "8": "ང་ཡི་དགའ་གྲོགས་གསུང་སྐད་ལ་ཉོན་དང་། ། ཁོང་ཉིད་རི་དང་ལ་ལུང་བརྒལ་ནས་ནི། ། ཚུར་རོལ་འབྱོན་བཞིན་པ་ལ་ལྟོས་ཤིག་ཀྱེ། །",
      "9": "ང་ཡི་དགའ་གྲོགས་དགོ་དང་ཤྭ་ཕྲུག་འདྲ། ། ལྟོས་ཤིག་ཁོང་ནི་ངེད་ཀྱི་རྩིག་འདབས་སླེབས། ། དཀར་ཁུང་ནང་དུ་བདག་ལ་གཟིགས་པ་དང་། ཤིང་དྲའི་བར་ནས་བདག་ལ་ནན་གྱིས་ལྟ། །",
      "10": "ང་ཡི་དགའ་གྲོགས་བདག་ལ་འདི་སྐད་གསུངས། ། ང་ཡི་སྙིང་སྡུག་བཟང་པོ་བཞིན་བཟང་མ། ། ཡར་ལ་བཞེངས་ཏེ་བདག་དང་མཉམ་དུ་འགྲོ། །",
      "11": "ཅི་ལ་ཟེར་ན་དགུན་དུས་རྫོགས་ཟིན་ལ། ། ཆར་གྱི་དུས་ཀྱང་འདས་ནས་སོང་ཟིན་ཏོ། །",
      "12": "ས་གཞི་ཡོངས་སུ་མེ་ཏོག་རྣམ་པར་བཀྲ། ། བྱིའུས་གསུང་སྙན་སྒྲོག་པའི་དུས་ལ་བབས། ། ང་ཚོའི་ཡུལ་དུ་ཐི་བའི་གསུང་སྐད་ཐོས། །",
      "13": "སེ་ཡབ་ཤིང་གི་ཤིང་ཏོག་རིམ་གྱིས་སྨིན། ། རྒུན་འབྲུམ་མེ་ཏོག་དྲི་ཞིམ་ཕྱོགས་བཞིར་འཐུལ། ། ང་ཡི་སྙིང་སྡུག་ང་ཡི་བཞིན་བཟང་མ། ། ཡར་ལ་བཞེངས་ཏེ་ང་དང་མཉམ་དུ་འགྲོ། །",
      "14": "ཀྱེ་ཀྱེ་ང་ཡི་ཕུག་རོན་ཁྱེད་རང་ནི། ། བྲག་སྲུབ་རི་གཟར་ཕུག་ཏུ་ཡིབ་སྡོད་དེ། ། ཁྱེད་ཀྱི་ཞལ་རས་ང་ལ་སྟོན་པར་མཛོད། ། ཁྱེད་ཀྱི་གསུང་སྐད་ང་ལ་ཐོས་འཇུག་རོགས། ། ཅི་ལ་ཟེར་ན་ཁྱེད་ཀྱི་གསུང་སྐད་སྙན། ། ཁྱེད་ཀྱི་ཞལ་རས་མཛེས་ཤིང་ལྟ་ན་སྡུག །",
      "15": "ང་ཚོའི་རྒུན་འབྲུམ་ཤིང་ལ་མེ་ཏོག་བཞད། ། དེ་བས་ཁྱེད་ཀྱིས་རྒུན་ཚལ་བརླག་པ་ཡི། ། ཝ་མོ་ཝ་ཕྲུག་ང་ཚོའི་དོན་དུ་འཛིན། །",
      "16": "ང་ཡི་དགའ་གྲོགས་ང་ལ་དབང་བ་ལྟར། ། ང་ཡི་ཡོད་ཚད་ཁོང་ལ་དབང་བ་ཡིན། ། ཁོང་གིས་ཀུ་མུད་གསེབ་ནས་ལུག་ཁྱུ་འཚོ། །",
      "17": "ཉི་མ་ནུབ་ནས་བསིལ་རླུང་ལྡང་དུས་སུ། ། ཁྱེད་ནི་དགོ་བ་དང་ནི་ཤྭ་ཕྲུག་ལྟར། ། བེ་ཐེར་རི་ནས་ལོག་ཤོག་ངའི་དགའ་གྲོགས། །"
    },
    "3": {
      "1": "¶ མཚན་མོར་རང་གི་མལ་ཁྲིའི་སྟེང་། ། ང་ཡི་སེམས་ཀྱི་བྱམས་པ་དེ། ། ཡང་ཡང་བཙལ་མོད་ངས་མ་རྙེད། །",
      "2": "དེ་ནས་ང་རང་ཡར་ལངས་ནས། ། གྲོང་ཁྱེར་ནང་དུ་བསྐྱོད་ནས་ནི། ། སྲང་ལམ་ཐང་ཆེན་དག་བརྒྱུད་ཅིང་། ། ང་ཡི་སེམས་ཀྱི་བྱམས་པ་དེ། ། ཡང་ཡང་བཙལ་མོད་ངས་མ་རྙེད། །",
      "3": "སྐོར་ཞིབ་བྱས་ནས་སྐྱོད་པ་ཡི། ། གྲོང་ཁྱེར་སྲུང་མཁན་བདག་དང་ཕྲད། ། ང་ཡི་སྙིང་གི་བྱམས་པ་དེ། ། ཁྱེད་ཚོས་མཐོང་ངམ་ཞེས་དྲིས་སོ། །",
      "4": "བདག་ནི་དེ་དག་ལས་བྲལ་རྗེས། ། སྙིང་གི་བྱམས་པ་དང་ཕྲད་བྱུང་། ། ང་ཡིས་ཁོང་ལ་འཇུས་ནས་ནི། ། ཁོང་ཉིད་འགྲོ་རུ་མ་བཅུག་པར། ། རང་གི་མ་ཡི་ཁྱིམ་གཞིས་ཏེ། ། ང་རང་མངལ་དུ་ཁུར་མཁན་གྱི། ། གཟིམ་ཆུང་ནང་དུ་ཁྲིད་པ་ཡིན། །",
      "5": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་བུ་མོ་རྣམས། ། ང་ཡི་དགའ་གྲོགས་དགྱེས་ཏེ་མ་བཞེངས་བར། ། ཁྱེད་ཚོས་ཁོང་ཉིད་མནལ་ལས་མི་སློང་ཕྱིར། ། བདག་གིས་དགོ་དང་ཐང་གི་ཡུ་མོ་གཉིས། ། དཔང་དུ་བཙུགས་ནས་ཁྱེད་ཚོར་མནའ་འགེལ་ལོ། །",
      "6": "གུ་གུལ་དང་ནི་སྤོས་དཀར་དང་། ། ཚོང་པའི་སྤོས་ཀྱི་དྲི་བསུང་གིས། ། ཀུན་ནས་བྱུགས་ཤིང་དབེན་སྟོང་ནས། ། དུ་བའི་ཀ་ལྟར་འབྱོན་པ་སུ། །",
      "7": "དེ་ནི་སོ་ལོ་མོན་གྱི་ཁྱོགས་ཁྲི་ཡིན། ། ཡེས་ར་ཨེལ་གྱི་དཔའ་བོ་དྲུག་ཅུ་ཡིས། ། དེ་ཡི་ཕྱོགས་བཞིར་ཡོངས་སུ་བསྐོར་ནས་ཡོད། །",
      "8": "ཀུན་གྱིས་རལ་གྲི་ལག་ཏུ་བཅངས། ། དེ་ཚོར་དམག་གི་རྩལ་དང་ལྡན། ། མཚན་མོའི་འཇིགས་པ་འགོག་པའི་ཆེད། ། རལ་གྲི་དཔྱི་ལ་བཏགས་ནས་འདུག །",
      "9": "རྒྱལ་པོ་སོ་ལོ་མོན་ཉིད་ཀྱིས། ། ལེ་པཱ་ནོན་གྱི་ཤིང་གིས་ནི། ། རང་ལ་ཁྱོགས་ཁྲི་ཞིག་བཟོས་ཏེ། །",
      "10": "ཁྱོགས་ཁྲིའི་ཀ་བ་དངུལ་ལས་བཟོས། ། ཁྱོགས་ཁྲིའི་མཐིལ་ནི་གསེར་གྱིས་གྲུབ། ། གདན་གྱི་ཁ་དོག་རྒྱ་སྨུག་ཡིན། ། དེའི་ནང་ཡེ་རུ་སཱ་ལེམ་གྱི། ། བུ་མོ་རྣམས་ཀྱི་བརྩེ་བས་ཁེངས། །",
      "11": "ཀྱེ་ཀྱེ་ཛ་ཡན་བུ་མོ་ཕྱིར་བུད་དང་། ། རྒྱལ་པོ་སོ་ལོ་མོན་གྱི་བག་སྟོན་ཉིན། ། ཁོང་གི་དབུ་ལ་ཅོད་པན་གྱིས་བརྒྱན་ཏེ། ། ཁོང་གི་ཡིད་སེམས་དགའ་བ་འབུམ་གྱིས་མཉེས། ། ཡུམ་གྱིས་བསྐོན་པའི་ཅོད་པན་ལ་ལྟོས་ཤིག །"
    },
    "4": {
      "1": "ང་ཡི་སྙིང་སྡུག་ཁྱེད་ཀྱི་བྱད་གཟུགས་རབ་ཏུ་མཛེས། ། གདོང་ཁེབས་འོག་ཏུ་ཕུག་རོན་ལྟ་བུའི་མིག་ཟུང་ལྡན། ། ཁྱེད་ཀྱི་སྐྲ་ལོ་དག་ནི་གིལ་ཨད་རི་བོའི་ངོགས། ། ཐུར་དུ་འབབ་པའི་ར་ཁྱུ་དང་ནི་ཀུན་ནས་མཚུངས། །",
      "2": "ཆ་ནི་འགྲིག་ཅིང་ཁེར་སྐྱེས་མིན་པའི་ཁྱེད་ཀྱི་ཚེམས། ། ལུག་བལ་བྲེགས་པའི་མ་མོ་དཀར་བཀྲུས་ཐོན་པ་འདྲ། །",
      "3": "ཁྱེད་ཀྱི་མཆུ་སྒྲོས་མཚལ་གྱི་སྣལ་མ་འདྲ། ། ཁྱེད་ཀྱི་སྨྲ་སྒོ་མཛེས་ཤིང་ལྟ་ན་སྡུག ། གདོང་ཁེབས་འོག་གི་ཁྱེད་ཀྱི་མཁུར་ཚོས་ནི། ། དམར་མདངས་བཀྲ་བའི་སེ་འབྲུ་ཕྱེད་ཀ་བཞིན། །",
      "4": "ཁྱེད་ཀྱི་མཇིང་ནི་དཱ་བིད་ཀྱིས་བརྩིགས་པའི། ། བང་རིམ་ལྡན་པའི་ལྕོག་མཁར་དང་མཚུངས་ཤིང་། ། དེ་ཡི་སྟེང་དུ་ཕུབ་ནི་སྟོང་ཕྲག་དཔྱངས། ། ཐམས་ཅད་དཔའ་རྒོད་དག་གི་ཕུབ་ཡིན་ནོ། །",
      "5": "ཁྱེད་ཀྱི་བྲང་ཁའི་ནུ་མ་ཟུང་དེ་ནི། ། མེ་ཏོག་ཀུ་མུད་གསེབ་ཏུ་རྩྭ་ཟ་བའི། ། དགོ་བའི་དགོ་ཕྲུག་མཚེ་མར་ཀུན་ནས་མཚུངས། །",
      "6": "ཉི་མ་ནུབ་སྟེ་བསིལ་རླུང་ལྡང་དུས་སུ། ། བདག་ནི་གུ་གུལ་རི་བོའི་ཕྱོགས་སུ་དང་། དྲི་ཞིམ་སྤོས་དཀར་སྒང་ལ་འགྲོ་བར་བྱ། །",
      "7": "ང་ཡི་སྙིང་སྡུག་ཁྱེད་ནི་ཀུན་ནས་མཛེས། ། ཁྱེད་ཀྱི་ལུས་ལ་སྐྱོན་ཆག་གང་ཡང་མེད། །",
      "8": "ཀྱེ་ཀྱེ་ང་ཡི་བག་མ་ལགས། ། ཁྱེད་རང་ང་དང་མཉམ་དུ་ནི། ། ལེ་པཱ་ནོན་དང་འབྲལ་བར་མཛོད། ། ལེ་པཱ་ནོན་དང་འབྲལ་བར་མཛོད། ། ཨ་མ་རཱ་དང་སེ་ནིར་དང་། ། ཧེར་མོན་རི་བོའི་རྩེ་མོ་དང་། སེང་གེའི་ཚང་དང་གཟིག་གི་རི། ། གནས་དེ་རྣམས་ལས་མར་ཐོན་ཤོག །",
      "9": "¶ ང་ཡི་ལྕམ་དང་བག་མ་ལགས། ། ཁྱེད་ཀྱི་མིག་གིས་བལྟས་ཙམ་དང་། ། མགུལ་ལ་བརྒྱན་པའི་སྐེ་འཕྲེང་གིས། ། ང་ཡི་ཡིད་སེམས་ཀུན་ནས་ཕྲོགས། །",
      "10": "ང་ཡི་ལྕམ་དང་བག་མ་ལགས། ། ཁྱེད་ཀྱི་བརྩེ་སེམས་མཛེས་པ་ལ། ། རྒུན་ཆང་ལས་ཀྱང་ལྷག་ཏུ་མངར། ། ཁྱེད་ཀྱི་སྤོས་ཆུའི་དྲི་ཞིམ་ནི། ། དྲི་བཟང་རིགས་ཀྱི་མཆོག་ཡིན་ནོ། །",
      "11": "ཀྱེ་ཀྱེ་ང་ཡི་བག་མ་ལགས། ། ཁྱེད་ཀྱི་མཆུ་ལས་སྦྲང་ཚང་བཞིན། ། སྦྲང་རྩི་མངར་མོ་ཐིགས་པ་དང་། ། ལྗགས་འོག་སྦྲང་རྩི་འོ་མ་ཡོད། ། ཁྱེད་ཀྱི་ན་བཟའི་དྲི་བསུང་ནི། ། ལེ་པཱ་ནོན་གྱི་དྲི་དང་མཚུངས། །",
      "12": "ང་ཡི་ལྕམ་དང་བག་མ་ཁྱེད། ། སྒོ་མོ་བཅད་པའི་སྐྱེད་ཚལ་དང་། ཁུངས་མིག་བཅད་པའི་ཆུ་མིག་དང་། ཁ་གཅོད་བརྒྱབ་པའི་ཁྲོན་པ་འདྲ། །",
      "13": "ཁྱེད་ཀྱིས་བཏབ་པའི་སྐྱེད་ཚལ་དུ། ། སེ་འབྲུ་ཤིང་ལ་འབྲས་བུ་ཐོགས། ། ད་དུང་མེ་ཏོག་གླང་སྣ་དང་། ། སྤང་སྤོས་ནཱར་དིའི་ཤིང་རྣམས་ཡོད། །",
      "14": "སྤང་སྤོས་ནཱར་དི་དང་ནི་གུར་ཀུམ་དང་། ། ཤུ་དག་ཤིང་ཚ་དང་ནི་སྤོས་དཀར་ཤིང་། ། གུ་གུལ་ཨ་ག་རུ་བཅས་རིན་ཆེན་པོའི། ། བསུང་རྫས་རིགས་ཀུན་དེ་རུ་འཛོམས་པ་ཡིན། །",
      "15": "ཁྱེད་ནི་སྐྱེད་ཚལ་ནང་གི་ཆུ་མིག་དང་། ། ཆུ་རྒྱུན་བཞུར་བའི་ཁྲོན་པ་ཡིན་ལགས་ཤིང་། ། ལེ་པཱ་ནོན་ནས་བཞུར་བའི་ཆུ་ཀླུང་ཡིན། །",
      "16": "ཀྱེ་ཀྱེ་བྱང་རླུང་ལྷོ་རླུང་ལྡང་བར་གྱིས། ། ང་ཡི་སྐྱེད་ཚལ་ནང་དུ་ལྡང་ནས་ནི། ། དྲི་ཞིམ་ཕྱོགས་བཞིར་འཐུལ་དུ་འཇུག་པར་མཛོད། ། ང་ཡི་དགའ་གྲོགས་རང་གི་སྐྱེད་ཚལ་དུ། ། བྱོན་ནས་ཤིང་ཏོག་མངར་མོ་བཞེས་གྱུར་ཅིག །"
    },
    "5": {
      "1": "ང་ཡི་ལྕམ་དང་བག་མ་ལགས། ། ང་ནི་སྐྱེད་ཚལ་དུ་ཕྱིན་ནས། ། གུ་གུལ་དང་ནི་སྤོས་བསྡུས་ཏེ། ། སྦྲང་ཚང་དང་བཅས་སྦྲང་རྩི་ཟོས། ། རྒུན་ཆང་དང་ནི་འོ་མ་འཐུངས། །",
      "2": "ངའི་ལུས་མལ་དུ་ཉལ་ན་ཡང་། ། བདག་སེམས་གཉིད་ལས་སད་ཡོད་དོ། ། དགའ་གྲོགས་ཀྱིས་ནི་སྒོ་རྡུང་བའི། ། སྐད་སྒྲ་ཡང་ནས་ཡང་དུ་ཐོས། །",
      "3": "དེ་ཡི་ལན་དུ་འདི་ལྟར་ཞུས། ། ང་ཡིས་གྱོན་གོས་ཕུད་ཟིན་པས། ། དེ་ནི་ཡང་བསྐྱར་ཇི་ལྟར་གྱོན། ། ང་ཡིས་རྐང་པ་བཀྲུས་ཟིན་པས། ། དེ་ནི་ཇི་ལྟར་བཙོག་པར་བྱ། །",
      "4": "ང་ཡི་དགའ་གྲོགས་ཀྱིས་ནི་ཨི་ཁུང་ལས། ། ཉིད་ཀྱི་ཕྱག་ནི་ནང་དུ་བརྐྱངས་པས་ན། ། ཁོང་གི་དོན་དུ་ང་ལ་སེམས་འགུལ་ཐེབས། །",
      "5": "ང་ཡི་དགའ་གྲོགས་ལ་ནི་སྒོ་འབྱེད་དུ། ། ཡར་ལ་ལངས་དུས་ང་ཡི་ལག་ཟུང་ལས། ། གུ་གུལ་ཐིགས་ཤིང་ང་ཡི་མཛུབ་མོ་ལས། ། གུ་གུལ་དྲི་ཞིམ་སྒོ་གཏན་སྟེང་ལ་ཐིགས། །",
      "6": "ང་ཡིས་དགའ་གྲོགས་ཁོང་ལ་ཕྱེས་པ་ལ། ། ཁོང་ཉིད་ཞལ་ཕྱིར་འཁོར་ནས་གྱེས་ཟིན་ཏོ། ། ཁོང་གི་གསུང་སྐད་ཐོས་དུས་སུ། ། རང་སེམས་རང་ལ་མ་དབང་ངོ་། ། ཁོང་ཉིད་བཙལ་ཡང་རྙེད་མ་བྱུང་། ། ཡང་ཡང་བོས་ཀྱང་ལན་མ་ཐོབ། །",
      "7": "དེ་ནས་གྲོང་ཁྱེར་ནང་འཁོར་བའི། ། བྱ་ར་པ་དང་བདག་ཕྲད་བྱུང་། ། བདག་ལ་བརྡུངས་ནས་རྨས་སུ་བཅུག ། ལྕགས་རིའི་སོ་པ་རྣམས་ཀྱིས་ཀྱང་། ། ང་ཡི་བེར་ཐུལ་བཤུས་ནས་ཁྱེར། །",
      "8": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་གྱི་བུ་མོ། ། བདག་གིས་ཁྱེད་ཚོར་འདི་བཞིན་གདམས་པར་བྱ། ། ཁྱེད་ཚོ་ང་ཡི་དགའ་གྲོགས་དང་ཕྲད་ན། ། ང་ནི་བརྩེ་དུངས་དབང་གིས་གདུང་ཞེས་སྨྲོས། །",
      "9": "ཁྱེད་ཀྱི་དགའ་གྲོགས་གཞན་ལས་ལྷག་པ་ཅི། ། ཀྱེ་ཀྱེ་བུད་མེད་ནང་གི་མཛེས་མའི་མཆོག ། ང་ཚོར་ཡང་ཡང་དེ་འདྲའི་མནའ་འགེལ་བས། ། ཁྱེད་ཀྱི་དགའ་གྲོགས་གཞན་ལས་ལྷག་པ་ཅི། །",
      "10": "ང་ཡི་དགའ་གྲོགས་དཀར་ལ་དམར་མདངས་རྒྱས། ། འཇིག་རྟེན་སྐྱེས་བོ་ཁྲི་ཕྲག་ལས་ཀྱང་མཆོག །",
      "11": "ཁོང་གི་དབུ་ནི་ལྷད་མེད་གསེར་དང་འདྲ། ། སྐྲ་ལོ་འཁྱིལ་ཞིང་ཕོ་རོག་ལྟར་ནག་གོ །",
      "12": "སྤྱན་ནི་གཙང་པོ་འགྲམ་གྱི་ཕུག་རོན་ལྟར། ། འོ་མའི་ཁྲུས་ལ་ཞུགས་ནས་ལེགས་པར་བཀོད། །",
      "13": "མཁུར་ཚོས་གཉིས་ནི་མེ་ཏོག་ར་བའི་ནང་། ། དྲི་ཞིམ་ཕྱོགས་བཞིར་འཐུལ་བའི་མེ་ཏོག་འདྲ། ། མཆུ་སྒྲོས་ཟུང་ནི་མེ་ཏོག་ཀུ་མུད་བཞིན། ། དེ་ལས་གུ་གུལ་རྩི་བཅུད་ཐིགས་པ་ཡིན། །",
      "14": "ཕྱག་ངར་བཻཌཱུརྱས་བརྒྱན་པའི། ། གསེར་གྱི་གདུབ་བུ་དང་མཚུངས་ཞིང་། ། སྐུ་ནི་བ་སོ་ལྷག་གེ་བ། ། དབང་སྔོན་གྱིས་ནི་བརྒྱན་དང་མཚུངས། །",
      "15": "ཞབས་ནི་ཀ་མ་རུ་ཡི་ཀ་བར་མཚུངས། ། ལྷད་མེད་གསེར་གྱི་ཞབས་རའི་སྟེང་དུ་བཞེངས། ། ཁོང་གི་གཟུགས་བརྙན་ལེ་པཱ་ནོན་དང་འདྲ། ། ཐང་ཤིང་ལྟར་དུ་མཛེས་ཤིང་ལྟ་ན་སྡུག །",
      "16": "ཁོང་གི་ཞལ་ནི་རབ་ཏུ་མངར་བ་དང་། ། ཐམས་ཅད་ཡིད་དུ་འོང་བ་ཡིན་ལགས་ཤིང་། ། ཡེ་རུ་སཱ་ལེམ་ཡུལ་གྱི་བུ་མོ་རྣམས། ། དེ་ནི་ང་ཡི་སྙིང་གི་དགའ་གྲོགས་དང་། ། དེ་ནི་ང་ཡི་གྲོགས་ཀྱི་མཆོག་ལགས་སོ། །"
    },
    "6": {
      "1": "བུད་མེད་རྣམས་ཀྱི་མཛེས་མའི་མཆོག ། ཁྱེད་ཀྱི་དགའ་གྲོགས་གང་དུ་སོང་། ། ངེད་ཀྱང་ཁྱེད་མཉམ་བཙལ་དུ་འགྲོ ། ཁྱེད་ཀྱི་དགའ་གྲོགས་གང་དུ་བཞུད། །",
      "2": "ང་ཡི་དགའ་གྲོགས་སྐྱེད་ཚལ་དུ། ། ལུག་ཁྱུ་འཚོ་རུ་ཕྱིན་པ་དང་། ། མེ་ཏོག་ཀུ་མུད་འཐུ་བ་ལ། ། ཉིད་ཀྱི་དྲི་ཞིམ་ར་བར་བཞུད། །",
      "3": "བདག་ནི་དགའ་གྲོགས་ཁོང་ལ་དབང་། ། ཁོང་གི་སེམས་ཀྱང་བདག་ལ་དབང་། ། ཁོང་གིས་མེ་ཏོག་ཀུ་མུད་གསེང་། ། ལུག་གི་ཁྱུ་ནི་འཚོ་བར་བྱེད། །",
      "4": "ཀྱེ་ཀྱེ་ང་ཡི་སྙིང་སྡུག་ལགས། ། ཁྱེད་ནི་ཐིར་ཙ་ལྟར་མཛེས་ཤིང་། ། ཡེ་རུ་སཱ་ལེམ་བཞིན་དུ་མཚར། ། རྒྱལ་མཚན་བསྒྲེངས་པའི་དམག་དཔུང་ལྟར། ། རྔམ་བརྗིད་ལྡན་པ་ཡིན་ལགས་སོ། །",
      "5": "ཀྱེ་ཀྱེ་ཁྱེད་ཀྱི་སྤྱན་གྱིས་ང་མ་གཟིགས། ། གཟིགས་ན་ང་ཡི་སེམས་ཀྱང་དབང་དུ་སྡུད། ། ཁྱེད་ཀྱི་སྐྲ་ལོ་གིལ་ཨད་རི་བོའི་ངོགས། ། ཐུར་དུ་འབབ་པའི་ར་ཁྱུར་ཀུན་ནས་མཚུངས། །",
      "6": "ཆ་ནི་འགྲིག་ཅིང་ཁེར་སྐྱེས་མིན་པའི་ཁྱེད་ཀྱི་ཚེམས། ། ལུག་བལ་བྲེགས་པའི་མ་མོ་དཀར་བཀྲུས་ཐོན་པ་འདྲ། །",
      "7": "གདོང་ཁེབས་འོག་གི་ཁྱེད་ཀྱི་མཁུར་ཚོས་ནི། ། དམར་མདངས་བཀྲ་བའི་སེ་འབྲུ་ཕྱེད་ཀ་བཞིན། །",
      "8": "རྒྱལ་མོ་དྲུག་ཅུ་བཙུན་མོ་བརྒྱད་ཅུ་དང་། ། ལང་ཚོ་མ་ནི་བགྲང་གིས་མི་ལང་ཡང་། །",
      "9": "ང་ཡི་ཕུག་རོན་ང་ཡི་ཕུལ་བྱུང་མ། ། མོ་ནི་ཨ་མའི་བུ་མོ་ཁེར་སྐྱེས་དང་། ། མངལ་དུ་འཁུར་མཁན་མ་ཡི་གཅེས་ཕྲུག་ཡིན། ། བུ་མོ་རྣམས་ཀྱིས་མོ་རང་མཐོང་བ་ན། ། མོ་ནི་ཁྱད་དུ་འཕགས་པ་ཡིན་ཞེས་སྨྲ། ། རྒྱལ་མོ་བཙུན་མོ་རྣམས་ཀྱིས་ཁོ་མོར་བསྟོད། །",
      "10": "ཞོགས་པའི་སྐྱ་རེངས་ཤར་འདྲ་དང་། ། ཞལ་རས་དཀར་གསལ་ཟླ་ལྟར་མཛེས། ། གདོང་ནི་ཉི་མ་བཞིན་དུ་གསལ། ། རྒྱལ་མཚན་བསྒྲེངས་པའི་དམག་དཔུང་ལྟར། ། རྔམ་བརྗིད་ལྡན་པ་སུ་ཡིན་ནམ། །",
      "11": "ལུང་པའི་ལྗོན་ཤིང་སྣ་ཚོགས་དང་། ། རྒུན་འབྲུམ་ལོ་མ་འབུས་མིན་དང་། ། སེ་འབྲུ་མེ་ཏོག་བཞད་མིན་ལ། ། བལྟ་ཕྱིར་སྟར་ཀའི་ར་བར་ཕྱིན། །",
      "12": "ཤེས་ཚོར་གང་ཡང་མ་བྱུང་བར། ། བདག་གི་སེམས་ཀྱིས་ང་རང་ནི། ། བཀུར་འོས་འབངས་ཀྱི་ཤིང་རྟར་བསྐྱོན། །",
      "13": "ལོག་ཤོག་ལོག་ཤོག་ཤུ་ལམ་མིད་ཀྱི་བུ་མོ་ཁྱེད། ། ལོག་ཤོག་ལོག་ཤོག་ང་ཚོས་ཁྱེད་ལ་བལྟ་བར་འདོད། །"
    },
    "7": {
      "1": "ཀྱེ་ཀྱེ་གུས་པར་འོས་པའི་སྲས་མོ་ལགས། ། ཁྱེད་ཞབས་བསིལ་ལྷམ་ནང་དུ་ཅི་འདྲ་མཛེས། ། ཁྱེད་ཀྱི་དཔྱི་དང་བརླ་ཡི་འཁྱོག་མཚམས་ནི། ། ལག་ཤེས་པ་ཡིས་བཟོས་པའི་གཡང་ཊི་བཞིན། །",
      "2": "ཁྱེད་ཀྱི་ལྟེ་བ་ཡོལ་གོར་ཟླུམ་པོ་བཞིན། ། དེའི་ནང་རྒུན་ཆང་མངར་མོས་གང་གྱུར་ཅིག ། ཁྱེད་ཀྱི་གྲོད་པ་གྲོ་འབྲུ་སྤུངས་པ་འདྲ། ། ཕྱོགས་བཞིར་མེ་ཏོག་ཀུ་མུད་བཞད་ནས་ཡོད། །",
      "3": "ཁྱེད་ཀྱི་ནུ་མ་ཟུང་ནི་དགོ་བ་མོའི། ། དགོ་ཕྲུག་མཚེ་མ་དང་ནི་ཀུན་ནས་མཚུངས། །",
      "4": "ཁྱེད་ཀྱི་མགུལ་ནི་བ་སོའི་ལྕོག་མཁར་བཞིན། ། ཡིད་འོང་སྤྱན་ཟུང་ཧེ་སི་པོན་དང་ནི། ། པཱ་ཐུ་ལ་པིན་སྒོ་འགྲམ་རྫིང་བུ་འདྲ། ། ཁྱེད་ཀྱི་དྲི་འཛིན་དབང་བོ་ནི། ། དཱ་མེ་སེག་ལ་འཁོར་བ་ཡི། ། ལེ་པཱ་ནོན་གྱི་ལྕོག་མཁར་བཞིན། །",
      "5": "ཁྱེད་ཀྱི་དབུ་ནི་ཀར་མེལ་རི་དང་མཚུངས། ། སྐྲ་ལོ་རྒྱ་སྨུག་ཅན་གྱིས་རྒྱལ་པོ་བཀུག །",
      "6": "ཀྱེ་ཀྱེ་ང་ཡི་སྙིང་སྡུག་མ། ། མི་ལ་དགའ་སྤྲོ་བསྐྱེད་པ་ཁྱེད། ། ཇི་འདྲའི་མཛེས་ཤིང་ཡིད་དུ་འོང་། །",
      "7": "ཁྱེད་ཀྱི་སྐུ་གཟུགས་ཏ་ལའི་ཤིང་དང་མཚུངས། ། ནུ་མ་ཟུང་ནི་ཤིང་ཏོག་ཐོགས་པ་འདྲ། །",
      "8": "ང་རང་ཏ་ལའི་ཤིང་དེར་འགོས་ནས་ནི། ། ཤིང་ཏོག་ཆུན་པོར་འཇུ་ཞེས་བདག་གིས་སྨྲས། ། ཁྱེད་ཀྱི་ནུ་མ་ཟུང་ནི་ཐུར་འཕྱང་བའི། ། རྒུན་འབྲུམ་ཆུན་པོ་རྣམས་དང་འདྲ་བར་ཤོག ། ཁ་རླངས་དྲི་བསུང་ཀུ་ཤུ་ལྟ་བུ་ཡིན། །",
      "9": "ཁྱེད་ཀྱི་ཞལ་ནི་རྒུན་ཆང་མཆོག་གྱུར་བཞིན། །",
      "10": "ང་ནི་ང་ཡི་དགའ་གྲོགས་ལ་དབང་ཞིང་། ། ཁོང་ཡང་ང་ལ་དགའ་ཞིང་དུངས་པ་ཡིན། །",
      "11": "ཀྱེ་ཀྱེ་ང་ཡི་དགའ་གྲོགས་ཚུར་ཕེབས་དང་། ། ཞིང་ཁར་ཕྱིན་ནས་གྲོང་སྡེ་རུ་བསྡད་ཆོག །",
      "12": "ཞོགས་པ་འུ་གཉིས་རྒུན་ཚལ་དུ་ཕྱིན་ཏེ། ། རྒུན་འབྲུམ་ཤིང་ལ་མྱུ་གུ་འབུས་མིན་དང་། ། རྒུན་འབྲུམ་ཤིང་ལ་མེ་ཏོག་བཞད་མིན་དང་། ། སེ་འབྲུ་ཤིང་ལ་མེ་ཏོག་འབུས་མིན་བལྟ། ། དེ་རུ་ང་ཡིས་བརྩེ་སེམས་ཁྱེད་ལ་འབུལ། །",
      "13": "དུའུ་དཱ་ནི་ཡི་དྲི་བསུང་འཐུལ་བ་དང་། ། ཀྱེ་ཀྱེ་ང་ཡི་དགའ་གྲོགས་ཁྱེད་ཀྱི་ཕྱིར། ། བསགས་པའི་ཤིང་ཏོག་གསར་རྙིང་སྣ་ཚོགས་པ། ། ང་ཚོའི་ཡུལ་གྱི་སྒོ་འགྲམ་བཞག་ཡོད་དོ། །"
    },
    "8": {
      "1": "¶ ཁྱེད་ནི་ང་དང་མ་གཅིག་ཅིང་། ། ཁོང་མོའི་ནུ་མ་ནུས་པ་ཡི། ། མིང་པོ་ཡིན་ན་ཅི་མ་རུང་། ། དེ་ནས་ང་དང་ཁྱེད་གཉིས་ནི། ། ཕྱི་རུ་འཕྲད་དུས་ཁ་སྐྱེལ་ཡང་། ། སུས་ཀྱང་མཐོང་ཆུང་བྱེད་མི་འགྱུར། །",
      "2": "དེ་ནས་ང་ཡིས་ཁྱེད་ཁྲིད་དེ། ། མ་ཡི་ཁང་པར་གདན་འདྲེན་བྱ། ། ཁོང་མོས་ང་ལ་ཞལ་ཏ་གནང་། ། བདག་གི་སེ་འབྲུ་ལས་བསྙལ་བའི། ། དྲི་ཞིམ་བདུད་རྩི་ཁྱེད་ལ་འདྲེན། །",
      "3": "ཁོང་ཕྱག་གཡོན་པས་བདག་གི་མགོ་བོ་སྐྱོར། ། ཁོང་ཕྱག་གཡས་པས་བདག་གི་ལུས་ཡོངས་འཁྱུད། །",
      "4": "ཀྱེ་ཀྱེ་ཡེ་རུ་སཱ་ལེམ་བུ་མོ་རྣམས། ། ང་ཡི་དགའ་གྲོགས་དགྱེས་ཏེ་མ་བཞེངས་བར། ། ཁྱེད་ཚོས་ཁོང་ཉིད་མནལ་ལས་མི་སློང་རོགས། །",
      "5": "དབེན་སྟོང་ཡུལ་ནས་དགའ་གྲོགས་ལ་བསྙེས་ཏེ། ། ཡར་ལ་བྱོན་པ་དེ་ནི་སུ་ཡིན་ལགས། །",
      "6": "རྟགས་ཐམ་བཞིན་དུ་བདག་ཁྱེད་སེམས་ལ་ཟུངས། ། ཐེལ་ཙེ་བཞིན་དུ་ཕྱག་ངར་འདོགས་པར་མཛོད། ། དུངས་སེམས་འཆི་བ་ལྟར་དུ་སྟོབས་ཤུགས་ཆེ། ། ཕྲག་དོག་གཤིན་ཡུལ་ནང་བཞིན་རྩུབ་པོ་ཡིན། ། དེ་ནི་མེ་དཔུང་དྲག་པོའི་མེ་ལྕེ་ཡིན། ། དེ་ནི་ཡ་ཝཱེའི་མེ་དཔུང་དྲག་པོ་ཡིན། །",
      "7": "ཆུ་བོ་མང་པོས་དུངས་སེམས་གསོད་མི་ནུས། ། གཙང་པོ་རྣམས་ཀྱིས་དེ་ནི་བསྣུབ་མི་ཐུབ། ། སུ་ཡིས་རང་གི་རྒྱུ་ནོར་ཀུན་བཏང་ནས། ། དུངས་སེམས་ཉོ་བར་འདོད་ན་སྨད་པའི་གནས། །",
      "8": "ངེད་ཅག་རྣམས་ལ་སྲིང་མོ་ཞིག་ཡོད་དེ། ། ཁོ་མོར་ད་དུང་ལང་ཚོ་དར་མེད་པས། ། མི་ཞིག་བག་མར་སློང་དུ་འོང་དུས་སུ། ། ང་ཚོས་ཁོ་མོའི་དོན་དུ་གཏམ་ཅི་སྨྲ། །",
      "9": "ཇི་སྟེ་མོ་ནི་ལྕགས་རི་ཞིག་ཡིན་ན། ། ངེད་ཀྱིས་ཐོག་ཏུ་དངུལ་གྱི་ལྕོག་མཁར་བརྩིག ། ཇི་སྟེ་མོ་ནི་སྒོ་ཞིག་ཡིན་པའི་ཚེ། ། ཐང་ཤིང་སྤང་ལེབ་ཀྱིས་ནི་བསྲུང་བར་བྱ། །",
      "10": "ང་ནི་ལྕགས་རི་ཡིན་པ་དང་། ནུ་མ་ཟུང་ནི་ལྕོག་མཁར་འདྲ། ། ཁོང་གི་སྤྱན་དྲུང་ང་རང་ནི། ། བདེ་ལ་བབས་པའི་མི་བཞིན་ཡིན། །",
      "11": "སོ་ལོ་མོན་ལ་པཱ་ཨལ་ཧ་མོན་དུ། ། རྒུན་འབྲུམ་ར་བ་ཞིག་ནི་ཡོད་པ་དང་། ། ཁོང་གིས་རྒུན་ཚལ་སྲུང་མཁན་དག་ལ་གླས། ། དེ་རྣམས་རེ་རེས་ཐོབ་པའི་ཤིང་ཏོག་ཕྱིར། ། དངུལ་སྲང་ཆིག་སྟོང་ཁོང་ལ་སྤྲོད་དགོས་སོ། །",
      "12": "བདག་ལ་རྒུན་འབྲུམ་ར་བ་ཞིག་ཡོད་དེ། ། དངུལ་སྲང་ཆིག་སྟོང་སོ་ལོ་མོན་ལ་དབང་། ། ཉིས་བརྒྱ་ཤིང་ཏོག་སྲུང་མཁན་རྣམས་ཀྱི་ཡིན། །",
      "13": "ཀྱེ་ཀྱེ་སྐྱེད་ཚལ་རྣམས་སུ་བཞུགས་པ་ཁྱེད། ། ཟླ་གྲོགས་རྣམས་ཀྱིས་ཁྱེད་ཀྱི་གསུང་སྐད་ཉན། ། གསུང་སྐད་དེ་ནི་བདག་ལ་ཐོས་པར་མཛོད། །",
      "14": "ཀྱེ་ཀྱེ་ང་ཡི་དགའ་གྲོགས་ལགས། ། དྲི་ཞིམ་རྩྭ་ཡི་རི་བོ་ལ། ། དགོ་བ་དང་ནི་ཤྭ་ཕྲུག་བཞིན། ། མྱུར་བ་མྱུར་དུ་ཡར་ཕེབས་ཤོག ། །།"
    }
  }
}
