{
  "name": "ཨོ་བད་ཡཱ།",
  "id": "ཨོ་བད་ཡཱ།",
  "order": 31,
  "chapters": {
    "1": {
      "1": "¶ ཨོ་བད་ཡཱས་མཐོང་བའི་ཞལ་གཟིགས་ནི། གཙོ་བོ་ཡ་ཝཱེས་ཨེ་དོམ་གྱི་སྐོར་ལ་བཀའ་གནང་ཞིང་། ང་ཚོས་དཀོན་མཆོག་ཡ་ཝཱེ་ནས་འཕྲིན་ཞིག་ཐོས་ཏེ། ཕོ་ཉ་ཞིག་མི་རིགས་དེ་དག་གི་ཁྲོད་དུ་མངགས་ནས་དེ་དག་ལ། ཡར་ལོངས་དང་། ངེད་རྣམས་ཡར་ལངས་ནས་ཨེ་དོམ་དང་འཐབ་དུ་འགྲོའོ་ཞེས་སྨྲས་སོ། །",
      "2": "ལྟོས་ཤིག བདག་གིས་ཨེ་དོམ་ཁྱོད་ནི་མི་རིགས་རྣམས་ཀྱི་ཁྲོད་དུ་ཉམ་ཞན་དུ་འགྱུར་བར་བྱ་ཞིང་། མི་ཡིས་ཁྱོད་ལ་མཐོང་ཆུང་དཔེ་མེད་བྱེད་པར་འགྱུར་རོ། །",
      "3": "བྲག་ཕུག་དང་མཐོ་སར་གནས་པ་ཁྱོད་ནི་རང་སེམས་ཀྱི་ང་རྒྱལ་གྱིས་བསླུས་ཏེ། སེམས་ལ་སུ་ཞིག་གིས་ང་རང་དམའ་སར་འབེབ་ནུས་སམ་ཞེས་སྨྲའོ། །",
      "4": "ཇི་སྟེ་ཁྱོད་ནི་གླག་ལྟར་ནམ་མཁའི་དབྱིངས་སུ་འཕུར་ཏེ། སྐར་ཚོགས་ཀྱི་དབུས་སུ་ཚང་བཅོས་ནའང་། བདག་གིས་ཁྱོད་ནི་དེ་ལས་མར་འབེབ་པར་བྱའོ་ཞེས་དཀོན་མཆོག་ཡ་ཝཱེས་འདི་སྐད་གསུངས།",
      "5": "གལ་ཏེ་ཁྱོད་ཀྱི་གནས་སུ་རྐུན་པོ་སླེབས་པའམ་མཚན་མོར་ཇག་པ་རྣམས་འོངས་ན། དེ་དག་གིས་རང་ལ་དགོས་འདོད་པ་འབའ་ཞིག་བརྐུ་བ་མ་ཡིན་ནམ། གལ་ཏེ་རྒུན་འབྲུམ་འཐོག་མཁན་ཁྱོད་ཀྱི་རྩར་འོངས་ན། དེ་དག་གིས་རྒུན་འབྲུམ་ཁ་ཤས་བསྐྱུར་བ་མ་ཡིན་ནམ། ཡིན་ནའང་ཁྱོད་ནི་མེད་པར་བཟོའོ། །",
      "6": "ཨེ་སཱབ་ལ་སྔོག་གཤེར་བྱས་ནས་དེས་སྦས་པའི་ནོར་རྣམས་ཕྱུང་བར་འགྱུར།",
      "7": "ཁྱོད་དང་ཁ་ཆད་བཞག་པ་རྣམས་ཀྱིས་ཁྱོད་ནི་ས་མཚམས་བར་དུ་སྐྲོད་ཅིང་། ཁྱོད་དང་འཆམ་པ་རྣམས་ཀྱིས་ཁྱོད་རང་བསླུས་ཏེ་ཁྱོད་ལས་རྒྱལ། ཁྱོད་དང་ལྷན་ཅིག་ཏུ་ཟས་སྤྱད་པ་རྣམས་ཀྱིས་ཁྱོད་ལ་རྙི་བཙུགས་ནའང་ཁྱོད་ཀྱིས་དེ་མི་ཤེས་སོ། །",
      "8": "ཉིན་མོ་དེ་སླེབས་དུས་སུ། བདག་གིས་ཨེ་དོམ་ཡུལ་ནས་མཁས་པ་རྣམས་དང་། ཨེ་སཱབ་རི་བོ་ལས་གྲུང་པོ་རྣམས་མེད་པར་མི་བཟོའམ་ཞེས་དཀོན་མཆོག་ཡ་ཝཱེས་གསུངས་སོ། །",
      "9": "ཀྱེ་ཐེ་མཱན། ཁྱོད་ཀྱི་དཔའ་བོ་རྣམས་ནི་འཇིགས་པར་འགྱུར་ངེས་ཏེ། ཨེ་སཱབ་རི་བོར་གནས་པ་རྣམས་རེ་རེ་བཞིན་སྲོག་དང་འབྲལ་བར་འགྱུར་རོ། །",
      "10": "¶ ཁྱོད་ཀྱིས་རང་གི་གཅུང་པོ་ཡ་ཀོབ་ལ་དྲག་གནོན་བྱས་པས། ཁྱོད་རང་ངོ་ཚ་བར་འགྱུར་ལ་ཇི་སྲིད་བར་དུ་མེད་པར་བཟོའོ། །",
      "11": "མི་རིགས་གཞན་རྣམས་ཀྱིས་ཡ་ཀོབ་ཀྱི་རྒྱུ་ནོར་འཕྲོག་པ་དང་། ཕྱི་ཕྱོགས་པ་རྣམས་དེའི་མཁར་སྒོ་ནང་དུ་འཛུལ་ཏེ། ཡེ་རུ་སཱ་ལེམ་གྱི་ཕྱིར་རྒྱན་འཕངས་ནས་རྒྱུ་ནོར་བགོ་བའི་དུས་སུ། ཁྱོད་ནི་དེ་དག་གི་གམ་དུ་ལངས་བསྡད་ནས་དེ་ཚོའི་ཕྱོགས་མཐུན་ཡིན་པ་འདྲ།",
      "12": "ཁྱོད་ཀྱི་གཅུང་པོ་སྡུག་བསྔལ་གྱིས་མནར་དུས་ཁྱོད་ཀྱིས་དེར་བལྟས་ནས་སྡོད་ག་ལ་རུང་། ཡ་ཧུ་དཱ་པ་རྣམས་འཇིག་པའི་ཉིན་མོར་ཁྱོད་ནི་དགའ་བར་མི་འོས་ལ། དེ་ཚོ་སྡུག་བསྔལ་གྱིས་མནར་བའི་དུས་སུ་ཁྱོད་ཀྱིས་ང་རྒྱལ་གྱི་གཏམ་སྨྲ་མི་འོས་སོ། །",
      "13": "ངའི་མི་རིགས་ལ་ཆག་སྒོ་འབྱུང་དུས་སུ་ཁྱོད་ནི་དེ་ཚོའི་མཁར་སྒོ་ནང་དུ་འཛུལ་ག་ལ་རུང་། དེ་དག་ལ་ཆག་སྒོ་འབྱུང་དུས་ཁྱོད་ཀྱིས་དེ་ཚོས་སྡུག་བསྔལ་མྱང་བར་བལྟས་ནས་སྡོད་ག་ལ་རུང་། ཡང་དེ་དག་ལ་ཆག་སྒོ་འབྱུང་དུས་ཁྱོད་ཀྱིས་ལག་པ་བརྐྱངས་ནས་དེ་ཚོའི་ནོར་རྫས་འཕྲོག་མི་འོས་སོ། །",
      "14": "དེ་དག་སྡུག་བསྔལ་གྱིས་མནར་དུས། ཁྱོད་ནི་བཞི་མདོར་ལངས་བསྡད་ནས་དེ་དག་གི་བྲོས་ནས་ཐར་བའི་མི་རྣམས་ཀྱི་སྲོག་གཅོད་པའམ། དེ་དག་གི་ལྷག་ལུས་རྣམས་དགྲ་ལག་ཏུ་སྤྲོད་མི་འོས།",
      "15": "¶ དཀོན་མཆོག་ཡ་ཝཱེའི་ཉིན་མོ་མི་རིགས་ཀུན་གྱི་སྟེང་དུ་འབྱོན་ཉེ་སྟེ། ཁྱོད་ཀྱིས་ཅི་བྱས་པ་བཞིན་དུ་མི་ཡིས་ཀྱང་ཁྱོད་ལ་དེ་ལྟར་བྱའོ། །ཁྱོད་ཀྱི་ལས་རྣམས་ཕྱིར་ཁྱོད་རང་གི་མགོར་འབབ་པར་འགྱུར།",
      "16": "ཁྱོད་ཀྱིས་ངའི་རི་བོ་དམ་པར་སྐྱོ་བའི་ཕོར་བ་ལས་བཏུངས་པ་བཞིན་དུ། མི་རིགས་ཀུན་གྱིས་རྟག་ཏུ་འཐུང་བར་འགྱུར། དེ་དག་གིས་བཏུངས་ནས་མིད་པར་བྱ་ཞིང་། ཡོད་ཚད་ནམ་ཡང་ཡོད་མ་མྱོང་བ་ལྟར་འགྱུར་རོ། །",
      "17": "འོན་ཀྱང་རི་བོ་ཛ་ཡན་དུ་ཐར་བའི་མི་རྣམས་གནས་ཤིང་། རི་དེ་ནི་དམ་པར་འགྱུར་ལ། ཡ་ཀོབ་ཀྱི་ཁྱིམ་རྒྱུད་ལ་སྔར་གྱི་ནོར་སྐལ་འཐོབ་པར་འགྱུར།",
      "18": "དེ་ནས་ཡ་ཀོབ་ཀྱི་ཁྱིམ་རྒྱུད་ནི་མེ་དང་། ཡོ་སེབ་ཀྱི་ཁྱིམ་རྒྱུད་ནི་མེ་ལྕེ་དང་། ཨེ་སཱབ་ཀྱི་ཁྱིམ་རྒྱུད་ནི་སོག་རོར་གྱུར་ཏེ། མེ་སྦར་ནས་མེད་པར་བྱ་ཞིང་། ཨེ་སཱབ་ཀྱི་ཁྱིམ་རྒྱུད་ལས་སུ་ཡང་ལུས་པར་མི་འགྱུར་ལ། དཀོན་མཆོག་ཡ་ཝཱེས་འདི་སྐད་གསུངས་སོ། །",
      "19": "ཡང་ནེ་གུབ་ཡུལ་གྱི་མི་རྣམས་ལ་ཨེ་སཱབ་ཀྱི་རི་བོ་འཐོབ་ཅིང་། རི་ཀླུང་གི་མི་རྣམས་ལ་ཕེ་ལེ་ཤེད་ཀྱི་ཡུལ་རྣམས་དབང་བ་དང་། ཡང་དེ་དག་ལ་ཨེ་ཕཱར་ཡིམ་གྱི་ས་དང་སཱ་མར་ཡའི་ས་རྣམས་ཀྱང་འཐོབ་པར་འགྱུར་ལ། པེན་ཡཱ་མེན་པ་རྣམས་ལ་གིལ་ཨད་འཐོབ་པར་འགྱུར།",
      "20": "ཡང་ཡེས་ར་ཨེལ་པ་རྣམས་ལས་བཙོན་དུ་ཁྲིད་ཡོད་པ་ཐམས་ཅད་ལ་ཀ་ན་ཨན་ཡུལ་ནས་སཱ་རེ་ཕད་ཀྱི་བར་དུ་དང་། སེ་ཕ་རཱད་དུ་ཡོད་པའི་ཡེ་རུ་སཱ་ལེམ་ནས་བཙོན་དུ་ཁྲིད་པ་རྣམས་ལ་ནེ་གུབ་ཡུལ་གྱི་གྲོང་ཁྱེར་རྣམས་འཐོབ་པར་འགྱུར།",
      "21": "ཡང་སྐྱོབ་མཁན་རྣམས་རི་བོ་ཛ་ཡན་གྱི་སྟེང་དུ་ཡར་ཕྱིན་ཏེ་ཨེ་སཱབ་རི་ལ་ཁྲིམས་ཐག་གཅོད་པར་འགྱུར་ལ། རྒྱལ་སྲིད་ནི་དཀོན་མཆོག་ཡ་ཝཱེར་དབང་ངོ་།། །།"
    }
  }
}
