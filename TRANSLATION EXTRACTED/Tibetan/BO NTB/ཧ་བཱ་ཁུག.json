{
  "name": "ཧ་བཱ་ཁུག",
  "id": "ཧ་བཱ་ཁུག",
  "order": 35,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་ལུང་སྟོན་པ་ཧ་བཱ་ཁུག་གིས་ཞལ་གཟིགས་ལས་མཐོང་བའི་བཀའ་ལུང་ནི་འདི་ལྟ་སྟེ།",
      "2": "ཀྱེ་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། བདག་གིས་ཞུས་ཀྱང་ཁྱེད་ཀྱིས་མི་གསན་པར་དུས་ཇི་ཙམ་ལ་འདུག་གམ། དོན་གདུག་རྩུབ་ཅན་གྱི་རྐྱེན་གྱིས་ངས་ཁྱེད་ཀྱི་ཕྱོགས་སུ་འོ་དོད་བོས་ནའང་ཁྱེད་ཀྱིས་ད་དུང་སྐྱོབ་པར་མ་མཛད།",
      "3": "ཁྱེད་ཀྱིས་ཅིའི་ཕྱིར་ང་ལ་སྡིག་ཉེས་མཐོང་བར་མཛད་དམ། ཁྱེད་ཀྱིས་སྤྱོད་ངན་གཟིགས་ཀྱང་དེར་བཟོད་སྒོམ་བྱེད་པ་ཅི་ཡིན་ནམ། གཏོར་བརླག་དང་གདུག་རྩུབ་ནི་ངའི་མདུན་དུ་ཡོད་པ་དང་། རྩོད་པ་དང་འཐབ་རྩོད་ཀྱང་རྒྱུན་དུ་འབྱུང་ངོ་། །",
      "4": "དེ་བས་བཀའ་ཁྲིམས་མི་བརྩི་ཞིང་། དྲང་བདེན་མི་སྲུང་ལ། མི་ངན་པས་དྲང་བདེན་ཅན་གྱི་མཐའ་ནས་བསྐོར་བས་དྲང་བདེན་གོ་ལྡོག་པ་ཡིན།",
      "5": "¶ ཁྱོད་རྣམས་ཀྱིས་མི་རིགས་ཀུན་ལ་ལྟོས་དང་ཤིན་ཏུ་ཧ་ལས་པར་འགྱུར། ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱི་མི་ཚེའི་ནང་དུ་ངས་དོན་ཞིག་མཛད་པར་འགྱུར་ཞིང་། གཞན་གྱིས་དོན་དེའི་སྐོར་ཁྱོད་རྣམས་ལ་བཤད་ཀྱང་ཁྱོད་རྣམས་དོན་དེ་ལ་ཡིད་མི་ཆེས་སོ། །",
      "6": "ངས་ཀལ་དི་པ་རྣམས་དར་བར་བཅུག་ནས། གདུག་རྩུབ་ཆེ་ཞིང་བྲེལ་འཚུབ་ཅན་གྱི་མི་སྡེ་དེ་ས་ཕྱོགས་ཀུན་ལ་ཁྱབ་པར་གྱུར་ཏེ། གཞན་གྱི་ཁྱིམ་གཞིས་བཙན་འཛིན་བྱེད་པ་དང་།",
      "7": "དེ་དག་ནི་རྔམ་བརྗིད་ཆེ་ལ་འཇིགས་སུ་རུང་བ་ཡིན་པས་རང་ཉིད་ཚད་མར་འཛིན་པ་དང་། ང་རྒྱལ་ཁེངས་དྲེགས་ཅན་ཡིན་ཞིང་།",
      "8": "དེ་ཚོའི་རྟ་ནི་གཟིག་ལས་མགྱོགས་ཤིང་། མཚན་མོའི་སྤྱང་ཀི་ལས་ཀྱང་གཏུམ་དྲག་ཆེ་ལ། དེ་དག་གི་རྟ་དམག་གདོང་མཆོང་བྱེད་ཀྱིན་རྒྱང་རིང་ནས་ཐོན་པ་དང་། དེ་དག་གིས་གླག་བཞིན་ལྡིང་སྐོར་བརྒྱབ་སྟེ་མྱུར་དུ་ཁྱུར་མིད་གཏོང་བའོ། །",
      "9": "དེ་དག་གིས་མདུན་ཕྱོགས་སུ་གདོང་གཏད་ནས་མཉམ་དུ་གདུག་རྩུབ་སྤྱོད་པ་དང་། བཙོན་པ་བགྲང་ལས་འདས་པ་ཐོབ་པའོ། །",
      "10": "དེ་དག་གིས་རྒྱལ་པོར་ཟུར་ཟ་དང་འགོ་དཔོན་རྣམས་ལ་འཕྱ་དམོད་བྱེད་ཅིང་། བཙན་རྫོང་རྣམས་ལ་ཁྲེལ་དགོད་བྱས་ནས་ས་རགས་བརྩིགས་ཏེ་གནས་དེ་བཙན་འཛིན་བྱེད།",
      "11": "དེ་དག་གིས་རང་གི་སྟོབས་ཤུགས་ལྷ་རུ་བཀུར་བ་དང་། རླུང་འཚུབ་བཞིན་གཡུགས་ནས་འགྲོ་ཞིང་སྡིག་ཅན་ཡིན་ནོ། །",
      "12": "¶ ཀྱེ་ང་ཡི་དཀོན་མཆོག་ཡ་ཝཱེ་དང་བདག་གི་དམ་པ་ཉིད་ལགས། ཁྱེད་ནི་ཐོག་མ་ཉིད་ནས་བཞུགས་པ་མ་ཡིན་ནམ། ངེད་ཅག་ནི་འཆི་བར་མི་འགྱུར་རོ། །ཀྱེ་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། ཁྱེད་ཀྱིས་ཁྲིམས་ཆད་གཅོད་དུ་དེ་དག་མངགས་པ་དང་། ཀྱེ་བྲག་རྡོ་ལགས། ཁྱེད་ཀྱིས་ཉེས་ཆད་གཅོད་དུ་དེ་དག་བསྐོས་པ་ཡིན།",
      "13": "ཁྱེད་ཀྱི་སྤྱན་ཟུང་ནི་རྣམ་དག་ཡིན་པས་ངན་པར་མི་གཟིགས་ལ། སྤྱོད་ངན་སྣང་མེད་དུ་མི་བསྐྱུར། དེས་ན་གཡོ་སྒྱུའི་སྦྱོར་བ་སྤེལ་བའི་མི་མཐོང་ཚེ་དེར་བཟོད་པ་ཅི་ཡིན་ནམ། མི་ངན་གྱིས་རང་ཉིད་ལས་དྲང་བདེན་ཡིན་པའི་མི་མེད་པར་བཟོ་དུས་ཁྱེད་ཉིད་ཞལ་རོག་བཞུགས་པ་ཅི་ཡིན་ནམ།",
      "14": "ཁྱེད་ཀྱིས་མི་ནི་རྒྱ་མཚོའི་ཉ་བཞིན་དང་། བདག་སྐྱོང་བྱེད་མཁན་མེད་པའི་ལྟོ་འགྲོའི་སྲོག་ཆགས་བཞིན་མཛད་པ་ཅི་ཡིན་ནམ།",
      "15": "ཀལ་དི་པས་དེ་ཐམས་ཅད་ལྕགས་ཀྱུས་ཡར་དྲངས་ཏེ། དྲ་རྒྱ་ཡིས་དེ་དག་འཛིན་པ་དང་། ཉ་དྲ་ཡིས་དེ་རྣམས་མཉམ་དུ་བསྡུས་ནས་དགའ་སྤྲོ་ཆེན་པོ་སྐྱེས་པས།",
      "16": "ཀལ་དི་པས་རང་གི་དྲ་རྒྱར་མཆོད་པ་ཕུལ་ནས་ཉ་རྒྱར་སྤོས་བདུགས་སོ། །ཅིའི་ཕྱིར་ཞེ་ན། དེ་ལ་བརྟེན་ནས་ཁོ་ཚོར་ཁ་ཟས་ཕུན་སུམ་ཚོགས་པ་ཐོབ་སྟེ། བཟའ་བཏུང་མོད་པོ་ཡོད་པ་ཡིན།",
      "17": "ཁོ་ཚོས་རང་གི་དྲ་རྒྱ་སྟོང་བར་མཛད་དེ། སྙིང་རྗེ་སྤུ་ཙམ་ཡང་མེད་པར་ཡུལ་ཁམས་གཞན་པའི་མི་སྡེ་རྣམས་གསོད་པ་ཡིན་ནམ།"
    },
    "2": {
      "1": "¶ ང་རང་བྱ་རའི་ལྕོག་མཁར་སྟེང་ལངས་ནས་ལྕགས་རིའི་སྟེང་འཛེགས་ཏེ། དཀོན་མཆོག་ཡ་ཝཱེས་ང་ལ་ཅི་ཞིག་གསུང་བ་དང་། ངའི་སྡུག་སྐད་ལ་ཅི་ལྟར་ལན་གནང་བར་གཟབ་གཟབ་བྱས་ནས་བལྟ་བར་བྱའོ། །",
      "2": "དཀོན་མཆོག་ཡ་ཝཱེས་ང་ལ་བཀའ་ལན་གནང་སྟེ་འདི་སྐད་དུ། ཞལ་གཟིགས་དེ་འཇིམ་པའི་བྱང་བུའི་སྟེང་དུ་ཕྲིས་ཤིག དེ་གསལ་པོར་བཀོད་ན་ཀློག་མཁན་རྣམས་ཀྱིས་ཀློག་བདེ་བར་འགྱུར།",
      "3": "ཞལ་གཟིགས་འདི་ནི་དུས་ངེས་ཅན་ཞིག་དང་འབྲེལ་ཡོད་པ་དང་། དངོས་སུ་འགྲུབ་པར་འགྱུར་བས་དོན་མེད་དུ་མ་ཡིན་ལ། འགོར་འགྱངས་བྱས་པ་འདྲ་ཡང་ད་དུང་སྒུག་དགོས། ཅིའི་ཕྱིར་ཞེ་ན། དོན་དེ་ནི་སླེབ་པར་འགྱུར་ལ་དེའི་ཚེ་འགོར་འགྱངས་མི་བྱེད་དོ། །",
      "4": "ཁོ་ཚོ་ནི་རང་རློམ་ཆེ་ཞིང་གཞུང་རྒྱུད་མི་དྲང་། འོན་ཀྱང་མི་རྣམ་དག་ནི་དད་པའི་སྒོ་ནས་འཚོ་བར་འགྱུར།",
      "5": "རྒྱུ་ནོར་གྱིས་གཡོ་ཟོལ་དང་ང་རྒྱལ་བསྐྱེད་པས་བདེ་བར་གནས་མི་ཐུབ་ལ། གཤིན་ཡུལ་བཞིན་དུ་འདོད་པ་བསྐྱེད་ཅིང་། ཡང་འཆི་བ་ནང་བཞིན་ནམ་ཡང་ཚིམ་པ་མེད་ལ། དེ་དག་གིས་རང་གི་ཕྱིར་དུ་མི་རིགས་ཐམས་ཅད་བསྡུ་ཞིང་མི་སྡེ་ཀུན་རང་ལ་དབང་བར་བྱེད་དོ། །",
      "6": "¶ ཡུལ་ཁམས་དེ་ཐམས་ཅད་ཀྱི་མི་སྡེ་དག་གིས་དཔེ་དང་ཟུར་ཟ། གབ་ཚིག་བཅས་ཀྱིས་དེ་དག་ལ། གང་བྱུང་དུ་མི་གཞན་པའི་རྒྱུ་ནོར་བླངས་ཏེ། བཙན་དབང་གིས་བུ་ལོན་འདེད་མཁན་དག་ལ་ཆག་སྒོ་འབྱུང་བ་ཡིན། ཁོ་ཚོས་ག་དུས་བར་དུ་དེ་བཞིན་བྱེད་ཡོང་ངམ་ཞེས་ཟེར་ཞིང་།",
      "7": "བུ་ལོན་ཅན་རྣམས་གློ་བུར་ཉིད་ལ་ལང་མི་འོང་ངམ། ཁྱོད་འདར་དུ་འཇུག་མཁན་རྣམས་སད་པར་མི་འགྱུར་རམ། དེ་ནས་ཁྱོད་ནི་ཁོ་ཚོའི་བཅོམ་ནོར་དུ་འགྱུར་རོ། །",
      "8": "ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱིས་ཡུལ་ཁམས་མང་པོ་བཅོམ་ནས་མི་བསད་དེ་ཁྲག་བཞུར་དུ་བཅུག་པ་དང་། ཡུལ་ཁམས་ཀུན་གྱི་གྲོང་ཁྱེར་རྣམས་དང་དེའི་ནང་དུ་སྡོད་པའི་མི་རྣམས་ལ་གདུག་རྩུབ་སྤྱད་པས། ཡུལ་ཁམས་དེའི་ལྷག་ལུས་རྣམས་ཀྱིས་ཁྱོད་རང་འཇོམས་པར་འགྱུར།",
      "9": "རང་གི་ཁྱིམ་གཞིས་ཀྱི་ཕྱིར་དུ་ཐོབ་མི་འོས་པའི་རྒྱུ་ནོར་བསགས་པ་དང་། མཐོ་ས་ནས་སྡོད་ཁང་ཕུབ་སྟེ་ཆག་སྒོ་ལ་གཡོལ་བསམ་པ་ཁྱོད་རྣམས་ལ་ཆག་སྒོ་འབྱུང་།",
      "10": "ཁྱོད་ཀྱིས་ཡུལ་ཁམས་མང་པོའི་མི་སྡེ་ཚར་གཅོད་བྱེད་པའི་ཇུས་ངན་བཤམས་ཤིང་། རང་གི་ཁྱིམ་གཞིས་ངོ་ཚར་སྦྱར་ནས་འབྲས་བུ་ངན་པ་རང་ལ་འཁོར་བ་ཡིན།",
      "11": "ཐ་ན་རྩིག་པའི་རྡོ་ཡིས་སྐད་རྒྱག་ཅིང་། ཁང་པའི་གདུང་མས་ཀྱང་ལན་སྤྲོད་པར་འགྱུར།",
      "12": "¶ མི་ཡི་ཁྲག་གིས་མཁར་བརྩིགས་པ་དང་། གདུག་ལས་ཀྱིས་གྲོང་ཁྱེར་འཛུགས་མཁན་ལ་ཆག་སྒོ་འབྱུང་།",
      "13": "མི་རྣམས་ཀྱིས་ངལ་རྩོལ་བྱས་ནས་ཐོབ་པ་དག་མེས་བསྲེག་པ་དང་། ཡུལ་ཁམས་ཀུན་གྱིས་དཀའ་བ་སྤྱད་དེ་ཐོབ་པ་དག་ནི་སྟོང་བར་འགྱུར་ལ། དོན་འདི་ཐམས་ཅད་ནི་དཔུང་ཚོགས་ཀུན་གྱི་དཀོན་མཆོག་ཡ་ཝཱེ་ལས་བྱུང་བ་མ་ཡིན་ནམ།",
      "14": "ཆུ་བོ་རྣམས་ཀྱིས་ཇི་ལྟར་རྒྱ་མཚོ་བཀང་བ་བཞིན་དུ། དཀོན་མཆོག་ཡ་ཝཱེའི་གཟི་བརྗིད་རྟོགས་པའི་ཤེས་ཡོན་ནི་ས་གཞི་ཡོངས་སུ་ཁྱབ་པར་འགྱུར།",
      "15": "¶ ཁྱིམ་མཚེས་ལ་ཁོང་ཁྲོ་དང་བཅས་ཆང་གཏོད་མཁན་དང་། དེའི་ལུས་གཅེར་བུ་མཐོང་བའི་ཆེད་དུ་ར་བཟི་བར་འཇུག་མཁན་ལ་ཆག་སྒོ་འབྱུང་།",
      "16": "ཁྱོད་རང་ངོ་ཚས་ཁེངས་པ་ལས་བཀུར་བར་མི་བྱ་སྟེ། ཁྱོད་ཀྱིས་ཀྱང་ཆང་འཐུང་ནས་ལུས་སྨད་མངོན་པར་གྱིས་ ཤིག དཀོན་མཆོག་ཡ་ཝཱེའི་ཕྱག་གཡས་པའི་ཕོར་བ་ནི་འཁོར་ནས་ཁྱོད་ལ་སྤྲོད་ཅིང་། དེའི་ཚེ་ཁྱོད་ཀྱི་གཟི་བརྗིད་ཡོད་ཚད་ངོ་ཚ་ཆེན་པོར་འགྱུར་རོ། །",
      "17": "ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱིས་ལེ་པཱ་ནོན་གྱི་ཕྱོགས་སུ་གདུག་རྩུབ་སྤྱད་པ་དང་། འཇིགས་སྐྲག་གིས་ཟིན་པའི་རི་དྭགས་རྣམས་བསད་ཅིང་། ཡང་མིའི་སྲོག་བཅད་དེ་ཁྲག་བཞུར་དུ་བཅུག་ནས། ས་གཞི་ཡོངས་ཀྱི་གྲོང་ཁྱེར་རེ་རེའི་ནང་སྡོད་པའི་མི་ཀུན་ལ་གདུག་རྩུབ་སྤྱད་པས་ཁྱོད་ཀྱང་དབང་འོག་ཏུ་བསྡུ་ངེས་ཡིན།",
      "18": "སྐུ་འདྲ་བརྐོས་མ་ལ་ཕན་ཐོགས་ཅི་ཞིག་ཡོད་དམ། དེ་ནི་བཟོ་བས་བརྐོས་པ་ཙམ་ཡིན་ཞིང་། སྐུ་འདྲ་བླུགས་མ་དང་དགེ་རྒན་རྫུས་མ་ལ་ཕན་ཐོགས་ཅི་ཞིག་ཡོད་དམ། བཟོ་བས་རང་ཉིད་ལ་བརྟེན་ནས་ལྷ་ལྐུགས་པ་རྣམས་བཟོས་པའོ། །",
      "19": "ཤིང་གི་གཟུགས་བརྙན་ལ་ཡར་ལོངས་ཞེས་སྨྲ་བ་དང་། རྡོ་ལྐུགས་པ་ལ་སད་པར་གྱུར་ཅིག་ཅེས་སྨྲ་མཁན་ལ་ཆག་སྒོ་འབྱུང་། དེ་ཡིས་ཁྱོད་ལ་ཅི་ལྟར་བཀའ་སློབ་གནང་ངམ། ལྟོས་ཤིག དེའི་ཕྱི་ལ་གསེར་དང་དངུལ་གྱིས་བརྒྱན་ན་ཡང་ནང་དུ་དབུགས་ཀྱི་རྒྱུ་བ་ནི་གཏན་ནས་མེད་དོ། །",
      "20": "ཡིན་ཡང་དཀོན་མཆོག་ཡ་ཝཱེ་ནི་ཁོང་གི་མཆོད་ཁང་དམ་པའི་ནང་དུ་བཞུགས་ལ། ས་གཞི་ཡོངས་ཀྱི་མི་རྣམས་ཁོང་གི་དྲུང་དུ་ཁུ་སིམ་མེར་འདུག་འོས་པ་ཡིན་ཞེས་གསུངས་སོ། །"
    },
    "3": {
      "1": "¶ ལུང་སྟོན་པ་ཧ་བཱ་ཁུག་གི་ཤིས་ག་ཡོན་གྱི་དབྱངས་ལ་གྱེར་བའི་གསོལ་འདེབས།",
      "2": "ཀྱེ་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། ངས་ཁྱེད་ཀྱི་གསུང་སྐད་ཐོས་པས་འཇིགས་སོ། །ཀྱེ་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། ཁྱེད་ཀྱིས་ཉིན་འདི་དག་གི་ནང་དུ་ཉིད་ཀྱི་མཛད་འཕྲིན་རྣམས་ཡང་བསྐྱར་དར་ཞིང་མངོན་པར་མཛོད་ཅིག ཐུགས་ཁྲོ་བའི་དུས་སུའང་སྙིང་རྗེ་དགོངས་པར་མཛོད།",
      "3": "དཀོན་མཆོག་ནི་ཐེ་མཱན་ཡུལ་ནས་ཕེབས་ཤིང་། དམ་པ་ཉིད་ནི་ཕཱ་རན་རི་བོའི་ཕྱོགས་ནས་འོངས་ཏེ། ཁོང་གི་གཟི་བརྗིད་ཀྱིས་ནམ་མཁའ་ཡོངས་སུ་ཁེབས་ཤིང་། ས་གཞི་ཐམས་ཅད་ཁོང་ལ་བསྟོད་པའི་སྒྲ་ཡིས་ཁྱབ་པ་ཡིན། ༼ སེ་ལཱ། ༽",
      "4": "ཁོང་གི་གཟི་བྱིན་ནི་ཉི་འོད་བཞིན་ཡིན་ལ། ཁོང་གི་ཕྱག་ལས་འོད་ཟེར་འཕྲོས་ཤིང་། དེའི་ནང་དུ་ཁོང་གི་ནུས་མཐུ་ཆེན་པོ་སྦས་ཡོད་པ་ཡིན།",
      "5": "རིམས་ནད་ཁོང་གི་མདུན་ནས་བརྒྱུད་ཅིང་། ཚ་ནད་ཁོང་གི་ཞབས་འོག་ནས་འབྱུང་བ་ཡིན།",
      "6": "ཁོང་ཡར་བཞེངས་དུས་ས་གཞི་ཐམས་ཅད་གཡོ་བ་དང་། ཁོང་གིས་གཟིགས་དུས་མི་རིགས་ཀུན་འདྲོགས་པ་ཡིན། གཏན་གནས་ཀྱི་རི་བོ་རྣམས་བསིལ་བུར་ཐོར་བ་དང་། ཡུན་གནས་ཀྱི་རི་ཕྲན་རྣམས་བརྡིབས་པ་ཡིན། ཁོང་གི་མཛད་པ་རྒྱུན་ནས་རྒྱུན་དུ་གནས།",
      "7": "ཀུ་ཤན་ཡུལ་གྱི་གུར་ལ་སྡུག་བསྔལ་འབྱུང་བ་ངས་མཐོང་ཞིང་། མིད་ཡཱན་ཡུལ་གྱི་ཡོལ་བ་འཇིགས་ཤིང་སྐྲག་པར་གྱུར།",
      "8": "ཀྱེ་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། ཁྱེད་ཉིད་རང་གི་རྟ་མཆོག་ལ་བཅིབས་ནས། རྒྱལ་ཁ་ཐོབ་པའི་ཤིང་རྟའི་ཁ་ལོ་སྒྱུར་བ་ནི་ཆུ་དང་གཙང་པོར་ཐུགས་ཁྲོས་ཤིང་། ཆུ་དང་གཙང་པོ། རྒྱ་མཚོ་བཅས་ལ་འཁོན་ལན་སློག་པ་ཡིན་ནམ་ཅི།",
      "9": "ཁྱེད་ཀྱི་གཞུ་ནི་ཕྱིར་མངོན་ཞིང་། ཁྱེད་ཀྱི་མདའ་རྣམས་གྲ་སྒྲིག་བྱས་ཡོད་ལ། གཙང་པོས་ས་གཞི་གས་སུ་བཅུག ༼ སེ་ལཱ། ༽",
      "10": "རི་བོ་རྣམས་ཀྱིས་ཁྱེད་ཉིད་མཐོང་སྟེ་གཅུ་གྲིམ་བརྒྱབ་པ་དང་། ཆུ་རྒྱུན་དྲག་པོ་བཞུར་ཅིང་། གཡང་གཟར་གྱིས་སྐད་སྒྲ་སྒྲོག་བཞིན་རྦ་རླབས་དྲག་ཏུ་འཕྱུར་བ་ཡིན།",
      "11": "ཁྱེད་ཀྱི་མདའ་ནི་འོད་ལྟར་འཕུར་བ་དང་། ཁྱེད་ཀྱི་མདུང་གིས་འོད་འཕྲོས་ཤིང་གཟི་བརྗིད་མངོན་པས་ན། ཉི་ཟླ་གཉིས་ཀའང་རང་གནས་སུ་བསྡད་དོ། །",
      "12": "ཁྱེད་ཀྱི་ཁྲོ་གཏུམ་གྱིས་ས་གཞི་ཡོངས་བརྫིས་ཤིང་། ཁྱེད་ཀྱི་ཐུགས་ཁྲོ་ཡིས་ཚར་མ་རྡུང་བ་ལྟར་ཡུལ་ཁམས་ཐམས་ཅད་ལ་བརྡེགས་པའོ། །",
      "13": "ཁྱེད་ནི་ཉིད་ཀྱི་འབངས་མི་རྣམས་སྒྲོལ་བ་དང་སྣུམ་གྱིས་བྱུགས་པ་དེ་ཉིད་སྐྱོབ་པར་ཕེབས་པ་དང་། ཁྱེད་ཀྱིས་ངན་པའི་ཁྱིམ་བདག་ལ་བརྡུངས་ཏེ་མཆོག་དམན་ཐམས་ཅད་མེད་པར་མཛད་ཅིང་། ༼ སེ་ལཱ། ༽",
      "14": "ཁྱེད་ཀྱིས་དགྲ་ཡི་མདུང་གིས་དེའི་དམག་མིའི་མགོ་ལ་བཙུགས་ཤིང་། དེ་དག་རླུང་དམར་བཞིན་དུ་ངེད་རྣམས་གཏོར་དུ་འོངས་པ་དང་། ཁོ་ཚོ་ནི་ལྐོག་ནས་དབུལ་པོ་རྣམས་མེད་པར་བཟོ་བར་དགའོ། །",
      "15": "ཁྱེད་ཉིད་རྟ་ལ་བཅིབས་ཏེ་རྒྱ་མཚོའི་སྟེང་དུ་བརྒྱུད་པ་ན། རྒྱ་མཚོའི་རྦ་རླབས་དྲག་ཏུ་འཕྱུར་བའོ། །",
      "16": "ངས་སྒྲ་དེ་ཐོས་མ་ཐག་ལུས་པོ་ཡོངས་སུ་འདར། སྒྲ་དེའི་རྐྱེན་གྱིས་ངའི་མཆུ་སྒྲོས་ཀྱང་འདར་ཞིང་། ངའི་རུས་པ་རྣམས་རུལ་བར་གྱུར་པ་དང་། ངས་རང་ཉིད་ལངས་ནས་འདུག་སར་སྐྲག་སྐྲག་འདར་འདར་ངང་ཡུལ་འདིར་རྒོལ་བའི་མི་རྣམས་ཀྱི་སྟེང་དུ་གནོད་འཚེ་འབྱུང་བའི་ཉིན་མོ་དེ་སླེབས་འོང་བར་ཡུན་གྱིས་སྒུག་གོ །",
      "17": "¶ སེ་ཡབ་ཤིང་ལ་མྱུ་གུ་མ་འབུས་ཤིང་། རྒུན་འབྲུམ་ཤིང་ལ་འབྲས་བུ་མ་ཐོགས་པ་དང་། སྐྱུ་རུ་ཤིང་ལས་ཅི་ཡང་མ་ཐོན་པར། ཞིང་ལས་ལོ་ཏོག་ཅི་ཡང་མ་སྨིན་ལ། ལུག་རའི་ལུག་རྣམས་ཚར་དུ་བཅད་ནས་ནི། ཕྱུགས་རའི་ནང་དུ་བ་གླང་ཚར་ནའང་།",
      "18": "ང་ནི་དཀོན་མཆོག་ཡ་ཝཱེའི་རྐྱེན་གྱིས་དགའ་ཞིང་། རང་ཉིད་སྐྱོབ་པའི་དཀོན་མཆོག་གི་དབང་གིས་སྤྲོ་བར་འགྱུར།",
      "19": "གཙོ་བོ་ཡ་ཝཱེ་ནི་ངའི་སྟོབས་ཤུགས་ཡིན་ཏེ། ཁོང་གིས་ངའི་རྐང་པ་གཉིས་ཀ་ཤ་མོ་བཞིན་དུ་མྱུར་བར་མཛད་དེ་མཐོ་ས་ནས་བསྐྱོད་ཐུབ་པར་གྱུར་ཏོ། །འདི་ནི་དབུ་མཛད་ལ་སྤྲད་པའི་མགུར་མ་རྒྱུད་མང་རོལ་ཆས་སྤེལ༌མ་ཡིན་ནོ།། །།"
    }
  }
}
