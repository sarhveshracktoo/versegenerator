{
  "name": "ཕི་ལེ་མོན།",
  "id": "ཕི་ལེ་མོན།",
  "order": 57,
  "chapters": {
    "1": {
      "1": "¶ སྐྱབས་མགོན་མཱ་ཤི་ཀ་ཡེ་ཤུའི་ཆེད་དུ་བཙོན་པར་གྱུར་པའི་ཕོལ་ལོལ་ང་རང་གིས། བདག་ཅག་གི་སྤུན་ཟླ་ཐི་མོ་ཐེ་དང་མཉམ༌དུ་སྙིང་ནས་བརྩེ་བའི་ཆོས་གྲོགས་ཕི་ལེ་མོན་དང་།",
      "2": "གཅུང་མོ་ཨ་ཕི་ཡཱ་དང་། ད་དུང་བདག་ཅག་གི་དཔུང་གྲོགས་ཨར་ཀི་པུ་དང་། ཁྱོད་ཀྱི་ཁྱིམ་དུ་ཡོད་པའི་ཆོས་ཚོགས་བཅས་ལ་འཕྲིན་ཡིག་འདི་སྤྲིངས་པ་ཡིན་ནོ།།",
      "3": "བདག་ཅག་གི་ཡབ་དཀོན་མཆོག་དང་གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀ་ནས་ཁྱོད་རྣམས་ལ་ཐུགས་རྗེ་དང་ཞི་བདེ་འཐོབ་པར༌སྨོན།",
      "4": "¶ ངས་རང་གི་དཀོན་མཆོག་ལ་གསོལ་བ་འདེབས་པའི་དུས༌སུ། རྒྱུན་དུ་ཁྱོད་རང་གླེང་ཞིང་ཁྱོད་ཀྱི་ཆེད་དུ་བཀའ་དྲིན་ཞུས་པ་ཡིན་ནོ།།",
      "5": "ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱིས་གཙོ་བོ་ཡེ་ཤུར་བཅངས་པའི་དད་སེམས་དང་། དད་ལྡན་དམ་པ་ཐམས་ཅད་ལ་བཅངས་པའི་བྱམས་པ་ག་འདྲ་ཡིན་པ་ཐོས་པའི་ཕྱིར༌རོ།།",
      "6": "ཁྱོད་དང་མི་ཐམས་ཅད་ལ་མཉམ་དུ་ཡོད་པའི་དད་སེམས་ལས་ཕན་ནུས་ཐོན་ཏེ། བདག་ཅག་གི་ནང་དུ་ཡོད་པའི་དོན་བཟང་པོ་ཐམས་ཅད་ནི་སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ཆེད་དུ་ཡིན་པ་ཤེས་སུ་འཇུག་པར་སྨོན།",
      "7": "སྤུན་ཟླ༌ལགས། ཁྱོད་ལ་བརྟེན་ནས་དད་ལྡན་དམ་པ་རྣམས་ཀྱི་སེམས་ལ་སྐྱིད་སྣང་ཤར༌བས། ཁྱོད་ཀྱི་བྱམས་པ་ལ་བརྟེན་ནས་བདག་ལའང་དགའ་སྤྲོ་དང་སེམས་གསོ་ཆེན་པོ་ཐོབ༌བོ།།",
      "8": "¶ དེ་ལྟར་ཡིན་པས། ངས་སྐྱབས་མགོན་མཱ་ཤི་ཀ་ལ་བརྟེན་ནས་སྤོབས་པ་ཆེན་པོས་ཁྱོད་ལ་ཅི་ཞིག་བསྒྲུབ་འོས་པ་དེ་བསྒྲུབ་པར་བསྒོ་ནུས་མོད།",
      "9": "འོན་ཀྱང་ཕོལ་ལོལ་ང་ནི་ལོ་ན་རྒས་པ་ཞིག༌ཡིན་པར་མ་ཟད། ད་ལྟ་སྐྱབས་མགོན་མཱ་ཤི་ཀ་ཡེ་ཤུའི་ཆེད་དུ་བཙོན་པར་གྱུར་པ་ཞིག་ཀྱང་ཡིན། ངས་བྱམས་པ་ལ་བརྟེན་ནས་ཁྱོད་ལ་ཞུ་བ་བྱ༌སྟེ།",
      "10": "ང་རང་བཙོན་དུ་སྦྱར་བའི་དུས༌སུ་བདག་ལས་སྐྱེས་པའི་བུ་ཨོ་ནེ་སི་མུའི་ཆེད་དུ་ཁྱོད་ལ་ཞུ་བ༌བྱའོ།།",
      "11": "ཁོ་ནི་དེ་སྔར་ཁྱོད་ལ་ཕན་ཐོགས་མེད༌ནའང༌། ད་ལྟ་ཁྱོད་དང་ང་གཉིས་ལ་ཕན་ཐོགས་མཆིས་སོ།།",
      "12": "¶ ངས་ད་ལྟ་ཁོ་རང་ཁྱོད་ཀྱི་གམ་དུ་ཕྱིར་མངག་པར་བྱ་ཞིང་། ཁོ་ནི་བདག་གི་སྙིང་དང་འདྲ་བ་ཡིན།",
      "13": "འཕྲིན་བཟང་གི་ཆེད་དུ་ང་རང་བཙོན་དུ་སྦྱར་ཡོད་པ༌ལ། ཁོས་ཁྱོད་ཀྱི་ཚབ་ཏུ་བདག་ལ་ཞབས་ཕྱི་སྒྲུབ་པའི༌ཕྱིར། ངས་ཁོ་རང་བདག་གི་གམ་དུ་སྡོད་པར་བྱ་འདོད༌མོད།",
      "14": "འོན་ཀྱང་ཁྱོད་ཀྱི་བསམ་ཚུལ་མ་ཤེས༌པས། ངས་དེ་ལྟར་བྱ་མི་འདོད། ཅིའི་ཕྱིར་ཞེ་ན། ཁྱོད་ཀྱི་ལས་བཟང་པོ་ནི་བཙན་སྐུལ་མ་ཡིན་པར་རང་མོས་ལས་འབྱུང་བའི་ཕྱིར༌རོ།།",
      "15": "ཁོ་རང་རེ་ཞིག་ཁྱོད་དང་ཁ་བྲལ་བ་ནི་གཏན་དུ་ཁྱོད་ལ་འཐོབ་པའི་ཕྱིར་ཡིན་ཡང་སྲིད་དེ།",
      "16": "ད་ལྟ་གཡོག་པོ་མ་ཡིན༌པར། གཡོག་པོ་ལས་གོ་ས་མཐོ་ཞིང་སྙིང་ནས་བརྩེ་བའི་སྤུན་ཟླ་ཡིན༌ཞིང་། བདག་ལ་དངོས་གནས་དེ་ལྟར་ཡིན༌པས་ཁྱོད་ལ་སྨོས་ཅི༌དགོས། ལུས་ཕུང་གི་ཆ་ཁོ་ན་མ་ཡིན་པར་གཙོ་བོའི་ནང་དུའང་དེ་བཞིན་ཡིན་ནོ།།",
      "17": "¶ གལ་ཏེ། ཁྱོད་ཀྱིས་ང་རང་ཆོས་གྲོགས་སུ་བརྩིས༌ན། ཁྱོད་ཀྱིས་ང་ལ་གུས་ལེན་བྱེད་པ་བཞིན་ཁོ་ཡང་དང་ལེན་བྱེད་པར༌གྱིས།",
      "18": "གལ་ཏེ། ཁོས་ཁྱོད་ལ་འོས་མེད་བྱས་པའམ། ཡང་ན་ཁྱོད་ལ་བུ་ལོན་གང་ཞིག་ཆད་ན། དེ་དག་ཐམས་ཅད་བདག་གི་རྩིས་ཐོའི་ནང་དུ་ཁོད་དང་།",
      "19": "ངས་ཁྱོད་ལ་སྐྱིན་ཚབ་སྤྲོད་ངེས་ཤིང་། འདི་ནི་ཕོལ་ལོལ་བདག་གིས་དངོས་སུ་བྲིས་པ་ཡིན། ཐ་ན་ཁྱོད་ཀྱིས་རང་ཉིད་ཀྱང་ང་ལ་འབུལ་དགོས་པ་བདག་གིས་ཁྱོད་ལ་སྨྲ་མི་དགོས་སོ།།",
      "20": "སྤུན་ཟླ༌ལགས། ཁྱོད་ཀྱིས་གཙོ་བོའི་ནང་དུ་ང་རང་ལ་ཕན་འདོགས་པ་དང་། སྐྱབས་མགོན་མཱ་ཤི་ཀའི་ནང་དུ་ངའི་སེམས་དགའ་ཞིང་སྤྲོ་རུ་འཇུག་པར་སྨོན།",
      "21": "བདག་གིས་ཁྱོད་ལ་འཕྲིན་ཡིག་འདི་འབྲི་དོན༌ནི། ཁྱོད་ཀྱིས་ངའི་ངག་ལ་མཉན་པར་ཡིད་ཆེས་བརྟན་པོ་ཡོད་པར་མ༌ཟད། ངས་སྨྲས་པ་ལས་ཀྱང་ལྷག་པ་ཞིག་བསྒྲུབ་ངེས་པ་ཤེས་པའི་ཕྱིར༌རོ།།",
      "22": "¶ གཞན༌ཡང༌། ཁྱོད་ཀྱིས་བདག་ལ་སྡོད་གནས་སྟ་གོན་བྱེད་པར་གྱིས། ཅིའི་ཕྱིར་ཞེ་ན། ངས་ཁྱོད་རྣམས་ཀྱི་སྨོན་ལམ་བརྒྱུད་ནས་ཐུགས་རྗེ་འཐོབ་པ་དང་། ཁྱོད་ཅག་གི་གམ་དུ་འགྲོ་བར་རེ་སྨོན་བཅངས་པའི་ཕྱིར༌རོ།།",
      "23": "¶ སྐྱབས་མགོན་མཱ་ཤི་ཀ་ཡེ་ཤུའི་ཆེད་དུ་བདག་དང་མཉམ་དུ་བཙོན་ལ་སྦྱར་བའི་ཨེ་པབ་རཱ་ཡིས་ཁྱོད་ལ་འཚམས་འདྲི༌ཞུའོ།།",
      "24": "བདག་གི་ཆོས་གྲོགས་མཱར་ཀུ༌དང༌། ཨ་རི་སྟར༌ཀུ ཏི༌མཱ། ལོ་ཀུ་བཅས་ཀྱིས་ཀྱང་ཁྱོད་ལ་འཚམས་འདྲི༌ཞུའོ།།",
      "25": "གཙོ་བོ་ཡེ་ཤུ་མཱ་ཤི་ཀའི་ཐུགས་རྗེ་ནམ་ཡང་ཁྱོད་ཅག་གི་སེམས་སུ་གནས་པར༌སྨོན།། །།"
    }
  }
}
