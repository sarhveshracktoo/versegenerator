{
  "name": "ཨེས་སི་རཱ།",
  "id": "ཨེས་སི་རཱ།",
  "order": 15,
  "chapters": {
    "1": {
      "1": "¶ དེ་ཡང་ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱི་སྲིད་ལོ་དང་པོར། དཀོན་མཆོག་ཡ་ཝཱེས་ཁོང་ཉིད་ཀྱི་བཀའ་སྟེ་ཡེ་རེམ་ཡཱའི་ངག་བརྒྱུད་ནས་གསུངས་པ་དེ་འགྲུབ་པར་མཛད་པའི་ཕྱིར། ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ལ་ཡི་གེར་བཀོད་དེ་རང་གི་རྒྱལ་ཁམས་ཡོངས་ལ་ཁྱབ་བསྒྲགས་བྱེད་པར་སྐུལ་མ་གནང་ནས་འདི་ལྟར་བྲིས་པ་སྟེ།",
      "2": "ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་འདི་ལྟར། ནམ་མཁའི་དཀོན་མཆོག་ཡ་ཝཱེས་ས་གཞིའི་རྒྱལ་ཁམས་ཐམས་ཅད་བདག་ལ་གནང་བ་དང་། ཁོང་གིས་བདག་ཡ་ཧུ་དཱ་ཡུལ་གྱི་ཡེ་རུ་སཱ་ལེམ་དུ་ཁོང་གི་ཕྱིར་མཆོད་ཁང་ཞིག་བཞེང་བར་བསྐོས་པ་ཡིན།",
      "3": "ཁྱོད་ཅག་གི་ཁྲོད་དུ་དཀོན་མཆོག་གི་འབངས་མི་གང་དང་གང་ཡོད་ན། ཁོ་ཚོའི་དཀོན་མཆོག་དེ་དག་དང་མཉམ་དུ་བཞུགས་པར་ཤོག དེ་དག་ཡ་ཧུ་དཱ་ཡུལ་གྱི་ཡེ་རུ་སཱ་ལེམ་དུ་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་ཡང་བསྐྱར་བཞེང་བར་ཡར་འགྲོ་རུ་ཆུག ཁོང་ནི་ཡེ་རུ་སཱ་ལེམ་དུ་བཞུགས་པའི་དཀོན་མཆོག་ཡིན།",
      "4": "གནས་དེའི་མི་ཡིས་གསེར་དང་དངུལ། རྒྱུ་ནོར། ཕྱུགས་ཟོག་བཅས་ཀྱིས་གང་ས་གང་དུ་སྡོད་པའི་མི་ལྷག་ལུས་རྣམས་ལ་རོགས་བྱེད་དགོས། དེར་མ་ཟད་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་ཡིད་མོས་མཆོད་པ་འབུལ་དགོས་ཞེས་བཀའ་བསྩལ།",
      "5": "དེ་ནས་ཡ་ཧུ་དཱ་དང་། པེན་ཡཱ་མེན་གྱི་ཚོ་དཔོན་དང་། མཆོད་དཔོན་རྣམས། ལེ་ཝི་པ་རྣམས་ཏེ་དཀོན་མཆོག་ནས་སེམས་འགུལ་ཐེབས་པ་ཐམས་ཅད་ཡར་ཡེ་རུ་སཱ་ལེམ་དུ་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་ཡང་བསྐྱར་བཞེང་བར་ཕྱིན།",
      "6": "ཡང་ཕྱོགས་བཞིར་གནས་པ་རྣམས་ཀྱིས་དངུལ་གྱི་ཡོ་བྱད་དང་གསེར། རྒྱུ་ནོར། ཕྱུགས་ཟོག རིན་པོ་ཆེ་བཅས་ཀྱིས་རྒྱབ་སྐྱོར་བྱས་པར་མ་ཟད། རང་མོས་ཀྱིས་འབུལ་བ་སྣ་ཚོགས་ཕུལ་ཞིང་།",
      "7": "རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་སྣོད་ཆས་རྣམས་ཕྱིར་བཏོན་པ་དང་། སྣོད་ཆས་དེ་དག་ནི་སྔར་རྒྱལ་པོ་ནེ་བོ་ཀད་ནེ་ཙར་གྱིས་ཡེ་རུ་སཱ་ལེམ་ནས་ཁྱེར་ཅིང་རང་གི་ལྷ་ཁང་དུ་བཞག་པ་རྣམས་ཡིན་ཏེ།",
      "8": "ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་ཕྱག་མཛོད་མིད་རེ་དད་མངགས་ཏེ་སྣོད་ཆས་དེ་རྣམས་ཕྱིར་བླངས་ནས་ཡ་ཧུ་དཱའི་འགོ་དཔོན་ཤེ་སཱ་པ་ཙར་ལ་རྩིས་སྤྲད་པ་རེད།",
      "9": "དེ་དག་གི་བསྡོམས་གྲངས་ནི་འདི་ལྟ་སྟེ། གསེར་གྱི་གསོལ་སྡེར་སུམ་ཅུ་དང་། དངུལ་གྱི་གསོལ་སྡེར་ཆིག་སྟོང་། གྲི་ཉེར་དགུ།",
      "10": "གསེར་གྱི་ཕོར་བ་སུམ་ཅུ། དངུལ་གྱི་ཕོར་བ་དམིགས་རྟེན་བཞི་བརྒྱ་དང་བཅུ། སྣོད་ཆས་གཞན་པའི་རིགས་ཆིག་སྟོང་བཅས་ཡོད།",
      "11": "གསེར་དང་དངུལ་གྱི་སྣོད་ཆས་ཐམས་ཅད་བསྡོམས་པས་ལྔ་སྟོང་བཞི་བརྒྱ་ཡོད། བཙོན་དུ་ཁྲིད་པའི་མི་རྣམས་པཱ་པེལ་ལོན་ནས་ཡེ་རུ་སཱ་ལེམ་དུ་འོང་དུས། ཤེ་སཱ་པ་ཙར་གྱིས་སྣོད་ཆས་འདི་ཐམས་ཅད་ཀྱང་ཁྱེར་འོངས་སོ། །"
    },
    "2": {
      "1": "¶ ཡ་ཧུ་དཱ་ཡུལ་གྱི་མི་འདི་རྣམས་ནི་སྔར་པཱ་པེལ་ལོན་གྱི་རྒྱལ་པོ་ནེ་བོ་ཀད་ནེ་ཙར་གྱིས་པཱ་པེལ་ལོན་ལ་བཙོན་དུ་ཁྲིད་པ་དང་། ད་ལྟ་ཁོ་རྣམས་བཙན་ཁྲིད་བྱས་པའི་ཡུལ་ནས་ཡར་ཐོན་ཏེ་ཡེ་རུ་སཱ་ལེམ་དང་ཡ་ཧུ་དཱའི་ཡུལ་དུ་སོ་སོའི་གནས་སུ་ཕྱིར་ལོག་པ་ནི་འདི་ལྟ་སྟེ།",
      "2": "ཁོ་ཚོ་ནི་ཟེ་རུ་པཱ་པེལ་དང་། ཡེ་ཤུ་ཨ། ནེ་ཧེམ་ཡཱ། སེ་ར་ཡཱ། རེ་ཨེ་ལ་ཡཱ། མོར་དོ་ཀཱ་ཡི། པིལ་ཤན། མིས་ཕར། པིག་ཝ་ཨི། རེ་ཧུམ། པ་ཨ་ནཱ་བཅས་མཉམ་དུ་ཕྱིར་ལོག་པ་སྟེ། ཡེས་ར་ཨེལ་གྱི་སྐྱེས་པ་རྣམས་ཀྱི་བསྡོམས་གྲངས་ནི།",
      "3": "ཕཱར་ཨོ་སིའི་བུ་རྒྱུད་ཉིས་སྟོང་བརྒྱ་དང་བདུན་ཅུ་དོན་གཉིས་ཡོད།",
      "4": "ཤེ་ཕད་ཡཱ་ཡི་བུ་རྒྱུད་སུམ་བརྒྱ་དང་བདུན་ཅུ་དོན་གཉིས་ཡོད།",
      "5": "ཨ་རཱའི་བུ་རྒྱུད་བདུན་བརྒྱ་དང་བདུན་ཅུ་དོན་ལྔ་ཡོད།",
      "6": "ཕཱ་ཧད་མོ་ཨབ་ཀྱི་རུས་རྒྱུད་དེ། ཡེ་ཤུ་ཨ་དང་ཡོ་ཨབ་ཀྱི་བུ་རྒྱུད་ཉིས་སྟོང་བརྒྱད་བརྒྱ་བཅུ་གཉིས་ཡོད།",
      "7": "ཨེ་ལཱམ་གྱི་བུ་རྒྱུད་ཆིག་སྟོང་ཉིས་བརྒྱ་ལྔ་བཅུ་ང་བཞི་ཡོད།",
      "8": "ཟད་ཐུའི་བུ་རྒྱུད་དགུ་བརྒྱ་དང་བཞི་བཅུ་ཞེ་ལྔ་ཡོད།",
      "9": "ཟག་ཀ་ཨི་ཡི་བུ་རྒྱུད་བདུན་བརྒྱ་དང་དྲུག་ཅུ་ཡོད།",
      "10": "པཱ་ནིའི་བུ་རྒྱུད་དྲུག་བརྒྱ་དང་བཞི་བཅུ་ཞེ་གཉིས་ཡོད།",
      "11": "པེ་བཱ་ཨིའི་བུ་རྒྱུད་དྲུག་བརྒྱ་དང་ཉེར་གསུམ་ཡོད།",
      "12": "ཨས་གད་ཀྱི་བུ་རྒྱུད་ཆིག་སྟོང་ཉིས་བརྒྱ་དང་ཉེར་གཉིས་ཡོད།",
      "13": "ཨ་དོ་ནི་ཀམ་གྱི་བུ་རྒྱུད་དྲུག་བརྒྱ་དང་དྲུག་ཅུ་རེ་དྲུག་ཡོད།",
      "14": "པིག་ཝ་ཨིའི་བུ་རྒྱུད་ཉིས་སྟོང་དང་ལྔ་བཅུ་ང་དྲུག་ཡོད།",
      "15": "ཨ་དིན་གྱི་བུ་རྒྱུད་བཞི་བརྒྱ་དང་ལྔ་བཅུ་ང་བཞི་ཡོད།",
      "16": "ཨ་ཏེར་གྱི་བུ་རྒྱུད་དེ། ཧི་ཟི་ཀི་ཡཱའི་བུ་རྒྱུད་དགུ་བཅུ་གོ་བརྒྱད་ཡོད།",
      "17": "པེ་ཙ་ཨིའི་བུ་རྒྱུད་སུམ་བརྒྱ་དང་ཉེར་གསུམ་ཡོད།",
      "18": "ཡོ་རཱའི་བུ་རྒྱུད་བརྒྱ་དང་བཅུ་གཉིས་ཡོད།",
      "19": "ཧ་ཤུམ་གྱི་བུ་རྒྱུད་ཉིས་བརྒྱ་དང་ཉེར་གསུམ་ཡོད།",
      "20": "གིབ་བར་གྱི་བུ་རྒྱུད་དགུ་བཅུ་གོ་ལྔ་ཡོད།",
      "21": "པེད་ལེ་ཧེམ་གྱི་མི་བརྒྱ་དང་ཉེར་གསུམ་ཡོད།",
      "22": "ནེ་ཏོ་ཕཱའི་མི་ལྔ་བཅུ་ང་དྲུག་ཡོད།",
      "23": "ཨ་ན་ཐོད་པའི་མི་བརྒྱ་དང་ཉེར་བརྒྱད་ཡོད།",
      "24": "ཨས་མ་ཝེད་ཀྱི་མི་བཞི་བཅུ་ཞེ་གཉིས་ཡོད།",
      "25": "ཀིར་ཡཱད་ཡེ་ཨ་རིམ་དང་ཀེ་ཕི་རཱ། པེ་ཨེ་རཱོད་ཀྱི་མི་བསྡོམས་པས་བདུན་བརྒྱ་དང་བཞི་བཅུ་ཞེ་གསུམ་ཡོད།",
      "26": "རཱ་མ་དང་གེ་བཱའི་མི་བསྡོམས་པས་དྲུག་བརྒྱ་དང་ཉེར་གཅིག་ཡོད།",
      "27": "མིགས་མཱ་སི་ཡི་མི་བརྒྱ་དང་ཉེར་གཉིས་ཡོད།",
      "28": "པེད་ཨེལ་དང་ཨེ་ཡུ་ཡི་མི་བསྡོམས་པས་ཉིས་བརྒྱ་དང་ཉེར་གསུམ་ཡོད།",
      "29": "ནེ་བོའི་མི་ལྔ་བཅུ་ང་གཉིས་ཡོད།",
      "30": "མ་བིས་ཀྱི་བུ་རྒྱུད་བརྒྱ་དང་ལྔ་བཅུ་ང་དྲུག་ཡོད།",
      "31": "ཨེ་ལཱམ་གཞན་དེའི་བུ་རྒྱུད་ཆིག་སྟོང་ཉིས་བརྒྱ་ལྔ་བཅུ་ང་བཞི་ཡོད།",
      "32": "ཧ་རིམ་གྱི་བུ་རྒྱུད་སུམ་བརྒྱ་ཉི་ཤུ་ཡོད།",
      "33": "ལོད་དང་ཧ་དིད་དང་ཨོ་ནོའི་བུ་རྒྱུད་བསྡོམས་པས་བདུན་བརྒྱ་དང་ཉེར་ལྔ་ཡོད།",
      "34": "ཡེ་རུ་ཀོའི་བུ་རྒྱུད་སུམ་བརྒྱ་དང་ཞེ་ལྔ་ཡོད།",
      "35": "སེ་ན་ཨའི་བུ་རྒྱུད་སུམ་སྟོང་དྲུག་བརྒྱ་སུམ་ཅུ་ཡོད།",
      "36": "¶ མཆོད་དཔོན་དག་ནི། ཡེ་ཤུ་ཨའི་ཁྱིམ་རྒྱུད་ཀྱི་ཡེ་དཱ་ཡའི་བུ་རྒྱུད་དགུ་བརྒྱ་བདུན་ཅུ་དོན་གསུམ་ཡོད།",
      "37": "ཨིམ་མེར་གྱི་བུ་རྒྱུད་ཆིག་སྟོང་ལྔ་བཅུ་ང་གཉིས་ཡོད།",
      "38": "ཕཱ་ཤུར་གྱི་བུ་རྒྱུད་ཆིག་སྟོང་ཉིས་བརྒྱ་བཞི་བཅུ་ཞེ་བདུན་ཡོད།",
      "39": "ཧ་རིམ་གྱི་བུ་རྒྱུད་ཆིག་སྟོང་བཅུ་བདུན་ཡོད།",
      "40": "¶ ལེ་ཝི་པ་རྣམས་ནི། ཧོ་དབ་ཡཱའི་རུས་རྒྱུད་དེ། ཡེ་ཤུ་ཨ་དང་ཀད་མི་ཨེལ་གྱི་བུ་རྒྱུད་བདུན་ཅུ་དོན་བཞི་ཡོད།",
      "41": "མགུར་ལེན་མཁན་རྣམས་ནི། ཨ་སབ་ཀྱི་བུ་རྒྱུད་བརྒྱ་དང་ཉེར་བརྒྱད་ཡོད།",
      "42": "སྒོ་སྲུང་རྣམས་ནི། ཤལ་ལུམ་གྱི་བུ་རྒྱུད་དང་། ཨ་ཏེར་གྱི་བུ་རྒྱུད། ཏལ་མོན་གྱི་བུ་རྒྱུད། ཨག་ཁུབ་ཀྱི་བུ་རྒྱུད། ཧ་ཏི་ཏའི་བུ་རྒྱུད། ཤོ་བཱའི་བུ་རྒྱུད་བཅས་བསྡོམས་པས་མི་བརྒྱ་དང་སུམ་ཅུ་སོ་དགུ་ཡིན།",
      "43": "¶ མཆོད་གཡོག་ནི། ཙི་ཧཱའི་བུ་རྒྱུད་དང་། ཧ་སུ་ཕའི་བུ་རྒྱུད། ཏབ་བ་ཨོད་ཀྱི་བུ་རྒྱུད།",
      "44": "ཀོ་རེས་ཀྱི་བུ་རྒྱུད། སི་ཨ་ཧའི་བུ་རྒྱུད། ཕ་དོན་གྱི་བུ་རྒྱུད།",
      "45": "ལེ་བ་ནཱའི་བུ་རྒྱུད། ཧ་ག་བཱའི་བུ་རྒྱུད། ཨག་ཁུབ་ཀྱི་བུ་རྒྱུད།",
      "46": "ཧ་གབ་ཀྱི་བུ་རྒྱུད། ཤལ་མཱ་ཨིའི་བུ་རྒྱུད། ཧ་ནན་གྱི་བུ་རྒྱུད།",
      "47": "གིད་དེལ་གྱི་བུ་རྒྱུད། ག་ཧར་གྱི་བུ་རྒྱུད། རེ་ཨ་ཡཱའི་བུ་རྒྱུད།",
      "48": "རེ་ཙིན་གྱི་བུ་རྒྱུད། ནེ་ཀོ་དཱའི་བུ་རྒྱུད། ག་ཟམ་གྱི་བུ་རྒྱུད།",
      "49": "ཨུ་ཟཱའི་བུ་རྒྱུད། ཕཱ་སེ་ཨའི་བུ་རྒྱུད། པེ་སཱ་ཨིའི་བུ་རྒྱུད།",
      "50": "ཨས་ནའི་བུ་རྒྱུད། མེ་ཧུ་ནིམ་གྱི་བུ་རྒྱུད། ནེ་ཕུ་སིམ་གྱི་བུ་རྒྱུད།",
      "51": "པག་པུག་གི་བུ་རྒྱུད། ཧ་ཀུ་ཕཱའི་བུ་རྒྱུད། ཧར་ཧར་གྱི་བུ་རྒྱུད།",
      "52": "པ་ཟི་ལུད་ཀྱི་བུ་རྒྱུད། མེ་ཧི་དཱའི་བུ་རྒྱུད། ཧར་ཤའི་བུ་རྒྱུད།",
      "53": "པཱར་ཀོས་ཀྱི་བུ་རྒྱུད། སི་ས་རཱའི་བུ་རྒྱུད། ཐེ་མཱའི་བུ་རྒྱུད།",
      "54": "ནེ་ཙི་ཡཱའི་བུ་རྒྱུད། ཧ་ཏི་ཕའི་བུ་རྒྱུད་བཅས་ཡིན།",
      "55": "སོ་ལོ་མོན་གྱི་གཡོག་པོའི་བུ་རྒྱུད་ནི་སོ་ཏའི་བུ་རྒྱུད་དང་། སོ་ཕེ་རེད་ཀྱི་བུ་རྒྱུད། པེ་རུ་དཱའི་བུ་རྒྱུད།",
      "56": "ཡ་ཨ་ལའི་བུ་རྒྱུད། དར་ཀོན་གྱི་བུ་རྒྱུད། གིད་དེལ་གྱི་བུ་རྒྱུད།",
      "57": "ཤེ་ཕད་ཡཱའི་བུ་རྒྱུད། ཧད་ཏིལ་གྱི་བུ་རྒྱུད། ཕོ་ཁེ་རེད་ཧ་ཙེ་བཱ་ཡི་བུ་རྒྱུད། ཨ་མིའི་བུ་རྒྱུད་བཅས་ཡིན།",
      "58": "མཆོད་གཡོག་ཐམས་ཅད་དང་སོ་ལོ་མོན་གྱི་གཡོག་པོ་དག་གི་བུ་རྒྱུད་ཀྱི་བསྡོམས་གྲངས་ནི་མི་སུམ་བརྒྱ་དང་དགུ་བཅུ་གོ་གཉིས་ཡིན།",
      "59": "ཡང་ཐེལ་མེ་ཝཱ་དང་། ཐེལ་ཧར་ཤ། ཀེ་རུབ། ཨད་དོན། ཨིམ་མེར་ཡུལ་བཅས་ནས་ཡོང་བ་རྣམས་ཀྱིས་རང་གི་ཕ་མེས་ཀྱི་གདུང་རབས་ཡེས་ར་ཨེལ་ནས་ཆད་པར་ར་སྤྲོད་བྱེད་མ་ནུས་སོ། །",
      "60": "དེ་རྣམས་ནི་དི་ལཱ་ཡའི་བུ་རྒྱུད་དང་། ཏོ་བི་ཡཱའི་བུ་རྒྱུད། ནེ་ཀོ་དཱའི་བུ་རྒྱུད་བཅས་བསྡོམས་པས་མི་དྲུག་བརྒྱ་ལྔ་བཅུ་ང་གཉིས་ཡིན།",
      "61": "མཆོད་དཔོན་དག་གི་བུ་རྒྱུད་ནས་ཧ་བཱ་ཡཱའི་བུ་རྒྱུད་དང་། ཧག་ཀོས་ཀྱི་བུ་རྒྱུད། པཱར་ཟི་ལ་ཨིའི་བུ་རྒྱུད་བཅས་ཡོད་དེ། པཱར་ཟི་ལ་ཨི་བྱ་བ་དེས་གིལ་ཨད་པའི་པཱར་ཟི་ལ་ཨི་ཞེས་པ་དེའི་བུ་མོ་ཆུང་མར་བླངས་པས། དེའི་མིང་བཞིན་དུ་བཏགས།",
      "62": "དེ་དག་གིས་རང་གི་རུས་རྒྱུད་ཀྱི་གདུང་རབས་བཙལ་ཡང་མ་རྙེད། དེའི་ཕྱིར་དེ་རྣམས་མི་གཙང་བར་བརྩིས་ཏེ་མཆོད་དཔོན་གྱི་གྲལ་ནས་ཕུད།",
      "63": "ཡང་འགོ་དཔོན་གྱིས་ཁོ་ཚོར། མཆོད་དཔོན་ཞིག་གིས་ཨུའུ་རིམ་དང་ཐུའུ་མིམ་ལ་བརྟེན་ནས་ཐག་གིས་མ་བཅད་བར་དུ། ཁོ་རྣམས་ཀྱིས་དམ་པའི་ཟས་ཅི་ཡང་བཟའ་མི་ཆོག་པར་བསྐུལ།",
      "64": "འདུ་ཚོགས་འདིའི་བསྡོམས་གྲངས་ནི་བཞི་ཁྲི་ཉིས་སྟོང་སུམ་བརྒྱ་དྲུག་ཅུ་ཡིན།",
      "65": "གཞན་གཡོག་པོ་དང་གཡོག་མོ་བདུན་སྟོང་སུམ་བརྒྱ་སུམ་ཅུ་སོ་བདུན་ཡོད་པ་དང་། ཡང་མགུར་ལེན་མཁན་སྐྱེས་པ་དང་བུད་མེད་ཉིས་བརྒྱ་ཡོད།",
      "66": "རྟ་བདུན་བརྒྱ་སུམ་ཅུ་སོ་དྲུག་ཡོད། དྲེལ་ཉིས་བརྒྱ་བཞི་བཅུ་ཞེ་ལྔ་ཡོད།",
      "67": "རྔ་མོང་བཞི་བརྒྱ་སུམ་ཅུ་སོ་ལྔ་ཡོད། བོང་བུ་དྲུག་སྟོང་བདུན་བརྒྱ་ཉི་ཤུ་ཡོད།",
      "68": "ཚོ་དཔོན་འགའ་ཤས་ཡེ་རུ་སཱ་ལེམ་དུ་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་དུ་སླེབས་ཚེ། དཀོན་མཆོག་གི་མཆོད་ཁང་དེ་སྔའི་རྨང་གཞི་སྟེང་ཡང་བསྐྱར་བཞེང་བའི་ཕྱིར་དུ་རང་མོས་ཀྱིས་འབུལ་བ་ཕུལ།",
      "69": "དེ་དག་གིས་རང་གི་ནུས་པར་བསྟུན་ནས་མཁར་བཟོའི་མཛོད་ཁང་ལ་གསེར་གྱི་དོང་ཙེ་དྲུག་ཁྲི་ཆིག་སྟོང་དང་། དངུལ་མཱེ་ན་ལྔ་སྟོང་། མཆོད་དཔོན་གྱི་གོས་བརྒྱ་བཅས་ཀྱི་འབུལ་བ་ཕུལ།",
      "70": "དེ་ནས་མཆོད་དཔོན་དང་། ལེ་ཝི་པ། མགུར་ལེན་མཁན། སྒོ་སྲུང་། མཆོད་གཡོག འབངས་མི་ཁ་ཤས་བཅས་སོ་སོ་རང་གི་གྲོང་ཁྱེར་དུ་གནས་པ་དང་། ཡེས་ར་ཨེལ་པ་རྣམས་རང་གི་གྲོང་ཁྱེར་དུ་གནས་སོ། །"
    },
    "3": {
      "1": "¶ དེ་ནས་ཟླ་བདུན་པ་ལོན་པའི་ཚེ། གྲོང་ཁྱེར་སོ་སོར་གནས་པའི་ཡེས་ར་ཨེལ་པ་རྣམས་ཡེ་རུ་སཱ་ལེམ་དུ་བློ་སེམས་གཅིག་མཐུན་ངང་མཉམ་དུ་འཛོམས་ཏེ།",
      "2": "ཡོ་ཚ་དག་གི་བུ་ཡེ་ཤུ་ཨ་དང་། ཁོའི་སྤུན་མཆོད་དཔོན་རྣམས་དང་། ཞིད་ཨལ་ཐེ་ཨེལ་གྱི་བུ་ཟེ་རུ་པཱ་པེལ་དང་། ཁོའི་སྤུན་རྣམས་ཡོང་ནས་དཀོན་མཆོག་གི་སྐྱེས་བུ་མོ་ཤེའི་བཀའ་ཁྲིམས་ནང་བཀོད་པ་བཞིན་དུ། སྦྱིན་སྲེག་གི་མཆོད་པ་འབུལ་ཕྱིར་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁྲི་བཞེངས་སོ། །",
      "3": "ཁོ་ཚོ་ཡུལ་མི་རྣམས་ལ་འཇིགས་པས། མཆོད་ཁྲི་དེ་སྔར་གནས་སུ་བཞེངས་ནས་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་ནངས་དགོང་སྦྱིན་སྲེག་གི་མཆོད་པ་ཕུལ་བ་དང་།",
      "4": "ཡང་མདོ་ནང་བཀོད་པ་བཞིན་དུ། དེ་དག་གིས་སྤྱིལ་བུའི་དུས་ཆེན་རོལ་ཏེ་ཁྲིམས་སྲོལ་ལྟར་སྦྱིན་སྲེག་གི་མཆོད་པ་ནི་ཉིན་རེའི་གྲངས་ཀ་བཞིན་དུ་ཕུལ།",
      "5": "ཡང་དེའི་རྗེས་སུ་དུས་རྒྱུན་གྱི་སྦྱིན་སྲེག་གི་མཆོད་པ་ཕུལ་བ་དང་། ཚེས་གཅིག་གི་མཆོད་པ་དང་དཀོན་མཆོག་ཡ་ཝཱེའི་དམ་པར་བྱས་པའི་དུས་ཆེན་གྱི་མཆོད་པ་དང་། ཡང་མི་རེ་རེས་དཀོན་མཆོག་ཡ་ཝཱེའི་ཕྱིར་ཡིད་མོས་མཆོད་པ་ཕུལ།",
      "6": "ཟླ་བདུན་པའི་ཚེས་གཅིག་ཉིན་ནས་བཟུང་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་རྨང་གཞི་ད་དུང་བཏིངས་མེད་ན་ཡང་། ཁོ་རྣམས་ཀྱིས་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་སྦྱིན་སྲེག་གི་མཆོད་པ་འབུལ་བའི་འགོ་བརྩམས།",
      "7": "ཡང་དེ་དག་གིས་རྡོ་བཟོ་དང་ཤིང་བཟོ་ལ་དངུལ་སྤྲད་དེ། ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱི་བཀའ་བཞིན་དུ། ལེ་པཱ་ནོན་ནས་རྒྱ་མཚོ་བརྒྱུད་དེ་ཡོ་ཕཱའི་བར་དུ་ཐང་ཤིང་འདྲེན་པའི་ཕྱིར། ཚི་ཏུན་པ་དང་ཐཱར་པ་རྣམས་ལ་བཟའ་བཏུང་དང་སྣུམ་བཅས་སྤྲད་དོ། །",
      "8": "¶ ཁོ་ཚོ་ཡེ་རུ་སཱ་ལེམ་དུ་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེངས་སར་སླེབས་པའི་ལོ་གཉིས་པའི་ཟླ་གཉིས་པར། ཞིད་ཨལ་ཐེ་ཨེལ་གྱི་བུ་ཟེ་རུ་པཱ་པེལ་དང་། ཡོ་ཚ་དག་གི་བུ་ཡེ་ཤུ་ཨ་དང་། དེ་དག་གི་སྤུན་མཆོད་དཔོན་རྣམས་དང་། ལེ་ཝི་པ་རྣམས་དང་། བཙོན་ལས་ཐར་ཏེ་ཡེ་རུ་སཱ་ལེམ་དུ་ཡོང་བ་རྣམས་ཀྱིས་ལས་འགོ་བརྩམས་པ་དང་། ལེ་ཝི་པ་ལོ་ཉི་ཤུ་ཡན་ལོན་པ་རྣམས་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་ལས་ཀའི་ལྟ་སྐུལ་བ་བྱེད་དུ་བཅུག",
      "9": "དེ་ནས་ཡ་ཧུ་དཱའི་བུ་རྒྱུད་དེ། ཡེ་ཤུ་ཨ་དང་ཁོའི་བུ་རྒྱུད་དང་སྤུན་རྣམས་དང་། ཀད་མི་ཨེལ་དང་ཁོའི་བུ་རྒྱུད་རྣམས་ནི་ལེ་ཝི་པ་ཧེ་ན་དད་ཀྱི་བུ་རྒྱུད་དང་སྤུན་རྣམས་དང་བཅས་འཛོམས་ནས། བློ་སེམས་རྩེ་གཅིག་ངང་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་བའི་ལས་བཟོ་པ་རྣམས་ལ་ལྟ་སྐུལ་བྱས།",
      "10": "ལས་བཟོ་པ་རྣམས་ཀྱིས་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་རྨང་གཞི་འདིང་བའི་ཚེ། མཆོད་དཔོན་གྱིས་ཆོས་གོས་གྱོན་ཏེ་དུང་ཐོགས་པ་དང་། ལེ་ཝི་པ་ཨ་སབ་ཀྱི་བུ་རྒྱུད་ཀྱིས་སྦུག་ཆལ་བརྡུངས་པ་དང་། ཡེས་ར་ཨེལ་གྱི་རྒྱལ་པོ་དཱ་བིད་ཀྱིས་བཙུགས་པའི་ཁྲིམས་བཞིན་དུ་ཡར་ལངས་ནས་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་བསྟོད་པ་ཕུལ་ཏེ།",
      "11": "ཁོ་ཚོས་མཉམ་དུ་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་བསྟོད་པ་དང་གཏང་རག་ཕུལ་ཞིང་འདི་ལྟར། ཁོང་ནི་བཟང་པོ་ལགས་ཤིང་། ཁོང་གིས་ཡེས་ར་ཨེལ་ལ་བཅངས་པའི་བྱམས་བརྩེ་རྒྱུན་ནས་རྒྱུན་དུ་གནས་སོ་ཞེས་བསྟོད་དབྱངས་ཕུལ་བ་དང་། ཁོ་ཚོས་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་བསྟོད་བསྔགས་འབུལ་བའི་དུས་སུ། དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་རྨང་གཞི་བཏིངས་ཟིན་པས་མི་ཚོགས་ཀྱིས་སྐད་ཆེན་པོས་ཀི་སྒྲ་བསྒྲགས་སོ། །",
      "12": "འོན་ཀྱང་མཆོད་དཔོན་མང་པོ་དང་ལེ་ཝི་པ། ཚོ་དཔོན་བཅས་སྔར་གྱི་མཆོད་ཁང་མཐོང་མྱོང་བའི་རྒན་པོ་མང་པོས་མཆོད་ཁང་འདིའི་རྨང་གཞི་ཡང་བསྐྱར་བཏིངས་པ་མཐོང་ནས་སྐད་ཆེན་པོས་ངུས་པ་དང་། ཡང་མི་མང་པོས་དགའ་སྤྲོའི་འབོད་སྒྲ་མཐོན་པོར་བསྒྲགས་པ་ལ།",
      "13": "དགའ་བའི་སྒྲ་དང་ངུ་བའི་སྒྲ་གང་ཡིན་ཁྱད་འབྱེད་མ་ནུས། གང་ལ་ཞེ་ན། འབངས་མི་རྣམས་ཀྱིས་སྐད་ཤིན་ཏུ་ཆེན་པོ་བཏོན་ཏེ། རྒྱང་རིང་ནས་ཀྱང་འུར་སྒྲ་དེ་ཐོས་ཐུབ་པའོ། །"
    },
    "4": {
      "1": "¶ ཡ་ཧུ་དཱ་དང་པེན་ཡཱ་མེན་གྱི་དགྲ་བོས་བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པའི་མི་རྣམས་ཀྱིས་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེའི་ཆེད་དུ་མཆོད་ཁང་ཡང་བསྐྱར་བཞེང་བ་ཐོས་ནས།",
      "2": "དེ་དག་ཟེ་རུ་པཱ་པེལ་དང་ཚོ་དཔོན་རྣམས་ཀྱི་མདུན་དུ་འོངས་ནས་དེ་རྣམས་ལ། ངེད་རྣམས་ལ་ཡང་ཁྱོད་ཚོ་དང་མཉམ་དུ་བཞེང་བར་འཇུག་རོགས། གང་ལ་ཞེ་ན། ངེད་རྣམས་ཀྱིས་ཀྱང་ཁྱོད་ཚོའི་དཀོན་མཆོག་འཚོལ་བཞིན་ཡོད་དེ། ཨ་སུར་གྱི་རྒྱལ་པོ་ཨེ་སར་ཧད་ཏོན་གྱིས་ངེད་རྣམས་བཟུང་སྟེ་གནས་འདིར་ཁྲིད་འོངས་པའི་དུས་ནས་བཟུང་ཁོང་ལ་རྒྱུན་དུ་མཆོད་པ་ཕུལ་བ་ཡིན་ཞེས་ཞུས།",
      "3": "འོན་ཀྱང་ཟེ་རུ་པཱ་པེལ་དང་ཡེ་ཤུ་ཨ། ཡེས་ར་ཨེལ་གྱི་ཚོ་དཔོན་རྣམས་ཀྱིས་དེ་དག་ལ། ངེད་རྣམས་ཀྱིས་དཀོན་མཆོག་གི་ཕྱིར་མཆོད་ཁང་བཞེང་བ་དེ་ཁྱོད་ཚོ་དང་འབྲེལ་བ་མེད་དེ། རྒྱུ་མཚན་ནི་ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་བཀའ་བསྒོས་པ་བཞིན་དུ་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་ནི་ང་ཚོ་རང་གིས་བཞེང་ཆོག་ཅེས་སྨྲས་སོ། །",
      "4": "དེ་ནས་གནས་དེའི་ཡུལ་མི་རྣམས་ཀྱིས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ་འཇིགས་བསྐུལ་ནས་མཆོད་ཁང་བཞེང་དུ་མ་བཅུག",
      "5": "ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་ཀྱི་དུས་ནས་ཏ་ཟིག་གི་རྒྱལ་པོ་དར་ཡཱའི་བར་དུ་དེ་དག་གིས་བློ་འདོན་མཁན་ནོར་གྱིས་བསླུས་ཏེ། ཡ་ཧུ་དཱ་པ་རྣམས་ཀྱི་འཆར་གཞི་ལ་གཏོར་བརླག་བྱེད་པའི་ཆེད་དུ་ཁོ་ཚོར་རྒོལ་བ་རེད།",
      "6": "¶ ཡང་ཨ་ཧཱ་ཤུ་ཝེ་རོ་ཤུ་བྱ་བས་རྒྱལ་སྲིད་ཐོག་མར་སྐྱོང་དུས། དེ་དག་གིས་གཏུག་ཡིག་བྲིས་ཏེ་ཡ་ཧུ་དཱ་དང་ཡེ་རུ་སཱ་ལེམ་གྱི་ཡུལ་མི་རྣམས་གཏུགས་པ་དང་།",
      "7": "དེ་ནས་ཨར་ཐག་ཤཱ་ཐིའི་དུས་སྐབས་སུ། པིས་ལམ་དང་མིད་རེ་དཱད་དང་། ཏ་བེ་ཨེལ་དང་། གྲོས་མི་གཞན་རྣམས་དང་མཉམ་དུ་ཏ་ཟིག་གི་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ལ་སྙན་ཞུ་ཕུལ་བ་སྟེ། སྙན་ཞུ་དེ་ནི་ཨ་རམ་གྱི་ཡི་གེ་ནས་བྲིས་ཤིང་སྐད་གཞན་དུ་བསྒྱུར།",
      "8": "འགོ་དཔོན་རེ་ཧུམ་དང་དྲུང་ཡིག་ཤིམ་ཤ་ཨི་གཉིས་ཀྱིས་ཀྱང་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ལ་སྙན་ཞུ་ཕུལ་ཏེ། ཡེ་རུ་སཱ་ལེམ་གྱི་འབངས་མི་རྣམས་གཏུག་བཤེར་བྱས་པ་འདི་ལྟར།",
      "9": "འགོ་དཔོན་རེ་ཧུམ་དང་དྲུང་ཡིག་ཤིམ་ཤ་ཨི་དང་གྲོས་མི་གཞན་རྣམས་ཏེ། ཁྲིམས་དཔོན་དང་། འགོ་དཔོན། དམག་དཔོན། ཏ་ཟིག་གི་འགོ་དཔོན། ཨེ་རེག་པ། པཱ་བེལ་པ། ཨེ་ལཱམ་ཡུལ་གྱི་མི་སྟེ་སོའུ་སཱན་པ།",
      "10": "ད་དུང་མི་ཆེན་ཨོས་ན་ཕཱར་གྱིས་བཙན་ཁྲིད་བྱས་ནས་སཱ་མར་ཡ་གྲོང་ཁྱེར་དང་གཙང་པོའི་ནུབ་ཕྱོགས་ལ་གནས་སུ་བཅུག་པའི་མི་མང་བཅས་ཀྱི་སྙན་ཞུ་འདི་ཡིན་ལགས།",
      "11": "ཁོ་ཚོས་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ལ་ཕུལ་བའི་སྙན་ཞུ་བཤུས་མ་ནི་འདི་ལྟ་སྟེ། གཙང་པོའི་ནུབ་རྒྱུད་དུ་སྡོད་པ་རྣམས་ཀྱིས་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ལ་སྙན་ཞུ་འབུལ་དོན་ནི།",
      "12": "རྒྱལ་པོ་ཆེན་པོར་ཞུ་དོན། རྒྱལ་པོའི་མདུན་ནས་ང་ཚོའི་འདིར་ཡར་འོངས་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ནི། ངོ་ལོག་ཐ་ཤལ་ཡིན་པའི་གྲོང་ཁྱེར་ཡེ་རུ་སཱ་ལེམ་དུ་སླེབས་ནས་དེ་བཞེང་བཞིན་འདུག་སྟེ། རྨང་གཞི་བཏིངས་ནས་མཁར་གྱང་བསྐྱར་གསོ་བྱེད་བཞིན་ནོ། །",
      "13": "ད་ལྟ་རྒྱལ་པོ་ཆེན་པོས་མཁྱེན་རོགས་ཞུ། གྲོང་ཁྱེར་འདི་བཞེངས་ནས་མཁར་གྱང་བརྩིགས་ཚར་དུས། དེ་དག་གིས་དཔྱ་ཁྲལ་དང་འབུལ་མཚན། འབྲུ་ཁྲལ་བཅས་མི་འཇལ་བར། རྒྱལ་པོའི་མཛོད་ཁང་གི་ཡོང་འབབ་ལ་གནོད་པ་འབྱུང་ངེས་ཏེ།",
      "14": "ད་ལྟ་བདག་ཅག་གིས་ཟ་བའི་ཚྭ་ཡང་རྒྱལ་པོའི་ཕོ་བྲང་གི་ཡིན་པས། རྒྱལ་པོ་ལ་སྨོད་པ་འབྱུང་བར་མི་འདོད། དེའི་ཕྱིར་རྒྱལ་པོ་ལ་སྙན་ཞུ་ཕུལ་བ་སྟེ།",
      "15": "ཁྱེད་ཀྱི་ཡབ་མེས་རྣམས་ཀྱི་ལོ་རྒྱུས་དེབ་ཐེར་ནང་དུ་རྩད་གཅོད་རོགས། ལོ་རྒྱུས་དེབ་ཐེར་ལས་གྲོང་ཁྱེར་འདི་ནི་གྲོང་ཁྱེར་ངོ་ལོག་ཅན་དང་། རྒྱལ་པོ་དང་ལྗོངས་རྣམས་ལ་གནོད་པ་ཆེ་བ་དང་། ཐོག་མ་ནས་གཞན་ལ་ངོ་ལོག་བྱེད་དུ་འཇུག་མཁན་ཡིན་པ་མཁྱེན་པར་འགྱུར་བས། གྲོང་ཁྱེར་འདི་སྔོན་ཆད་མེད་པར་བྱས་སོ། །",
      "16": "གལ་ཏེ་གྲོང་ཁྱེར་འདི་ཡང་བསྐྱར་བཞེངས་ནས་མཁར་གྱང་བརྩིགས་ཚར་ན། གཙང་པོའི་ཕ་རོལ་གྱི་ཡུལ་རྣམས་སུ་རྒྱལ་པོ་ལ་དབང་ཅི་ཡང་མེད་དོ་ཞེས་པའོ། །",
      "17": "དེར་རྒྱལ་པོས་འགོ་དཔོན་རེ་ཧུམ་དང་དྲུང་ཡིག་ཤིམ་ཤ་ཨི་གཉིས་དང་། དེ་དག་གི་གྲོས་མི་གཞན་རྣམས་ཏེ་སཱ་མར་ཡ་དང་གཙང་པོའི་ནུབ་རྒྱུད་དུ་གནས་པ་རྣམས་ལ་གོང་མའི་བཀའ་བབས་ནས་འདི་ལྟར། ཁྱོད་ཅག་བདེའམ།",
      "18": "ཁྱོད་ཚོས་ང་ལ་བསྐུར་བའི་སྙན་ཞུ་དེ་ངའི་མདུན་ནས་ཞིབ་ཏུ་བཀླགས་པ་དང་།",
      "19": "ངས་བཀའ་གནང་ནས་རྩད་བཅད་པ་ཡིན། དེ་ནི་གྲོང་ཁྱེར་དེས་གནའ་ནས་རྒྱལ་པོ་ལ་ངོ་ལོག་བྱས་ཤིང་། དེའི་ནང་རྒྱུན་དུ་ངོ་ལོག་དང་ཟིང་འཁྲུག་བྱུང་འདུག",
      "20": "སྔར་ཡེ་རུ་སཱ་ལེམ་དུ་རྒྱལ་པོ་ཤིན་ཏུ་དབང་ཅན་རྣམས་བྱུང་སྟེ། གཙང་པོའི་ནུབ་རྒྱུད་ཀྱི་ཡུལ་ཐམས་ཅད་དུ་སྲིད་བྱས་ཤིང་། མི་ཐམས་ཅད་ཀྱིས་དེ་དག་ལ་དཔྱ་ཁྲལ་དང་འབུལ་མཚན། འབྲུ་ཁྲལ་བཅས་བཅལ་ཏོ། །",
      "21": "ད་ཁྱོད་ཅག་གིས་མི་དེ་རྣམས་ཀྱི་ལས་མཚམས་འཇོག་པར་གྱིས་ཤིག བདག་གིས་བཀའ་མ་གནང་བར་དུ། གྲོང་ཁྱེར་དེ་ཡང་བསྐྱར་བཞེངས་མི་ཆོག",
      "22": "ཁྱོད་ཚོས་བྱ་བ་འདི་གཟབ་ནན་གྱིས་སྒྲུབས་ཤིག སྣང་མེད་དུ་བསྐྱུར་མི་རུང་། དེ་མིན་ཚེ་རྒྱལ་པོ་རྣམས་ལ་གནོད་པ་འདི་ལྡབ་འགྱུར་གྱིས་འཕེལ་བར་འགྱུར་རོ་ཞེས་པའོ། །",
      "23": "རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐིའི་གོང་མའི་བཀའ་ཡིག་བཤུས་མ་དེ་རེ་ཧུམ་དང་། དྲུང་ཡིག་ཤིམ་ཤ་ཨི་དང་། གྲོས་མི་རྣམས་ཀྱི་མདུན་དུ་བཀླགས་པ་དང་། དེ་རྣམས་མྱུར་དུ་ཡེ་རུ་སཱ་ལེམ་དུ་ཡ་ཧུ་དཱ་པའི་རྩར་ཕྱིན་ནས། དེ་དག་གི་ལས་མཚམས་བཙན་གྱིས་བཀག",
      "24": "དེའི་ཕྱིར་ཏ་ཟིག་གི་རྒྱལ་པོ་དར་ཡཱའི་སྲིད་ལོ་གཉིས་པའི་བར་དུ་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་མཚམས་བཞག་གོ །"
    },
    "5": {
      "1": "¶ དེ་ནས་ལུང་སྟོན་པ་ཧག་གཱ་ཨི་དང་། ཨིད་དོའི་བུ་རྒྱུད་དེ་ལུང་སྟོན་པ་ཟཱ་ཀར་ཡ་གཉིས་ཀྱིས་ཡ་ཧུ་དཱ་ཡུལ་དང་ཡེ་རུ་སཱ་ལེམ་དུ་གནས་པའི་ཡ་ཧུ་དཱ་པ་རྣམས་ལ། ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་གི་མཚན་བརྗོད་ནས་ལུང་བསྟན་གནང་།",
      "2": "དེ་ནས་ཞིད་ཨལ་ཐེ་ཨེལ་གྱི་བུ་ཟེ་རུ་པཱ་པེལ་དང་ཡོ་ཚ་དག་གི་བུ་ཡེ་ཤུ་ཨ་གཉིས་ལངས་ཏེ། ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་དེ་ཡང་བསྐྱར་བཞེང་བའི་འགོ་བརྩམས་ནས། དེ་དག་ལ་དཀོན་མཆོག་གི་ལུང་སྟོན་པས་རྒྱབ་སྐྱོར་མཛད་དོ། །",
      "3": "དུས་དེ་ཉིད་དུ་གཙང་པོའི་ཕ་རོལ་གྱི་སྤྱི་དཔོན་ཐད་ན་ཨི་དང་། ཧྲི་ཐིར་པོ་ཟི་ནཱ་ཨི་དང་། དེའི་གྲོས་མི་རྣམས་འོངས་ནས་ཡ་ཧུ་དཱ་པ་རྣམས་ལ། སུ་ཞིག་གིས་ཁྱོད་ཅག་ལ་མཆོད་ཁང་འདི་ཡང་བསྐྱར་བཞེང་བར་བཀའ་བསྩལ་ལམ་ཞེས་དང་།",
      "4": "ཡང་དེ་དག་གིས། བཟོ་སྐྲུན་འདིའི་འགན་འཁུར་མཁན་རྣམས་ཀྱི་མིང་ལ་ཅི་ཟེར་རམ་ཞེས་དྲིས།",
      "5": "འོན་ཀྱང་ཡ་ཧུ་དཱ་པའི་རྒན་པོ་རྣམས་ལ་དཀོན་མཆོག་གིས་གཟིགས་སྐྱོང་མཛད་པས། དར་ཡཱ་ལ་སྙན་ཞུ་ཞིག་ཕུལ་བ་དང་། དེར་བཀའ་ལན་འཐོབ་པའི་བར་དུ་མི་སུས་ཀྱང་ཁོ་ཚོའི་ལས་ཀར་བཀག་འགོག་མ་བྱས།",
      "6": "ཡང་གཙང་པོའི་ཕ་རོལ་གྱི་སྤྱི་དཔོན་ཐད་ན་ཨི་དང་། ཧྲི་ཐིར་པོ་ཟི་ནཱ་ཨི་དང་། དེའི་གྲོས་མི་རྣམས་ཏེ། གཙང་པོའི་ཕ་རོལ་གྱི་འགོ་དཔོན་རྣམས་ཀྱིས་རྒྱལ་པོ་དར་ཡཱ་ལ་ཕུལ་བའི་སྙན་ཞུ་བཤུས་མ་ནི་འདི་ལྟར་ཡིན།",
      "7": "དེའི་ནང་དུ་འདི་ལྟར་བྲིས་ཡོད་དེ། རྒྱལ་པོ་དར་ཡཱ་ཁྱེད་ཉིད་ཕྱོགས་ཀུན་ནས་བདེ་བར་སྨོན།",
      "8": "རྒྱལ་པོ་ཆེན་པོས་མཁྱེན་རོགས་ཞུ། བདག་ཅག་ཡ་ཧུ་དཱ་ཡུལ་གྱི་དཀོན་མཆོག་ཆེན་པོའི་མཆོད་ཁང་དུ་སོང་བ་ན། དེ་རྣམས་ཀྱིས་མཆོད་ཁང་ནི་རྡོ་ཕ་བོང་ཆེན་པོས་བརྩིགས་ཏེ། གྱང་གི་ནང་དུ་གདུང་མ་བཅུག་ཡོད། ལས་ཀ་འདི་ནི་མྱུར་དུ་བྱས་པ་དང་། དེ་དག་གིས་ལེགས་པར་སྒྲུབ་བཞིན་འདུག",
      "9": "དེ་ནས་བདག་ཅག་གིས་རྒན་པོ་རྣམས་ལ། སུ་ཞིག་གིས་ཁྱོད་ཅག་ལ་མཆོད་ཁང་འདི་ཡང་བསྐྱར་བཞེང་བར་བཀའ་བསྩལ་ལམ་ཞེས་དྲིས་པ་དང་།",
      "10": "དེ་དག་གི་འགོ་དཔོན་སུ་ཡིན་པའི་འཕྲིན་ཁྱེད་ལ་འབུལ་བའི་ཕྱིར་སོ་སོའི་མིང་ཡང་དྲིས་པ་ཡིན།",
      "11": "ཁོ་ཚོས་ངེད་རྣམས་ཀྱི་ལན་དུ། ངེད་ཅག་ནི་གནམ་ས་གཉིས་ཀྱི་དཀོན་མཆོག་གི་ཞབས་ཕྱི་ཡིན་ཏེ། ལོ་མང་པོའི་སྔོན་དུ་ཡེས་ར་ཨེལ་གྱི་རྒྱལ་པོ་ཆེན་པོ་ཞིག་གིས་བཞེངས་པའི་མཆོད་ཁང་འདི་ཡང་བསྐྱར་བཞེང་བཞིན་ཡོད།",
      "12": "འོན་ཀྱང་ངེད་རྣམས་ཀྱི་ཕ་མེས་རྣམས་ཀྱིས་ནམ་མཁའི་དཀོན་མཆོག་ཐུགས་ཁྲོས་པར་བྱས་པས། ཁོང་གིས་དེ་རྣམས་ཀལ་དི་པ་ཡིན་པའི་པཱ་པེལ་ལོན་གྱི་རྒྱལ་པོ་ནེ་བོ་ཀད་ནེ་ཙར་གྱི་ལག་ཏུ་སྤྲད་དེ། མཆོད་ཁང་བཤིགས་ནས་མི་རྣམས་པཱ་པེལ་ལོན་དུ་བཙན་ཁྲིད་བྱས།",
      "13": "ཡིན་ཡང་པཱ་པེལ་ལོན་གྱི་རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་རྒྱལ་སྲིད་བསྐྱངས་པའི་ལོ་དང་པོར། རྒྱལ་པོས་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་བར་བཀའ་གནང་ངོ་། །",
      "14": "དཀོན་མཆོག་གི་མཆོད་ཁང་གི་གསེར་དངུལ་གྱི་སྣོད་ཆས་ཏེ། ནེ་བོ་ཀད་ནེ་ཙར་གྱིས་ཡེ་རུ་སཱ་ལེམ་གྱི་མཆོད་ཁང་ནས་ཕྲོགས་ཏེ། པཱ་པེལ་ལོན་གྱི་ལྷ་ཁང་དུ་ཁྱེར་བ་དག་ཀྱང་རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་པཱ་པེལ་ལོན་གྱི་ལྷ་ཁང་ནས་ཕྱིར་བླངས་ཤིང་། ཁོ་རང་ཉིད་ཀྱིས་འགོ་དཔོན་དུ་བསྐོས་པའི་ཤེ་སཱ་པ་ཙར་བྱ་བའི་ལག་ཏུ་སྤྲད་དེ།",
      "15": "ཁོ་ལ་སྣོད་ཆས་འདི་དག་ཡེ་རུ་སཱ་ལེམ་གྱི་མཆོད་ཁང་དུ་ཁྱེར་ནས་དཀོན་མཆོག་གི་མཆོད་ཁང་དེ་སྔར་གནས་སུ་བཞེང་བར་གྱིས་ཞེས་བཀའ་བསྩལ།",
      "16": "དེ་ནས་ཤེ་སཱ་པ་ཙར་ཕྱིར་འོངས་ནས། ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་རྨང་གཞི་བཏིངས་པ་དང་། དུས་དེ་ནས་བཟུང་ད་ལྟའི་བར་དུ་བཞེང་བཞིན་ཡོད་ཀྱང་ད་དུང་མ་འགྲུབ་བོ་ཞེས་སྨྲས་བྱུང་ངོ་། །",
      "17": "གལ་ཏེ་རྒྱལ་པོ་ཐུགས་མོས་ན། པཱ་པེལ་ལོན་དུ་ཡོད་པའི་རྒྱལ་པོའི་ཡིག་ཚང་ཁང་དུ་རྩད་གཅོད་མཛད་ནས། རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་ཡེ་རུ་སཱ་ལེམ་དུ་དཀོན་མཆོག་གི་མཆོད་ཁང་ཡང་བསྐྱར་བཞེང་བའི་ཕྱིར་བཀའ་བསྩལ་བའི་གོང་མའི་བཀའ་ཡིག་ཡོད་མེད་ལ་གཟིགས་རོགས། ཡང་རྒྱལ་པོ་ལགས་ཀྱིས་བདག་ཅག་ལ་བྱ་གཞག་འདིའི་ཐད་ཀྱི་དགོངས་པ་སྟོན་པར་མཛོད་ཅེས་པའོ། །"
    },
    "6": {
      "1": "¶ དེར་རྒྱལ་པོ་དར་ཡཱ་ཡིས་པཱ་པེལ་ལོན་གྱི་ཡིག་ཚང་ཁང་དུ་རྩད་གཅོད་བྱེད་པའི་བཀའ་གནང་བས།",
      "2": "མ་དཱི་ཡ་ཡུལ་གྱི་ཨག་མེ་ཐའི་མཁར་ནང་དུ་ཤོག་དྲིལ་ཞིག་རྙེད་ཅིང་། དེའི་ནང་དུ་འདི་ལྟར་བྲིས་ཡོད་དེ།",
      "3": "རྒྱལ་པོ་ཀོ་རེས་ཀྱིས་རྒྱལ་སྲིད་བསྐྱངས་པའི་ལོ་དང་པོར། རྒྱལ་པོས་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་སྐོར་ལ་འདི་སྐད་ཅེས་བཀའ་གནང་སྟེ། མཆོད་ཁང་དེ་ཡང་བསྐྱར་བཞེངས་ནས་མཆོད་པ་འབུལ་བའི་གནས་སུ་གྱིས་ཤིག མཆོད་ཁང་གི་རྨང་གཞི་འདིང་དགོས། མཐོ་ཚད་ལ་དཔུང་ཚད་དྲུག་ཅུ་དང་། ཞེང་ལ་དཔུང་ཚད་དྲུག་ཅུ་ཡོད་པ་ཞིག་དགོས།",
      "4": "རྡོ་ཕ་བོང་ཆེན་པོའི་བང་རིམ་གསུམ་དང་། གདུང་མ་བང་རིམ་གཅིག་ཡོད་དགོས། དེའི་འགྲོ་སོང་ནི་རྒྱལ་པོའི་བང་མཛོད་ནས་འབུལ་བར་འགྱུར།",
      "5": "ཡང་ནེ་བོ་ཀད་ནེ་ཙར་གྱིས་ཡེ་རུ་སཱ་ལེམ་དུ་དཀོན་མཆོག་གི་མཆོད་ཁང་ནས་གསེར་དང་དངུལ་གྱི་སྣོད་ཆས་རྣམས་ཕྲོགས་ཏེ་པཱ་པེལ་ལོན་དུ་ཁྱེར་བ་དེ་དག་ཕྱིར་སྤྲད་དེ། ཡེ་རུ་སཱ་ལེམ་གྱི་མཆོད་ཁང་དུ་ཁྱེར་ནས་སྔར་གནས་སུ་ཞོག་ཅིག་ཅེས་པའོ། །",
      "6": "¶ དེ་ནས་རྒྱལ་པོ་དར་ཡཱས་འདི་ལྟར། ཀྱེ། གཙང་པོའི་ནུབ་ཕྱོགས་སུ་སྡོད་པའི་སྤྱི་དཔོན་ཐད་ན་ཨི་དང་། ཧྲི་ཐིར་པོ་ཟི་ནཱ་ཨི་དང་། ཁྱོད་ཚོའི་གཙང་པོའི་ནུབ་ཕྱོགས་སུ་སྡོད་པའི་གྲོས་མི་རྣམས་དང་བཅས་པའི་འོ་ཟི་ག་པ་ཁྱོད་རྣམས་ཡུལ་དེར་རྒྱང་བཀྱེད་ཅིག",
      "7": "ཁྱོད་ཚོས་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་བར་བཀག་འགོག་མ་བྱེད་ཅིག ཡ་ཧུ་དཱ་པའི་འགོ་དཔོན་དང་རྒན་པོ་རྣམས་ལ་སྔར་གནས་སུ་མཆོད་ཁང་ཡང་བསྐྱར་བཞེང་དུ་ཆུག",
      "8": "ད་ལྟ་བདག་གིས་ཡང་བསྐྱར་བཀའ་ཞིག་འབེབ་པར་བྱ་སྟེ། ཁྱོད་ཚོས་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་བའི་ཡ་ཧུ་དཱ་པའི་རྒན་པོ་རྣམས་ལ་རོགས་བྱས་ཏེ། ཁོ་ཚོའི་འགྲོ་སོང་རྒྱལ་པོའི་བང་མཛོད་ནས་གཙང་པོའི་ཕ་རོལ་གྱི་དཔྱ་ཁྲལ་ལས་གཏོང་དགོས། དེ་ལྟར་མ་བསྒྲུབས་ན་ལས་མཚམས་ཆད་ངེས་ཡིན།",
      "9": "ཁོ་ཚོས་ནམ་མཁའི་དཀོན་མཆོག་ལ་སྦྱིན་སྲེག་གི་མཆོད་པར་འབུལ་བའི་གླང་ཐུག་དང་། ལུག་ཐུག ལུ་གུ། གྲོ། ཚྭ། རྒུན་ཆང་། སྣུམ་བཅས་ཐམས་ཅད་ཡེ་རུ་སཱ་ལེམ་གྱི་མཆོད་དཔོན་གྱིས་སྨྲས་པ་བཞིན་དུ་མ་ཆག་པར་ཉིན་རེ་བཞིན་སྤྲད་ནས།",
      "10": "དེ་དག་གིས་ནམ་མཁའི་དཀོན་མཆོག་ལ་དྲི་ཞིམ་གྱི་མཆོད་པ་འབུལ་བ་དང་། རྒྱལ་པོ་དང་ཁོང་གི་བུ་རྒྱུད་རྣམས་བདེ་ཞིང་སྐྱིད་པའི་ཕྱིར་སྨོན་ལམ་འདེབས་སུ་ཆུག",
      "11": "ཡང་བདག་གིས་བཀའ་ཞིག་འབེབ་པར་བྱ་སྟེ། སུ་ཞིག་གིས་བཀའ་འདི་བསྒྱུར་ན། མི་དེའི་ཁང་པ་ནས་གདུང་མ་ཞིག་བླངས་ཏེ་ཁོ་རང་དེའི་སྟེང་དུ་བཀལ་ནས་དཔྱང་དགོས་ལ། ཁོའི་ཁང་པ་ཡང་ཐལ་དུ་བརླག་པར་འགྱུར།",
      "12": "རྒྱལ་པོ་དང་ཡང་ན་འབངས་མི་སུ་ཞིག་གིས་བདག་གི་བཀའ་འདི་བསྒྱུར་ནས་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་འདི་བཤིག་ན། ཉིད་ཀྱི་མཚན་དེ་རུ་གནས་པར་མཛད་པའི་དཀོན་མཆོག་གིས་དེ་དག་འཇོམས་པར་མཛོད་ཅིག འདི་ནི་ང་དར་ཡཱའི་བཀའ་ཡིན་ཏེ། ཁྱོད་ཚོས་བརྩོན་འགྲུས་ཀྱིས་མྱུར་དུ་སྒྲུབས་ཤིག་ཅེས་བཀའ་བསྒོས་སོ། །",
      "13": "¶ དེ་ནས་གཙང་པོའི་ཕ་རོལ་གྱི་སྤྱི་དཔོན་ཐད་ན་ཨི་དང་། ཧྲི་ཐིར་པོ་ཟི་ནཱ་ཨི་དང་། དེ་དག་གི་གྲོས་མི་རྣམས་ཀྱིས་རྒྱལ་པོ་དར་ཡཱའི་བཀའ་གནང་བ་བཞིན་མྱུར་དུ་བསྒྲུབས།",
      "14": "ཡང་ཡ་ཧུ་དཱ་པའི་རྒན་པོ་རྣམས་ཀྱིས་ལུང་སྟོན་པ་ཧག་གཱ་ཨི་དང་། ཨིད་དོའི་ཚ་བོ་སྟེ་ཟཱ་ཀར་ཡའི་ལུང་བསྟན་གྱི་སྒོ་ནས་མྱུར་དུ་བསྐྱར་བཞེངས་ཀྱི་ལས་ཀ་བསྒྲུབས། ཁོ་ཚོས་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་གི་བཀའ་དང་། ཏ་ཟིག་གི་རྒྱལ་པོ་ཀོ་རེས་དང་། དར་ཡཱ་དང་། ཨར་ཐག་ཤཱ་ཐི་བཅས་ཀྱི་བཀའ་ལྟར་བསྐྱར་བཞེངས་ཀྱི་ལས་ཀ་འགྲུབ་པར་བྱས།",
      "15": "རྒྱལ་པོ་དར་ཡཱས་རྒྱལ་སྲིད་བསྐྱངས་པའི་ལོ་དྲུག་པའི་ཨ་དར་ཟླ་བའི་ཚེས་གསུམ་ཉིན་མཆོད་ཁང་བཞེངས་ནས་གྲུབ་བོ། །",
      "16": "དེ་ནས་ཡེས་ར་ཨེལ་པའི་མཆོད་དཔོན་དང་ལེ་ཝི་པ། བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པའི་མི་རྣམས་ཀྱིས་དགའ་དགའ་སྤྲོ་སྤྲོའི་ངང་དཀོན་མཆོག་གི་མཆོད་ཁང་བསྔོ་བའི་མཛད་སྒོར་རོལ།",
      "17": "ཁོ་ཚོས་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་མཛད་སྒོར་རྟེན་འབྲེལ་ཞུ་བའི་སྐབས་སུ། གླང་བརྒྱ་དང་། ལུག་ཐུག་ཉིས་བརྒྱ། ལུ་གུ་བཞི་བརྒྱ་བཅས་དང་། ཡང་ཡེས་ར་ཨེལ་ཚོ་ཁག་བཅུ་གཉིས་ཀྱི་གྲངས་ཀ་ལྟར་ཚང་མས་སྡིག་བཤགས་ཀྱི་མཆོད་པའི་ཕྱིར་ར་ཕོ་བཅུ་གཉིས་ཕུལ།",
      "18": "ཡང་མོ་ཤེའི་མདོ་ནང་བཀོད་པ་བཞིན་དུ། མཆོད་དཔོན་དང་ལེ་ཝི་པ་རྣམས་ལ་དུས་བཅད་བཞིན་དུ་ཡེ་རུ་སཱ་ལེམ་ནས་དཀོན་མཆོག་གི་ཞབས་ཏོག་སྒྲུབ་ཏུ་བཅུག་གོ །",
      "19": "¶ དེ་ནས་བཙོན་ལས་ཐར་བའི་མི་རྣམས་ཀྱིས་ཟླ་དང་པོའི་ཚེས་བཅུ་བཞི་ཉིན་པེ་སག་དུས་ཆེན་བསྲུངས་ཏེ།",
      "20": "མཆོད་དཔོན་དང་ལེ་ཝི་པ་རྣམས་ཀྱིས་ལྷན་ཅིག་ཏུ་རང་ཉིད་གཙང་མར་བཟོས་ནས་ཐམས་ཅད་དག་པར་གྱུར། དེ་ནས་ལེ་ཝི་པ་རྣམས་ཀྱིས་བཙོན་ལས་ཐར་བའི་མི་རྣམས་དང་། ཁོ་ཚོའི་སྤུན་མཆོད་དཔོན་རྣམས་དང་རང་ཉིད་ཀྱི་ཕྱིར་པེ་སག་དུས་ཆེན་གྱི་ལུ་གུ་བཤས་པ་དང་།",
      "21": "བཙོན་ལས་ཐར་བའི་ཡེས་ར་ཨེལ་པ་རྣམས་དང་། ཡུལ་དེའི་ཕྱི་རོལ་པའི་མི་གཙང་བ་དང་བྲལ་ཞིང་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེ་འཚོལ་འདོད་པ་ཐམས་ཅད་ཀྱིས་ལྷན་ཅིག་ཏུ་ལུ་གུའི་ཤ་ཟོས་ཤིང་།",
      "22": "ཉིན་བདུན་གྱི་རིང་ལ་སྐྱུར་མེད་བག་ལེབ་ཀྱི་དུས་ཆེན་ལ་དགའ་དགའ་སྤྲོ་སྤྲོའི་ངང་རོལ། གང་ལ་ཞེ་ན། དཀོན་མཆོག་ཡ་ཝཱེས་ཁོ་ཚོར་སྤྲོ་སྐྱིད་དང་ལྡན་པར་མཛད་ཅིང་། ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་བཞེང་བར་རོགས་བྱེད་པའི་ཕྱིར། ཡ་ཝཱེས་ཨ་སུར་རྒྱལ་པོའི་སེམས་ཁོ་ཚོའི་ཕྱོགས་སུ་བསྒྱུར་བའོ། །"
    },
    "7": {
      "1": "¶ ཡང་དོན་དེ་དག་གི་རྗེས་སུ། ཏ་ཟིག་གི་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ཡིས་རྒྱལ་སྲིད་འཛིན་པའི་དུས་སུ། ཨེས་སི་རཱ་བྱ་བ་ཞིག་ཡོད་དེ། ཨེས་སི་རཱ་ནི་སེ་ར་ཡཱའི་བུ་ཡིན། སེ་ར་ཡཱ་ནི་ཨ་ཟར་ཡཱ་ཡི་བུ་ཡིན། ཨ་ཟར་ཡཱ་ནི་ཧིལ་ཀི་ཡཱའི་བུ་ཡིན།",
      "2": "ཧིལ་ཀི་ཡཱ་ནི་ཤལ་ལུམ་གྱི་བུ་ཡིན། ཤལ་ལུམ་ནི་ཟཱ་ཏོག་གི་བུ་ཡིན། ཟཱ་ཏོག་ནི་ཨ་ཧི་ཏུབ་ཀྱི་བུ་ཡིན།",
      "3": "ཨ་ཧི་ཏུབ་ནི་ཨ་མར་ཡཱའི་བུ་ཡིན། ཨ་མར་ཡཱ་ནི་ཨ་ཟར་ཡཱའི་བུ་ཡིན། ཨ་ཟར་ཡཱ་ནི་མེ་ར་ཡོད་ཀྱི་བུ་ཡིན།",
      "4": "མེ་ར་ཡོད་ནི་ཟེ་རཱ་ཡཱའི་བུ་ཡིན། ཟེ་རཱ་ཡཱ་ནི་ཨུ་ཟིའི་བུ་ཡིན། ཨུ་ཟི་ནི་པུག་ཀིའི་བུ་ཡིན།",
      "5": "པུག་ཀི་ནི་ཨ་བི་ཤུ་ཨའི་བུ་ཡིན། ཨ་བི་ཤུ་ཨ་ནི་ཕི་ནེ་ཧེའི་བུ་ཡིན། ཕི་ནེ་ཧེ་ནི་ཨེ་ལི་ཨ་ཟར་གྱི་བུ་ཡིན། ཨེ་ལི་ཨ་ཟར་ནི་མཆོད་དཔོན་ཆེན་པོ་ཨ་རོན་གྱི་བུ་ཡིན།",
      "6": "ཨེས་སི་རཱ་འདི་ནི་པཱ་པེལ་ལོན་ནས་ཡར་ཕྱིན་ཏེ། ཁོ་ནི་དྲུང་ཡིག་ཅིག་ཡིན་པ་དང་། ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེས་མོ་ཤེ་ལ་གནང་བའི་བཀའ་ཁྲིམས་ལ་ཤིན་ཏུ་མཁས་པ་ཡིན་ལ། ཁོའི་དཀོན་མཆོག་ཡ་ཝཱེས་ཁོ་ལ་རོགས་རམ་མཛད་པས། རྒྱལ་པོས་ཁོས་ཞུ་བ་ལྟར་གནང་ངོ་། །",
      "7": "ཡང་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ཡིས་རྒྱལ་སྲིད་འཛིན་པའི་ལོ་བདུན་པར། ཡེས་ར་ཨེལ་གྱི་མི་འགའ་ཞིག་དང་། མཆོད་དཔོན་འགའ་ཞིག་དང་། ལེ་ཝི་པ། མཆོད་ཁང་གི་མགུར་ལེན་མཁན། སྒོ་སྲུང་། མཆོད་གཡོག་འགའ་ཞིག་བཅས་ཡར་ཡེ་རུ་སཱ་ལེམ་དུ་སོང་།",
      "8": "ཡང་རྒྱལ་པོ་དེའི་ལོ་བདུན་པའི་ཟླ་ལྔ་བའི་ནང་དུ་ཨེས་སི་རཱ་ཁོང་ཉིད་ཡེ་རུ་སཱ་ལེམ་དུ་ཕྱིན།",
      "9": "ཁོ་ནི་ཟླ་དང་པོའི་ཚེས་གཅིག་ཉིན་པཱ་པེལ་ལོན་ནས་ལམ་དུ་ཆས་ཤིང་། ཁོའི་དཀོན་མཆོག་གིས་རོགས་རམ་མཛད་པས། ཟླ་ལྔ་བའི་ཚེས་གཅིག་ཉིན་ཡེ་རུ་སཱ་ལེམ་དུ་སླེབས།",
      "10": "ཡང་ཨེས་སི་རཱ་ཡིས་བློ་སེམས་རྩེ་གཅིག་གིས་དཀོན་མཆོག་ཡ་ཝཱེའི་བཀའ་ཁྲིམས་སྦྱངས་ནས་དེ་བཞིན་བརྩིས་པ་དང་། བཀའ་རྒྱ་དང་སྒྲིག་སྲོལ་དག་གིས་ཡེས་ར་ཨེལ་གྱི་འབངས་མི་ལ་མཛུབ་སྟོན་གནང་ངོ་། །",
      "11": "¶ དཀོན་མཆོག་ཡ་ཝཱེའི་བཀའ་ཁྲིམས་དང་ཡེས་ར་ཨེལ་ལ་གནང་བའི་བཀའ་རྒྱ་རྣམས་སྦྱོང་མཁན་གྱི་མཆོད་དཔོན་དང་དྲུང་ཡིག་ཨེས་སི་རཱ་བྱ་བ་ལ་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ཡིས་གནང་བའི་བཀའ་ཡིག་གི་ངོ་བཤུས་ནི་འདི་ལྟ་སྟེ།",
      "12": "རྒྱལ་པོ་རྣམས་ཀྱི་རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་ཡིས། ནམ་མཁའི་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་བྱང་དུ་ཆུབ་པའི་དཔེ་ཆ་པ་མཆོད་དཔོན་ཨེས་སི་རཱ་ལ་གོང་མའི་བཀའ་ཡིག་སྤྲིངས་དོན་འདི་ལྟ་སྟེ།",
      "13": "ངའི་རྒྱལ་ཁམས་སུ་ཡོད་པའི་ཡེས་ར་ཨེལ་པ་རྣམས་ལས། ཡར་ཡེ་རུ་སཱ་ལེམ་དུ་འགྲོ་འདོད་པའི་མཆོད་དཔོན་དང་ལེ་ཝི་པ་ཐམས་ཅད་ཁྱོད་དང་མཉམ་དུ་སོང་ཆོག",
      "14": "ཁྱོད་ནི་རྒྱལ་པོ་དང་གྲོས་མི་བདུན་པོས་མངགས་པ་ཡིན་པས། ཁྱོད་ཀྱི་ལག་ཏུ་ཡོད་པའི་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་ལྟར་ཡ་ཧུ་དཱ་དང་ཡེ་རུ་སཱ་ལེམ་གྱི་གནས་ཚུལ་ལ་རྩད་ཆོད་ཅིག",
      "15": "རྒྱལ་པོ་དང་གྲོས་མི་རྣམས་ཀྱིས་ཡེ་རུ་སཱ་ལེམ་དུ་བཞུགས་པའི་དཀོན་མཆོག་ལ་དགའ་མགུ་ངང་ཕུལ་བའི་གསེར་དངུལ་ཡང་ཁྱོད་ཀྱིས་འཁྱེར་དགོས།",
      "16": "དེར་མ་ཟད། ཁྱོད་ཀྱིས་པཱ་པེལ་ལོན་གྱི་ཡུལ་ཐམས་ཅད་ནས་བསྡུས་པའི་གསེར་དངུལ་དང་། འབངས་མི་དང་མཆོད་དཔོན་རྣམས་ཀྱིས་ཡིད་མོས་ངང་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་ཕུལ་བའི་ལེགས་སྐྱེས་དག་ཀྱང་འཁྱེར་དགོས།",
      "17": "ཁྱོད་ཀྱིས་དངུལ་འདི་ལས་གཟབ་ནན་གྱིས་གླང་དང་ལུག་ཐུག་དང་ལུ་གུ་དང་། འབྲུ་རིགས་ཀྱི་མཆོད་པ་དང་སྐྱེམས་མཆོད་ཉོས་ནས། ཡེ་རུ་སཱ་ལེམ་དུ་ཡོད་པའི་ཁྱོད་ཚོའི་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་མཆོད་ཁྲིའི་སྟེང་ནས་མཆོད་ཅིག",
      "18": "ཡང་གསེར་དངུལ་ལྷག་མ་དེ་དག་ནི། ཁྱོད་ཚོའི་དཀོན་མཆོག་གི་དགོངས་པ་བཞིན་དུ། ཁྱོད་དང་ཁྱོད་ཀྱི་སྤུན་རྣམས་ཀྱིས་གང་ལེགས་པར་བསམས་ན་དེ་བཞིན་གྱིས་ཤིག",
      "19": "ཡང་ཁྱོད་ལ་བཅོལ་བའི་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་ཞབས་ཕྱི་སྒྲུབ་བྱེད་ཀྱི་སྣོད་ཆས་རྣམས་ནི་ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་ལ་ཕུལ་ཞིག",
      "20": "དེ་མིན་ཁྱོད་ཀྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་ཅི་ཞིག་མཁོ་ན། འགྲོ་གྲོན་ཚང་མ་རྒྱལ་པོའི་བང་མཛོད་ནས་ལོངས་ཤིག",
      "21": "རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐི་བདག་གིས་གཙང་པོའི་ཕ་རོལ་གྱི་ཕྱག་མཛོད་ཐམས་ཅད་ལ་བཀའ་འདི་གནང་བ་ཡིན། ནམ་མཁའི་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་ལ་མཁས་པའི་དཔེ་ཆ་པ་མཆོད་དཔོན་ཨེས་སི་རཱ་ལ་ཁྱོད་ཅག་ལས་ཅི་དགོས་ན་མྱུར་དུ་སྒྲུབས་ཤིག",
      "22": "དངུལ་གྱི་རྡོ་ཚད་བརྒྱ་དང་། གྲོ་ཁལ་བརྒྱ། རྒུན་ཆང་ཆུ་བེན་བརྒྱ། སྐྱུ་རུའི་ཚི་སྣུམ་ཆུ་བེན་བརྒྱ། ཚྭ་འདོད་པ་བཞིན་དུ་འབུལ་དགོས།",
      "23": "ནམ་མཁར་བཞུགས་པའི་དཀོན་མཆོག་གིས་བཀའ་གང་ཞིག་གནང་བ་དེ། ནམ་མཁའི་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་ཕྱིར་བརྩོན་པར་གྱིས། གང་ལ་ཞེ་ན། རྒྱལ་པོ་དང་དེའི་སྲས་ཀྱི་རྒྱལ་ཁམས་ལ་ཐུགས་ཁྲོ་བར་མི་འགྱུར་རོ། །",
      "24": "ཁྱོད་རྣམས་ཀྱིས་ཤེས་དགོས་པ་ཞིག་ནི། མཆོད་དཔོན་དང་། ལེ་ཝི་པ། མགུར་ལེན་མཁན། སྒོ་སྲུང། མཆོད་གཡོག་རྣམས་དང་། དཀོན་མཆོག་གི་མཆོད་ཁང་འདིའི་གཉེར་པ་རྣམས་ལས་དཔྱ་ཁྲལ་དང་འབུལ་མཚན། འབྲུ་ཁྲལ་བཅས་བླང་མི་ཆོག",
      "25": "ཀྱེ་ཨེས་སི་རཱ་ཁྱོད་རང་ལ་མཚོན་ན། ཁྱོད་ཀྱི་དཀོན་མཆོག་གིས་གནང་བའི་ཤེས་རབ་བཞིན་དུ་ཁྲིམས་དཔོན་དང་འགོ་དཔོན་བསྐོས་ནས། གཙང་པོའི་ཕ་རོལ་ཏུ་གནས་པའི་འབངས་མི་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་ཤེས་པ་རྣམས་ལ་དབང་བསྒྱུར་དགོས་ལ། ཁྱོད་ཀྱིས་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་མི་ཤེས་པ་རྣམས་ལ་སློབས་ཤིག",
      "26": "གལ་ཏེ། མི་སུ་ཞིག་གིས་ཁྱོད་ཀྱི་དཀོན་མཆོག་གི་བཀའ་ཁྲིམས་དང་རྒྱལ་པོའི་བཀའ་མི་བསྲུང་ན། དེ་ལ་སྲོག་ཆད་གཅོད་པའམ་རྒྱང་ཕུད་དུ་གཏོང་བའམ། རྒྱུ་ནོར་ལེན་པའམ་བཙོན་དུ་འཇུག་པའི་ཁྲིམས་སོགས་གཟབ་ནན་གྱིས་ཆོད་ཅིག་ཅེས་བྲིས་སོ། །",
      "27": "¶ ཨེས་སི་རཱ་ན་རེ། ངེད་ཀྱི་མེས་པོ་རྣམས་ཀྱི་དཀོན་མཆོག་ཡ་ཝཱེ་ནི་བསྟོད་འོས་པ་ཡིན། གང་ལ་ཞེ་ན། ཡེ་རུ་སཱ་ལེམ་གྱི་ཡ་ཝཱེའི་མཆོད་ཁང་ལ་གཟི་བརྗིད་འབུལ་བའི་བསམ་པ་འདི་རྒྱལ་པོའི་སེམས་སུ་གནང་བ་དང་།",
      "28": "ཡང་ཁོང་གིས་རྒྱལ་པོ་དང་། དེའི་གྲོས་མི་དང་། རྒྱལ་པོའི་འགོ་དཔོན་ནུས་པ་ཅན་ཐམས་ཅད་ཀྱི་མདུན་ནས་བདག་ཐུགས་རྗེས་བསྐྱངས་པའི་ཕྱིར་རོ། །བདག་གི་དཀོན་མཆོག་ཡ་ཝཱེས་ང་ལ་རོགས་རམ་མཛད་པས། བདག་ལ་སྤོབས་པ་འཛོམས་ཏེ། ཡེས་ར་ཨེལ་གྱི་འགོ་དཔོན་ཁ་ཤས་ང་དང་མཉམ་དུ་འགྲོ་བའི་ཕྱིར་བསྡུས་པ་ཡིན་ཞེས་པའོ། །"
    },
    "8": {
      "1": "¶ རྒྱལ་པོ་ཨར་ཐག་ཤཱ་ཐིའི་དུས་སུ་པཱ་པེལ་ལོན་ནས་ང་དང་མཉམ་དུ་འོངས་པ་རྣམས་ཀྱི་ཚོ་དཔོན་དག་དང་ཁོ་ཚོའི་གདུང་རྒྱུད་ཀྱི་ཐོ་ནི།",
      "2": "ཕི་ནེ་ཧེ་ཡི་བུ་རྒྱུད་ནས་གེར་ཤོམ་དང་། ཨི་ཐ་མཱར་གྱི་བུ་རྒྱུད་ནས་དཱ་ནེ་ཨེལ་དང་། དཱ་བིད་ཀྱི་བུ་རྒྱུད་ནས་ཧད་ཏུས་དང་།",
      "3": "ཤེ་ཀན་ཡཱའི་བུ་རྒྱུད་དེ་ཕཱར་ཨོ་སིའི་བུ་རྒྱུད་ནས་ཟཱ་ཀར་ཡ་དང་། དེ་དང་མཉམ་དུ་ཁྱིམ་རྒྱུད་ཀྱི་ཐོ་ལྟར་སྐྱེས་པ་བརྒྱ་དང་ལྔ་བཅུ་ཡོད།",
      "4": "ཕཱ་ཧད་མོ་ཨབ་ཀྱི་བུ་རྒྱུད་ནས་ཟེ་རཱ་ཡཱའི་བུ་ཨེ་ལི་ཧོ་ནེ་ཨི་དང་མཉམ་དུ་སྐྱེས་པ་ཉིས་བརྒྱ་ཡོད།",
      "5": "ཤེ་ཀན་ཡཱའི་བུ་རྒྱུད་ནས་ཡེ་ཧ་ཟི་ཨེལ་གྱི་བུ་དང་མཉམ་དུ་སྐྱེས་པ་སུམ་བརྒྱ་ཡོད།",
      "6": "ཨ་དིན་གྱི་བུ་རྒྱུད་ནས་ཡོ་ནཱ་ཐན་གྱི་བུ་ཨེ་བད་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་ལྔ་བཅུ་ཡོད།",
      "7": "ཨེ་ལཱམ་གྱི་བུ་རྒྱུད་ནས་ཨ་ཐལ་ཡཱའི་བུ་ཡེ་ཤ་ཡཱ་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་བདུན་ཅུ་ཡོད།",
      "8": "ཤེ་ཕད་ཡཱའི་བུ་རྒྱུད་ནས་མེའ་ཀཱ་ཨེལ་གྱི་བུ་ཟེ་བད་ཡཱ་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་བརྒྱད་ཅུ་ཡོད།",
      "9": "ཡོ་ཨབ་ཀྱི་བུ་རྒྱུད་ནས་ཡེ་ཧི་ཨེལ་གྱི་བུ་ཨོ་བད་ཡཱ་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་ཉིས་བརྒྱ་དང་བཅོ་བརྒྱད་ཡོད།",
      "10": "ཤེ་ལོ་མིད་ཀྱི་བུ་རྒྱུད་ནས་ཡོ་སེབ་ཡཱའི་བུ་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་བརྒྱ་དང་དྲུག་ཅུ་ཡོད།",
      "11": "པེ་བཱ་ཨིའི་བུ་རྒྱུད་ནས་པེ་བཱ་ཨིའི་བུ་ཟཱ་ཀར་ཡ་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་ཉེར་བརྒྱད་ཡོད།",
      "12": "ཨས་གད་ཀྱི་བུ་རྒྱུད་ནས་ཧག་ག་ཏན་གྱི་བུ་ཡོ་ཧ་ནན་དང་། དེ་དང་མཉམ་དུ་སྐྱེས་པ་བརྒྱ་དང་བཅུ་ཡོད།",
      "13": "ཨ་དོ་ནི་ཀམ་གྱི་བུ་རྒྱུད་ནི་མཐའ་མ་རྣམས་ཡིན་ཏེ་ཨེ་ལི་ཕེ་ལེད་དང་། ཡེ་ཧི་ཨེལ་དང་། ཤེ་མ་ཡཱ་གསུམ་དང་མཉམ་དུ་སྐྱེས་པ་དྲུག་ཅུ་ཡོད།",
      "14": "པིག་ཝ་ཨིའི་བུ་རྒྱུད་ནི་ཨུ་ཐ་ཨི་དང་ཟ་ཀུར་དང་མཉམ་དུ་སྐྱེས་པ་བདུན་ཅུ་ཐམ་པ་ཡོད།",
      "15": "¶ བདག་གིས་ཨ་ཧ་ཝའི་ཕྱོགས་སུ་འབབ་པའི་ཆུ་བོའི་འགྲམ་དུ་དེ་རྣམས་བསྡུས་ནས་སྒར་བརྒྱབ་སྟེ་དེར་ཉིན་གསུམ་ལ་བསྡད། འབངས་མི་དང་མཆོད་དཔོན་རྣམས་ཀྱི་གྲས་སུ་རྩད་བཅད་ཀྱང་ལེ་ཝི་པ་གཅིག་ཀྱང་མ་རྙེད།",
      "16": "དེ་ནས་ངས་ཨེ་ལི་ཨེ་བཟིར་དང་། ཨ་རི་ཨེལ། ཤེ་མ་ཡཱ། ཨེལ་ནཱ་ཐན། ཡ་རིབ། ཨེལ་ནཱ་ཐན། ནཱ་ཐན། ཟཱ་ཀར་ཡ། མཱེ་ཤུལ་ལིམ་སོགས་འགོ་དཔོན་རྣམས་དང་། ཡོ་ཡཱ་རིབ་དང་ཨེལ་ནཱ་ཐན་ཞེས་བྱ་བའི་ཡོན་ཏན་ཅན་གཉིས་བཅས་བསྡུས་ཏེ།",
      "17": "ཁོ་ཚོ་ཀ་སིབ་ཡཱ་བྱ་བའི་ས་གནས་ཀྱི་འགོ་དཔོན་ཨིད་དོའི་དྲུང་དུ་མངགས་ནས། དེ་རྣམས་ཀྱིས་ཨིད་དོ་དང་ཁོའི་སྤུན་མཆོད་གཡོག་ཡིན་པ་རྣམས་ལ་ཅི་ལྟར་སྨྲ་དགོས་ལུགས་བསླབས་པ་དང་། ངེད་ཀྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་ཕྱིར་ཞབས་ཕྱི་སྒྲུབ་མཁན་གཏོང་བར་ཞུས་པ་ཡིན།",
      "18": "ངེད་ཀྱི་དཀོན་མཆོག་གི་ཐུགས་རྗེའི་རོགས་རམ་ལ་བརྟེན་ནས། དེ་རྣམས་ཀྱིས་ཡེས་ར་ཨེལ་གྱི་བུ་རྒྱུད་དང་ལེ་ཝིའི་བུ་རྒྱུད་དང་། མཱ་ལིའི་བུ་རྒྱུད་ལས་མི་བློ་རིག་ཅན་ཞིག་ཁྲིད་ཡོང་བ་སྟེ། ཤེ་རེབ་ཡཱ་དང་དེའི་བུ་རྣམས་དང་སྤུན་དག་བསྡོམས་པས་མི་བཅོ་བརྒྱད་ཡོད།",
      "19": "གཞན་ད་དུང་ཧ་ཤབ་ཡཱ་དང་། དེ་དང་མཉམ་དུ་མཱ་རཱ་རེའེ་ཡི་བུ་རྒྱུད་ལས་ཡེ་ཤ་ཡཱ་དང་། དེའི་སྤུན་དང་དེ་དག་གི་བུ་རྣམས་བསྡོམས་པས་མི་ཉི་ཤུ་ཡོད།",
      "20": "དེར་མ་ཟད་སྔར་དཱ་བིད་དང་འགོ་དཔོན་དག་གིས་ལེ་ཝི་པ་རྣམས་ལ་ཞབས་ཕྱི་བསྒྲུབ་པར་བསྐོས་པའི་མཆོད་གཡོག་རྣམས་ལས། མིང་བཀོད་ཡོད་པའི་མི་ཉིས་བརྒྱ་དང་ཉི་ཤུ་བཅས་མངགས་ཡོད་དོ། །",
      "21": "¶ སྐབས་དེར་ངས་ཆུ་བོ་ཨ་ཧ་ཝའི་འགྲམ་དུ་སྨྱུང་གནས་བསྲུང་དགོས་པའི་བཀའ་བསྒྲགས་པ་ཡིན། གང་ལ་ཞེ་ན། ང་ཚོའི་དཀོན་མཆོག་གི་དྲུང་དུ་ཁེངས་སྐྱུང་གི་སེམས་དང་བཅས་ང་ཚོ་དང་ང་ཚོའི་ཕྲུ་གུ་རྣམས་དང་། རང་གི་རྒྱུ་ནོམ་པ་ཐམས་ཅད་ལ་བགྲོད་བདེའི་ལམ་བུ་ཞིག་འབྱུང་བའི་ཕྱིར་གསོལ་བ་བཏབ་པ་ཡིན།",
      "22": "ལམ་བར་དུ་དགྲ་ལས་བསྲུང་བའི་ཕྱིར་རྒྱལ་པོ་ལ་རྐང་དམག་དང་སྐྱ་དམག་མངགས་པར་ཞུ་བ་ལ་ངོ་ཚ་བྱུང་། གང་ལ་ཞེ་ན། སྔར་ངེད་རྣམས་ཀྱིས་རྒྱལ་པོར་སྨྲས་པ་ལྟར། སུ་ཞིག་གིས་ང་ཚོའི་དཀོན་མཆོག་བཙལ་ན་དེ་ལ་བྱིན་རླབས་གནང་ངེས་ཡིན་པ་དང་། གལ་ཏེ་སུ་ཞིག་གིས་ཁོང་ལ་རྒྱབ་འགལ་བྱས་ན་ཁོང་ཐུགས་ཁྲོ་བ་དང་དེ་ལ་ཆད་པ་གཅོད་ངེས་སོ་ཞེས་སྨྲས་པའི་ཕྱིར་རོ། །",
      "23": "དེ་ནས་ངེད་རྣམས་ཀྱིས་སྨྱུང་གནས་བསྲུངས་ཏེ་རང་གི་དཀོན་མཆོག་ལ་གསོལ་བ་བཏབ་པ་དང་ཁོང་གིས་གསན་པར་མཛད་དོ། །",
      "24": "¶ དེར་ངས་མཆོད་དཔོན་འགོ་ཁྲིད་རྣམས་ལས་མི་བཅུ་གཉིས་དང་། ཡང་ཤེ་རེབ་ཡཱ་དང་། ཧ་ཤབ་ཡཱ། དེ་དག་གི་སྤུན་བཅུ་བཅས་བསྐོ་མངགས་བྱས་ཏེ།",
      "25": "རྒྱལ་པོ་དང་བློ་འདོན་པ་དང་། དམག་དཔོན་དང་། དེར་ཡོད་པའི་ཡེས་ར་ཨེལ་པ་ཐམས་ཅད་ཀྱིས་ང་ཚོའི་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་ཕྱིར་ཕུལ་བའི་གསེར་དངུལ་དང་སྣོད་ཆས་དག་ཚད་ནས་ཁོ་ཚོར་སྤྲད་པ་ཡིན།",
      "26": "ངས་ཚད་ནས་སྤྲད་པའི་དངུལ་རྡོ་ཚད་དྲུག་བརྒྱ་ལྔ་བཅུ་དང་། རྡོ་ཚད་བརྒྱ་ཡི་དངུལ་ཆས་དང་། གསེར་རྡོ་ཚད་བརྒྱ་དང་།",
      "27": "གསེར་གྱི་དཀར་ཡོལ་ཉི་ཤུ་སྟེ། དེའི་རིན་ཐང་ནི་གསེར་གྱི་དོང་ཙེ་ཆིག་སྟོང་དང་། གསེར་ལྟར་རིན་ཐང་ཆེ་བའི་ལི་ཆས་འོད་ཅན་གཉིས་བཅས་ཡོད།",
      "28": "ངས་ཁོ་ཚོར་སྨྲས་པ། ཁྱོད་རྣམས་དཀོན་མཆོག་ཡ་ཝཱེའི་དོན་དུ་དམ་པ་ཡིན་ལ། སྣོད་ཆས་འདི་དག་ཀྱང་དམ་པ་ཡིན། ཡང་གསེར་དངུལ་ནི་ཁྱོད་ཚོའི་ཕ་མེས་རྣམས་ཀྱི་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་ཡིད་མོས་ངང་ཕུལ་བའི་འབུལ་བ་ཡིན་ནོ། །",
      "29": "མཆོད་དཔོན་དང་ལེ་ཝི་པའི་ཚོ་དཔོན་དག་དང་། དེ་མིན་ཡེས་ར་ཨེལ་གྱི་ཚོ་དཔོན་རྣམས་ཀྱི་མདུན་དུ་སླེབས་པའི་བར་དུ་ཁྱོད་ཚོས་གཟབ་ནན་ངང་སྲུངས་ཤིག ཡེ་རུ་སཱ་ལེམ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེའི་མཆོད་ཁང་གི་མཛོད་ཁང་དུ་རྩིས་བླངས་ཏེ་སྤྲོད་ཅིག་ཅེས་པའོ། །",
      "30": "དེར་རྩིས་བླངས་པའི་གསེར་དངུལ་དང་སྣོད་ཆས་རྣམས་ཡེ་རུ་སཱ་ལེམ་དུ་ངེད་ཀྱི་དཀོན་མཆོག་གི་མཆོད་ཁང་དུ་འཁྱེར་བའི་ཕྱིར་མཆོད་དཔོན་དང་ལེ་ཝི་པ་རྣམས་ཀྱིས་བླངས་སོ། །",
      "31": "¶ ཟླ་དང་པོའི་ཚེས་བཅུ་གཉིས་ཉིན་ང་ཚོ་ཆུ་བོ་ཨ་ཧ་ཝའི་འགྲམ་ནས་ཆས་ཏེ་ཡེ་རུ་སཱ་ལེམ་གྱི་ཕྱོགས་སུ་ཕྱིན། ངེད་ཀྱི་དཀོན་མཆོག་གིས་རོགས་སྐྱོབ་མཛད་ནས་ངེད་རྣམས་དགྲ་དང་ལམ་གྱི་ཇག་པའི་ལག་ནས་ཐར་བར་བཅུག",
      "32": "ངེད་རྣམས་ཡེ་རུ་སཱ་ལེམ་དུ་སླེབས་པ་དང་ཉིན་གསུམ་གྱི་རིང་ལ་དེ་རུ་བསྡད།",
      "33": "ཉིན་བཞི་པར་གསེར་དངུལ་དང་སྣོད་ཆས་དག་དཀོན་མཆོག་གི་མཆོད་ཁང་ནས་རྩིས་གྲངས་བླངས་ཏེ། ཨུ་རི་ཡཱའི་བུ་སྟེ་མཆོད་དཔོན་མེ་རེ་མོད་ལ་སྤྲད། ཁོ་དང་མཉམ་དུ་གཞན་ཕི་ནེ་ཧེ་ཡི་བུ་ཨེ་ལི་ཨ་ཟར་དང་། ད་དུང་ལེ་ཝི་པ་ཡེ་ཤུ་ཨའི་བུ་ཡོ་ཟཱ་བད་དང་། པིན་ནུ་ཨིའི་བུ་ནོ་ཨད་ཡཱ་རྣམས་ཡོད་པ་ཡིན།",
      "34": "དེ་དག་རེ་རེ་བཞིན་རྩིས་གྲངས་བླངས་ནས་ལྗིད་ཚད་ཚང་མ་དུས་དེ་རང་ལ་ཟིན་ཐོར་བཀོད་དོ། །",
      "35": "བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་རྣམས་ཀྱིས་ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ལ་སྦྱིན་སྲེག་ཕུལ་བ་སྟེ། ཡེས་ར་ཨེལ་པ་ཐམས་ཅད་ཀྱི་དོན་དུ་གླང་བཅུ་གཉིས་དང་། ལུག་ཐུག་དགུ་བཅུ་གོ་དྲུག་དང་། ལུ་གུ་བདུན་ཅུ་དོན་བདུན་ཕུལ་ཞིང་། སྡིག་བཤགས་ཀྱི་མཆོད་པར་ར་མ་བཅུ་གཉིས་ཕུལ། འདི་ཐམས་ཅད་དཀོན་མཆོག་ཡ་ཝཱེ་ལ་ཕུལ་བའི་སྦྱིན་སྲེག་གི་མཆོད་པ་ཡིན།",
      "36": "ཁོ་རྣམས་ཀྱིས་རྒྱལ་པོའི་བཀའ་ཡིག་རྒྱལ་པོའི་སྤྱི་དཔོན་དང་གཙང་པོའི་ཕ་རོལ་གྱི་འགོ་དཔོན་རྣམས་ལ་སྤྲད་ཅིང་། དེ་རྣམས་ཀྱིས་དཀོན་མཆོག་གི་མཆོད་ཁང་དང་འབངས་མི་ལ་རོགས་བྱས་སོ། །"
    },
    "9": {
      "1": "¶ དོན་དེ་དག་འགྲུབ་རྗེས་འགོ་དཔོན་རྣམས་ངའི་རྩར་འོངས་ནས་འདི་ལྟར། ཡེས་ར་ཨེལ་གྱི་མི་མང་དང་། མཆོད་དཔོན་རྣམས་དང་། ལེ་ཝི་པ་རྣམས་ཀྱིས་ཀ་ན་ཨན་པ་དང་། ཧེད་པ། ཕེ་རེ་ཟི་པ། ཡེ་བུ་སི་པ། ཨམ་མོན་པ། མོ་ཨབ་པ། ཨེ་ཅིབ་པ། ཨེ་མོར་པ་རྣམས་ཏེ། ཡུལ་མི་རྣམས་ཀྱི་ཞེན་ལོག་གི་བྱ་སྤྱོད་དག་ལ་བསྟུན་ནས།",
      "2": "ཁོ་རྣམས་ཀྱིས་རང་ཉིད་དང་རང་གི་བུ་རྣམས་ལ་ཕྱི་ཕྱོགས་པའི་ཆུང་མ་བླངས་ཏེ། རིགས་རྒྱུད་གཙང་མ་དེ་མི་རིགས་གཞན་དང་བསྲེས་འདུག དེར་མ་ཟད་འགོ་དཔོན་དང་འགོ་ཁྲིད་རྣམས་བྱ་བ་འདིའི་སྟེང་ནས་ཉེས་ཅན་གཏེ་བོ་ཡིན་ཞུས་བྱུང་།",
      "3": "ངས་གཏམ་དེ་ཐོས་པ་དང་། གྱོན་གོས་དང་བེར་གོས་ཧྲལ་ཏེ། མགོའི་སྐྲ་དང་སྨྲ་ར་བལ་ཞིང་། དངངས་སྐྲག་དང་བཅས་བསྡད།",
      "4": "བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་རྣམས་ཀྱི་སྡིག་ཉེས་ཀྱི་ཕྱིར། ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་གི་བཀའ་ཡི་རྐྱེན་གྱིས་སྐྲག་ནས་འདར་མཁན་ཐམས་ཅད་ངའི་མདུན་དུ་འཛོམས་ཤིང་། ང་རང་མཚན་མོའི་སྦྱིན་སྲེག་འབུལ་བའི་བར་དུ་འཇིགས་སྣང་དང་བཅས་བསྡད་པ་ཡིན།",
      "5": "མཚན་མོའི་སྦྱིན་སྲེག་གི་མཆོད་པའི་དུས་སུ་ང་རང་སྡུག་བསྔལ་ཁྲོད་ཡར་ལངས་ཏེ། སྔར་བཞིན་གྱོན་གོས་དང་བེར་གོས་ཧྲལ་པོ་དག་གྱོན་ནས་པུས་མོ་སར་བཙུགས་ཤིང་། བདག་གི་དཀོན་མཆོག་ཡ་ཝཱེའི་ཕྱོགས་སུ་ལག་པ་བརྐྱངས་ནས་སྨོན་ལམ་ཞུས།",
      "6": "ཀྱེ། བདག་གི་དཀོན་མཆོག་ལགས། ངེད་ཅག་གིས་སྡིག་པ་མང་པོ་སྲོག་ལ་འབབ་འོས་པ་བྱས་ཤིང་། ངེད་ཅག་གི་སྡིག་པ་ནི་ནམ་མཁར་ཡང་མི་ཤོང་བས། ང་རང་ཁྱེད་ཀྱི་ཕྱོགས་སུ་མགོ་བོ་འདེགས་པར་ངོ་གནོང་བའོ། །",
      "7": "ང་ཚོའི་ཕ་མེས་རྣམས་ཀྱི་དུས་ནས་ད་བར་དུ། ངེད་ཅག་གི་སྡིག་པ་ཤིན་ཏུ་ཚབས་ཆེ་ཞིང་། ཡང་སྡིག་པ་བྱས་ཡོད་པའི་ཕྱིར། ངེད་ཅག་དང་ངེད་ཅག་གི་རྒྱལ་པོ་རྣམས་དང་མཆོད་དཔོན་རྣམས་ནི་རྒྱལ་ཁབ་གཞན་གྱི་རྒྱལ་པོ་རྣམས་ཀྱི་ལག་ཏུ་ལྷུང་ནས་བསད་པ་དང་། བཟུང་བ་དང་། བཅོམ་པ་དང་། ངོ་ཚར་སྦྱར་བ་སོགས་ནི་ད་ལྟའི་དུས་དང་གཅིག་མཚུངས་ཡིན།",
      "8": "ད་ལྟ་ངེད་ཅག་གི་དཀོན་མཆོག་ཡ་ཝཱེས་ཡུད་ཙམ་ལ་ཐུགས་རྗེ་མཛད་ཅིང་། ངེད་ཅག་ལ་ལྷག་ལུས་འགའ་རེ་བསྐྱུར་ཡོད་ལ། ངེད་ཅག་ནི་ཁོང་གི་གནས་དམ་པ་རུ་འཛེར་མ་བརྡབས་པ་བཞིན་དུ་བག་ཕེབས་ངང་གནས་ཐུབ་པར་མཛད་ཅིང་། ཁོང་གི་གཟི་འོད་ཀྱིས་ང་ཚོའི་མིག་སྒོ་ཡང་ཕྱེས་ཏེ་བཙན་གནོན་འོག་ཡང་བསྐྱར་དར་བ་ཙམ་བྱས།",
      "9": "ངེད་ཅག་བྲན་གཡོག་ཡིན་ནའང་། རང་རེའི་དཀོན་མཆོག་གིས་ངེད་ཅག་བཙན་གནོན་འོག་ཏུ་མ་བསྐྱུར་བར། ཏ་ཟིག་གི་རྒྱལ་པོ་རྣམས་ཀྱི་མདུན་ནས་ངེད་ཅག་ལ་ཐུགས་རྗེས་གཟིགས་ཏེ་བསྐྱར་དར་མཛད་ཅིང་། རང་རེའི་དཀོན་མཆོག་གི་མཆོད་ཁང་ཞིག་རལ་དེ་ཉམས་གསོ་མཛད་པ་དང་། ངེད་ཅག་ལ་ཡ་ཧུ་དཱ་དང་ཡེ་རུ་སཱ་ལེམ་དུ་མཁར་གྱང་ཡོད་པར་མཛད།",
      "10": "ཀྱེ། ངེད་ཀྱི་དཀོན་མཆོག་ལགས། ད་ནི་ངེད་ཅག་གིས་ཅི་ཞུ་བར་བྱའམ། གང་ལ་ཞེ་ན། ངེད་ཅག་གིས་ཁྱེད་ཀྱི་བཀའ་དོར་བ་དང་།",
      "11": "བཀའ་དེ་ནི་ཁྱེད་ཀྱིས་ཞབས་ཕྱི་ལུང་སྟོན་པ་རྣམས་བརྒྱུད་ནས་གསུངས་པ་ཡིན་ཏེ། ཁྱེད་ཀྱིས་འདི་སྐད་དུ། ཁྱོད་རྣམས་ལ་བགོ་སྐལ་དུ་འཐོབ་པར་འགྱུར་བའི་ཡུལ་ནི་བཙོག་པ་ཡིན་ཏེ། ཡུལ་དེའི་མི་རིགས་རྣམས་ཀྱི་བཙོག་པས་བཀང་ཡོད་པ་ཡིན། ཁོ་རྣམས་ཀྱི་ཞེན་ལོག་གི་ལས་ཀྱིས་ཡུལ་དེའི་མགོ་ནས་མཇུག་བར་དུ་བཙོག་པས་གང་བར་བྱས།",
      "12": "དེའི་ཕྱིར། ཁྱོད་ཅག་གིས་རང་གི་བུ་མོ་རྣམས་དེ་དག་ལ་མནའ་མར་བྱིན་མི་ཆོག་ལ། ཁྱོད་ཅག་གི་བུ་རྣམས་ལ་དེ་དག་གི་བུ་མོ་རྣམས་མནའ་མར་བླངས་ནའང་མི་ཆོག ཁོ་ཚོའི་ཞི་བདེ་དང་ཁོ་ཚོའི་ཁེ་ཕན་ནམ་ཡང་བཙལ་མི་ཆོག དེ་ལྟར་བྱས་ན་ཁྱོད་རྣམས་སྟོབས་ཅན་དུ་འགྱུར་ངེས་ཏེ། ཡུལ་འདིའི་ཟས་མཆོག་རྣམས་སྤྱོད་ཅིང་། ཡུལ་འདི་རྒྱུན་ནས་རྒྱུན་དུ་ཁྱོད་ཚོའི་བུ་རྒྱུད་རྣམས་ལ་བགོ་སྐལ་དུ་བསྐྱུར་བར་འགྱུར་ཞེས་གསུངས་སོ། །",
      "13": "ཡང་ངེད་ཅག་གིས་སྤྱོད་ངན་དང་སྡིག་པ་ཆེན་པོ་བྱས་པས། འདི་ཐམས་ཅད་ངེད་ཅག་གི་སྟེང་དུ་བྱུང་བ་རེད། ཡིན་ཡང་ངེད་ཀྱི་དཀོན་མཆོག་ཁྱེད་ཉིད་ཀྱིས་ངེད་ཅག་གི་སྡིག་པའི་ཚད་དང་བསྟུན་ནས་ཉེས་ཆད་ལྗིད་མོ་མ་བཅད་པར། ང་ཚོ་ལ་ལྷག་ལུས་འགའ་རེ་བསྐྱུར་ཡོད།",
      "14": "ད་ནི་ངེད་ཅག་གིས་སླར་ཡང་ཁྱེད་ཀྱི་བཀའ་དང་འགལ་ནས། སྤྱད་པ་ཞེན་ལོག་སྤྱོད་པའི་མི་རིགས་འདི་རྣམས་དང་གཉེན་འབྲེལ་བྱེད་དམ། གལ་ཏེ་ང་ཚོས་འདི་ལྟར་བྱས་ན་ཁྱེད་རང་ཐུགས་ཁྲོས་ཏེ་ང་ཚོ་མེད་པར་བཏང་ནས་མི་གཅིག་ཀྱང་མི་ལྷག་པར་མཛད་པ་མ་ཡིན་ནམ།",
      "15": "ཀྱེ། ཡེས་ར་ཨེལ་གྱི་དཀོན་མཆོག་ཡ་ཝཱེ་ལགས། ཁྱེད་ནི་དྲང་བདེན་ཡིན་པས་ངེད་ཅག་ལུས་ནས་ལྷག་མ་རུ་གྱུར་ཏེ། གཟིགས་དང་། ངེད་ཅག་ལ་ཁྱེད་ཀྱི་དྲུང་དུ་སྡིག་པ་ཡོད་པས། མི་སུ་ཡིན་ཡང་ཁྱེད་ཀྱི་དྲུང་དུ་ཚུགས་མི་ནུས་ཞེས་ཞུས་སོ། །"
    },
    "10": {
      "1": "¶ དེ་ནས་ཨེས་སི་རཱ་ཡིས་དཀོན་མཆོག་གི་མཆོད་ཁང་མདུན་ནས་སྨོན་ལམ་ཞུས་ཏེ། འགྱོད་བཤགས་བྱས་ནས་ངུས་ཤིང་ཕྱག་བཙལ་ནས་སྡོད་སྐབས། ཡེས་ར་ཨེལ་པའི་སྐྱེས་པ་དང་བུད་མེད། བྱིས་པ་བཅས་ཀྱི་མི་ཚོགས་ཆེན་པོ་ཞིག་ཁོའི་རྩར་འདུས་ཏེ་སྡུག་བསྔལ་དང་བཅས་མཉམ་དུ་ངུས་སོ། །",
      "2": "དེར་ཨེ་ལཱམ་གྱི་བུ་རྒྱུད་དེ། ཡེ་ཧི་ཨེལ་གྱི་བུ་ཤེ་ཀན་ཡཱ་ཡིས་ཨེས་སི་རཱ་ལ་འདི་ལྟར། ངེད་ཅག་ནི་རང་གི་དཀོན་མཆོག་ལ་བློ་མི་དཀར་ཞིང་། ཡུལ་འདིའི་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་ཆུང་མར་བླངས་པ་ཡིན། འོན་ཀྱང་ཡེས་ར་ཨེལ་ལ་ད་དུང་རེ་བ་ཡོད་དེ།",
      "3": "ད་ལྟ་ངེད་ཅག་གིས་དཀོན་མཆོག་ལ་དམ་བཅས་ནས། ཕྱི་རོལ་པའི་བུད་མེད་དང་ཁོ་ཚོའི་ཕྲུ་གུ་རྣམས་ཕྱིར་བསྐྱལ་དགོས། བདག་པོ་ཁྱེད་དང་དཀོན་མཆོག་གི་བཀའ་ལ་འཇིགས་མཁན་རྣམས་ཀྱི་གྲོས་ཆོད་ནང་ལྟར་བཀའ་ཁྲིམས་བཞིན་བྱེད་པར་རིགས་སོ། །",
      "4": "ཁྱེད་རང་ཡར་བཞེང་བར་མཛོད། འདི་ཁྱེད་ཀྱི་ལས་འགན་ཡིན། ངེད་ཅག་གིས་ཁྱེད་ལ་རྒྱབ་སྐྱོར་བྱེད་ངེས་ཡིན། ཁྱེད་ཀྱིས་སྤོབས་པ་བསྐྱེད་ནས་བྱ་བ་བསྒྲུབ་པར་མཛོད་ཅེས་སྨྲས་པ་དང་།",
      "5": "དེར་ཨེས་སི་རཱ་ཡར་ལངས་ནས། མཆོད་དཔོན་འགོ་ཁྲིད་དང་ལེ་ཝི་པ། ཡེས་ར་ཨེལ་པ་ཐམས་ཅད་ལ་དེ་བཞིན་དུ་བྱེད་པའི་མནའ་བཀལ་བས་ཁོ་རྣམས་ཀྱིས་མནའ་དེ་བསྐྱལ།",
      "6": "དེ་ནས་ཨེས་སི་རཱ་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་མདུན་ནས་ལངས་ཏེ། ཨེལ་ཡཱ་ཤིབ་ཀྱི་བུ་ཡེ་ཧོ་ཧ་ནན་གྱི་ཁང་མིག་ཏུ་སོང་ནས། ཟས་མ་སྤྱད་ལ་ཆུ་ཡང་མ་འཐུང་། གང་ལ་ཞེ་ན། བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་རྣམས་ཀྱི་སྡིག་པའི་ཕྱིར་མྱ་ངན་བྱས་སོ། །",
      "7": "¶ ཡང་འགོ་དཔོན་རྣམས་ཀྱིས་ཡ་ཧུ་དཱ་དང་ཡེ་རུ་སཱ་ལེམ་གྱི་བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་ཐམས་ཅད་ལ་བརྡ་བརྒྱབ་སྟེ། ཡེ་རུ་སཱ་ལེམ་དུ་འཛོམས་དགོས་པར་བསྒྲགས་ནས།",
      "8": "འགོ་དཔོན་རྣམས་དང་རྒན་པོ་རྣམས་ཀྱི་གྲོས་ཆོད་བཞིན་དུ་སུ་ཞིག་ཉིན་ཞག་གསུམ་གྱི་ནང་ཚུན་དུ་མ་འོངས་ན། མི་དེའི་ནོར་རྫས་ཐམས་ཅད་གཞུང་བཞེས་བྱེད་པ་དང་བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་རྣམས་ཀྱི་ཚོགས་ནས་ཀྱང་འདོན་པར་བྱའོ། །",
      "9": "དེ་ནས་ཉིན་གསུམ་གྱི་ནང་དུ་ཡ་ཧུ་དཱ་དང་པེན་ཡཱ་མེན་གྱི་མི་ཐམས་ཅད་ཡེ་རུ་སཱ་ལེམ་དུ་འཛོམས་ཤིང་། དེ་ནི་ཟླ་དགུ་བའི་ཚེས་ཉི་ཤུ་ཉིན་ཡིན་ལ། འབངས་མི་རྣམས་དཀོན་མཆོག་གི་མཆོད་ཁང་གི་ཐང་ཆེན་ནས་བསྡད་པ་དང་། ཡང་བྱ་བ་དེའི་ཕྱིར་དང་ཆར་པ་ཡང་དྲག་པོ་བབས་པས་མི་རྣམས་འདར་བཞིན་ཡོད།",
      "10": "དེར་མཆོད་དཔོན་ཨེས་སི་རཱ་ཡར་ལངས་ནས་དེ་རྣམས་ལ། ཁྱོད་རྣམས་དཀོན་མཆོག་ལ་བློ་མི་དཀར་ཏེ། རྒྱུ་མཚན་ནི་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་རྣམས་ཆུང་མར་བླངས་ནས་ཡེས་ར་ཨེལ་གྱི་སྡིག་པ་སྔར་ལས་མང་དུ་བཏང་།",
      "11": "ད་ནི་རང་གི་ཕ་མེས་རྣམས་ཀྱི་དཀོན་མཆོག་ཡ་ཝཱེའི་དྲུང་དུ་འགྱོད་བཤགས་བྱས་ནས། ཁོང་གི་ཐུགས་དགོངས་བཞིན་དུ་ཡུལ་འདིའི་འབངས་མི་དང་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་རྣམས་དང་སོ་སོར་གྱེས་ཤིག་ཅེས་བསྐུལ་ཏོ། །",
      "12": "དེ་ནས་མི་ཚོགས་ཐམས་ཅད་ཀྱིས་སྐད་གསང་མཐོན་པོས་ལན་བཏབ་ནས་ན་རེ། ངེད་ཅག་གིས་ཁྱེད་ཀྱི་བསྒོ་བ་བཞིན་དུ་བསྒྲུབ་བོ། །",
      "13": "འོན་ཀྱང་མི་ཚོགས་ནི་མང་པོ་ཡོད་པར་མ་ཟད་དུས་ཚིགས་འདི་ལ་ཆར་པའང་མང་བས། བདག་ཅག་ཕྱི་རོལ་ཏུ་ལངས་ནས་སྡོད་ཐབས་མེད། ཡང་བདག་ཅག་གིས་བྱ་བ་འདིའི་ཐད་ཉེས་པ་ཆེན་པོ་བྱས་པས། འདི་ནི་ཞག་གཅིག་གམ་གཉིས་ཀྱི་ནང་དུ་བསྒྲུབ་ཐུབ་པའི་ལས་མ་ཡིན།",
      "14": "བདག་ཅག་གི་འགོ་དཔོན་རྣམས་མི་ཚོགས་ཐམས་ཅད་ཀྱི་ཚབ་ཏུ་འདིར་བཞུགས་སུ་མཛོད་ཅིག བྱ་བ་འདིའི་རྐྱེན་གྱིས་བྱུང་བའི་དཀོན་མཆོག་གི་ཐུགས་ཁྲོ་དྲག་པོ་ཞི་བའི་བར་དུ། གྲོང་ཁྱེར་སོ་སོ་ནས་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་ཆུང་མར་བླངས་པ་ཐམས་ཅད་ནི། དུས་བཅད་ལྟར་གྲོང་ཁྱེར་དེའི་རྒན་པོ་དང་ཁྲིམས་དཔོན་རྣམས་མཉམ་དུ་ཡོང་ནས་ལས་འདི་བསྒྲུབ་པར་མཛོད་ཅེས་ཞུས་སོ། །",
      "15": "གྲོས་འདི་ལ་ཨ་ས་ཧེལ་གྱི་བུ་ཡོ་ནཱ་ཐན་དང་ཏིག་ཝའི་བུ་ཡ་ཧ་ཟེ་གཉིས་མོས་མཐུན་མ་བྱུང་ལ། མཱེ་ཤུལ་ལིམ་དང་ལེ་ཝི་པ་ཤབ་བེ་ཐ་ཨི་གཉིས་ཀྱིས་དེ་རྣམས་ལ་རྒྱབ་སྐྱོར་མཛད།",
      "16": "དེ་ནས་བཙོན་ལས་ཐར་ཏེ་ཕྱིར་ལོག་པ་རྣམས་ཀྱིས་དེ་ལྟར་བསྒྲུབས་ཏེ། མཆོད་དཔོན་ཨེས་སི་རཱ་ཡིས་མིང་བཏོན་ནས་རུས་རྒྱུད་སོ་སོའི་ཚོ་དཔོན་རྣམས་བདམས་མངགས་བྱས་པ་དང་། ཟླ་བཅུ་པའི་ཚེས་གཅིག་ཉིན་ནས་བྱ་བ་འདིར་རྩད་གཅོད་བྱས་ནས།",
      "17": "ཟླ་དང་པོའི་ཚེས་གཅིག་ཉིན་ཁོ་རྣམས་ཀྱིས་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་ཆུང་མར་ལེན་མཁན་རྣམས་རྩད་ཆོད་དོ། །",
      "18": "¶ མཆོད་དཔོན་གྱི་བུ་རྒྱུད་ཁྲོད་དུ་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་ཆུང་མར་ལེན་མཁན་རྣམས་ནི་ཡོ་ཚ་དག་གི་བུ་ཡེ་ཤུ་ཨ་ཡི་བུ་རྒྱུད་དང་སྤུན་རྣམས་ལས། མ་ཨ་སེ་ཡཱ་དང་། ཨེ་ལི་ཨེ་བཟིར། ཡཱ་རིབ། གེ་དལ་ཡཱ་བཅས་སོ། །",
      "19": "དེ་དག་གིས་རང་གི་ཆུང་མ་རྣམས་སྤངས་པའི་དམ་བཅའ་བཞག་ནས་སྡིག་བཤགས་མཆོད་པ་ཕུལ་བ་སྟེ། རང་རང་གི་སྡིག་པའི་དོན་དུ་ལུག་ཁྱུ་ནས་ལུག་ཐུག་ཅིག་མཆོད་པར་ཕུལ།",
      "20": "ཡང་ཨིམ་མེར་གྱི་བུ་རྒྱུད་རྣམས་ལས་ཧ་ནཱ་ནེ་དང་ཟེ་བད་ཡཱ་གཉིས་ཡོད་ཅིང་།",
      "21": "ཧ་རིམ་གྱི་བུ་རྒྱུད་རྣམས་ལས་མ་ཨ་སེ་ཡཱ་དང་། ཨེ་ལི་ཡཱ། ཤེ་མ་ཡཱ། ཡེ་ཧི་ཨེལ། ཨུ་ཟི་ཡཱ་བཅས་ཡོད་དོ། །",
      "22": "ཕཱ་ཤུར་གྱི་བུ་རྒྱུད་རྣམས་ལས་ཨེལ་ཡོ་ཨེ་ནཱ་ཨི། མ་ཨ་སེ་ཡཱ། ཡེས་མ་ཨེལ། ནེ་ཐན་ཨེལ། ཡོ་ཟཱ་བད། ཨེ་ལ་ཟ་བཅས་ཡོད་དོ། །",
      "23": "ལེ་ཝི་པ་རྣམས་ལས་ཡོ་ཟཱ་བད་དང་། ཤིམ་ཨི། ཀེ་ལ་ཡཱའམ་ཀེ་ལི་ཏ་བྱ་བ། ཕེ་ཐ་ཡཱ། ཡ་ཧུ་དཱ། ཨེ་ལི་ཨེ་བཟིར་བཅས་ཡོད་དོ། །",
      "24": "མགུར་ལེན་མཁན་རྣམས་ལས་ཨེལ་ཡཱ་ཤིབ་དང་། སྒོ་སྲུང་རྣམས་ལས་ཤལ་ལུམ་དང་། ཏེ་ལེམ། ཨུ་རི་བཅས་ཡོད་དོ། །",
      "25": "ཡེས་ར་ཨེལ་པ་ཕཱར་ཨོ་སིའི་བུ་རྒྱུད་རྣམས་ལས་རམ་ཡཱ་དང་། ཡི་ཟི་ཡཱ། མལ་ཀི་ཡཱ། མི་ཡཱ་མིན། ཨེ་ལི་ཨ་ཟར། མལ་ཀི་ཡཱ། པེ་ན་ཡཱ་བཅས་ཡོད་དོ། །",
      "26": "ཨེ་ལཱམ་གྱི་བུ་རྒྱུད་རྣམས་ལས་མད་ཐན་ཡཱ་དང་། ཟཱ་ཀར་ཡ། ཡེ་ཧི་ཨེལ། ཨབ་དི། ཡེ་རེ་མོད། ཨེ་ལི་ཡཱ་བཅས་ཡོད་དོ། །",
      "27": "ཟད་ཐུའི་བུ་རྒྱུད་རྣམས་ལས་ཨེལ་ཡོ་ཨེ་ནཱ་ཨི་དང་། ཨེལ་ཡཱ་ཤིབ། མད་ཐན་ཡཱ། ཡེ་རེ་མོད། ཟཱ་བད། ཨ་ཟི་ཟ་བཅས་ཡོད་དོ། །",
      "28": "པེ་བཱ་ཨིའི་བུ་རྒྱུད་རྣམས་ལས་ཡེ་ཧོ་ཧ་ནན་དང་། ཧ་ནན་ཡཱ། ཟ་བཱ་ཨི། ཨད་ལཱ་ཨི་བཅས་ཡོད་དོ། །",
      "29": "པཱ་ནིའི་བུ་རྒྱུད་རྣམས་ལས་མཱེ་ཤུལ་ལིམ་དང་། མལ་ལུག ཨ་ད་ཡཱ། ཡ་ཤུབ། ཤེ་ཨལ། རཱ་མོད་བཅས་ཡོད་དོ། །",
      "30": "ཕཱ་ཧད་མོ་ཨབ་ཀྱི་བུ་རྒྱུད་རྣམས་ལས་ཨད་ནཱ་དང་། ཁེ་ལམ། པེ་ན་ཡཱ། མ་ཨ་སེ་ཡཱ། མད་ཐན་ཡཱ། པེ་ཟལ་ཨེལ། པིན་ནུ་ཨི། མ་ན་ཤེ་བཅས་ཡོད་དོ། །",
      "31": "ཧ་རིམ་གྱི་བུ་རྒྱུད་རྣམས་ལས་ཨེ་ལི་ཨེ་བཟིར་དང་། ཨི་ཤི་ཡཱ། མལ་ཀི་ཡཱ། ཤེ་མ་ཡཱ། སི་མུ་ཨོན།",
      "32": "པེན་ཡཱ་མེན། མལ་ལུག ཤེ་མར་ཡཱ་བཅས་ཡོད་དོ། །",
      "33": "ཧ་ཤུམ་གྱི་བུ་རྒྱུད་རྣམས་ལས་མད་ཏེ་ནཱ་ཨི་དང་། མད་ཐད་ཐཱ། ཟཱ་བད། ཨེ་ལི་ཕེ་ལེད། ཡེ་རེ་མཱ་ཨི། མ་ན་ཤེ། ཤིམ་ཨི་བཅས་ཡོད་དོ། །",
      "34": "པཱ་ནིའི་བུ་རྒྱུད་རྣམས་ལས་མ་ཨ་དཱ་ཨི་དང་། ཨམ་རམ། ཨུ་ཨེལ།",
      "35": "པེ་ན་ཡཱ། པེ་དེ་ཡཱ། ཁེ་ལུ་ཧི།",
      "36": "ཝན་ཡཱ། མེ་རེ་མོད། ཨེལ་ཡཱ་ཤིབ།",
      "37": "མད་ཐན་ཡཱ། མད་ཏེ་ནཱ་ཨི། ཡ་ཡ་སུ།",
      "38": "པཱ་ནི། པིན་ནུ་ཨི། ཤིམ་ཨི།",
      "39": "ཤེ་ལེམ་ཡཱ། ནཱ་ཐན། ཨ་ད་ཡཱ།",
      "40": "མག་ནཱད་བ་ཨི། ཤ་ཤ་ཨི། ཤ་ར་ཨི།",
      "41": "ཨ་ཟར་ཨེལ། ཤེ་ལེམ་ཡཱ། ཤེ་མར་ཡཱ།",
      "42": "ཤལ་ལུམ། ཨ་མར་ཡཱ། ཡོ་སེབ་བཅས་ཡོད་དོ། །",
      "43": "ནེ་བོའི་བུ་རྒྱུད་རྣམས་ལས་ཡེ་ཨི་ཨེལ་དང་། མད་ཏིད་ཡཱ། ཟཱ་བད། ཟེ་བི་ནཱ། ཡད་དཱ་ཨི། ཡོ་ཨེལ། པེ་ན་ཡཱ་བཅས་ཡོད་དོ། །",
      "44": "དེ་ཐམས་ཅད་ཀྱིས་ཕྱི་ཕྱོགས་ཀྱི་བུད་མེད་ཆུང་མར་བླངས་པ་དང་། འགའ་ཞིག་གི་ཆུང་མར་ཕྲུ་གུ་ཡང་སྐྱེས་ཡོད་དོ།། །།"
    }
  }
}
