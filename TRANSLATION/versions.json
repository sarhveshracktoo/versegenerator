{
    "_meta": {
        "name": "Bible Versions Master Index",
        "version": "1.0.0",
        "created": "2026-06-17",
        "description": "Master index for Bible translation JSON files in the versegenerator TRANSLATION folder. Use this file to avoid hardcoding every raw JSON link inside the HTML.",
        "repository": "https://github.com/sarhveshracktoo/versegenerator",
        "translationRoot": "TRANSLATION",
        "defaultTranslation": "KJV",
        "recommendedCache": "IndexedDB for Bible JSON, localStorage only for settings",
        "cacheKeyPrefix": "bible_version_",
        "cacheVersion": "2026-06-17"
    },
    "sources": {
        "githubPagesBase": "https://sarhveshracktoo.github.io/versegenerator/TRANSLATION/",
        "rawGitHubBase": "https://raw.githubusercontent.com/sarhveshracktoo/versegenerator/refs/heads/main/TRANSLATION/",
        "githubTreeApi": "https://api.github.com/repos/sarhveshracktoo/versegenerator/git/trees/main?recursive=1"
    },
    "loadingStrategy": {
        "firstLoad": [
            "Load this versions.json file first",
            "Build the language/version selector from this index",
            "Fetch only the selected Bible JSON when the user chooses a version",
            "Cache loaded Bible JSON in IndexedDB",
            "When cacheVersion changes, refresh old cached Bible data"
        ],
        "doNotLoadOnStartup": [
            "Do not load every Bible version on page load",
            "Do not store large Bible JSON in localStorage",
            "Do not hardcode every raw GitHub link inside the HTML"
        ]
    },
    "autoDiscovery": {
        "enabled": true,
        "mode": "github-tree-api",
        "includeOnly": "TRANSLATION/**/*.json",
        "exclude": [
            "TRANSLATION/versions.json",
            "TRANSLATION/Translations_api.json",
            "TRANSLATION/Bible API.json"
        ],
        "instructions": "Your HTML can fetch sources.githubTreeApi, filter paths beginning with TRANSLATION/ and ending with .json, remove excluded files, then create raw URLs using sources.rawGitHubBase + relative path after TRANSLATION/. This means new Bible JSON files uploaded later can be detected without editing the HTML."
    },
